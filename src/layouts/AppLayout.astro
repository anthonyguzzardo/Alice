---
import BaseLayout from './BaseLayout.astro';
import AppNav from '../components/AppNav.astro';

interface Props {
  title?: string;
  active?: string;
}

const { title = 'Alice', active = '' } = Astro.props;
---

<BaseLayout title={title}>
  <AppNav active={active} />
  <main class="app-main">
    <slot />
  </main>
</BaseLayout>

<style is:global>
  .app-main {
    max-width: 820px;
    margin: 0 auto;
    padding: 2rem;
    min-height: calc(100vh - 60px);
  }

  @media (max-width: 768px) {
    .app-main { padding: 1.5rem 1.25rem; }
  }
</style>
