---
interface Props {
  active?: string;
}
const { active = '' } = Astro.props;
---

<div class="top-controls">
  <div class="nav-menu">
    <button class="nav-menu-btn" id="nav-menu-btn" aria-label="Navigation" title="Navigation">&#x2022;&#x2022;&#x2022;</button>
    <div class="nav-dropdown" id="nav-dropdown">
      <a href="/landing" class:list={[{ current: active === 'home' }]}>Home</a>
      <a href="/vision" class:list={[{ current: active === 'vision' }]}>Vision</a>
      <a href="/questions" class:list={[{ current: active === 'questions' }]}>Questions</a>
      <a href="/research" class:list={[{ current: active === 'research' }]}>Research</a>
      <a href="/instrument" class:list={[{ current: active === 'instrument' }]}>Instrument</a>
      <a href="/methodology" class:list={[{ current: active === 'methodology' }]}>Methodology</a>
      <a href="/papers" class:list={[{ current: active === 'papers' }]}>Papers</a>
      <a href="/log" class:list={[{ current: active === 'log' }]}>Log</a>
      <a href="/collaborate" class:list={[{ current: active === 'collaborate' }]}>Collaborate</a>
      <a href="/about" class:list={[{ current: active === 'about' }]}>About</a>
      <div class="nav-divider"></div>
      <a href="/avatar" class:list={[{ current: active === 'avatar' }]}>Avatar</a>
      <div class="nav-divider"></div>
      <a href="/">Journal</a>
      <a href="/observatory">Observatory</a>
      <div class="nav-divider"></div>
      <a href="/dev/signals">Signal Sandbox</a>
    </div>
  </div>
  <button class="top-btn" id="public-theme-toggle" aria-label="Toggle theme"></button>
</div>

<script is:inline>
  (function () {
    // Nav menu dropdown
    var menuBtn = document.getElementById('nav-menu-btn');
    var dropdown = document.getElementById('nav-dropdown');
    if (!menuBtn || !dropdown) return;

    menuBtn.addEventListener('click', function (e) {
      e.stopPropagation();
      var isOpen = dropdown.classList.toggle('open');
      menuBtn.classList.toggle('open', isOpen);
    });

    document.addEventListener('click', function () {
      dropdown.classList.remove('open');
      menuBtn.classList.remove('open');
    });

    // Theme toggle
    var btn = document.getElementById('public-theme-toggle');
    if (!btn) return;
    var saved = localStorage.getItem('alice-theme') || 'light';
    document.documentElement.setAttribute('data-theme', saved);
    btn.textContent = saved === 'dark' ? '\u2600' : '\u263E';
    btn.addEventListener('click', function () {
      var current = document.documentElement.getAttribute('data-theme');
      var next = current === 'dark' ? 'light' : 'dark';
      document.documentElement.setAttribute('data-theme', next);
      localStorage.setItem('alice-theme', next);
      btn.textContent = next === 'dark' ? '\u2600' : '\u263E';
    });
  })();
</script>

<style is:global>
  .top-controls {
    position: fixed;
    top: 2rem;
    right: 2rem;
    display: flex;
    gap: 0.6rem;
    align-items: center;
    z-index: 100;
  }

  .top-btn {
    background: none;
    border: 1px solid var(--border);
    border-radius: 50%;
    width: 36px;
    height: 36px;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: all 0.3s ease;
    color: var(--text-muted);
    font-size: 1rem;
    text-decoration: none;
  }

  .top-btn:hover {
    border-color: var(--border-focus);
    color: var(--text);
  }

  .nav-menu {
    position: relative;
  }

  .nav-menu-btn {
    background: none;
    border: 1px solid var(--border);
    border-radius: 50%;
    width: 36px;
    height: 36px;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: all 0.3s ease;
    color: var(--text-muted);
    font-size: 1.1rem;
  }

  .nav-menu-btn:hover {
    border-color: var(--border-focus);
    color: var(--text);
  }

  .nav-menu-btn.open {
    border-color: var(--border-focus);
    color: var(--text);
  }

  .nav-dropdown {
    position: absolute;
    top: calc(100% + 0.6rem);
    right: 0;
    background: var(--bg);
    border: 1px solid var(--border);
    border-radius: 8px;
    padding: 0.5rem 0;
    min-width: 180px;
    opacity: 0;
    pointer-events: none;
    transform: translateY(-4px);
    transition: opacity 0.2s ease, transform 0.2s ease;
    z-index: 100;
  }

  .nav-dropdown.open {
    opacity: 1;
    pointer-events: auto;
    transform: translateY(0);
  }

  .nav-dropdown a {
    display: block;
    padding: 0.6rem 1.2rem;
    color: var(--text-muted);
    text-decoration: none;
    font-family: var(--serif-body);
    font-size: 1.05rem;
    letter-spacing: 0.03em;
    transition: color 0.2s ease, background 0.2s ease;
  }

  .nav-dropdown a:hover {
    color: var(--text);
    background: var(--bg-dim);
  }

  .nav-dropdown a.current {
    color: var(--text);
  }

  .nav-dropdown .nav-divider {
    height: 1px;
    background: var(--border);
    margin: 0.4rem 1.2rem;
  }
</style>
