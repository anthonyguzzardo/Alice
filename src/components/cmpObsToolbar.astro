---
/**
 * Observatory toolbar: subject picker + inbox badge.
 *
 * Inserted after the nav in every /observatory/* page header. Provides:
 *   - A custom dropdown of active subjects (loaded from /api/observatory/subjects).
 *     Native <select> dropdowns are rendered by the OS — CSS can't reach the
 *     open option list. The picker is a button + listbox so the menu inherits
 *     the observatory palette.
 *   - An inbox badge counting subject submissions since the operator's last
 *     visit. Hidden on the inbox page itself.
 *
 * Synchronizes the active subject with `?subjectId=N` URL query param +
 * localStorage('alice-obs-subject'). When the operator changes the picker
 * the page reloads with the new param so all server-side handlers see the
 * scoped subject. Owner (subject_id = 1) is the default; URLs stay clean
 * for owner so links shared between operators do not pin a stale subject.
 *
 * Exposes a global helper `window.__obsUrl(path)` for client-side scripts
 * that build fetch URLs or navigation hrefs — appends `?subjectId=N` when
 * viewing a non-owner subject. Static <a href> links inside the rendered
 * page are rewritten on DOMContentLoaded so cross-page navigation preserves
 * the active subject.
 *
 * Designer-facing only — `/observatory/*` is gated by the universal
 * session-cookie middleware in `src/middleware.ts` (owner-only).
 */
---

<div class="obs-toolbar">
  <div class="obs-pick">
    <span class="k">subject</span>
    <div class="obs-pick-select" data-open="false">
      <button
        type="button"
        class="obs-pick-trigger"
        id="obs-subject-trigger"
        aria-haspopup="listbox"
        aria-expanded="false"
        aria-controls="obs-subject-menu"
        disabled
      >
        <span class="obs-pick-trigger-label" id="obs-subject-label">…</span>
        <span class="obs-pick-chevron" aria-hidden="true"></span>
      </button>
      <ul
        class="obs-pick-menu"
        id="obs-subject-menu"
        role="listbox"
        aria-labelledby="obs-subject-trigger"
        tabindex="-1"
        hidden
      ></ul>
    </div>
  </div>
  <a id="obs-inbox-link" href="/observatory/inbox" class="obs-inbox" data-count="0" hidden>
    <span class="k">inbox</span>
    <span class="v" id="obs-inbox-count">0</span>
  </a>
</div>

<script is:inline>
  // Sync subjectId BEFORE any page module runs. Pages call window.__obsUrl()
  // to propagate the active subject through fetches and dynamic hrefs.
  // Define __obsUrl unconditionally up-front so module scripts that fire
  // during the redirect window (below) don't crash on undefined.
  window.__obsSubjectId = null;
  window.__obsUrl = function (p) { return p; };

  (function () {
    var url = new URL(window.location.href);
    var fromUrl = url.searchParams.get('subjectId');
    var fromLs = window.localStorage.getItem('alice-obs-subject');
    var sid = null;

    if (fromUrl) {
      var parsed = parseInt(fromUrl, 10);
      if (Number.isFinite(parsed) && parsed > 0) sid = parsed;
    }

    // Bare URL with a non-owner subject in localStorage: redirect so the
    // server-side handlers see the scoped subjectId without the operator
    // having to manually re-pick after every navigation.
    if (sid == null && fromLs && fromLs !== '1') {
      var lsParsed = parseInt(fromLs, 10);
      if (Number.isFinite(lsParsed) && lsParsed > 0) {
        url.searchParams.set('subjectId', String(lsParsed));
        window.location.replace(url.toString());
        return;
      }
    }

    // Persist the current pick so cross-page nav remembers it. Clear the
    // localStorage entry when the operator is back on owner so we don't
    // re-redirect them next time they visit a bare URL.
    if (sid != null) {
      window.localStorage.setItem('alice-obs-subject', String(sid));
    } else if (fromLs === '1') {
      window.localStorage.removeItem('alice-obs-subject');
    }

    window.__obsSubjectId = sid;
    window.__obsUrl = function (path) {
      if (sid == null) return path;
      var u = new URL(path, window.location.origin);
      if (!u.searchParams.has('subjectId')) {
        u.searchParams.set('subjectId', String(sid));
      }
      return path.startsWith('/') ? u.pathname + u.search + u.hash : u.toString();
    };

    // Rewrite static observatory hrefs to carry the active subject. Runs
    // once on DOMContentLoaded; dynamically-rendered links must use
    // window.__obsUrl() explicitly.
    if (sid != null) {
      document.addEventListener('DOMContentLoaded', function () {
        var anchors = document.querySelectorAll('a[href^="/observatory"], a[href="/"]');
        anchors.forEach(function (a) {
          var href = a.getAttribute('href');
          if (!href || href.indexOf('subjectId=') !== -1) return;
          // Don't tag the cross-link back to the owner-side journal at "/".
          if (href === '/') return;
          var au = new URL(href, window.location.origin);
          au.searchParams.set('subjectId', String(sid));
          a.setAttribute('href', au.pathname + au.search + au.hash);
        });
      });
    }

    // Logout delegate. Any nav element with [data-logout] anywhere on the
    // page wipes the server session row and bounces to /login. Lives in the
    // toolbar script so every /observatory/* page picks it up automatically
    // — owner journal has its own logout handler in index.astro.
    document.addEventListener('click', function (e) {
      var t = e.target;
      while (t && t !== document.body) {
        if (t.dataset && t.dataset.logout != null) {
          e.preventDefault();
          fetch('/api/subject/logout', { method: 'POST' })
            .catch(function () { /* fall through to redirect */ })
            .finally(function () { window.location.href = '/login'; });
          return;
        }
        t = t.parentElement;
      }
    });
  })();
</script>

<script type="module">
  // Populate dropdown + inbox badge once the toolbar markup is in the DOM.
  (async function () {
    const wrap = document.querySelector('.obs-pick-select');
    const trigger = document.getElementById('obs-subject-trigger');
    const labelEl = document.getElementById('obs-subject-label');
    const menu = document.getElementById('obs-subject-menu');
    const inboxLink = document.getElementById('obs-inbox-link');
    const inboxCount = document.getElementById('obs-inbox-count');
    if (!trigger || !menu || !labelEl || !wrap) return;

    const current = window.__obsSubjectId ?? 1;
    let subjects = [];
    let activeIndex = -1;

    function fmtLabel(s) {
      const name = s.display_name || s.username;
      return name + ' · #' + s.subject_id + (s.is_owner ? ' · owner' : '');
    }

    function renderMenu() {
      menu.innerHTML = subjects.map((s, i) => {
        const selected = s.subject_id === current;
        return [
          '<li',
          ' role="option"',
          ' data-id="' + s.subject_id + '"',
          ' data-index="' + i + '"',
          selected ? ' aria-selected="true"' : '',
          '>',
          '<span class="check" aria-hidden="true">',
          selected ? '✓' : '',
          '</span>',
          '<span class="opt-label">' + fmtLabel(s).replace(/</g, '&lt;') + '</span>',
          '</li>',
        ].join('');
      }).join('');
    }

    function openMenu() {
      if (trigger.disabled) return;
      wrap.dataset.open = 'true';
      trigger.setAttribute('aria-expanded', 'true');
      menu.hidden = false;
      // Default keyboard focus to the currently-selected option.
      const selectedIdx = subjects.findIndex((s) => s.subject_id === current);
      setActive(selectedIdx >= 0 ? selectedIdx : 0);
      // Move keyboard focus into the menu so arrow keys work immediately.
      menu.focus({ preventScroll: true });
      document.addEventListener('mousedown', onDocMouseDown);
    }

    function closeMenu(focusTrigger) {
      wrap.dataset.open = 'false';
      trigger.setAttribute('aria-expanded', 'false');
      menu.hidden = true;
      activeIndex = -1;
      menu.querySelectorAll('li[data-active="true"]').forEach((el) => {
        el.removeAttribute('data-active');
      });
      document.removeEventListener('mousedown', onDocMouseDown);
      if (focusTrigger) trigger.focus({ preventScroll: true });
    }

    function setActive(i) {
      const items = menu.querySelectorAll('li');
      if (items.length === 0) return;
      const next = ((i % items.length) + items.length) % items.length;
      items.forEach((el) => el.removeAttribute('data-active'));
      items[next].setAttribute('data-active', 'true');
      items[next].scrollIntoView({ block: 'nearest' });
      activeIndex = next;
    }

    function pick(subjectId) {
      if (!Number.isFinite(subjectId) || subjectId <= 0) return;
      window.localStorage.setItem('alice-obs-subject', String(subjectId));
      const u = new URL(window.location.href);
      if (subjectId === 1) u.searchParams.delete('subjectId');
      else u.searchParams.set('subjectId', String(subjectId));
      window.location.href = u.toString();
    }

    function onDocMouseDown(e) {
      if (!wrap.contains(e.target)) closeMenu(false);
    }

    trigger.addEventListener('click', () => {
      if (wrap.dataset.open === 'true') closeMenu(true);
      else openMenu();
    });

    trigger.addEventListener('keydown', (e) => {
      if (e.key === 'ArrowDown' || e.key === 'ArrowUp' || e.key === 'Enter' || e.key === ' ') {
        e.preventDefault();
        openMenu();
      }
    });

    menu.addEventListener('keydown', (e) => {
      if (e.key === 'Escape') {
        e.preventDefault();
        closeMenu(true);
      } else if (e.key === 'ArrowDown') {
        e.preventDefault();
        setActive(activeIndex + 1);
      } else if (e.key === 'ArrowUp') {
        e.preventDefault();
        setActive(activeIndex - 1);
      } else if (e.key === 'Home') {
        e.preventDefault();
        setActive(0);
      } else if (e.key === 'End') {
        e.preventDefault();
        setActive(subjects.length - 1);
      } else if (e.key === 'Enter' || e.key === ' ') {
        e.preventDefault();
        const sel = subjects[activeIndex];
        if (sel) pick(sel.subject_id);
      } else if (e.key === 'Tab') {
        closeMenu(false);
      }
    });

    menu.addEventListener('click', (e) => {
      const li = e.target.closest('li[data-id]');
      if (!li) return;
      const id = parseInt(li.dataset.id, 10);
      pick(id);
    });

    menu.addEventListener('mousemove', (e) => {
      const li = e.target.closest('li[data-index]');
      if (!li) return;
      setActive(parseInt(li.dataset.index, 10));
    });

    try {
      const res = await fetch('/api/observatory/subjects');
      const data = await res.json();
      subjects = data.subjects || [];
      const cur = subjects.find((s) => s.subject_id === current);
      labelEl.textContent = cur ? fmtLabel(cur) : 'unknown #' + current;
      renderMenu();
      trigger.disabled = false;
    } catch {
      labelEl.textContent = 'load failed';
    }

    // Inbox badge: count subject submissions since the cursor. Suppress on
    // the inbox page itself — the operator is already there.
    if (window.location.pathname !== '/observatory/inbox') {
      try {
        const since = window.localStorage.getItem('alice-obs-inbox-cursor') || '1970-01-01T00:00:00Z';
        const resI = await fetch('/api/observatory/inbox?since=' + encodeURIComponent(since));
        const dataI = await resI.json();
        const count = dataI.count || 0;
        if (count > 0 && inboxLink && inboxCount) {
          inboxCount.textContent = String(count);
          inboxLink.dataset.count = String(count);
          inboxLink.removeAttribute('hidden');
        }
      } catch {
        // inbox is non-critical; fail silently
      }
    }
  })();
</script>

<style is:global>
  .obs-toolbar {
    display: flex;
    align-items: center;
    gap: 1.25rem;
    margin: 0 0 1rem;
    flex-wrap: wrap;
  }

  /* Subject picker --------------------------------------------------- */
  .obs-pick {
    display: inline-flex;
    align-items: center;
    gap: 0.6rem;
  }
  .obs-pick > .k {
    font-family: var(--mono);
    font-size: 9px;
    font-weight: 500;
    color: var(--text-faint);
    text-transform: uppercase;
    letter-spacing: 0.18em;
  }

  .obs-pick-select {
    position: relative;
    display: inline-block;
  }

  .obs-pick-trigger {
    appearance: none;
    -webkit-appearance: none;
    display: inline-flex;
    align-items: center;
    justify-content: space-between;
    gap: 0.6rem;
    background: var(--bg-panel);
    color: var(--text);
    border: 1px solid var(--border);
    border-radius: 2px;
    padding: 0.32rem 0.65rem;
    font-family: var(--mono);
    font-size: 11px;
    font-weight: 500;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    cursor: pointer;
    line-height: 1.2;
    min-width: 12rem;
    text-align: left;
    transition: border-color 0.15s ease, background-color 0.15s ease;
  }
  .obs-pick-trigger:hover {
    border-color: var(--border-focus);
    background: var(--bg-panel-hover);
  }
  .obs-pick-trigger:focus-visible {
    outline: none;
    border-color: var(--border-focus);
    box-shadow: 0 0 0 1px var(--border-focus);
  }
  .obs-pick-trigger:disabled {
    opacity: 0.45;
    cursor: default;
  }
  .obs-pick-trigger-label {
    flex: 1;
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
  }
  .obs-pick-chevron {
    width: 6px;
    height: 6px;
    border-right: 1px solid var(--text-faint);
    border-bottom: 1px solid var(--text-faint);
    transform: translateY(-2px) rotate(45deg);
    transition: transform 0.15s ease, border-color 0.15s ease;
  }
  .obs-pick-trigger:hover .obs-pick-chevron { border-color: var(--text-muted); }
  .obs-pick-select[data-open="true"] .obs-pick-chevron {
    transform: translateY(1px) rotate(-135deg);
    border-color: var(--text);
  }
  .obs-pick-select[data-open="true"] .obs-pick-trigger {
    border-color: var(--border-focus);
    background: var(--bg-panel-hover);
  }

  .obs-pick-menu {
    position: absolute;
    top: calc(100% + 4px);
    left: 0;
    margin: 0;
    padding: 0.25rem 0;
    list-style: none;
    background: var(--bg-panel);
    border: 1px solid var(--border-focus);
    border-radius: 2px;
    min-width: 100%;
    max-height: 320px;
    overflow-y: auto;
    z-index: 100;
    box-shadow: 0 8px 24px -8px rgba(0,0,0,0.25), 0 2px 4px rgba(0,0,0,0.08);
    outline: none;
  }
  .obs-pick-menu[hidden] { display: none; }
  .obs-pick-menu li {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.4rem 0.7rem 0.4rem 0.5rem;
    font-family: var(--mono);
    font-size: 11px;
    font-weight: 500;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--text-muted);
    cursor: pointer;
    white-space: nowrap;
    transition: color 0.1s ease, background-color 0.1s ease;
  }
  .obs-pick-menu li .check {
    width: 0.85rem;
    color: var(--accent);
    font-size: 10px;
    text-align: center;
    flex-shrink: 0;
  }
  .obs-pick-menu li:hover,
  .obs-pick-menu li[data-active="true"] {
    color: var(--text);
    background: var(--bg-panel-hover);
  }
  .obs-pick-menu li[aria-selected="true"] {
    color: var(--text);
  }

  /* Inbox badge ------------------------------------------------------ */
  .obs-inbox {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    text-decoration: none;
    border: 1px solid var(--accent);
    color: var(--accent);
    padding: 0.32rem 0.7rem;
    border-radius: 2px;
    font-family: var(--mono);
    line-height: 1.2;
    transition: background-color 0.15s ease;
  }
  .obs-inbox[hidden] { display: none; }
  .obs-inbox .k {
    font-size: 9px;
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 0.18em;
  }
  .obs-inbox .v {
    font-size: 11px;
    font-weight: 600;
    letter-spacing: 0.02em;
  }
  .obs-inbox:hover { background: var(--bg-panel-hover); }
</style>
