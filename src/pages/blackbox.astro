---

---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>The Black Box</title>
    <style is:global>
      * { margin: 0; padding: 0; box-sizing: border-box; }
      html, body { height: 100%; background: #000; overflow: hidden; }
      canvas { position: fixed; top: 0; left: 0; width: 100%; height: 100%; }
      .back-btn {
        position: fixed; top: 2rem; right: 2rem;
        background: none; border: 1px solid rgba(255,255,255,0.04);
        border-radius: 50%; width: 36px; height: 36px; cursor: pointer;
        display: flex; align-items: center; justify-content: center;
        color: rgba(255,255,255,0.1); font-size: 1rem;
        text-decoration: none; z-index: 10; transition: all 0.3s ease;
        opacity: 0;
      }
      .back-btn.visible { opacity: 1; }
      .back-btn:hover {
        border-color: rgba(255,255,255,0.15); color: rgba(255,255,255,0.25);
      }
    </style>
  </head>
  <body>
    <a href="/" class="back-btn" id="back" aria-label="Back to journal">&larr;</a>
    <canvas id="blackbox"></canvas>

    <script>
      import * as THREE from 'three';
      import type { WitnessState } from '../lib/dream/types';
      import { DEFAULT_WITNESS } from '../lib/dream/types';

      import witnessVert from '../assets/shaders/witness.vert?raw';
      import witnessFrag from '../assets/shaders/witness.frag?raw';

      // ─── Setup ──────────────────────────────────────────────────

      const canvas = document.getElementById('blackbox') as HTMLCanvasElement;
      const backBtn = document.getElementById('back') as HTMLElement;
      let W = window.innerWidth;
      let H = window.innerHeight;

      const renderer = new THREE.WebGLRenderer({ canvas, antialias: true, alpha: false });
      renderer.setSize(W, H);
      renderer.setPixelRatio(Math.min(window.devicePixelRatio, 2));
      renderer.setClearColor(0x000000, 1);

      const scene = new THREE.Scene();

      // Camera: slightly off-center, creates subtle asymmetry
      const camera = new THREE.PerspectiveCamera(40, W / H, 0.1, 100);
      camera.position.set(0, 0.1, 3.5);
      camera.lookAt(0, 0, 0);

      // ─── Witness State ──────────────────────────────────────────

      let witnessState: WitnessState = { ...DEFAULT_WITNESS };
      let stateLoaded = false;

      // ─── Witness Mesh ───────────────────────────────────────────

      // High-poly sphere as base — displacement does the shaping
      const baseGeometry = new THREE.IcosahedronGeometry(1, 64);
      baseGeometry.computeVertexNormals();

      const witnessMaterial = new THREE.ShaderMaterial({
        vertexShader: witnessVert,
        fragmentShader: witnessFrag,
        uniforms: {
          uTime: { value: 0 },
          uDensity: { value: 0.1 },
          uCoherence: { value: 0.5 },
          uAsymmetry: { value: 0 },
          uConcavity: { value: 0 },
          uErosion: { value: 0.8 },
          uMass: { value: 0.1 },
          uBreathRate: { value: 25 },
          uBreathDepth: { value: 0.02 },
          uReveal: { value: 0 },
          uCameraPos: { value: camera.position },
        },
        transparent: true,
        depthWrite: true,
        side: THREE.DoubleSide,
      });

      const witnessMesh = new THREE.Mesh(baseGeometry, witnessMaterial);
      witnessMesh.position.set(0, -0.1, 0); // slightly below center
      scene.add(witnessMesh);

      // ─── Threshold System ───────────────────────────────────────

      let thresholdStartTime = 0;
      let thresholdDuration = 8; // seconds, updated from state
      let thresholdComplete = false;
      let revealValue = 0;

      // Threshold character affects the reveal curve
      let thresholdCharacter: WitnessState['thresholdCharacter'] = 'normal';

      function getRevealCurve(progress: number): number {
        // progress: 0 (start) to 1 (fully revealed)
        switch (thresholdCharacter) {
          case 'slow':
            // Very gradual — cubic ease-in
            return progress * progress * progress;
          case 'misaligned':
            // Stuttered — two-step reveal with a pause
            if (progress < 0.4) return progress / 0.4 * 0.3;
            if (progress < 0.6) return 0.3; // pause
            return 0.3 + ((progress - 0.6) / 0.4) * 0.7;
          case 'abrupt':
            // Quick snap after brief darkness
            if (progress < 0.3) return 0;
            return Math.min(1, (progress - 0.3) / 0.3);
          default:
            // Smooth ease-in-out
            return progress < 0.5
              ? 2 * progress * progress
              : 1 - 2 * (1 - progress) * (1 - progress);
        }
      }

      // ─── Camera Drift ───────────────────────────────────────────
      // Slow, dream-like camera movement. Not controllable.

      const cameraDrift = {
        basePos: new THREE.Vector3(0, 0.1, 3.5),
        // Irrational frequencies for non-repeating orbits
        freqX: 0.017,   // ~59s period
        freqY: 0.013,   // ~77s period
        freqZ: 0.0091,  // ~110s period
        ampX: 0.15,
        ampY: 0.08,
        ampZ: 0.1,
      };

      function updateCamera(time: number): void {
        const d = cameraDrift;
        camera.position.set(
          d.basePos.x + Math.sin(time * d.freqX * Math.PI * 2) * d.ampX,
          d.basePos.y + Math.sin(time * d.freqY * Math.PI * 2) * d.ampY,
          d.basePos.z + Math.sin(time * d.freqZ * Math.PI * 2) * d.ampZ,
        );
        camera.lookAt(0, -0.05, 0);
      }

      // ─── Uniform Sync ──────────────────────────────────────────

      // Current displayed values — lerp toward target for smooth transitions
      const displayed = {
        density: 0.1,
        coherence: 0.5,
        asymmetry: 0,
        concavity: 0,
        erosion: 0.8,
        mass: 0.1,
        breathRate: 25,
        breathDepth: 0.02,
      };

      function lerpUniforms(dt: number): void {
        const rate = 0.3 * dt; // slow convergence
        displayed.density += (witnessState.density - displayed.density) * rate;
        displayed.coherence += (witnessState.coherence - displayed.coherence) * rate;
        displayed.asymmetry += (witnessState.asymmetry - displayed.asymmetry) * rate;
        displayed.concavity += (witnessState.concavity - displayed.concavity) * rate;
        displayed.erosion += (witnessState.erosion - displayed.erosion) * rate;
        displayed.mass += (witnessState.mass - displayed.mass) * rate;
        displayed.breathRate += (witnessState.breathRate - displayed.breathRate) * rate;
        displayed.breathDepth += (witnessState.breathDepth - displayed.breathDepth) * rate;

        const u = witnessMaterial.uniforms;
        u.uDensity.value = displayed.density;
        u.uCoherence.value = displayed.coherence;
        u.uAsymmetry.value = displayed.asymmetry;
        u.uConcavity.value = displayed.concavity;
        u.uErosion.value = displayed.erosion;
        u.uMass.value = displayed.mass;
        u.uBreathRate.value = displayed.breathRate;
        u.uBreathDepth.value = displayed.breathDepth;
      }

      // ─── Data Fetch ─────────────────────────────────────────────

      async function fetchWitnessState(): Promise<void> {
        try {
          const res = await fetch('/api/witness');
          if (res.ok) {
            const state: WitnessState = await res.json();
            witnessState = state;
            thresholdDuration = state.thresholdDuration;
            thresholdCharacter = state.thresholdCharacter;
            stateLoaded = true;
          }
        } catch {
          stateLoaded = true; // proceed with defaults
        }
      }

      // Fetch once on load. No periodic fetching — data only changes
      // when a journal entry is written, and you're not writing here.
      fetchWitnessState();

      // ─── Animation Loop ─────────────────────────────────────────

      let startTime = 0;
      let lastFrame = 0;
      let backBtnShown = false;

      function frame(now: number): void {
        if (!startTime) {
          startTime = now;
          lastFrame = now;
          thresholdStartTime = now;
        }

        const elapsed = (now - startTime) / 1000; // seconds since page open
        const dt = Math.min((now - lastFrame) / 1000, 0.05); // capped delta
        lastFrame = now;

        // ─── Threshold ─────────────────────────────
        if (!thresholdComplete) {
          const thresholdElapsed = (now - thresholdStartTime) / 1000;
          const progress = Math.min(1, thresholdElapsed / thresholdDuration);
          revealValue = getRevealCurve(progress);

          if (progress >= 1) {
            thresholdComplete = true;
            revealValue = 1;
          }
        }

        witnessMaterial.uniforms.uReveal.value = revealValue;
        witnessMaterial.uniforms.uTime.value = elapsed;

        // ─── Lerp uniforms toward data state ───────
        if (stateLoaded) {
          lerpUniforms(dt);
        }

        // ─── Camera drift ──────────────────────────
        updateCamera(elapsed);

        // ─── Render ────────────────────────────────
        renderer.render(scene, camera);

        // Show back button after threshold completes
        if (thresholdComplete && !backBtnShown) {
          backBtn.classList.add('visible');
          backBtnShown = true;
        }

        requestAnimationFrame(frame);
      }

      requestAnimationFrame(frame);

      // ─── Resize ─────────────────────────────────────────────────

      window.addEventListener('resize', () => {
        W = window.innerWidth;
        H = window.innerHeight;
        renderer.setSize(W, H);
        camera.aspect = W / H;
        camera.updateProjectionMatrix();
      });
    </script>
  </body>
</html>
