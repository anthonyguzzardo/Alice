---

---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>The Black Box</title>
    <script is:inline>
      (function() {
        var t = localStorage.getItem('marrow-theme') || 'dark';
        document.documentElement.setAttribute('data-theme', t);
      })();
    </script>
    <style is:global>
      :root {
        --bg: #f5f2ed;
        --text-muted: #6b6560;
      }
      [data-theme="dark"] {
        --bg: #0a0a0a;
        --text-muted: #7a7570;
      }
      * { margin: 0; padding: 0; box-sizing: border-box; }
      html, body {
        height: 100%;
        background: var(--bg);
        overflow: hidden;
      }
      canvas {
        position: fixed;
        top: 0;
        left: 0;
        width: 100%;
        height: 100%;
      }
      .back-btn {
        position: fixed;
        top: 2rem;
        right: 2rem;
        background: none;
        border: 1px solid rgba(255,255,255,0.15);
        border-radius: 50%;
        width: 36px;
        height: 36px;
        cursor: pointer;
        display: flex;
        align-items: center;
        justify-content: center;
        color: rgba(255,255,255,0.3);
        font-size: 1rem;
        text-decoration: none;
        z-index: 10;
        transition: all 0.3s ease;
      }
      [data-theme="light"] .back-btn {
        border-color: rgba(0,0,0,0.15);
        color: rgba(0,0,0,0.3);
      }
      .back-btn:hover {
        border-color: rgba(255,255,255,0.4);
        color: rgba(255,255,255,0.6);
      }
      [data-theme="light"] .back-btn:hover {
        border-color: rgba(0,0,0,0.4);
        color: rgba(0,0,0,0.6);
      }
    </style>
  </head>
  <body>
    <a href="/" class="back-btn" aria-label="Back to Marrow" title="Back to Marrow">&larr;</a>
    <canvas id="canvas"></canvas>
    <script>
      /**
       * THE BLACK BOX — data-driven ambient visualization
       * Every visual property maps to a real system metric.
       * Nothing is random. Everything is derived from your data.
       *
       * MAPPING:
       * - Drop SPEED        = your avgHesitation (slow starter = slow drops)
       * - Drop DENSITY       = sessionCount (more entries = denser field)
       * - Drop OPACITY       = system confidence (HIGH=bright, LOW=faint)
       * - DELETION FLICKERS  = your deletionIntensity (more deleting = more visual noise)
       * - COLOR HUE          = thematicDensity (repetitive=warm/amber, diverse=cool/blue)
       * - PULSE RATE         = suppressedCount (more held-back questions = faster pulse)
       * - TRAIL LENGTH       = reflectionCount (more reflections = longer memory trails)
       * - GLYPH SET          = which interpretive frame dominates latest observation
       * - FADE SPEED         = commitment ratio (decisive writer = cleaner fade)
       * - INITIAL DENSITY    = session count (grows with you)
       */

      const canvas = document.getElementById('canvas') as HTMLCanvasElement;
      const ctx = canvas.getContext('2d')!;

      // Glyph pools mapped to interpretive frames
      const FRAME_A = '◯◎○◌◍●◉∘∙·'.split('');       // circles — wholeness, charitable
      const FRAME_B = '╱╲╳╴╵╶╷┊┋┆┇│'.split('');      // fractures — avoidance
      const FRAME_C = '─━┄┅┈┉╌╍═≡≈'.split('');       // flat lines — mundane
      const NEUTRAL = '∴∵∶∷∸∹∺∻∼∽∾∿'.split('');      // logic — processing

      interface Signal {
        avgCommitment: number;
        avgHesitation: number;
        deletionIntensity: number;
        pauseFrequency: number;
        sessionCount: number;
        observationCount: number;
        reflectionCount: number;
        suppressedCount: number;
        embeddingCount: number;
        latestConfidence: string | null;
        thematicDensity: number;
        landedRatio: number;
        feedbackCount: number;
      }

      interface Drop {
        x: number;
        y: number;
        speed: number;
        char: string;
        opacity: number;
        fontSize: number;
        trailLength: number;
        trail: Array<{ x: number; y: number; char: string }>;
        nextMutateTime: number;
        flickering: boolean;
        glyphPool: string[];
        pulsePhase: number;
      }

      let signal: Signal | null = null;
      let drops: Drop[] = [];

      function resize() {
        canvas.width = window.innerWidth;
        canvas.height = window.innerHeight;
      }

      function getGlyphPool(): string[] {
        if (!signal?.latestConfidence) return NEUTRAL;
        switch (signal.latestConfidence) {
          case 'HIGH': return FRAME_A;
          case 'MODERATE': return [...FRAME_A, ...FRAME_B];
          case 'LOW': return [...FRAME_B, ...FRAME_C];
          case 'INSUFFICIENT DATA': return FRAME_C;
          default: return NEUTRAL;
        }
      }

      function createDrop(): Drop {
        const s = signal;
        const pool = getGlyphPool();

        const baseSpeed = s ? 0.2 + (1 - s.avgHesitation) * 0.8 : 0.4;
        const speed = baseSpeed * (0.7 + Math.random() * 0.6);
        const trailLength = s ? Math.min(8, 2 + s.reflectionCount) : 3;

        let baseOpacity = 0.06;
        if (s?.latestConfidence === 'HIGH') baseOpacity = 0.12;
        else if (s?.latestConfidence === 'MODERATE') baseOpacity = 0.08;
        else if (s?.latestConfidence === 'LOW') baseOpacity = 0.04;
        else if (s?.latestConfidence === 'INSUFFICIENT DATA') baseOpacity = 0.025;

        const flickering = s ? Math.random() < s.deletionIntensity : false;

        return {
          x: Math.random() * canvas.width,
          y: -20 - Math.random() * 100,
          speed,
          char: pool[Math.floor(Math.random() * pool.length)],
          opacity: baseOpacity + Math.random() * 0.03,
          fontSize: 11 + Math.random() * 6,
          trailLength,
          trail: [],
          nextMutateTime: 0,
          flickering,
          glyphPool: pool,
          pulsePhase: Math.random() * Math.PI * 2,
        };
      }

      function getColor(opacity: number, isDark: boolean): string {
        if (!signal) {
          return isDark ? `rgba(74, 69, 64, ${opacity})` : `rgba(180, 175, 168, ${opacity})`;
        }
        const d = signal.thematicDensity;
        if (isDark) {
          return `rgba(${Math.floor(64 + d * 50)}, ${Math.floor(59 + (1 - d) * 30)}, ${Math.floor(54 + (1 - d) * 60)}, ${opacity})`;
        } else {
          return `rgba(${Math.floor(160 + d * 40)}, ${Math.floor(155 + (1 - d) * 20)}, ${Math.floor(148 + (1 - d) * 50)}, ${opacity})`;
        }
      }

      function draw(timestamp: number) {
        const isDark = document.documentElement.getAttribute('data-theme') === 'dark';

        const fadeAlpha = signal ? 0.03 + signal.avgCommitment * 0.04 : 0.05;
        ctx.fillStyle = isDark
          ? `rgba(10, 10, 10, ${fadeAlpha})`
          : `rgba(245, 242, 237, ${fadeAlpha})`;
        ctx.fillRect(0, 0, canvas.width, canvas.height);

        const maxDrops = signal ? Math.min(80, 15 + signal.sessionCount * 2) : 25;
        const spawnRate = signal ? 0.03 + (signal.sessionCount / 200) : 0.05;

        if (drops.length < maxDrops && Math.random() < spawnRate) {
          drops.push(createDrop());
        }

        const pulseSpeed = signal ? 0.001 + signal.suppressedCount * 0.0003 : 0.002;

        for (let i = drops.length - 1; i >= 0; i--) {
          const drop = drops[i];
          drop.y += drop.speed;

          drop.trail.push({ x: drop.x, y: drop.y, char: drop.char });
          if (drop.trail.length > drop.trailLength) drop.trail.shift();

          if (timestamp > drop.nextMutateTime) {
            drop.char = drop.glyphPool[Math.floor(Math.random() * drop.glyphPool.length)];
            drop.nextMutateTime = timestamp + 200 + Math.random() * 500;
          }

          if (drop.flickering && Math.random() < 0.15) continue;

          const pulse = Math.sin(drop.pulsePhase + timestamp * pulseSpeed);
          const pulseOpacity = drop.opacity * (0.7 + pulse * 0.3);

          // Trail
          for (let t = 0; t < drop.trail.length - 1; t++) {
            const te = drop.trail[t];
            const trailAge = (drop.trail.length - 1 - t) / drop.trail.length;
            const trailOp = pulseOpacity * (1 - trailAge) * 0.5;
            if (trailOp > 0.005) {
              ctx.font = `${drop.fontSize - 1}px monospace`;
              ctx.fillStyle = getColor(trailOp, isDark);
              ctx.fillText(te.char, te.x, te.y);
            }
          }

          // Head
          ctx.font = `${drop.fontSize}px monospace`;
          ctx.fillStyle = getColor(pulseOpacity, isDark);
          ctx.fillText(drop.char, drop.x, drop.y);

          if (drop.y > canvas.height + 50) {
            drops.splice(i, 1);
          }
        }

        requestAnimationFrame(draw);
      }

      async function init() {
        resize();
        window.addEventListener('resize', resize);

        try {
          const res = await fetch('/api/blackbox');
          if (res.ok) signal = await res.json();
        } catch {}

        // Seed
        const seedCount = signal ? Math.min(30, 8 + signal.sessionCount) : 15;
        for (let i = 0; i < seedCount; i++) {
          const d = createDrop();
          d.y = Math.random() * canvas.height;
          drops.push(d);
        }

        requestAnimationFrame(draw);

        // Refresh signal every 60 seconds
        setInterval(async () => {
          try {
            const res = await fetch('/api/blackbox');
            if (res.ok) signal = await res.json();
          } catch {}
        }, 60000);
      }

      init();
    </script>
  </body>
</html>
