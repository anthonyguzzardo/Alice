---

---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Alice Negative</title>
    <style is:global>
      * { margin: 0; padding: 0; box-sizing: border-box; }
      html, body { height: 100%; background: #000; overflow: hidden; }
      canvas { position: fixed; top: 0; left: 0; width: 100%; height: 100%; }
      .back-btn {
        position: fixed; top: 2rem; right: 2rem;
        background: none; border: 1px solid rgba(255,255,255,0.15);
        border-radius: 50%; width: 36px; height: 36px; cursor: pointer;
        display: flex; align-items: center; justify-content: center;
        color: rgba(255,255,255,0.4); font-size: 1rem;
        text-decoration: none; z-index: 10; transition: all 0.3s ease;
        opacity: 1;
      }
      .back-btn:hover {
        border-color: rgba(255,255,255,0.35); color: rgba(255,255,255,0.6);
      }
    </style>
  </head>
  <body>
    <a href="/" class="back-btn" id="back" aria-label="Back to journal" title="journal">&larr;</a>
    <a href="/gallery" class="back-btn" id="gallery-link" style="right: 5rem; line-height: 1;" aria-label="Gallery" title="gallery">&#x25A6;</a>
    <canvas id="alice-negative"></canvas>

    <script>
      import * as THREE from 'three';
      import type { WitnessState, WitnessTraits } from '../lib/libAliceNegative/libTypes';
      import { DEFAULT_WITNESS, TRAIT_KEYS } from '../lib/libAliceNegative/libTypes';
      import { deriveShaderWeights, WEIGHT_KEYS, weightUniformName } from '../lib/libAliceNegative/libShaderWeights';

      import witnessVert from '../assets/shaders/witness.vert?raw';
      import witnessFrag from '../assets/shaders/witness.frag?raw';

      // ─── Setup ──────────────────────────────────────────────────

      const canvas = document.getElementById('alice-negative') as HTMLCanvasElement;
      const backBtn = document.getElementById('back') as HTMLElement;
      let W = window.innerWidth;
      let H = window.innerHeight;

      const renderer = new THREE.WebGLRenderer({ canvas, antialias: true, alpha: false });
      renderer.setSize(W, H);
      renderer.setPixelRatio(Math.min(window.devicePixelRatio, 2));
      renderer.setClearColor(0x000000, 1);

      const scene = new THREE.Scene();

      const camera = new THREE.PerspectiveCamera(40, W / H, 0.1, 100);
      camera.position.set(0, 0, 3.5);
      camera.lookAt(0, 0, 0);

      // ─── Witness State ──────────────────────────────────────────

      let witnessState: WitnessState = { ...DEFAULT_WITNESS, traits: { ...DEFAULT_WITNESS.traits } };
      let stateLoaded = false;

      // ─── Trait uniform name mapping ─────────────────────────────

      function traitUniformName(key: keyof WitnessTraits): string {
        return 'u' + key.charAt(0).toUpperCase() + key.slice(1);
      }

      // ─── Build uniforms ─────────────────────────────────────────

      const traitUniforms: Record<string, { value: number }> = {};
      for (const key of TRAIT_KEYS) {
        traitUniforms[traitUniformName(key)] = { value: DEFAULT_WITNESS.traits[key] };
      }

      const weightUniforms: Record<string, { value: number }> = {};
      for (const key of WEIGHT_KEYS) {
        weightUniforms[weightUniformName(key)] = { value: 0 };
      }

      const witnessMaterial = new THREE.ShaderMaterial({
        vertexShader: witnessVert,
        fragmentShader: witnessFrag,
        uniforms: {
          uTime: { value: 0 },
          uReveal: { value: 0 },
          uMass: { value: DEFAULT_WITNESS.mass },
          uCameraPos: { value: camera.position },
          ...traitUniforms,
          ...weightUniforms,
        },
        transparent: true,
        depthWrite: true,
        side: THREE.DoubleSide,
      });

      // ─── Witness Mesh ───────────────────────────────────────────

      const baseGeometry = new THREE.IcosahedronGeometry(1, 64);
      baseGeometry.computeVertexNormals();

      const witnessMesh = new THREE.Mesh(baseGeometry, witnessMaterial);
      witnessMesh.position.set(0, 0, 0);
      scene.add(witnessMesh);

      // ─── Threshold System ───────────────────────────────────────

      let thresholdStartTime = 0;
      let thresholdDuration = DEFAULT_WITNESS.thresholdDuration;
      let thresholdComplete = false;
      let revealValue = 0;
      let thresholdCharacter: WitnessState['thresholdCharacter'] = DEFAULT_WITNESS.thresholdCharacter;

      function getRevealCurve(progress: number): number {
        switch (thresholdCharacter) {
          case 'slow':
            return progress * progress * progress;
          case 'misaligned':
            if (progress < 0.4) return progress / 0.4 * 0.3;
            if (progress < 0.6) return 0.3;
            return 0.3 + ((progress - 0.6) / 0.4) * 0.7;
          case 'abrupt':
            if (progress < 0.3) return 0;
            return Math.min(1, (progress - 0.3) / 0.3);
          default:
            return progress < 0.5
              ? 2 * progress * progress
              : 1 - 2 * (1 - progress) * (1 - progress);
        }
      }

      // ─── Camera Drift ───────────────────────────────────────────

      const cameraDrift = {
        basePos: new THREE.Vector3(0, 0, 3.5),
        freqX: 0.017,
        freqY: 0.013,
        freqZ: 0.0091,
        ampX: 0.15,
        ampY: 0.08,
        ampZ: 0.1,
      };

      function updateCamera(time: number): void {
        const d = cameraDrift;
        camera.position.set(
          d.basePos.x + Math.sin(time * d.freqX * Math.PI * 2) * d.ampX,
          d.basePos.y + Math.sin(time * d.freqY * Math.PI * 2) * d.ampY,
          d.basePos.z + Math.sin(time * d.freqZ * Math.PI * 2) * d.ampZ,
        );
        camera.lookAt(0, 0, 0);
      }

      // ─── Uniform Lerping ───────────────────────────────────────

      const displayedTraits: Record<string, number> = {};
      for (const key of TRAIT_KEYS) {
        displayedTraits[key] = DEFAULT_WITNESS.traits[key];
      }
      let displayedMass = DEFAULT_WITNESS.mass;

      function lerpUniforms(dt: number): void {
        const rate = 0.3 * dt;

        for (const key of TRAIT_KEYS) {
          const target = witnessState.traits[key];
          displayedTraits[key] += (target - displayedTraits[key]) * rate;
          const uniformName = traitUniformName(key);
          witnessMaterial.uniforms[uniformName].value = displayedTraits[key];
        }

        displayedMass += (witnessState.mass - displayedMass) * rate;
        witnessMaterial.uniforms.uMass.value = displayedMass;

        // Derive strategy weights from current (lerped) trait values
        const traitObj = {} as WitnessTraits;
        for (const key of TRAIT_KEYS) {
          (traitObj as any)[key] = displayedTraits[key];
        }
        const weights = deriveShaderWeights(traitObj);
        for (const key of WEIGHT_KEYS) {
          witnessMaterial.uniforms[weightUniformName(key)].value = weights[key];
        }
      }

      // ─── Data Fetch ─────────────────────────────────────────────

      async function fetchWitnessState(): Promise<void> {
        try {
          const res = await fetch('/api/witness');
          if (res.ok) {
            const state: WitnessState = await res.json();
            witnessState = state;
            thresholdDuration = state.thresholdDuration;
            thresholdCharacter = state.thresholdCharacter;
            stateLoaded = true;
          }
        } catch {
          stateLoaded = true;
        }
      }

      fetchWitnessState();

      // ─── Animation Loop ─────────────────────────────────────────

      let startTime = 0;
      let lastFrame = 0;
      function frame(now: number): void {
        if (!startTime) {
          startTime = now;
          lastFrame = now;
          thresholdStartTime = now;
        }

        const elapsed = (now - startTime) / 1000;
        const dt = Math.min((now - lastFrame) / 1000, 0.05);
        lastFrame = now;

        // ─── Threshold ─────────────────────────────
        if (!thresholdComplete) {
          const thresholdElapsed = (now - thresholdStartTime) / 1000;
          const progress = Math.min(1, thresholdElapsed / thresholdDuration);
          revealValue = getRevealCurve(progress);

          if (progress >= 1) {
            thresholdComplete = true;
            revealValue = 1;
          }
        }

        witnessMaterial.uniforms.uReveal.value = revealValue;
        witnessMaterial.uniforms.uTime.value = elapsed;
        witnessMaterial.uniforms.uCameraPos.value = camera.position;

        // ─── Lerp uniforms toward data state ───────
        if (stateLoaded) {
          lerpUniforms(dt);
        }

        // ─── Mesh rotation from rotation trait ─────
        const rotationSpeed = displayedTraits['rotation'] * 8.0;
        witnessMesh.rotation.y += rotationSpeed * dt;

        // ─── Camera drift ──────────────────────────
        updateCamera(elapsed);

        // ─── Render ────────────────────────────────
        renderer.render(scene, camera);

        requestAnimationFrame(frame);
      }

      requestAnimationFrame(frame);

      // ─── Resize ─────────────────────────────────────────────────

      window.addEventListener('resize', () => {
        W = window.innerWidth;
        H = window.innerHeight;
        renderer.setSize(W, H);
        camera.aspect = W / H;
        camera.updateProjectionMatrix();
      });
    </script>
  </body>
</html>
