---
/**
 * Trajectory viewer.
 * Two modes (click to toggle):
 *   DETAIL  — 4 panels, one per dimension over time
 *   TRACE   — single plot, 4 dimensions collapsed to 2 via PCA
 */
---
<html lang="en">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width" />
  <title>trajectory</title>
  <style>
    * { margin: 0; padding: 0; box-sizing: border-box; }
    body {
      background: #0a0a0a;
      color: #666;
      font-family: 'SF Mono', 'Fira Code', monospace;
      font-size: 11px;
      height: 100vh;
      overflow: hidden;
      cursor: pointer;
      user-select: none;
    }

    /* ─── Detail mode (4 panels) ─── */
    .detail-view {
      display: grid;
      grid-template-columns: 1fr 1fr;
      grid-template-rows: 1fr 1fr;
      height: 100vh;
      gap: 1px;
      background: #1a1a1a;
    }
    .detail-view.hidden { display: none; }
    .panel {
      background: #0a0a0a;
      position: relative;
      overflow: hidden;
    }
    .panel-label {
      position: absolute;
      top: 12px;
      left: 14px;
      color: #333;
      font-size: 10px;
      letter-spacing: 2px;
      text-transform: uppercase;
      z-index: 1;
    }
    .panel-value {
      position: absolute;
      top: 12px;
      right: 14px;
      color: #444;
      font-size: 10px;
      z-index: 1;
    }

    /* ─── Trace mode (collapsed) ─── */
    .trace-view {
      height: 100vh;
      width: 100vw;
      position: relative;
    }
    .trace-view.hidden { display: none; }
    .trace-view canvas {
      width: 100%;
      height: 100%;
    }
    .axis-label {
      position: absolute;
      color: #222;
      font-size: 9px;
      letter-spacing: 2px;
      text-transform: uppercase;
    }
    .axis-x { bottom: 14px; left: 50%; transform: translateX(-50%); }
    .axis-y { top: 50%; left: 14px; transform: rotate(-90deg) translateX(-50%); transform-origin: left center; }

    /* ─── Shared ─── */
    canvas { width: 100%; height: 100%; }
    .convergence-bar {
      position: fixed;
      bottom: 0;
      left: 0;
      right: 0;
      height: 3px;
      background: #111;
      z-index: 10;
    }
    .convergence-fill {
      height: 100%;
      background: #333;
      transition: width 0.5s ease, background 0.5s ease;
    }
    .phase-label {
      position: fixed;
      bottom: 8px;
      right: 14px;
      color: #333;
      font-size: 9px;
      letter-spacing: 2px;
      text-transform: uppercase;
      z-index: 10;
    }
    .velocity-label {
      position: fixed;
      bottom: 8px;
      left: 14px;
      color: #333;
      font-size: 9px;
      letter-spacing: 2px;
      z-index: 10;
    }
    .mode-label {
      position: fixed;
      top: 12px;
      right: 14px;
      color: #222;
      font-size: 9px;
      letter-spacing: 2px;
      text-transform: uppercase;
      z-index: 20;
    }
    .empty {
      position: fixed;
      top: 50%;
      left: 50%;
      transform: translate(-50%, -50%);
      color: #222;
      font-size: 11px;
      letter-spacing: 3px;
      text-transform: uppercase;
      z-index: 20;
    }
    .nav {
      position: fixed;
      top: 12px;
      left: 14px;
      display: flex;
      gap: 8px;
      z-index: 20;
    }
    .nav-btn {
      background: none;
      border: 1px solid rgba(255,255,255,0.04);
      border-radius: 50%;
      width: 30px;
      height: 30px;
      cursor: pointer;
      display: flex;
      align-items: center;
      justify-content: center;
      color: rgba(255,255,255,0.12);
      font-size: 0.85rem;
      text-decoration: none;
      transition: all 0.3s ease;
    }
    .nav-btn:hover {
      border-color: rgba(255,255,255,0.15);
      color: rgba(255,255,255,0.3);
    }
  </style>
</head>
<body>
  <!-- Detail view: 4 panels -->
  <div class="detail-view" id="detail-view">
    <div class="panel">
      <span class="panel-label">fluency</span>
      <span class="panel-value" id="val-fluency">—</span>
      <canvas id="canvas-fluency"></canvas>
    </div>
    <div class="panel">
      <span class="panel-label">deliberation</span>
      <span class="panel-value" id="val-deliberation">—</span>
      <canvas id="canvas-deliberation"></canvas>
    </div>
    <div class="panel">
      <span class="panel-label">revision</span>
      <span class="panel-value" id="val-revision">—</span>
      <canvas id="canvas-revision"></canvas>
    </div>
    <div class="panel">
      <span class="panel-label">expression</span>
      <span class="panel-value" id="val-expression">—</span>
      <canvas id="canvas-expression"></canvas>
    </div>
  </div>

  <!-- Trace view: collapsed PCA -->
  <div class="trace-view hidden" id="trace-view">
    <canvas id="canvas-trace"></canvas>
    <span class="axis-label axis-x" id="axis-x-label">pc1</span>
    <span class="axis-label axis-y" id="axis-y-label">pc2</span>
  </div>

  <!-- Nav -->
  <div class="nav">
    <a href="/" class="nav-btn" aria-label="Journal">&larr;</a>
    <a href="/bob" class="nav-btn" aria-label="Bob">&#x25CF;</a>
  </div>

  <!-- Shared UI -->
  <div class="convergence-bar">
    <div class="convergence-fill" id="convergence-fill" style="width: 0%"></div>
  </div>
  <span class="velocity-label" id="velocity-label"></span>
  <span class="phase-label" id="phase-label"></span>
  <span class="mode-label" id="mode-label">detail</span>
  <div class="empty" id="empty-state">waiting for data</div>

  <script>
    // ─── State ────────────────────────────────────────────────────
    let mode = 'detail'; // 'detail' | 'trace'
    let trajectoryData = null;

    const DIMS = ['fluency', 'deliberation', 'revision', 'expression'];
    const COLORS = {
      fluency:      { line: '#3a6ea5', glow: 'rgba(58, 110, 165, 0.15)', dot: '#5a9ed6' },
      deliberation: { line: '#8a5a44', glow: 'rgba(138, 90, 68, 0.15)', dot: '#c4836a' },
      revision:     { line: '#5a7a5a', glow: 'rgba(90, 122, 90, 0.15)', dot: '#7aaa7a' },
      expression:   { line: '#7a5a7a', glow: 'rgba(122, 90, 122, 0.15)', dot: '#aa7aaa' },
    };

    // ─── Toggle ───────────────────────────────────────────────────
    document.body.addEventListener('click', () => {
      mode = mode === 'detail' ? 'trace' : 'detail';
      document.getElementById('mode-label').textContent = mode;
      updateVisibility();
      if (trajectoryData) render(trajectoryData);
    });

    function updateVisibility() {
      document.getElementById('detail-view').classList.toggle('hidden', mode !== 'detail');
      document.getElementById('trace-view').classList.toggle('hidden', mode !== 'trace');
    }

    // ─── Load ─────────────────────────────────────────────────────
    async function load() {
      try {
        const res = await fetch('/api/trajectory');
        trajectoryData = await res.json();
        render(trajectoryData);
      } catch (e) {
        console.error('Failed to load trajectory:', e);
      }
    }

    // ─── Render ───────────────────────────────────────────────────
    function render(data) {
      const empty = document.getElementById('empty-state');
      const phaseLabel = document.getElementById('phase-label');
      const velocityLabel = document.getElementById('velocity-label');
      const convergenceFill = document.getElementById('convergence-fill');

      if (!data.points || data.points.length === 0) {
        empty.style.display = 'block';
        phaseLabel.textContent = data.phase || '';
        return;
      }

      empty.style.display = 'none';
      phaseLabel.textContent = data.phase;
      velocityLabel.textContent = 'v ' + data.velocity.toFixed(2);

      const latest = data.points[data.points.length - 1];
      const convPct = Math.round(latest.convergence * 100);
      convergenceFill.style.width = convPct + '%';
      convergenceFill.style.background =
        latest.convergenceLevel === 'high' ? '#a44' :
        latest.convergenceLevel === 'moderate' ? '#aa8833' : '#333';

      if (mode === 'detail') renderDetail(data);
      else renderTrace(data);
    }

    // ─── Detail mode ──────────────────────────────────────────────
    function renderDetail(data) {
      for (const dim of DIMS) {
        const canvas = document.getElementById('canvas-' + dim);
        const valEl = document.getElementById('val-' + dim);
        const values = data.points.map(p => p[dim]);
        const latestVal = values[values.length - 1];
        valEl.textContent = latestVal >= 0 ? '+' + latestVal.toFixed(2) : latestVal.toFixed(2);
        drawLineChart(canvas, values, COLORS[dim], data.points.map(p => p.convergenceLevel));
      }
    }

    function drawLineChart(canvas, values, colors, convergenceLevels) {
      const dpr = window.devicePixelRatio || 1;
      const rect = canvas.getBoundingClientRect();
      canvas.width = rect.width * dpr;
      canvas.height = rect.height * dpr;
      const ctx = canvas.getContext('2d');
      ctx.scale(dpr, dpr);

      const w = rect.width;
      const h = rect.height;
      const pad = 30;

      const maxAbs = Math.max(2, ...values.map(v => Math.abs(v)));
      const range = maxAbs * 1.2;

      const toX = (i) => pad + (i / Math.max(1, values.length - 1)) * (w - pad * 2);
      const toY = (v) => h / 2 - (v / range) * (h / 2 - pad);

      // Zero line
      ctx.strokeStyle = '#1a1a1a';
      ctx.lineWidth = 1;
      ctx.beginPath();
      ctx.moveTo(pad, h / 2);
      ctx.lineTo(w - pad, h / 2);
      ctx.stroke();

      // ±1σ lines
      ctx.strokeStyle = '#141414';
      ctx.setLineDash([2, 4]);
      for (const sigma of [-1, 1]) {
        ctx.beginPath();
        ctx.moveTo(pad, toY(sigma));
        ctx.lineTo(w - pad, toY(sigma));
        ctx.stroke();
      }
      ctx.setLineDash([]);

      if (values.length < 2) {
        if (values.length === 1) {
          ctx.fillStyle = colors.dot;
          ctx.beginPath();
          ctx.arc(w / 2, toY(values[0]), 4, 0, Math.PI * 2);
          ctx.fill();
        }
        return;
      }

      // Area fill
      ctx.fillStyle = colors.glow;
      ctx.beginPath();
      ctx.moveTo(toX(0), h / 2);
      for (let i = 0; i < values.length; i++) ctx.lineTo(toX(i), toY(values[i]));
      ctx.lineTo(toX(values.length - 1), h / 2);
      ctx.closePath();
      ctx.fill();

      // Line
      ctx.strokeStyle = colors.line;
      ctx.lineWidth = 1.5;
      ctx.lineJoin = 'round';
      ctx.beginPath();
      for (let i = 0; i < values.length; i++) {
        const x = toX(i); const y = toY(values[i]);
        if (i === 0) ctx.moveTo(x, y); else ctx.lineTo(x, y);
      }
      ctx.stroke();

      // Dots
      for (let i = 0; i < values.length; i++) {
        const x = toX(i); const y = toY(values[i]);
        const isHigh = convergenceLevels[i] === 'high';
        const isMod = convergenceLevels[i] === 'moderate';

        ctx.fillStyle = isHigh ? '#c44' : isMod ? '#aa8833' : colors.dot;
        ctx.beginPath();
        ctx.arc(x, y, isHigh ? 5 : 3, 0, Math.PI * 2);
        ctx.fill();

        if (isHigh) {
          ctx.strokeStyle = 'rgba(204, 68, 68, 0.3)';
          ctx.lineWidth = 2;
          ctx.beginPath();
          ctx.arc(x, y, 10, 0, Math.PI * 2);
          ctx.stroke();
        }
      }
    }

    // ─── Trace mode (PCA) ─────────────────────────────────────────
    function renderTrace(data) {
      const canvas = document.getElementById('canvas-trace');
      const points = data.points;

      // Extract 4D vectors
      const vectors = points.map(p => [p.fluency, p.deliberation, p.revision, p.expression]);

      // PCA → 2D
      const projected = pca2D(vectors);
      if (!projected) return;

      drawTrajectoryPlot(canvas, projected, points.map(p => p.convergenceLevel));
    }

    // ─── PCA (4D → 2D) ───────────────────────────────────────────
    function pca2D(vectors) {
      const n = vectors.length;
      if (n < 2) return null;
      const d = vectors[0].length;

      // Center
      const mean = Array(d).fill(0);
      for (const v of vectors) for (let i = 0; i < d; i++) mean[i] += v[i];
      for (let i = 0; i < d; i++) mean[i] /= n;
      const centered = vectors.map(v => v.map((x, i) => x - mean[i]));

      // Covariance matrix
      const cov = Array(d).fill(null).map(() => Array(d).fill(0));
      for (const v of centered) {
        for (let i = 0; i < d; i++) {
          for (let j = 0; j < d; j++) {
            cov[i][j] += v[i] * v[j];
          }
        }
      }
      for (let i = 0; i < d; i++) for (let j = 0; j < d; j++) cov[i][j] /= (n - 1);

      // Power iteration for top 2 eigenvectors
      const e1 = powerIteration(cov, d, 100);
      // Deflate
      const cov2 = cov.map(row => [...row]);
      const lambda1 = dotProduct(matVecMul(cov, e1), e1);
      for (let i = 0; i < d; i++) for (let j = 0; j < d; j++) cov2[i][j] -= lambda1 * e1[i] * e1[j];
      const e2 = powerIteration(cov2, d, 100);

      // Project
      return centered.map(v => [dotProduct(v, e1), dotProduct(v, e2)]);
    }

    function powerIteration(matrix, d, iters) {
      let v = Array(d).fill(0).map(() => Math.random() - 0.5);
      for (let iter = 0; iter < iters; iter++) {
        const mv = matVecMul(matrix, v);
        const norm = Math.sqrt(mv.reduce((s, x) => s + x * x, 0));
        if (norm < 1e-10) break;
        v = mv.map(x => x / norm);
      }
      return v;
    }

    function matVecMul(mat, vec) {
      return mat.map(row => row.reduce((s, x, i) => s + x * vec[i], 0));
    }

    function dotProduct(a, b) {
      return a.reduce((s, x, i) => s + x * b[i], 0);
    }

    // ─── Trajectory plot ──────────────────────────────────────────
    function drawTrajectoryPlot(canvas, projected, convergenceLevels) {
      const dpr = window.devicePixelRatio || 1;
      const rect = canvas.getBoundingClientRect();
      canvas.width = rect.width * dpr;
      canvas.height = rect.height * dpr;
      const ctx = canvas.getContext('2d');
      ctx.scale(dpr, dpr);

      const w = rect.width;
      const h = rect.height;
      const pad = 50;

      // Find range — symmetric around 0
      let maxAbs = 0;
      for (const [x, y] of projected) {
        maxAbs = Math.max(maxAbs, Math.abs(x), Math.abs(y));
      }
      maxAbs = Math.max(1, maxAbs * 1.3);

      const toX = (v) => w / 2 + (v / maxAbs) * (w / 2 - pad);
      const toY = (v) => h / 2 - (v / maxAbs) * (h / 2 - pad);

      // Crosshair at origin
      ctx.strokeStyle = '#1a1a1a';
      ctx.lineWidth = 1;
      ctx.beginPath();
      ctx.moveTo(pad, h / 2);
      ctx.lineTo(w - pad, h / 2);
      ctx.stroke();
      ctx.beginPath();
      ctx.moveTo(w / 2, pad);
      ctx.lineTo(w / 2, h - pad);
      ctx.stroke();

      // Origin dot
      ctx.fillStyle = '#1a1a1a';
      ctx.beginPath();
      ctx.arc(w / 2, h / 2, 3, 0, Math.PI * 2);
      ctx.fill();

      if (projected.length < 2) {
        if (projected.length === 1) {
          ctx.fillStyle = '#5a9ed6';
          ctx.beginPath();
          ctx.arc(toX(projected[0][0]), toY(projected[0][1]), 5, 0, Math.PI * 2);
          ctx.fill();
        }
        return;
      }

      // Draw path — fading from old to new
      for (let i = 1; i < projected.length; i++) {
        const t = i / (projected.length - 1); // 0 = oldest, 1 = newest
        const alpha = 0.15 + t * 0.6;
        const x0 = toX(projected[i - 1][0]);
        const y0 = toY(projected[i - 1][1]);
        const x1 = toX(projected[i][0]);
        const y1 = toY(projected[i][1]);

        ctx.strokeStyle = `rgba(100, 140, 180, ${alpha})`;
        ctx.lineWidth = 1 + t * 1.5;
        ctx.beginPath();
        ctx.moveTo(x0, y0);
        ctx.lineTo(x1, y1);
        ctx.stroke();
      }

      // Draw dots
      for (let i = 0; i < projected.length; i++) {
        const t = i / Math.max(1, projected.length - 1);
        const x = toX(projected[i][0]);
        const y = toY(projected[i][1]);
        const isHigh = convergenceLevels[i] === 'high';
        const isMod = convergenceLevels[i] === 'moderate';
        const isLatest = i === projected.length - 1;

        const alpha = 0.3 + t * 0.7;
        const radius = isLatest ? 6 : isHigh ? 5 : 3;

        // Dot
        if (isHigh) {
          ctx.fillStyle = `rgba(204, 68, 68, ${alpha})`;
        } else if (isMod) {
          ctx.fillStyle = `rgba(170, 136, 51, ${alpha})`;
        } else {
          ctx.fillStyle = `rgba(90, 158, 214, ${alpha})`;
        }
        ctx.beginPath();
        ctx.arc(x, y, radius, 0, Math.PI * 2);
        ctx.fill();

        // Entry number
        if (projected.length <= 30 || isHigh || isLatest) {
          ctx.fillStyle = `rgba(80, 80, 80, ${alpha})`;
          ctx.font = '8px monospace';
          ctx.fillText(String(i + 1), x + radius + 3, y + 3);
        }

        // Glow on high convergence
        if (isHigh) {
          ctx.strokeStyle = 'rgba(204, 68, 68, 0.2)';
          ctx.lineWidth = 2;
          ctx.beginPath();
          ctx.arc(x, y, 12, 0, Math.PI * 2);
          ctx.stroke();
        }

        // Ring on latest
        if (isLatest) {
          ctx.strokeStyle = `rgba(90, 158, 214, 0.4)`;
          ctx.lineWidth = 2;
          ctx.beginPath();
          ctx.arc(x, y, 10, 0, Math.PI * 2);
          ctx.stroke();
        }
      }
    }

    // ─── Resize ───────────────────────────────────────────────────
    let resizeTimer;
    window.addEventListener('resize', () => {
      clearTimeout(resizeTimer);
      resizeTimer = setTimeout(() => { if (trajectoryData) render(trajectoryData); }, 100);
    });

    load();
  </script>
</body>
</html>
