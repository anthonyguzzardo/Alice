---
/**
 * Forced password reset page.
 *
 * Reachable only after login when the subject's `must_reset_password` flag
 * is true. POSTs to /api/subject/reset-password with current + new password;
 * on success the server clears the flag, invalidates all sessions (including
 * the cookie just used), and the page sends the user back to /enter to
 * sign in fresh with their new password.
 */
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Alice — reset password</title>
    <script is:inline>
      (function() {
        var t = localStorage.getItem('alice-theme') || 'light';
        document.documentElement.setAttribute('data-theme', t);
      })();
    </script>
    <style is:global>
      @import url('/fonts/styFonts.css');

      :root {
        --bg: #f5f2ed;
        --text: #1a1a1a;
        --text-muted: #6b6560;
        --border: #ccc5bc;
        --border-focus: #8a8580;
        --bg-input: #ebe7e1;
        --btn-bg: #e0dbd5;
        --btn-hover: #ccc5bc;
      }

      [data-theme="dark"] {
        --bg: #141210;
        --text: #ffffff;
        --text-muted: #7a7570;
        --border: #333;
        --border-focus: #666;
        --bg-input: #161514;
        --btn-bg: #222;
        --btn-hover: #444;
      }

      * { margin: 0; padding: 0; box-sizing: border-box; }

      body {
        font-family: 'Cormorant Garamond', Georgia, serif;
        background: var(--bg);
        color: var(--text);
        min-height: 100vh;
        display: flex;
        align-items: center;
        justify-content: center;
      }

      .reset-container {
        text-align: center;
        max-width: 420px;
        padding: 2rem;
      }

      .reset-title {
        font-size: 1.6rem;
        font-weight: 300;
        margin-bottom: 0.6rem;
        color: var(--text);
      }

      .reset-subtitle {
        font-size: 1rem;
        font-weight: 300;
        margin-bottom: 1.6rem;
        color: var(--text-muted);
      }

      .reset-input {
        font-family: 'Cormorant Garamond', Georgia, serif;
        font-size: 1.2rem;
        width: 100%;
        padding: 0.8rem 1rem;
        background: var(--bg-input);
        border: 1px solid var(--border);
        border-radius: 6px;
        color: var(--text);
        text-align: center;
        margin-top: 0.6rem;
        outline: none;
        transition: border-color 0.2s ease;
      }

      .reset-input:focus { border-color: var(--border-focus); }

      .reset-btn {
        font-family: 'Cormorant Garamond', Georgia, serif;
        font-size: 1.1rem;
        margin-top: 1.2rem;
        padding: 0.6rem 2rem;
        background: var(--btn-bg);
        border: 1px solid var(--border);
        border-radius: 6px;
        color: var(--text);
        cursor: pointer;
        transition: background 0.2s ease;
      }

      .reset-btn:hover { background: var(--btn-hover); }
      .reset-btn:disabled { opacity: 0.4; cursor: default; }

      .reset-error {
        color: #b5603f;
        font-size: 0.95rem;
        margin-top: 0.8rem;
        min-height: 1.4em;
      }
    </style>
  </head>
  <body>
    <div class="reset-container">
      <div class="reset-title">reset your password</div>
      <div class="reset-subtitle">your temporary password must be changed before you can continue</div>

      <input
        type="password"
        class="reset-input"
        id="current-password"
        placeholder="current (temporary) password"
        autocomplete="current-password"
      />
      <input
        type="password"
        class="reset-input"
        id="new-password"
        placeholder="new password (min 12 chars)"
        autocomplete="new-password"
      />
      <input
        type="password"
        class="reset-input"
        id="confirm-password"
        placeholder="confirm new password"
        autocomplete="new-password"
      />
      <br />
      <button class="reset-btn" id="reset-btn" disabled>set password</button>
      <div class="reset-error" id="error-msg"></div>
    </div>

    <script>
      const cur = document.getElementById('current-password') as HTMLInputElement;
      const nw  = document.getElementById('new-password') as HTMLInputElement;
      const cf  = document.getElementById('confirm-password') as HTMLInputElement;
      const btn = document.getElementById('reset-btn') as HTMLButtonElement;
      const err = document.getElementById('error-msg')!;

      function refresh() {
        btn.disabled = cur.value.length === 0 || nw.value.length < 12 || cf.value.length === 0;
        err.textContent = '';
      }
      [cur, nw, cf].forEach((el) => el.addEventListener('input', refresh));
      [cur, nw, cf].forEach((el) => el.addEventListener('keydown', (e: KeyboardEvent) => {
        if (e.key === 'Enter' && !btn.disabled) btn.click();
      }));

      btn.addEventListener('click', async () => {
        if (nw.value !== cf.value) {
          err.textContent = 'new passwords do not match';
          return;
        }
        if (nw.value === cur.value) {
          err.textContent = 'new password must differ from current';
          return;
        }

        btn.disabled = true;
        const res = await fetch('/api/subject/reset-password', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ currentPassword: cur.value, newPassword: nw.value }),
        });

        if (res.status === 401) {
          err.textContent = 'current password was wrong';
          cur.value = '';
          refresh();
          return;
        }

        if (!res.ok) {
          const body = await res.json().catch(() => ({})) as { error?: string };
          err.textContent = body.error ?? 'reset failed';
          btn.disabled = false;
          return;
        }

        // Reset cleared all sessions, including ours. Send the user back to login.
        window.location.href = '/login';
      });

      cur.focus();
    </script>
  </body>
</html>
