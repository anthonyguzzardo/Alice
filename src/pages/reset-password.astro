---
/**
 * Forced password reset page.
 *
 * Reachable only after login when the subject's `must_reset_password` flag
 * is true. POSTs to /api/subject/reset-password with current + new password;
 * on success the server clears the flag, invalidates all sessions (including
 * the cookie just used), and the page sends the user back to /enter to
 * sign in fresh with their new password.
 */
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Alice — reset password</title>
    <script is:inline>
      (function() {
        var t = localStorage.getItem('alice-theme') || 'light';
        document.documentElement.setAttribute('data-theme', t);
      })();
    </script>
    <style is:global>
      @import url('/fonts/styFonts.css');

      :root {
        --bg: #f5f2ed;
        --text: #1a1a1a;
        --text-muted: #6b6560;
        --border: #ccc5bc;
        --border-focus: #8a8580;
        --bg-input: #ebe7e1;
        --btn-bg: #e0dbd5;
        --btn-hover: #ccc5bc;
      }

      [data-theme="dark"] {
        --bg: #141210;
        --text: #ffffff;
        --text-muted: #7a7570;
        --border: #333;
        --border-focus: #666;
        --bg-input: #161514;
        --btn-bg: #222;
        --btn-hover: #444;
      }

      * { margin: 0; padding: 0; box-sizing: border-box; }

      body {
        font-family: 'Cormorant Garamond', Georgia, serif;
        background: var(--bg);
        color: var(--text);
        min-height: 100vh;
        display: flex;
        align-items: center;
        justify-content: center;
      }

      .reset-container {
        text-align: center;
        max-width: 420px;
        padding: 2rem;
      }

      .reset-title {
        font-size: 1.6rem;
        font-weight: 300;
        margin-bottom: 0.6rem;
        color: var(--text);
      }

      .reset-subtitle {
        font-size: 1rem;
        font-weight: 300;
        margin-bottom: 1.6rem;
        color: var(--text-muted);
      }

      .reset-input {
        font-family: 'Cormorant Garamond', Georgia, serif;
        font-size: 1.2rem;
        width: 100%;
        padding: 0.8rem 1rem;
        background: var(--bg-input);
        border: 1px solid var(--border);
        border-radius: 6px;
        color: var(--text);
        text-align: center;
        margin-top: 0.6rem;
        outline: none;
        transition: border-color 0.2s ease;
      }

      .reset-input:focus { border-color: var(--border-focus); }

      .reset-btn {
        font-family: 'Cormorant Garamond', Georgia, serif;
        font-size: 1.1rem;
        margin-top: 1.2rem;
        padding: 0.6rem 2rem;
        background: var(--btn-bg);
        border: 1px solid var(--border);
        border-radius: 6px;
        color: var(--text);
        cursor: pointer;
        transition: background 0.2s ease;
      }

      .reset-btn:hover { background: var(--btn-hover); }
      .reset-btn:disabled { opacity: 0.4; cursor: default; }

      .reset-error {
        color: #b5603f;
        font-size: 0.95rem;
        margin-top: 0.8rem;
        min-height: 1.4em;
      }

      .reset-criteria {
        list-style: none;
        margin: 1.2rem auto 0;
        padding: 0;
        font-size: 0.95rem;
        color: var(--text-muted);
        text-align: left;
        display: inline-block;
      }

      .reset-criteria .criterion {
        padding: 0.15rem 0;
        transition: color 0.15s ease;
      }

      .reset-criteria .criterion .dot {
        display: inline-block;
        width: 1.4em;
        text-align: center;
      }

      .reset-criteria .criterion.met {
        color: var(--text);
      }
    </style>
  </head>
  <body>
    <div class="reset-container">
      <div class="reset-title">reset your password</div>
      <div class="reset-subtitle">your temporary password must be changed before you can continue</div>

      <input
        type="password"
        class="reset-input"
        id="current-password"
        placeholder="current (temporary) password"
        autocomplete="current-password"
      />
      <input
        type="password"
        class="reset-input"
        id="new-password"
        placeholder="new password (min 12 chars)"
        autocomplete="new-password"
      />
      <input
        type="password"
        class="reset-input"
        id="confirm-password"
        placeholder="confirm new password"
        autocomplete="new-password"
      />

      <ul class="reset-criteria">
        <li class="criterion" id="c-current"><span class="dot"></span><span class="text"></span></li>
        <li class="criterion" id="c-length"><span class="dot"></span><span class="text"></span></li>
        <li class="criterion" id="c-match"><span class="dot"></span><span class="text"></span></li>
        <li class="criterion" id="c-different"><span class="dot"></span><span class="text"></span></li>
      </ul>

      <br />
      <button class="reset-btn" id="reset-btn" disabled>set password</button>
      <div class="reset-error" id="error-msg"></div>
    </div>

    <script>
      const cur = document.getElementById('current-password') as HTMLInputElement;
      const nw  = document.getElementById('new-password') as HTMLInputElement;
      const cf  = document.getElementById('confirm-password') as HTMLInputElement;
      const btn = document.getElementById('reset-btn') as HTMLButtonElement;
      const err = document.getElementById('error-msg')!;

      type Criterion = { id: string; met: () => boolean; text: () => string };
      const criteria: Criterion[] = [
        {
          id: 'c-current',
          met: () => cur.value.length > 0,
          text: () => 'current password entered',
        },
        {
          id: 'c-length',
          met: () => nw.value.length >= 12,
          text: () => `new password is at least 12 characters (${nw.value.length} / 12)`,
        },
        {
          id: 'c-match',
          met: () => nw.value.length > 0 && nw.value === cf.value,
          text: () => 'new and confirmation match',
        },
        {
          id: 'c-different',
          met: () => nw.value.length > 0 && cur.value.length > 0 && nw.value !== cur.value,
          text: () => 'new password differs from current',
        },
      ];

      function refresh() {
        let allMet = true;
        for (const c of criteria) {
          const el = document.getElementById(c.id)!;
          const met = c.met();
          if (!met) allMet = false;
          el.classList.toggle('met', met);
          (el.querySelector('.dot') as HTMLElement).textContent = met ? '●' : '○';
          (el.querySelector('.text') as HTMLElement).textContent = c.text();
        }
        btn.disabled = !allMet;
      }

      // Error messages persist until the user starts editing again. Clearing
      // happens on the input event, not inside refresh() — refresh() runs in
      // response to programmatic value changes too (e.g. wiping cur.value
      // after a 401), and we want the error displayed in those cases.
      [cur, nw, cf].forEach((el) => el.addEventListener('input', () => {
        err.textContent = '';
        refresh();
      }));
      [cur, nw, cf].forEach((el) => el.addEventListener('keydown', (e: KeyboardEvent) => {
        if (e.key !== 'Enter') return;
        if (btn.disabled) return; // criteria list already shows what's missing
        btn.click();
      }));

      btn.addEventListener('click', async () => {
        if (btn.disabled) return;

        btn.disabled = true;
        err.textContent = 'submitting...';

        let res: Response;
        try {
          res = await fetch('/api/subject/reset-password', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ currentPassword: cur.value, newPassword: nw.value }),
          });
        } catch (e) {
          err.textContent = `network error: ${(e as Error).message ?? 'unknown'}`;
          btn.disabled = false;
          return;
        }

        if (res.status === 401) {
          err.textContent = 'current password was wrong';
          cur.value = '';
          refresh();
          return;
        }

        if (!res.ok) {
          const body = await res.json().catch(() => ({})) as { error?: string };
          err.textContent = body.error ?? `reset failed (HTTP ${res.status})`;
          btn.disabled = false;
          return;
        }

        // Reset cleared all sessions, including ours. Send the user back to
        // login. If the original deep-link target was preserved through the
        // reset detour (server stashed it on the login-with-mustReset POST
        // and is returning it now), forward it on `/login?next=…` so the
        // post-reset login lands at the original destination instead of the
        // generic /subject home.
        const okBody = await res.json().catch(() => ({})) as { next?: string };
        const next = typeof okBody.next === 'string'
          && okBody.next.startsWith('/')
          && !okBody.next.startsWith('//')
            ? okBody.next : null;
        window.location.href = next
          ? `/login?next=${encodeURIComponent(next)}`
          : '/login';
      });

      // Initial render so the criteria list is populated even before the user types.
      refresh();
      cur.focus();
    </script>
  </body>
</html>
