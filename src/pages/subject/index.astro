---
/**
 * Subject daily journal page.
 *
 * Identical keystroke instrumentation as the owner page (src/pages/index.astro).
 * Posts to /api/subject/respond instead of /api/respond.
 * No owner-only UI: no health panel, no nav menu, no observatory links.
 * No background tasks fire on submit.
 */
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Alice</title>
    <script is:inline>
      (function() {
        var t = localStorage.getItem('alice-theme') || 'light';
        document.documentElement.setAttribute('data-theme', t);
      })();
    </script>
    <style is:global>
      @import url('https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,400;1,300;1,400&family=EB+Garamond:ital,wght@0,400;0,500;1,400&display=swap');

      :root {
        --bg: #f5f2ed;
        --bg-pre: #e9e5de;
        --bg-input: #ebe7e1;
        --text: #1a1a1a;
        --text-pre: #a8a39d;
        --text-muted: #6b6560;
        --text-faint: #9a9590;
        --border: #ccc5bc;
        --border-focus: #8a8580;
        --btn-bg: #e0dbd5;
        --btn-hover: #ccc5bc;
        --btn-text: #1a1a1a;
        --done-text: #8a8580;
        --loading: #c5c0ba;
      }

      [data-theme="dark"] {
        --bg: #0f0e0c;
        --bg-pre: #050505;
        --bg-input: #161514;
        --text: #d4d0c8;
        --text-pre: #6a6560;
        --text-muted: #b0aba5;
        --text-faint: #888178;
        --border: #333;
        --border-focus: #666;
        --btn-bg: #222;
        --btn-hover: #444;
        --btn-text: #d4d0c8;
        --done-text: #7A746B;
        --loading: #888178;
      }

      * { margin: 0; padding: 0; box-sizing: border-box; }

      html, body {
        height: 100%;
        background: var(--bg);
        color: var(--text);
        font-family: 'EB Garamond', Georgia, serif;
      }

      body {
        display: flex;
        align-items: flex-start;
        justify-content: center;
        padding: 6rem 2rem 2rem;
        background-color: var(--bg);
        transition: background-color 2.5s ease;
        min-height: 100%;
      }

      body.pre-arrival {
        background-color: var(--bg-pre);
      }

      .container {
        max-width: 820px;
        width: 100%;
      }

      .date {
        font-size: 11px;
        color: var(--text-faint);
        letter-spacing: 0.22em;
        text-transform: uppercase;
        margin-bottom: 5rem;
        transition: opacity 2s ease;
      }

      body.pre-arrival .date { opacity: 0.5; }
      body.deepening-3 .date { opacity: 0.3; }

      .question {
        font-family: 'Cormorant Garamond', Georgia, serif;
        font-size: 1.95rem;
        font-weight: 300;
        line-height: 1.7;
        letter-spacing: 0.015em;
        color: var(--text);
        margin-bottom: 1.4rem;
        font-style: italic;
        transition: color 2.5s ease, opacity 3s ease;
      }

      /* Dark theme: hairline italic at 300 doesn't survive on dark — bump to 400 for body, dim color for prompt feel. */
      [data-theme="dark"] .question {
        color: #A8A39A;
        font-weight: 400;
      }
      [data-theme="dark"] .date {
        color: #736D65;
      }
      [data-theme="dark"] .submit-btn {
        border-color: #7A746B;
      }

      body.pre-arrival .question { color: var(--text-pre); }
      body.deepening-1 .question { opacity: 0.55; }
      body.deepening-2 .question { opacity: 0.3; }
      body.deepening-3 .question { opacity: 0.12; }

      .question.loading { color: var(--loading); font-style: italic; }

      /* Writing surface — same as owner's: borderless, transparent, the
         response continues from the question on the same column. */
      .response-area {
        width: 100%;
        min-height: 200px;
        background: transparent;
        border: none;
        border-radius: 0;
        color: var(--text);
        font-family: 'EB Garamond', Georgia, serif;
        font-size: 1.55rem;
        line-height: 1.7;
        letter-spacing: 0.005em;
        padding: 0;
        resize: none;
        outline: none;
        -webkit-appearance: none;
        appearance: none;
        caret-color: var(--text);
        transition: caret-color 2s ease, color 2.5s ease;
      }

      .response-area:focus { outline: none; }

      body.pre-arrival .response-area {
        caret-color: var(--text-faint);
        color: var(--text-pre);
      }

      .submit-row {
        margin-top: 3.5rem;
        --submit-presence: 0;
        opacity: var(--submit-presence);
        pointer-events: none;
        transition: opacity 0.8s ease;
      }

      .submit-row.present {
        pointer-events: auto;
      }

      .submit-btn {
        background: none;
        border: 1px solid var(--border);
        border-radius: 3px;
        color: color-mix(in oklab, var(--text-faint), var(--done-text) calc(var(--submit-presence, 0) * 100%));
        font-family: 'Cormorant Garamond', Georgia, serif;
        font-size: 1.15rem;
        font-style: italic;
        font-weight: 300;
        letter-spacing: 0.06em;
        padding: 0.55rem 2.4rem;
        cursor: pointer;
        transition: color 0.4s ease, border-color 0.4s ease, opacity 0.4s ease;
      }

      .submit-btn:hover:not(:disabled) {
        color: var(--text);
        border-color: var(--border-focus);
      }

      .submit-btn:active:not(:disabled) { opacity: 0.7; }
      .submit-btn:disabled { opacity: 0.3; cursor: default; }

      .done-message {
        font-family: 'Cormorant Garamond', Georgia, serif;
        font-size: 1.8rem;
        font-weight: 300;
        font-style: italic;
        line-height: 1.8;
        color: var(--done-text);
        margin-top: 1rem;
      }

      .no-question {
        font-family: 'Cormorant Garamond', Georgia, serif;
        font-size: 1.5rem;
        font-weight: 300;
        font-style: italic;
        color: var(--text-muted);
        margin-top: 1rem;
      }

      /* Calibration affordance — same look as owner's "free write" button. */
      .free-write-link {
        display: inline-block;
        margin-top: 3rem;
        color: var(--text-muted);
        font-size: 1.25rem;
        letter-spacing: 0.1em;
        text-transform: lowercase;
        cursor: pointer;
        border: 1px solid var(--border);
        background: none;
        font-family: 'Cormorant Garamond', Georgia, serif;
        font-style: italic;
        font-weight: 300;
        text-decoration: none;
        padding: 0.6rem 1.8rem;
        border-radius: 4px;
        transition: all 0.4s ease;
      }
      .free-write-link:hover {
        color: var(--text);
        border-color: var(--border-focus);
        background: rgba(0, 0, 0, 0.03);
      }
      [data-theme="dark"] .free-write-link:hover {
        background: rgba(255, 255, 255, 0.04);
      }

      /* Top-right controls — theme toggle + logout (subject's only nav). */
      .top-controls {
        position: fixed;
        top: 2rem;
        right: 2rem;
        display: flex;
        gap: 0.6rem;
        align-items: center;
        z-index: 10;
      }

      .top-btn {
        background: none;
        border: 1px solid var(--border);
        border-radius: 50%;
        width: 36px;
        height: 36px;
        cursor: pointer;
        display: flex;
        align-items: center;
        justify-content: center;
        transition: all 0.3s ease;
        color: var(--text-muted);
        font-size: 1rem;
        text-decoration: none;
        font-family: 'Cormorant Garamond', Georgia, serif;
      }

      .top-btn:hover {
        border-color: var(--border-focus);
        color: var(--text);
      }
    </style>
  </head>
  <body>
    <div class="top-controls">
      <button class="top-btn" id="theme-toggle" aria-label="Toggle theme"></button>
      <button class="top-btn" id="logout-btn" aria-label="Log out" title="Log out">⏻</button>
    </div>
    <div class="container">
      <div class="date" id="date"></div>
      <div class="question loading" id="question">...</div>
      <div id="input-area"></div>
    </div>

    <script>
      // ── Theme toggle ────────────────────────────────────────────────────
      const themeBtn = document.getElementById('theme-toggle')!;
      const savedTheme = localStorage.getItem('alice-theme') || 'light';
      document.documentElement.setAttribute('data-theme', savedTheme);
      themeBtn.textContent = savedTheme === 'dark' ? '☀' : '☾';
      themeBtn.addEventListener('click', () => {
        const current = document.documentElement.getAttribute('data-theme');
        const next = current === 'dark' ? 'light' : 'dark';
        document.documentElement.setAttribute('data-theme', next);
        localStorage.setItem('alice-theme', next);
        themeBtn.textContent = next === 'dark' ? '☀' : '☾';
      });

      // ── Logout ──────────────────────────────────────────────────────────
      const logoutBtn = document.getElementById('logout-btn')!;
      logoutBtn.addEventListener('click', async () => {
        try { await fetch('/api/subject/logout', { method: 'POST' }); }
        catch { /* fall through to redirect anyway */ }
        window.location.href = '/enter';
      });

      // ── Presence — the room is dim until you arrive. Any signal of
      //    presence (mouse, scroll, touch, keystroke) warms the room.
      //    Brightening happens *around* your typing, not before it.
      document.body.classList.add('pre-arrival');
      {
        const presenceEvents: Array<keyof WindowEventMap> = ['mousemove', 'scroll', 'touchstart', 'pointerdown', 'keydown'];
        function onPresence() {
          document.body.classList.remove('pre-arrival');
          for (const ev of presenceEvents) window.removeEventListener(ev, onPresence);
        }
        for (const ev of presenceEvents) window.addEventListener(ev, onPresence, { once: false, passive: true });
      }
      // Deepening transitions — same cadence as owner page.
      setTimeout(() => document.body.classList.add('deepening-1'), 30000);
      setTimeout(() => document.body.classList.add('deepening-2'), 75000);
      setTimeout(() => document.body.classList.add('deepening-3'), 150000);

      const dateEl = document.getElementById('date')!;
      const questionEl = document.getElementById('question')!;
      const inputArea = document.getElementById('input-area')!;

      const today = new Date();
      dateEl.textContent = today.toLocaleDateString('en-US', {
        weekday: 'long',
        year: 'numeric',
        month: 'long',
        day: 'numeric',
      });

      // Device context
      const isMobile = /Mobi|Android|iPhone|iPad/i.test(navigator.userAgent);
      const deviceType = isMobile ? 'mobile' : 'desktop';
      const hourOfDay = new Date().getHours();
      const dayOfWeek = new Date().getDay();
      const rawUserAgent = navigator.userAgent;

      // QWERTY left-hand mapping (Kim et al. 2024)
      const LEFT_HAND_CODES = new Set([
        'Backquote','Digit1','Digit2','Digit3','Digit4','Digit5',
        'KeyQ','KeyW','KeyE','KeyR','KeyT',
        'KeyA','KeyS','KeyD','KeyF','KeyG',
        'KeyZ','KeyX','KeyC','KeyV','KeyB',
        'Tab','CapsLock','ShiftLeft','ControlLeft','AltLeft','MetaLeft',
      ]);

      const PUNCTUATION_CODES = new Set([
        'Period', 'Comma', 'Slash', 'Quote', 'Semicolon',
        'BracketLeft', 'BracketRight', 'Minus', 'Equal',
        'Backquote', 'Backslash',
      ]);

      function getDoneMessage(): string {
        const messages = [
          "Noted. Let it sit.",
          "That thought is yours now. Come back tomorrow.",
          "Done. Don't rehearse it.",
          "Saved. Go do something with your hands.",
          "Good. Now forget about it until tomorrow.",
          "The thought is planted. Leave it alone.",
          "You showed up. That's the whole thing.",
          "Stop thinking about what you just wrote.",
          "That's enough for today.",
        ];
        return messages[Math.floor(Math.random() * messages.length)];
      }

      type WritingMode = 'journal' | 'calibration';

      function showDoneMessageWithFreeWrite() {
        questionEl.textContent = '';
        inputArea.innerHTML = `
          <div class="done-message">${getDoneMessage()}</div>
          <button class="free-write-link" id="free-write-btn">free write</button>
        `;
        document.getElementById('free-write-btn')!.addEventListener('click', startFreeWrite);
      }

      async function startFreeWrite() {
        const res = await fetch('/api/subject/calibrate');
        if (!res.ok) return;
        const data = await res.json();
        // Calibration is a deliberate click — presence is already established;
        // skip pre-arrival fade so the surface starts lit.
        document.body.classList.remove('pre-arrival', 'deepening-1', 'deepening-2', 'deepening-3');
        await runWritingFlow('calibration', { prompt: data.prompt as string });
      }

      async function load() {
        const res = await fetch('/api/subject/today');

        if (res.status === 401) {
          window.location.href = '/enter';
          return;
        }

        if (res.status === 404) {
          questionEl.textContent = '';
          questionEl.classList.remove('loading');
          inputArea.innerHTML = `
            <div class="no-question">No question today. Check back tomorrow.</div>
            <button class="free-write-link" id="free-write-btn">free write</button>
          `;
          document.getElementById('free-write-btn')!.addEventListener('click', startFreeWrite);
          return;
        }

        if (!res.ok) {
          questionEl.textContent = 'Something went wrong.';
          questionEl.classList.remove('loading');
          return;
        }

        const data = await res.json();
        questionEl.textContent = data.text;
        questionEl.classList.remove('loading');

        if (data.existing_response_text) {
          showDoneMessageWithFreeWrite();
          return;
        }

        await runWritingFlow('journal', { questionId: data.question_id as number });
      }

      async function runWritingFlow(
        mode: WritingMode,
        ctx: { questionId?: number; prompt?: string },
      ) {
        if (mode === 'calibration') {
          questionEl.textContent = ctx.prompt!;
          questionEl.classList.remove('loading');
        }
        const pageOpenTime = performance.now();

        inputArea.innerHTML = `
          <textarea
            class="response-area"
            id="response"
            autocomplete="off"
            autocorrect="off"
            autocapitalize="off"
            spellcheck="false"
          ></textarea>
          <div class="submit-row" id="submit-row">
            <button class="submit-btn" id="submit" disabled>done</button>
          </div>
        `;

        const textarea = document.getElementById('response') as HTMLTextAreaElement;
        const submitBtn = document.getElementById('submit') as HTMLButtonElement;
        const submitRow = document.getElementById('submit-row')!;

        textarea.focus();

        // Calibration is a deliberate click — full presence immediately.
        // Journal uses a continuous fade-in driven by content length: faint
        // ghost at 5 chars, full presence around 500 chars, always clickable
        // once visible. (Hallnäs & Redström 2001 reframed: no moment of
        // permission, just a peripheral signal that grows with the work.)
        const SUBMIT_START_CHARS = 5;
        const SUBMIT_FULL_CHARS = 500;
        const SUBMIT_MIN_PRESENCE = 0.10;
        function updateSubmitPresence() {
          if (mode === 'calibration') return; // presence pinned at 1 below
          const chars = textarea.value.trim().length;
          let presence;
          if (chars < SUBMIT_START_CHARS) {
            presence = 0;
          } else if (chars >= SUBMIT_FULL_CHARS) {
            presence = 1;
          } else {
            const t = (chars - SUBMIT_START_CHARS) / (SUBMIT_FULL_CHARS - SUBMIT_START_CHARS);
            presence = SUBMIT_MIN_PRESENCE + (1 - SUBMIT_MIN_PRESENCE) * Math.pow(t, 1.5);
          }
          submitRow.style.setProperty('--submit-presence', presence.toFixed(3));
          submitRow.classList.toggle('present', presence > 0);
        }

        if (mode === 'calibration') {
          submitRow.style.setProperty('--submit-presence', '1');
          submitRow.classList.add('present');
        }

        // ================================================================
        // KEYSTROKE INSTRUMENTATION (identical to owner path in index.astro)
        // ================================================================

        let firstKeystrokeSent = false;
        let firstKeystrokeTime: number | null = null;
        let pauseTimer: number | null = null;
        let isPaused = false;
        let pauseStartTime: number | null = null;
        let totalPauseMs = 0;
        let pauseCount = 0;
        let totalCharsTyped = 0;
        let totalCharsDeleted = 0;
        let deletionCount = 0;
        let largestDeletion = 0;
        let lastTextLength = 0;
        let tabAwayCount = 0;
        let tabAwayStartTime: number | null = null;
        let totalTabAwayMs = 0;
        let smallDeletionCount = 0;
        let largeDeletionCount = 0;
        let largeDeletionChars = 0;
        const deletionTimestamps: Array<{chars: number; time: number}> = [];
        let eventLogTotalInputs = 0;
        const eventLog: Array<[number, string]> = [];
        let lastInputTime: number | null = null;
        let currentBurstChars = 0;
        let burstStartTime: number | null = null;
        const burstLengths: number[] = [];
        const burstSequence: Array<{chars: number; startOffsetMs: number; durationMs: number}> = [];
        let lastKeystrokeTime: number | null = null;
        const interKeyIntervals: number[] = [];
        let currentRevisionChainLength = 0;
        let lastDeletionTime: number | null = null;
        const revisionChains: number[] = [];
        const holdTimes: number[] = [];
        const flightTimes: number[] = [];
        let lastKeyupTime: number | null = null;
        const keydownTimes = new Map<string, number>();
        const keystrokeStream: Array<{c: string; d: number; u: number}> = [];
        let leadingEdgeInputCount = 0;
        let totalInputActionCount = 0;
        let contextualRevisionCount = 0;
        let preContextualRevisionCount = 0;
        let readBackCount = 0;
        let readBackPending = false;
        let readBackTimer: ReturnType<typeof setTimeout> | null = null;
        let consideredAndKeptCount = 0;
        let lastSelectionWasRange = false;
        let pasteCount = 0;
        let pasteCharsTotal = 0;
        let dropCount = 0;
        const holdTimesLeft: number[] = [];
        const holdTimesRight: number[] = [];
        let negativeFlightTimeCount = 0;
        const errorDetectionLatencies: number[] = [];
        let lastNonDeleteKeystrokeTime: number | null = null;
        const mousePauseSamples: Array<{x: number; y: number}> = [];
        let currentMouseX = 0;
        let currentMouseY = 0;
        let lastMouseSampleX = 0;
        let lastMouseSampleY = 0;
        let cursorTotalDistance = 0;
        let cursorStillSamples = 0;
        let driftToSubmitCount = 0;
        let lastWasInSubmit = false;
        const deletionExecutionIKIs: number[] = [];
        const postcorrectionLatencies: number[] = [];
        let lastDeletionKeystrokeTime: number | null = null;
        let awaitingPostcorrection = false;
        const revisionDistances: number[] = [];
        const punctuationFlightTimes: number[] = [];
        const letterFlightTimes: number[] = [];
        let scrollBackCount = 0;
        let questionRereadCount = 0;
        let lastScrollTop = 0;

        // Mouse tracking during pauses
        document.addEventListener('mousemove', (e: MouseEvent) => {
          currentMouseX = e.clientX;
          currentMouseY = e.clientY;
        });

        const mouseTrackingInterval = window.setInterval(() => {
          if (!firstKeystrokeSent || !lastInputTime) return;
          if ((performance.now() - lastInputTime) < 2000) return;
          const dx = currentMouseX - lastMouseSampleX;
          const dy = currentMouseY - lastMouseSampleY;
          const dist = Math.sqrt(dx * dx + dy * dy);
          cursorTotalDistance += dist;
          if (dist < 5) cursorStillSamples++;
          mousePauseSamples.push({ x: currentMouseX, y: currentMouseY });
          lastMouseSampleX = currentMouseX;
          lastMouseSampleY = currentMouseY;
          const btnRect = submitBtn.getBoundingClientRect();
          const inSubmit = currentMouseX >= btnRect.left && currentMouseX <= btnRect.right
            && currentMouseY >= btnRect.top && currentMouseY <= btnRect.bottom;
          if (inSubmit && !lastWasInSubmit) driftToSubmitCount++;
          lastWasInSubmit = inSubmit;
        }, 200);

        // Scroll tracking
        textarea.addEventListener('scroll', () => {
          if (textarea.scrollTop < lastScrollTop && lastScrollTop > 0) scrollBackCount++;
          lastScrollTop = textarea.scrollTop;
        });
        window.addEventListener('scroll', () => {
          if (window.scrollY < 50 && textarea.value.length > 0) questionRereadCount++;
        }, { passive: true });

        // Read-back + selection tracking
        document.addEventListener('selectionchange', () => {
          if (document.activeElement !== textarea) return;
          if (readBackTimer) clearTimeout(readBackTimer);
          readBackPending = true;
          readBackTimer = setTimeout(() => {
            if (readBackPending) { readBackCount++; readBackPending = false; }
          }, 500);
          const hasRange = textarea.selectionStart !== textarea.selectionEnd;
          if (lastSelectionWasRange && !hasRange) consideredAndKeptCount++;
          lastSelectionWasRange = hasRange;
        });

        // Paste/drop blocked
        let pasteMessageShown = false;
        textarea.addEventListener('paste', (e: ClipboardEvent) => {
          e.preventDefault();
          pasteCount++;
          pasteCharsTotal += (e.clipboardData?.getData('text/plain') ?? '').length;
          if (!pasteMessageShown) {
            pasteMessageShown = true;
            const msg = document.createElement('div');
            msg.textContent = 'paste is disabled during writing';
            msg.style.cssText = 'position:fixed;bottom:2rem;left:50%;transform:translateX(-50%);font-size:10px;letter-spacing:0.14em;text-transform:uppercase;color:var(--text-faint);opacity:1;transition:opacity 2s ease 3s;pointer-events:none;';
            document.body.appendChild(msg);
            setTimeout(() => { msg.style.opacity = '0'; }, 100);
            setTimeout(() => { msg.remove(); }, 6000);
          }
        });
        textarea.addEventListener('dragover', (e: DragEvent) => { e.preventDefault(); });
        textarea.addEventListener('drop', (e: DragEvent) => { e.preventDefault(); dropCount++; });

        // Keydown handler
        textarea.addEventListener('keydown', (e: KeyboardEvent) => {
          const now = performance.now();
          if (!e.repeat) {
            if (lastKeystrokeTime !== null) {
              const interval = now - lastKeystrokeTime;
              if (interval < 5000) interKeyIntervals.push(interval);
            }
            lastKeystrokeTime = now;
            keydownTimes.set(e.code, now);
            if (lastKeyupTime !== null) {
              const ft = now - lastKeyupTime;
              if (ft > 0 && ft < 5000) {
                flightTimes.push(ft);
                if (PUNCTUATION_CODES.has(e.code)) punctuationFlightTimes.push(ft);
                else if (e.code.startsWith('Key')) letterFlightTimes.push(ft);
              } else if (ft < 0) {
                negativeFlightTimeCount++;
              }
            }
          }
          totalInputActionCount++;
          if (textarea.selectionStart >= textarea.value.length) leadingEdgeInputCount++;
          if (readBackPending) { readBackPending = false; if (readBackTimer) clearTimeout(readBackTimer); }

          if (e.key === 'Backspace' || e.key === 'Delete') {
            if (lastDeletionTime !== null && (now - lastDeletionTime) < 500) {
              currentRevisionChainLength++;
              const delIKI = now - lastDeletionTime;
              if (delIKI > 0 && delIKI < 2000) deletionExecutionIKIs.push(delIKI);
            } else {
              if (currentRevisionChainLength > 0) revisionChains.push(currentRevisionChainLength);
              currentRevisionChainLength = 1;
            }
            lastDeletionTime = now;
            lastDeletionKeystrokeTime = now;
            awaitingPostcorrection = true;
            if (lastNonDeleteKeystrokeTime !== null) {
              const edl = now - lastNonDeleteKeystrokeTime;
              if (edl > 0 && edl < 5000) errorDetectionLatencies.push(edl);
            }
            const isContextual = textarea.selectionStart < textarea.value.length - 1;
            if (isContextual) {
              contextualRevisionCount++;
              const dist = textarea.value.length - textarea.selectionStart;
              if (dist > 0) revisionDistances.push(dist);
            } else {
              preContextualRevisionCount++;
            }
          } else {
            if (currentRevisionChainLength > 0) { revisionChains.push(currentRevisionChainLength); currentRevisionChainLength = 0; }
            lastNonDeleteKeystrokeTime = now;
          }
        });

        // Keyup handler
        textarea.addEventListener('keyup', (e: KeyboardEvent) => {
          const now = performance.now();
          lastKeyupTime = now;
          const downTime = keydownTimes.get(e.code);
          if (downTime != null) {
            const ht = now - downTime;
            if (ht > 0 && ht < 2000) {
              holdTimes.push(ht);
              keystrokeStream.push({ c: e.code, d: downTime - pageOpenTime, u: now - pageOpenTime });
              if (LEFT_HAND_CODES.has(e.code)) holdTimesLeft.push(ht);
              else holdTimesRight.push(ht);
            }
            keydownTimes.delete(e.code);
          }
        });

        // Input handler
        textarea.addEventListener('input', () => {
          const now = performance.now();
          const currentLength = textarea.value.length;
          const delta = currentLength - lastTextLength;

          eventLogTotalInputs++;
          const cursorPos = textarea.selectionStart;
          if (delta > 0) {
            const inserted = textarea.value.slice(cursorPos - delta, cursorPos);
            eventLog.push([now - pageOpenTime, cursorPos - delta, 0, inserted]);
          } else if (delta < 0) {
            eventLog.push([now - pageOpenTime, cursorPos, -delta, '']);
          }

          // Question fade on first keystroke
          if (!firstKeystrokeSent && delta > 0) {
            questionEl.classList.add('faded');
          }

          if (delta > 0) {
            totalCharsTyped += delta;
            if (awaitingPostcorrection && lastDeletionKeystrokeTime !== null) {
              const pcl = now - lastDeletionKeystrokeTime;
              if (pcl > 0 && pcl < 10000) postcorrectionLatencies.push(pcl);
              awaitingPostcorrection = false;
            }
            if (lastInputTime !== null && (now - lastInputTime) > 2000) {
              if (currentBurstChars > 0) {
                burstLengths.push(currentBurstChars);
                burstSequence.push({
                  chars: currentBurstChars,
                  startOffsetMs: (burstStartTime ?? now) - pageOpenTime,
                  durationMs: lastInputTime - (burstStartTime ?? lastInputTime),
                });
              }
              currentBurstChars = 0;
              burstStartTime = now;
            }
            if (burstStartTime === null) burstStartTime = now;
            currentBurstChars += delta;
            lastInputTime = now;
          } else if (delta < 0) {
            const deleted = Math.abs(delta);
            totalCharsDeleted += deleted;
            deletionCount++;
            if (deleted > largestDeletion) largestDeletion = deleted;
            if (deleted < 10) smallDeletionCount++;
            else { largeDeletionCount++; largeDeletionChars += deleted; }
            deletionTimestamps.push({ chars: deleted, time: now });
          }

          lastTextLength = currentLength;
          submitBtn.disabled = !textarea.value.trim();
          updateSubmitPresence();

          if (!firstKeystrokeSent) {
            firstKeystrokeTime = performance.now();
            firstKeystrokeSent = true;
          }

          if (isPaused) {
            if (pauseStartTime) { totalPauseMs += performance.now() - pauseStartTime; pauseStartTime = null; }
            isPaused = false;
          }

          if (pauseTimer) clearTimeout(pauseTimer);
          pauseTimer = window.setTimeout(() => {
            if (firstKeystrokeSent) { pauseCount++; pauseStartTime = performance.now(); isPaused = true; }
          }, 30000);
        });

        // Tab away tracking
        document.addEventListener('visibilitychange', () => {
          if (document.hidden) {
            tabAwayStartTime = performance.now();
            if (currentBurstChars > 0) {
              burstLengths.push(currentBurstChars);
              burstSequence.push({
                chars: currentBurstChars,
                startOffsetMs: (burstStartTime ?? performance.now()) - pageOpenTime,
                durationMs: performance.now() - (burstStartTime ?? performance.now()),
              });
              currentBurstChars = 0;
              burstStartTime = null;
            }
          } else {
            if (tabAwayStartTime) {
              totalTabAwayMs += performance.now() - tabAwayStartTime;
              tabAwayCount++;
              tabAwayStartTime = null;
            }
          }
        });

        // Submit handler
        submitBtn.addEventListener('click', async () => {
          const text = textarea.value.trim();
          if (!text) return;

          submitBtn.disabled = true;
          submitBtn.textContent = '...';

          if (isPaused && pauseStartTime) totalPauseMs += performance.now() - pauseStartTime;
          if (currentBurstChars > 0) {
            const now = performance.now();
            burstLengths.push(currentBurstChars);
            burstSequence.push({
              chars: currentBurstChars,
              startOffsetMs: (burstStartTime ?? now) - pageOpenTime,
              durationMs: now - (burstStartTime ?? now),
            });
          }
          if (currentRevisionChainLength > 0) revisionChains.push(currentRevisionChainLength);

          const submitTime = performance.now();
          const finalCharCount = text.length;
          const wordCount = text.split(/\s+/).filter(Boolean).length;
          const sentenceCount = text.split(/[.!?]+/).filter((s: string) => s.trim()).length;
          const totalDurationMs = submitTime - pageOpenTime;
          const firstKeystrokeMs = firstKeystrokeTime ? firstKeystrokeTime - pageOpenTime : null;
          const commitmentRatio = totalCharsTyped > 0 ? finalCharCount / totalCharsTyped : null;
          const activeTypingMs = Math.max(0, totalDurationMs - totalPauseMs - totalTabAwayMs);
          const charsPerMinute = activeTypingMs > 0 ? totalCharsTyped / (activeTypingMs / 60000) : null;
          const pBurstCount = burstLengths.length;
          const avgPBurstLength = pBurstCount > 0 ? burstLengths.reduce((a, b) => a + b, 0) / pBurstCount : null;
          const midpoint = pageOpenTime + totalDurationMs / 2;
          let firstHalfDeletionChars = 0, secondHalfDeletionChars = 0;
          for (const d of deletionTimestamps) {
            if (d.time <= midpoint) firstHalfDeletionChars += d.chars;
            else secondHalfDeletionChars += d.chars;
          }
          const ikiCount = interKeyIntervals.length;
          const ikiMean = ikiCount > 0 ? interKeyIntervals.reduce((a, b) => a + b, 0) / ikiCount : null;
          const ikiStd = ikiCount > 1 ? Math.sqrt(interKeyIntervals.reduce((sum, v) => sum + (v - ikiMean!) ** 2, 0) / (ikiCount - 1)) : null;
          const htCount = holdTimes.length;
          const holdTimeMean = htCount > 0 ? holdTimes.reduce((a, b) => a + b, 0) / htCount : null;
          const holdTimeStd = htCount > 1 ? Math.sqrt(holdTimes.reduce((sum, v) => sum + (v - holdTimeMean!) ** 2, 0) / (htCount - 1)) : null;
          const ftCount = flightTimes.length;
          const flightTimeMean = ftCount > 0 ? flightTimes.reduce((a, b) => a + b, 0) / ftCount : null;
          const flightTimeStd = ftCount > 1 ? Math.sqrt(flightTimes.reduce((sum, v) => sum + (v - flightTimeMean!) ** 2, 0) / (ftCount - 1)) : null;
          let keystrokeEntropy: number | null = null;
          if (ikiCount >= 10) {
            const BIN_WIDTH = 50, NUM_BINS = 40;
            const bins = new Array(NUM_BINS).fill(0);
            for (const iki of interKeyIntervals) bins[Math.min(NUM_BINS - 1, Math.floor(iki / BIN_WIDTH))]++;
            let entropy = 0;
            for (const count of bins) { if (count > 0) { const p = count / ikiCount; entropy -= p * Math.log2(p); } }
            keystrokeEntropy = entropy;
          }
          const revChainCount = revisionChains.length;
          const revChainAvgLength = revChainCount > 0 ? revisionChains.reduce((a, b) => a + b, 0) / revChainCount : null;
          const confirmationLatencyMs = lastInputTime ? submitTime - lastInputTime : null;
          const leadingEdgeRatio = totalInputActionCount > 0 ? leadingEdgeInputCount / totalInputActionCount : null;
          const htLeftCount = holdTimesLeft.length;
          const holdTimeMeanLeft = htLeftCount > 0 ? holdTimesLeft.reduce((a, b) => a + b, 0) / htLeftCount : null;
          const holdTimeStdLeft = htLeftCount > 1 ? Math.sqrt(holdTimesLeft.reduce((s, v) => s + (v - holdTimeMeanLeft!) ** 2, 0) / (htLeftCount - 1)) : null;
          const htRightCount = holdTimesRight.length;
          const holdTimeMeanRight = htRightCount > 0 ? holdTimesRight.reduce((a, b) => a + b, 0) / htRightCount : null;
          const holdTimeStdRight = htRightCount > 1 ? Math.sqrt(holdTimesRight.reduce((s, v) => s + (v - holdTimeMeanRight!) ** 2, 0) / (htRightCount - 1)) : null;
          const holdTimeCV = (holdTimeMean != null && holdTimeMean > 0 && holdTimeStd != null) ? holdTimeStd / holdTimeMean : null;
          let ikiSkewness: number | null = null, ikiKurtosis: number | null = null;
          if (ikiCount >= 10 && ikiMean != null && ikiStd != null && ikiStd > 0) {
            let m3 = 0, m4 = 0;
            for (const iki of interKeyIntervals) { const d = (iki - ikiMean) / ikiStd; m3 += d ** 3; m4 += d ** 4; }
            ikiSkewness = m3 / ikiCount;
            ikiKurtosis = (m4 / ikiCount) - 3;
          }
          const edlCount = errorDetectionLatencies.length;
          const errorDetectionLatencyMean = edlCount > 0 ? errorDetectionLatencies.reduce((a, b) => a + b, 0) / edlCount : null;
          let terminalVelocity: number | null = null;
          if (ikiCount >= 20 && ikiMean != null && ikiMean > 0) {
            const tail = Math.max(2, Math.floor(ikiCount * 0.1));
            const tailMean = interKeyIntervals.slice(-tail).reduce((a, b) => a + b, 0) / tail;
            terminalVelocity = tailMean / ikiMean;
          }
          clearInterval(mouseTrackingInterval);
          const totalMouseSamples = mousePauseSamples.length;
          const cursorFidgetRatio = activeTypingMs > 0 ? cursorTotalDistance / activeTypingMs : null;
          const cursorStillnessDuringPauses = totalMouseSamples > 0 ? cursorStillSamples / totalMouseSamples : null;
          const delExecCount = deletionExecutionIKIs.length;
          const deletionExecutionSpeedMean = delExecCount > 0 ? deletionExecutionIKIs.reduce((a, b) => a + b, 0) / delExecCount : null;
          const pcCount = postcorrectionLatencies.length;
          const postcorrectionLatencyMean = pcCount > 0 ? postcorrectionLatencies.reduce((a, b) => a + b, 0) / pcCount : null;
          const revDistCount = revisionDistances.length;
          const meanRevisionDistance = revDistCount > 0 ? revisionDistances.reduce((a, b) => a + b, 0) / revDistCount : null;
          const maxRevisionDistance = revDistCount > 0 ? Math.max(...revisionDistances) : null;
          const punctFtCount = punctuationFlightTimes.length;
          const punctuationFlightMean = punctFtCount > 0 ? punctuationFlightTimes.reduce((a, b) => a + b, 0) / punctFtCount : null;
          const letterFtCount = letterFlightTimes.length;
          const letterFlightMean = letterFtCount > 0 ? letterFlightTimes.reduce((a, b) => a + b, 0) / letterFtCount : null;
          const punctuationLetterRatio = (punctuationFlightMean != null && letterFlightMean != null && letterFlightMean > 0) ? punctuationFlightMean / letterFlightMean : null;

          const sessionSummary = {
            // Journal mode: real question_id; calibration: 0 placeholder, the
            // server overwrites with the inserted question_id inside the
            // calibration transaction.
            questionId: ctx.questionId ?? 0,
            firstKeystrokeMs, totalDurationMs, totalCharsTyped, finalCharCount,
            commitmentRatio, pauseCount, totalPauseMs, deletionCount, largestDeletion,
            totalCharsDeleted, tabAwayCount, totalTabAwayMs, wordCount, sentenceCount,
            smallDeletionCount, largeDeletionCount, largeDeletionChars,
            firstHalfDeletionChars, secondHalfDeletionChars,
            activeTypingMs, charsPerMinute, pBurstCount, avgPBurstLength,
            burstSequence,
            interKeyIntervalMean: ikiMean, interKeyIntervalStd: ikiStd,
            revisionChainCount: revChainCount, revisionChainAvgLength: revChainAvgLength,
            holdTimeMean, holdTimeStd, flightTimeMean, flightTimeStd,
            keystrokeEntropy, scrollBackCount, questionRereadCount,
            confirmationLatencyMs, pasteCount, pasteCharsTotal, dropCount,
            readBackCount, leadingEdgeRatio,
            contextualRevisionCount, preContextualRevisionCount, consideredAndKeptCount,
            holdTimeMeanLeft, holdTimeMeanRight, holdTimeStdLeft, holdTimeStdRight,
            holdTimeCV, negativeFlightTimeCount, ikiSkewness, ikiKurtosis,
            errorDetectionLatencyMean, terminalVelocity,
            cursorDistanceDuringPauses: cursorTotalDistance, cursorFidgetRatio,
            cursorStillnessDuringPauses, driftToSubmitCount,
            cursorPauseSampleCount: totalMouseSamples,
            deletionExecutionSpeedMean, postcorrectionLatencyMean,
            meanRevisionDistance, maxRevisionDistance,
            punctuationFlightMean, punctuationLetterRatio,
            deletionEvents: deletionTimestamps.map(d => ({ chars: d.chars, time: d.time - pageOpenTime })),
            eventLog, eventLogTotalInputs, keystrokeStream,
            deviceType, userAgent: rawUserAgent, hourOfDay, dayOfWeek,
          };

          const submitUrl = mode === 'calibration' ? '/api/subject/calibrate' : '/api/subject/respond';
          const submitBody = mode === 'calibration'
            ? { prompt: ctx.prompt!, text, sessionSummary }
            : { question_id: ctx.questionId!, text, sessionSummary };

          const res = await fetch(submitUrl, {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify(submitBody),
          });

          if (res.ok) {
            // Both modes land on the same done-message + free-write affordance.
            // After calibration, the same button lets the subject run another
            // calibration prompt — unlimited access, owner gates nothing.
            showDoneMessageWithFreeWrite();
          } else {
            submitBtn.textContent = 'done';
            submitBtn.disabled = false;
          }
        });
      }

      load();
    </script>
  </body>
</html>
