---

---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Alice Negative — Gallery</title>
    <style is:global>
      * { margin: 0; padding: 0; box-sizing: border-box; }
      html, body {
        height: 100%;
        background: #000;
        color: rgba(255,255,255,0.5);
        font-family: 'SF Mono', 'Fira Code', monospace;
        overflow-x: hidden;
      }

      .gallery-header {
        text-align: center;
        padding: 1.5rem 2rem 0.5rem;
      }
      .gallery-header h1 {
        font-size: 0.75rem;
        font-weight: 400;
        letter-spacing: 0.3em;
        text-transform: uppercase;
        color: rgba(255,255,255,0.7);
        margin-bottom: 0.5rem;
      }
      .gallery-header p {
        font-size: 0.65rem;
        color: rgba(255,255,255,0.5);
      }

      .gallery-filters {
        display: none;
        justify-content: center;
        gap: 0.5rem;
        padding: 0.5rem 2rem;
      }
      .gallery-filters.visible {
        display: flex;
      }
      .filter-btn {
        background: none;
        border: 1px solid rgba(255,255,255,0.2);
        border-radius: 4px;
        padding: 0.3rem 0.8rem;
        font-family: 'SF Mono', 'Fira Code', monospace;
        font-size: 0.6rem;
        letter-spacing: 0.15em;
        text-transform: uppercase;
        color: rgba(255,255,255,0.4);
        cursor: pointer;
        transition: all 0.2s ease;
      }
      .filter-btn:hover {
        border-color: rgba(255,255,255,0.4);
        color: rgba(255,255,255,0.7);
      }
      .filter-btn.active {
        border-color: rgba(255,255,255,0.5);
        color: rgba(255,255,255,0.8);
      }

      .gallery-grid {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(380px, 650px));
        justify-content: center;
        gap: 1rem;
        padding: 0.5rem 2rem 4rem;
        max-width: 1400px;
        margin: 0 auto;
      }
      .gallery-grid.layout-stack {
        grid-template-columns: 1fr;
        max-width: 800px;
      }

      .alice-negative-cell {
        position: relative;
        aspect-ratio: 1;
        max-height: 80vh;
        max-width: 80vh;
        margin: 0 auto;
        overflow: hidden;
      }
      .layout-stack .alice-negative-cell {
        max-width: 100%;
        max-height: none;
      }
      .alice-negative-cell canvas {
        width: 100%;
        height: 100%;
        display: block;
      }

      .alice-negative-label {
        position: absolute;
        bottom: 1.2rem;
        left: 1.2rem;
        z-index: 2;
        pointer-events: none;
      }
      .alice-negative-label .version {
        font-size: 0.6rem;
        letter-spacing: 0.2em;
        text-transform: uppercase;
        color: rgba(255,255,255,0.7);
        margin-bottom: 0.2rem;
      }
      .alice-negative-label .meta {
        font-size: 0.55rem;
        color: rgba(255,255,255,0.5);
      }

      .alice-negative-label-right {
        position: absolute;
        bottom: 1.2rem;
        right: 1.2rem;
        z-index: 2;
        pointer-events: none;
        text-align: right;
      }
      .alice-negative-label-right .entries {
        font-size: 0.6rem;
        color: rgba(255,255,255,0.6);
      }

      .back-btn {
        position: fixed; top: 2rem; right: 2rem;
        background: none; border: 1px solid rgba(255,255,255,0.15);
        border-radius: 50%; width: 36px; height: 36px; cursor: pointer;
        display: flex; align-items: center; justify-content: center;
        color: rgba(255,255,255,0.4); font-size: 1rem;
        text-decoration: none; z-index: 10; transition: all 0.3s ease;
      }
      .back-btn:hover {
        border-color: rgba(255,255,255,0.35); color: rgba(255,255,255,0.6);
      }

      @media (max-width: 800px) {
        .gallery-grid {
          grid-template-columns: 1fr;
          padding: 0.5rem;
        }
      }
    </style>
  </head>
  <body>
    <a href="/alice-negative" class="back-btn" aria-label="Back to Alice Negative">&larr;</a>

    <div class="gallery-header">
      <h1>Lineage</h1>
      <p id="gallery-date"></p>
    </div>

    <div class="gallery-filters" id="filters">
      <button class="filter-btn active" data-layout="grid">grid</button>
      <button class="filter-btn" data-layout="stack">stack</button>
    </div>

    <div class="gallery-grid" id="grid"></div>

    <script>
      import * as THREE from 'three';
      import type { WitnessTraits } from '../lib/alice-negative/types';
      import { DEFAULT_WITNESS, TRAIT_KEYS } from '../lib/alice-negative/types';
      import { deriveShaderWeights, WEIGHT_KEYS, weightUniformName } from '../lib/alice-negative/shader-weights';

      import witnessVert from '../assets/shaders/witness.vert?raw';
      import witnessFrag from '../assets/shaders/witness.frag?raw';

      interface GalleryEntry {
        id: number;
        version: number;
        entryCount: number;
        traits: WitnessTraits;
        createdAt: string;
      }

      interface AliceNegativeInstance {
        renderer: THREE.WebGLRenderer;
        scene: THREE.Scene;
        camera: THREE.PerspectiveCamera;
        mesh: THREE.Mesh;
        material: THREE.ShaderMaterial;
        traits: WitnessTraits;
        mass: number;
        displayed: Record<string, number>;
        displayedMass: number;
        revealed: boolean;
        revealStart: number;
      }

      function traitUniformName(key: keyof WitnessTraits): string {
        return 'u' + key.charAt(0).toUpperCase() + key.slice(1);
      }

      function createAliceNegativeInstance(
        canvas: HTMLCanvasElement,
        traits: WitnessTraits,
        entryCount: number,
      ): AliceNegativeInstance {
        const w = canvas.clientWidth;
        const h = canvas.clientHeight;

        const renderer = new THREE.WebGLRenderer({ canvas, antialias: true, alpha: false });
        renderer.setSize(w, h);
        renderer.setPixelRatio(Math.min(window.devicePixelRatio, 2));
        renderer.setClearColor(0x000000, 1);

        const scene = new THREE.Scene();
        const camera = new THREE.PerspectiveCamera(40, w / h, 0.1, 100);
        camera.position.set(0, 0.1, 3.5);
        camera.lookAt(0, 0, 0);

        const mass = Math.min(1, Math.log(1 + entryCount) / Math.log(501));

        // Build uniforms
        const traitUniforms: Record<string, { value: number }> = {};
        for (const key of TRAIT_KEYS) {
          traitUniforms[traitUniformName(key)] = { value: DEFAULT_WITNESS.traits[key] };
        }
        const weightUniforms: Record<string, { value: number }> = {};
        for (const key of WEIGHT_KEYS) {
          weightUniforms[weightUniformName(key)] = { value: 0 };
        }

        const material = new THREE.ShaderMaterial({
          vertexShader: witnessVert,
          fragmentShader: witnessFrag,
          uniforms: {
            uTime: { value: 0 },
            uReveal: { value: 0 },
            uMass: { value: 0.1 },
            uCameraPos: { value: camera.position },
            ...traitUniforms,
            ...weightUniforms,
          },
          transparent: true,
          depthWrite: true,
          side: THREE.DoubleSide,
        });

        const geo = new THREE.IcosahedronGeometry(1, 64);
        geo.computeVertexNormals();
        const mesh = new THREE.Mesh(geo, material);
        mesh.position.set(0, -0.1, 0);
        scene.add(mesh);

        const displayed: Record<string, number> = {};
        for (const key of TRAIT_KEYS) {
          displayed[key] = DEFAULT_WITNESS.traits[key];
        }

        return {
          renderer, scene, camera, mesh, material,
          traits, mass,
          displayed, displayedMass: 0.1,
          revealed: false, revealStart: 0,
        };
      }

      // ─── Fetch & Build ───────────────────────────────────────

      const grid = document.getElementById('grid')!;
      const filters = document.getElementById('filters')!;
      const instances: AliceNegativeInstance[] = [];

      // ─── Layout filter toggle ───────────────────────────────
      filters.addEventListener('click', (e) => {
        const btn = (e.target as HTMLElement).closest('.filter-btn') as HTMLElement | null;
        if (!btn) return;
        const layout = btn.dataset.layout;
        filters.querySelectorAll('.filter-btn').forEach(b => b.classList.remove('active'));
        btn.classList.add('active');
        grid.classList.toggle('layout-stack', layout === 'stack');
        // Resize all renderers after layout change
        requestAnimationFrame(() => {
          for (const inst of instances) {
            const canvas = inst.renderer.domElement;
            const w = canvas.clientWidth;
            const h = canvas.clientHeight;
            inst.renderer.setSize(w, h);
            inst.camera.aspect = w / h;
            inst.camera.updateProjectionMatrix();
          }
        });
      });

      async function init() {
        const res = await fetch('/api/gallery');
        const entries: GalleryEntry[] = await res.json();

        // Set date from latest entry
        const dateEl = document.getElementById('gallery-date')!;
        if (entries.length > 0) {
          const latest = entries[entries.length - 1];
          const d = new Date(latest.createdAt + 'Z');
          dateEl.textContent = d.toLocaleDateString('en-US', { month: 'long', day: 'numeric', year: 'numeric' }).toLowerCase();
        }

        // Only show filters when there's more than one Alice Negative
        if (entries.length > 1) {
          filters.classList.add('visible');
        }

        for (const entry of entries) {
          const cell = document.createElement('div');
          cell.className = 'alice-negative-cell';

          const canvas = document.createElement('canvas');
          cell.appendChild(canvas);

          // Labels
          const label = document.createElement('div');
          label.className = 'alice-negative-label';
          const ts = new Date(entry.createdAt + 'Z');
          const timeStr = ts.toLocaleTimeString('en-US', { hour: 'numeric', minute: '2-digit', hour12: true }).toLowerCase();
          label.innerHTML = `
            <div class="version">alice-negative ${entry.version}</div>
            <div class="meta">${timeStr}</div>
          `;
          cell.appendChild(label);

          const labelRight = document.createElement('div');
          labelRight.className = 'alice-negative-label-right';
          labelRight.innerHTML = `<div class="entries">${entry.entryCount} entries</div>`;
          cell.appendChild(labelRight);

          grid.appendChild(cell);

          // Wait for layout so canvas has dimensions
          await new Promise(r => requestAnimationFrame(r));

          const instance = createAliceNegativeInstance(canvas, entry.traits, entry.entryCount);
          instances.push(instance);
        }

        // Start animation
        requestAnimationFrame(animate);
      }

      // ─── Camera Drift (per instance, varied) ────────────────

      function updateInstanceCamera(inst: AliceNegativeInstance, time: number, idx: number): void {
        // Slightly different frequency per instance for visual variety
        const offset = idx * 1.7;
        const fx = 0.017 + idx * 0.003;
        const fy = 0.013 + idx * 0.002;
        const fz = 0.0091 + idx * 0.001;
        inst.camera.position.set(
          Math.sin((time + offset) * fx * Math.PI * 2) * 0.15,
          0.1 + Math.sin((time + offset) * fy * Math.PI * 2) * 0.08,
          3.5 + Math.sin((time + offset) * fz * Math.PI * 2) * 0.1,
        );
        inst.camera.lookAt(0, -0.05, 0);
      }

      // ─── Animation Loop ─────────────────────────────────────

      let startTime = 0;
      let lastFrame = 0;

      function animate(now: number): void {
        if (!startTime) {
          startTime = now;
          lastFrame = now;
          for (const inst of instances) inst.revealStart = now;
        }

        const elapsed = (now - startTime) / 1000;
        const dt = Math.min((now - lastFrame) / 1000, 0.05);
        lastFrame = now;

        for (let i = 0; i < instances.length; i++) {
          const inst = instances[i];

          // Staggered reveal — each Alice Negative fades in 0.3s after the previous
          const revealDelay = i * 0.3;
          const revealElapsed = elapsed - revealDelay;
          const revealDuration = 3;
          let reveal = 0;
          if (revealElapsed > 0) {
            const progress = Math.min(1, revealElapsed / revealDuration);
            reveal = progress < 0.5
              ? 2 * progress * progress
              : 1 - 2 * (1 - progress) * (1 - progress);
          }

          inst.material.uniforms.uReveal.value = reveal;
          inst.material.uniforms.uTime.value = elapsed;
          inst.material.uniforms.uCameraPos.value = inst.camera.position;

          // Lerp traits toward target
          const rate = 0.3 * dt;
          for (const key of TRAIT_KEYS) {
            const target = inst.traits[key];
            inst.displayed[key] += (target - inst.displayed[key]) * rate;
            inst.material.uniforms[traitUniformName(key)].value = inst.displayed[key];
          }

          inst.displayedMass += (inst.mass - inst.displayedMass) * rate;
          inst.material.uniforms.uMass.value = inst.displayedMass;

          // Derive strategy weights
          const traitObj = {} as WitnessTraits;
          for (const key of TRAIT_KEYS) {
            (traitObj as any)[key] = inst.displayed[key];
          }
          const weights = deriveShaderWeights(traitObj);
          for (const key of WEIGHT_KEYS) {
            inst.material.uniforms[weightUniformName(key)].value = weights[key];
          }

          // Rotation from trait
          const rotationSpeed = inst.displayed['rotation'] * 8.0;
          inst.mesh.rotation.y += rotationSpeed * dt;

          // Camera drift
          updateInstanceCamera(inst, elapsed, i);

          // Render
          inst.renderer.render(inst.scene, inst.camera);
        }

        requestAnimationFrame(animate);
      }

      // ─── Resize ──────────────────────────────────────────────

      window.addEventListener('resize', () => {
        for (const inst of instances) {
          const canvas = inst.renderer.domElement;
          const w = canvas.clientWidth;
          const h = canvas.clientHeight;
          inst.renderer.setSize(w, h);
          inst.camera.aspect = w / h;
          inst.camera.updateProjectionMatrix();
        }
      });

      init();
    </script>
  </body>
</html>
