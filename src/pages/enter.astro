---
/**
 * Invite code entry page.
 *
 * Subject enters their invite code, which is stored as an httpOnly cookie.
 * After successful validation, redirects to /subject.
 * Minimal UI — no nav, no chrome.
 */
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Alice</title>
    <script is:inline>
      (function() {
        var t = localStorage.getItem('alice-theme') || 'light';
        document.documentElement.setAttribute('data-theme', t);
      })();
    </script>
    <style is:global>
      @import url('https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,400;1,300;1,400&family=EB+Garamond:ital,wght@0,400;0,500;1,400&display=swap');

      :root {
        --bg: #f5f2ed;
        --text: #1a1a1a;
        --text-muted: #6b6560;
        --border: #ccc5bc;
        --border-focus: #8a8580;
        --bg-input: #ebe7e1;
        --btn-bg: #e0dbd5;
        --btn-hover: #ccc5bc;
      }

      [data-theme="dark"] {
        --bg: #141210;
        --text: #ffffff;
        --text-muted: #7a7570;
        --border: #333;
        --border-focus: #666;
        --bg-input: #161514;
        --btn-bg: #222;
        --btn-hover: #444;
      }

      * { margin: 0; padding: 0; box-sizing: border-box; }

      body {
        font-family: 'Cormorant Garamond', Georgia, serif;
        background: var(--bg);
        color: var(--text);
        min-height: 100vh;
        display: flex;
        align-items: center;
        justify-content: center;
      }

      .enter-container {
        text-align: center;
        max-width: 400px;
        padding: 2rem;
      }

      .enter-title {
        font-size: 1.8rem;
        font-weight: 300;
        margin-bottom: 2rem;
        color: var(--text-muted);
      }

      .enter-input {
        font-family: 'Cormorant Garamond', Georgia, serif;
        font-size: 1.2rem;
        width: 100%;
        padding: 0.8rem 1rem;
        background: var(--bg-input);
        border: 1px solid var(--border);
        border-radius: 6px;
        color: var(--text);
        text-align: center;
        letter-spacing: 0.05em;
        outline: none;
        transition: border-color 0.2s ease;
      }

      .enter-input:focus { border-color: var(--border-focus); }

      .enter-btn {
        font-family: 'Cormorant Garamond', Georgia, serif;
        font-size: 1.1rem;
        margin-top: 1rem;
        padding: 0.6rem 2rem;
        background: var(--btn-bg);
        border: 1px solid var(--border);
        border-radius: 6px;
        color: var(--text);
        cursor: pointer;
        transition: background 0.2s ease;
      }

      .enter-btn:hover { background: var(--btn-hover); }
      .enter-btn:disabled { opacity: 0.4; cursor: default; }

      .enter-error {
        color: #b5603f;
        font-size: 0.95rem;
        margin-top: 0.8rem;
        min-height: 1.4em;
      }
    </style>
  </head>
  <body>
    <div class="enter-container">
      <div class="enter-title">enter your code</div>
      <input
        type="text"
        class="enter-input"
        id="code-input"
        placeholder="invite code"
        autocomplete="off"
        autocorrect="off"
        autocapitalize="off"
        spellcheck="false"
      />
      <br />
      <button class="enter-btn" id="enter-btn" disabled>enter</button>
      <div class="enter-error" id="error-msg"></div>
    </div>

    <script>
      const input = document.getElementById('code-input') as HTMLInputElement;
      const btn = document.getElementById('enter-btn') as HTMLButtonElement;
      const errorMsg = document.getElementById('error-msg')!;

      input.addEventListener('input', () => {
        btn.disabled = input.value.trim().length === 0;
        errorMsg.textContent = '';
      });

      input.addEventListener('keydown', (e: KeyboardEvent) => {
        if (e.key === 'Enter' && !btn.disabled) btn.click();
      });

      btn.addEventListener('click', async () => {
        const code = input.value.trim();
        if (!code) return;

        btn.disabled = true;
        errorMsg.textContent = '';

        // Set cookie and validate via the subject/today endpoint
        document.cookie = `alice_subject=${encodeURIComponent(code)}; path=/; max-age=${60 * 60 * 24 * 365}; SameSite=Strict`;

        const res = await fetch('/api/subject/today');

        if (res.status === 401) {
          errorMsg.textContent = 'code not recognized';
          document.cookie = 'alice_subject=; path=/; max-age=0';
          btn.disabled = false;
          return;
        }

        if (res.status === 403) {
          // Owner — redirect to main path
          window.location.href = '/';
          return;
        }

        // Valid subject (200 or 404-no-question-yet both mean the code worked)
        window.location.href = '/subject';
      });

      input.focus();
    </script>
  </body>
</html>
