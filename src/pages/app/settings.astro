---
import AppLayout from '../../layouts/layApp.astro';
---

<AppLayout title="Settings - Alice" active="settings">
  <div class="settings-page">
    <h1 class="settings-title">Settings</h1>

    <section class="settings-section">
      <h2 class="settings-heading">Account</h2>
      <div class="settings-row">
        <div>
          <span class="settings-label">Email</span>
          <span class="settings-value" id="user-email">user@example.com</span>
        </div>
        <button class="settings-action" disabled>Change</button>
      </div>
      <div class="settings-row">
        <div>
          <span class="settings-label">Password</span>
          <span class="settings-value">Last changed: never</span>
        </div>
        <button class="settings-action" disabled>Update</button>
      </div>
    </section>

    <section class="settings-section">
      <h2 class="settings-heading">Appearance</h2>
      <div class="settings-row">
        <div>
          <span class="settings-label">Theme</span>
          <span class="settings-value">Follows system preference</span>
        </div>
        <select class="settings-select" id="theme-select">
          <option value="system">System</option>
          <option value="light">Light</option>
          <option value="dark">Dark</option>
        </select>
      </div>
    </section>

    <section class="settings-section">
      <h2 class="settings-heading">Data</h2>
      <div class="settings-row">
        <div>
          <span class="settings-label">Export</span>
          <span class="settings-value">Download your behavioral data as JSON</span>
        </div>
        <button class="settings-action" disabled>Export</button>
      </div>
      <div class="settings-row">
        <div>
          <span class="settings-label">Delete account</span>
          <span class="settings-value settings-danger">This removes all data permanently</span>
        </div>
        <button class="settings-action settings-action-danger" disabled>Delete</button>
      </div>
    </section>
  </div>
</AppLayout>

<script is:inline>
  (function() {
    const sel = document.getElementById('theme-select');
    if (!sel) return;
    const saved = localStorage.getItem('alice-theme');
    if (saved) sel.value = saved;
    sel.addEventListener('change', function() {
      if (sel.value === 'system') {
        localStorage.removeItem('alice-theme');
        const pref = window.matchMedia('(prefers-color-scheme: dark)').matches ? 'dark' : 'light';
        document.documentElement.setAttribute('data-theme', pref);
      } else {
        localStorage.setItem('alice-theme', sel.value);
        document.documentElement.setAttribute('data-theme', sel.value);
      }
    });
  })();
</script>

<style is:global>
  .settings-page {
    padding-top: 2rem;
    max-width: 600px;
  }

  .settings-title {
    font-family: var(--serif-display);
    font-weight: 400;
    font-size: 1.5rem;
    margin-bottom: 2rem;
  }

  .settings-section {
    margin-bottom: 2.5rem;
  }

  .settings-heading {
    font-family: var(--sans);
    font-size: 0.75rem;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    color: var(--text-faint);
    margin-bottom: 1rem;
    padding-bottom: 0.5rem;
    border-bottom: 1px solid var(--border);
  }

  .settings-row {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 0.75rem 0;
  }
  .settings-row + .settings-row {
    border-top: 1px solid var(--border);
  }

  .settings-label {
    display: block;
    font-size: 0.9375rem;
    color: var(--text);
    margin-bottom: 0.125rem;
  }

  .settings-value {
    font-size: 0.8125rem;
    color: var(--text-muted);
  }

  .settings-danger {
    color: var(--negative);
  }

  .settings-action {
    padding: 0.375rem 1rem;
    border: 1px solid var(--border);
    border-radius: 6px;
    background: transparent;
    color: var(--text-muted);
    font-family: var(--sans);
    font-size: 0.8125rem;
    cursor: pointer;
    transition: border-color 0.2s;
    white-space: nowrap;
  }
  .settings-action:hover:not(:disabled) {
    border-color: var(--border-focus);
  }
  .settings-action:disabled {
    opacity: 0.4;
    cursor: default;
  }

  .settings-action-danger {
    border-color: var(--negative);
    color: var(--negative);
  }

  .settings-select {
    padding: 0.375rem 0.75rem;
    border: 1px solid var(--border);
    border-radius: 6px;
    background: var(--bg);
    color: var(--text);
    font-family: var(--sans);
    font-size: 0.8125rem;
    cursor: pointer;
    outline: none;
  }
</style>
