---
import PublicLayout from '../layouts/layPublic.astro';
---

<PublicLayout title="Alice -- Avatar" active="avatar" description="Writing process reconstruction from behavioral profile.">

<article class="avatar-page">

  <header class="av-hero">
    <h1>Avatar</h1>
    <p class="av-lead">Behavioral reconstruction from your writing process profile. Markov chain text, motor timing, revision, tempo drift. No LLM.</p>
  </header>

  <section class="av-section">
    <form class="av-form" id="avatar-form">
      <input type="text" id="topic-input" class="av-input" placeholder="Enter a topic..." required />
      <div class="av-dropdown" id="variant-dropdown">
        <button type="button" class="av-dropdown-trigger" id="variant-trigger">
          <span id="variant-label">Baseline</span>
          <svg width="10" height="6" viewBox="0 0 10 6" fill="none"><path d="M1 1l4 4 4-4" stroke="currentColor" stroke-width="1.2"/></svg>
        </button>
        <ul class="av-dropdown-menu" id="variant-menu">
          <li class="av-dropdown-item av-dropdown-active" data-value="1">Baseline</li>
          <li class="av-dropdown-item" data-value="2">Conditional Timing</li>
          <li class="av-dropdown-item" data-value="3">Copula Motor</li>
          <li class="av-dropdown-item" data-value="4">PPM Text</li>
          <li class="av-dropdown-item" data-value="5">Full Adversary</li>
        </ul>
        <input type="hidden" id="variant-select" name="variant" value="1" />
      </div>
      <button type="submit" class="av-btn" id="generate-btn">Generate</button>
    </form>

    <div class="av-meta" id="meta" hidden>
      <span id="meta-corpus"></span>
      <span id="meta-order"></span>
      <span id="meta-sessions"></span>
    </div>
  </section>

  <section class="av-section">
    <div class="av-stage" id="stage">
      <div class="av-textarea" id="output"></div>
      <div class="av-cursor" id="cursor" hidden></div>
    </div>

    <div class="av-signals" id="signals" hidden>
      <div class="av-signal-row">
        <div class="av-signal">
          <span class="av-signal-label">chars</span>
          <span class="av-signal-value" id="sig-chars">0</span>
        </div>
        <div class="av-signal">
          <span class="av-signal-label">bursts</span>
          <span class="av-signal-value" id="sig-bursts">0</span>
        </div>
        <div class="av-signal">
          <span class="av-signal-label">pauses</span>
          <span class="av-signal-value" id="sig-pauses">0</span>
        </div>
        <div class="av-signal">
          <span class="av-signal-label">avg iki</span>
          <span class="av-signal-value" id="sig-iki">0ms</span>
        </div>
        <div class="av-signal">
          <span class="av-signal-label">elapsed</span>
          <span class="av-signal-value" id="sig-elapsed">0s</span>
        </div>
      </div>
      <div class="av-signal-row">
        <div class="av-signal">
          <span class="av-signal-label">deletions</span>
          <span class="av-signal-value" id="sig-deletions">0</span>
        </div>
        <div class="av-signal">
          <span class="av-signal-label">r-bursts</span>
          <span class="av-signal-value" id="sig-rbursts">0</span>
        </div>
        <div class="av-signal">
          <span class="av-signal-label">i-bursts</span>
          <span class="av-signal-value" id="sig-ibursts">0</span>
        </div>
        <div class="av-signal">
          <span class="av-signal-label">eval pauses</span>
          <span class="av-signal-value" id="sig-evals">0</span>
        </div>
        <div class="av-signal">
          <span class="av-signal-label">tempo</span>
          <span class="av-signal-value" id="sig-tempo">--</span>
        </div>
      </div>
    </div>

  </section>

</article>

</PublicLayout>

<script is:inline>
(function () {
  var form = document.getElementById('avatar-form');
  var input = document.getElementById('topic-input');
  var btn = document.getElementById('generate-btn');
  var output = document.getElementById('output');
  var cursor = document.getElementById('cursor');
  var meta = document.getElementById('meta');
  var signals = document.getElementById('signals');

  var sigChars = document.getElementById('sig-chars');
  var sigBursts = document.getElementById('sig-bursts');
  var sigPauses = document.getElementById('sig-pauses');
  var sigIki = document.getElementById('sig-iki');
  var sigElapsed = document.getElementById('sig-elapsed');
  var sigDeletions = document.getElementById('sig-deletions');
  var sigRbursts = document.getElementById('sig-rbursts');
  var sigIbursts = document.getElementById('sig-ibursts');
  var sigEvals = document.getElementById('sig-evals');
  var sigTempo = document.getElementById('sig-tempo');

  if (!form || !input || !output) return;

  var PAUSE_THRESHOLD = 500;
  var BURST_THRESHOLD = 2000;
  var EVAL_THRESHOLD = 3500;
  var BACKSPACE = '\u0008';

  var cancelReplay = null;

  form.addEventListener('submit', function (e) {
    e.preventDefault();
    var topic = input.value.trim();
    if (!topic) return;

    if (cancelReplay) cancelReplay();

    btn.disabled = true;
    btn.textContent = 'Generating...';
    output.textContent = '';
    cursor.hidden = false;
    meta.hidden = true;
    signals.hidden = true;
    var oldDone = document.querySelector('.av-done');
    if (oldDone) oldDone.remove();

    var variant = parseInt(document.getElementById('variant-select').value, 10) || 1;

    fetch('/api/avatar', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ topic: topic, variant: variant }),
    })
      .then(function (res) { return res.json(); })
      .then(function (data) {
        btn.disabled = false;
        btn.textContent = 'Generate';

        if (data.error) {
          output.textContent = data.error;
          cursor.hidden = true;
          return;
        }

        // Show meta
        document.getElementById('meta-corpus').textContent = data.corpusSize + ' entries';
        document.getElementById('meta-order').textContent = 'order-' + data.markovOrder + ' markov';
        document.getElementById('meta-sessions').textContent = data.sessionCount + ' sessions profiled';
        meta.hidden = false;
        signals.hidden = false;

        // Parse the keystroke stream for replay
        var stream = [];
        try {
          stream = JSON.parse(data.keystrokeStreamJson || '[]');
        } catch (e) {
          stream = [];
        }

        // Fall back to text + delays if no stream
        var useStream = stream.length > 0;
        var text = data.text;
        var delays = data.delays || [];

        var i = 0;
        var charCount = 0;
        var burstCount = 1;
        var pauseCount = 0;
        var deletionCount = 0;
        var rBurstCount = 0;
        var iBurstCount = data.iBurstCount || 0;
        var evalPauseCount = 0;
        var totalIki = 0;
        var ikiCount = 0;
        var recentIkis = [];
        var displayText = '';
        var startTime = performance.now();
        var cancelled = false;
        var totalEvents = useStream ? stream.length : text.length;
        var inDeletion = false;
        var deletionRun = 0;

        cancelReplay = function () { cancelled = true; };

        function getDelay() {
          if (useStream && i > 0 && i < stream.length) {
            return Math.max(0, stream[i].d - stream[i - 1].d);
          }
          return i < delays.length ? delays[i] : 120;
        }

        function getChar() {
          if (useStream && i < stream.length) {
            return stream[i].c;
          }
          return i < text.length ? text[i] : null;
        }

        function updateTempo() {
          if (recentIkis.length < 3) {
            sigTempo.textContent = '--';
            return;
          }
          var recent = recentIkis.slice(-10);
          var avg = recent.reduce(function (a, b) { return a + b; }, 0) / recent.length;
          if (avg < 150) {
            sigTempo.textContent = 'fast';
          } else if (avg < 300) {
            sigTempo.textContent = 'steady';
          } else {
            sigTempo.textContent = 'slow';
          }
        }

        function typeNext() {
          if (cancelled || i >= totalEvents) {
            cursor.hidden = true;
            cancelReplay = null;
            var elapsed = (performance.now() - startTime) / 1000;
            sigElapsed.textContent = elapsed.toFixed(1) + 's';
            var done = document.createElement('div');
            done.className = 'av-done';
            done.textContent = charCount + ' chars in ' + elapsed.toFixed(1) + 's';
            output.parentNode.appendChild(done);
            return;
          }

          var ch = getChar();
          var delay = getDelay();

          if (ch === BACKSPACE || ch === '\b') {
            // Deletion event
            if (displayText.length > 0) {
              displayText = displayText.slice(0, -1);
              output.textContent = displayText;
            }
            deletionCount++;
            deletionRun++;
            if (!inDeletion) {
              inDeletion = true;
              deletionRun = 1;
            }
          } else if (ch !== null) {
            // Production or insertion event
            if (inDeletion) {
              // Finished a deletion run
              if (deletionRun >= 4) {
                rBurstCount++;
              }
              inDeletion = false;
              deletionRun = 0;
            }

            displayText += ch;
            output.textContent = displayText;
            charCount++;
          }

          // Classify delay for signals
          if (delay >= EVAL_THRESHOLD) {
            evalPauseCount++;
            pauseCount++;
            burstCount++;
          } else if (delay >= BURST_THRESHOLD) {
            burstCount++;
            pauseCount++;
          } else if (delay >= PAUSE_THRESHOLD) {
            pauseCount++;
          }

          if (delay > 0 && delay < BURST_THRESHOLD) {
            totalIki += delay;
            ikiCount++;
            recentIkis.push(delay);
            if (recentIkis.length > 30) recentIkis.shift();
          }

          // Update live signals
          sigChars.textContent = charCount;
          sigDeletions.textContent = deletionCount;
          sigRbursts.textContent = rBurstCount;
          sigIbursts.textContent = iBurstCount;
          sigEvals.textContent = evalPauseCount;
          var elapsed = (performance.now() - startTime) / 1000;
          sigElapsed.textContent = elapsed.toFixed(1) + 's';
          sigBursts.textContent = burstCount;
          sigPauses.textContent = pauseCount;
          sigIki.textContent = ikiCount > 0 ? Math.round(totalIki / ikiCount) + 'ms' : '0ms';

          updateTempo();

          output.scrollTop = output.scrollHeight;
          i++;

          setTimeout(typeNext, delay);
        }

        // Start replay
        var firstDelay = useStream && stream.length > 0 ? stream[0].d : (delays.length > 0 ? delays[0] : 3000);
        // First delay is absolute timestamp; convert to relative
        if (useStream && firstDelay > 10000) firstDelay = 3000;
        setTimeout(typeNext, Math.min(firstDelay, 5000));
      })
      .catch(function () {
        btn.disabled = false;
        btn.textContent = 'Generate';
        output.textContent = 'Failed to generate.';
        cursor.hidden = true;
      });
  });
})();

(function () {
  var trigger = document.getElementById('variant-trigger');
  var menu = document.getElementById('variant-menu');
  var hidden = document.getElementById('variant-select');
  var label = document.getElementById('variant-label');
  if (!trigger || !menu || !hidden || !label) return;

  trigger.addEventListener('click', function () {
    var open = menu.classList.toggle('av-dropdown-open');
    trigger.classList.toggle('av-dropdown-trigger-open', open);
  });

  menu.addEventListener('click', function (e) {
    var item = e.target.closest('.av-dropdown-item');
    if (!item) return;
    hidden.value = item.dataset.value;
    label.textContent = item.textContent;
    menu.querySelector('.av-dropdown-active').classList.remove('av-dropdown-active');
    item.classList.add('av-dropdown-active');
    menu.classList.remove('av-dropdown-open');
    trigger.classList.remove('av-dropdown-trigger-open');
  });

  document.addEventListener('click', function (e) {
    if (!e.target.closest('#variant-dropdown')) {
      menu.classList.remove('av-dropdown-open');
      trigger.classList.remove('av-dropdown-trigger-open');
    }
  });
})();
</script>

<style is:global>
  .avatar-page {
    padding-bottom: 4rem;
  }

  .av-hero {
    padding: 5rem 0 2rem;
    max-width: 720px;
  }

  .av-hero h1 {
    font-family: var(--serif-display);
    font-size: 2.2rem;
    font-weight: 400;
    color: var(--text);
    margin-bottom: 0.75rem;
  }

  .av-lead {
    font-family: var(--serif-body);
    font-size: 1rem;
    color: var(--text-muted);
    line-height: 1.6;
  }

  .av-section {
    padding: 1.5rem 0;
    border-top: 1px solid var(--border);
  }

  /* --- Form --- */
  .av-form {
    display: flex;
    gap: 0.75rem;
    max-width: 540px;
  }

  .av-input {
    flex: 1;
    padding: 0.7rem 1rem;
    border: 1px solid var(--border);
    border-radius: 6px;
    background: var(--bg-panel);
    color: var(--text);
    font-family: var(--serif-body);
    font-size: 1rem;
    outline: none;
    transition: border-color 0.2s ease;
  }

  .av-input:focus {
    border-color: var(--border-focus);
  }

  .av-input::placeholder {
    color: var(--text-faint);
    font-style: italic;
  }

  .av-dropdown {
    position: relative;
  }

  .av-dropdown-trigger {
    display: flex;
    align-items: center;
    gap: 0.6rem;
    padding: 0.7rem 1rem;
    border: 1px solid var(--border);
    border-radius: 6px;
    background: var(--bg-panel);
    color: var(--text-muted);
    font-family: var(--mono);
    font-size: 0.7rem;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    cursor: pointer;
    white-space: nowrap;
    transition: border-color 0.2s ease, color 0.2s ease;
  }

  .av-dropdown-trigger svg {
    flex-shrink: 0;
    transition: transform 0.2s ease;
  }

  .av-dropdown-trigger-open svg {
    transform: rotate(180deg);
  }

  .av-dropdown-trigger:hover,
  .av-dropdown-trigger-open {
    border-color: var(--border-focus);
    color: var(--text);
  }

  .av-dropdown-menu {
    display: none;
    position: absolute;
    top: calc(100% + 4px);
    left: 0;
    min-width: 100%;
    margin: 0;
    padding: 0.35rem 0;
    list-style: none;
    background: var(--bg);
    border: 1px solid var(--border);
    border-radius: 6px;
    z-index: 10;
  }

  .av-dropdown-menu.av-dropdown-open {
    display: block;
  }

  .av-dropdown-item {
    padding: 0.5rem 1rem;
    font-family: var(--mono);
    font-size: 0.7rem;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    color: var(--text-muted);
    cursor: pointer;
    transition: color 0.15s ease, background 0.15s ease;
  }

  .av-dropdown-item:hover {
    color: var(--text);
    background: var(--bg-dim);
  }

  .av-dropdown-item.av-dropdown-active {
    color: var(--text);
  }

  .av-btn {
    padding: 0.7rem 1.5rem;
    border: 1px solid var(--border);
    border-radius: 6px;
    background: transparent;
    color: var(--text-muted);
    font-family: var(--mono);
    font-size: 0.75rem;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    cursor: pointer;
    transition: border-color 0.2s ease, color 0.2s ease;
    white-space: nowrap;
  }

  .av-btn:hover:not(:disabled) {
    border-color: var(--border-focus);
    color: var(--text);
  }

  .av-btn:disabled {
    opacity: 0.4;
    cursor: default;
  }

  /* --- Meta --- */
  .av-meta {
    display: flex;
    gap: 1.5rem;
    margin-top: 1rem;
    font-family: var(--mono);
    font-size: 0.65rem;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--text-faint);
  }

  /* --- Stage (where the typing happens) --- */
  .av-stage {
    position: relative;
    min-height: 200px;
    max-height: 400px;
    overflow-y: auto;
    padding: 1.5rem;
    border: 1px solid var(--border);
    border-radius: 6px;
    background: var(--bg-panel);
  }

  .av-textarea {
    font-family: var(--serif-body);
    font-size: 1.1rem;
    line-height: 1.8;
    color: var(--text);
    white-space: pre-wrap;
    word-wrap: break-word;
  }

  .av-cursor {
    display: inline-block;
    width: 2px;
    height: 1.2em;
    background: var(--accent);
    margin-left: 1px;
    animation: blink 1s step-end infinite;
    vertical-align: text-bottom;
  }

  @keyframes blink {
    0%, 100% { opacity: 1; }
    50% { opacity: 0; }
  }

  /* --- Live signals --- */
  .av-signals {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
    margin-top: 1rem;
    padding: 1rem 0;
  }

  .av-signal-row {
    display: flex;
    gap: 2rem;
  }

  .av-signal {
    display: flex;
    flex-direction: column;
    gap: 0.2rem;
  }

  .av-signal-label {
    font-family: var(--mono);
    font-size: 0.6rem;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--text-faint);
  }

  .av-signal-value {
    font-family: var(--mono);
    font-size: 1.1rem;
    color: var(--text);
    letter-spacing: -0.02em;
  }

  .av-done {
    font-family: var(--mono);
    font-size: 0.7rem;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--text-faint);
    text-align: center;
    padding: 1rem 0;
  }

  @media (max-width: 768px) {
    .av-hero { padding: 4rem 0 1.5rem; }
    .av-hero h1 { font-size: 1.6rem; }
    .av-form { flex-direction: column; }
    .av-dropdown { width: 100%; }
    .av-dropdown-trigger { width: 100%; justify-content: space-between; }
    .av-dropdown-menu { width: 100%; }
    .av-signal-row { flex-wrap: wrap; gap: 1rem; }
    .av-meta { flex-wrap: wrap; gap: 0.75rem; }
  }
</style>
</PublicLayout>
