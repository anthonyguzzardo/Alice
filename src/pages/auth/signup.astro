---
import BaseLayout from '../../layouts/BaseLayout.astro';
---

<BaseLayout title="Sign up - Alice">
  <div class="auth-page">
    <a href="/landing" class="auth-back">&larr; Back</a>
    <div class="auth-card">
      <h1 class="auth-title">Begin</h1>
      <p class="auth-sub">One question per day. No obligations.</p>

      <form class="auth-form" id="signup-form">
        <div class="field">
          <label for="email">Email</label>
          <input type="email" id="email" name="email" required autocomplete="email" />
        </div>
        <div class="field">
          <label for="password">Password</label>
          <input type="password" id="password" name="password" required autocomplete="new-password" minlength="8" />
        </div>
        <div class="field">
          <label for="password-confirm">Confirm password</label>
          <input type="password" id="password-confirm" name="password-confirm" required autocomplete="new-password" />
        </div>
        <button type="submit" class="auth-submit">Create account</button>
      </form>

      <div class="auth-divider"><span>or</span></div>

      <a href="/app" class="auth-bypass">Skip to app (dev bypass)</a>

      <p class="auth-switch">
        Already have an account? <a href="/auth/login">Log in</a>
      </p>

      <p class="auth-fine-print">
        By creating an account, you agree that your writing belongs to you.
        Alice stores behavioral measurements, not your words.
      </p>
    </div>
  </div>
</BaseLayout>

<script is:inline>
  document.getElementById('signup-form').addEventListener('submit', function(e) {
    e.preventDefault();
    // TODO: real auth
    window.location.href = '/app';
  });
</script>

<style is:global>
  .auth-fine-print {
    text-align: center;
    margin-top: 1.5rem;
    font-size: 0.75rem;
    color: var(--text-faint);
    line-height: 1.6;
    max-width: 300px;
    margin-left: auto;
    margin-right: auto;
  }
</style>
