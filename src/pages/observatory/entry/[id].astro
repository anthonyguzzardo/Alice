---
/**
 * Observatory · Entry Detail
 *
 * Drill-down for one journal entry. Surfaces:
 *   - The question + scheduled date
 *   - Behavioral 7D radar
 *   - Semantic 11D radar
 *   - Session summary metrics
 *   - Slice-3 metadata (deletion curve, burst shape, hour typicality, etc.)
 *   - Replay link if event log was captured
 *
 * No interpretation. No three-frame, no predictions, no suppressed questions.
 * Designer-facing only.
 */
import '../../../styles/styObservatory.css';
const { id } = Astro.params;
const responseId = parseInt(id ?? '', 10);
---
<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Entry · Observatory · Alice</title>
    <script is:inline>
      (function () {
        var saved = localStorage.getItem('alice-theme');
        var t = saved || (window.matchMedia('(prefers-color-scheme: dark)').matches ? 'dark' : 'light');
        document.documentElement.setAttribute('data-theme', t);
        document.addEventListener('DOMContentLoaded', function () {
          var btn = document.getElementById('obs-theme-toggle');
          if (!btn) return;
          btn.textContent = t === 'dark' ? '\u2600' : '\u263E';
          btn.addEventListener('click', function () {
            var cur = document.documentElement.getAttribute('data-theme');
            var next = cur === 'dark' ? 'light' : 'dark';
            document.documentElement.setAttribute('data-theme', next);
            localStorage.setItem('alice-theme', next);
            btn.textContent = next === 'dark' ? '\u2600' : '\u263E';
          });
        });
      })();
    </script>
    <style is:global>
      /* page-specific overrides go here */
    </style>
  </head>
  <body>
    <div class="frame">
      <header>
        <h1>Entry · response {responseId}</h1>
        <nav>
          <a href="/observatory">overview</a>
          <a href="/observatory/trajectory">trajectory</a>
          <a href="/observatory/scales">scales</a>
          <a href="/observatory/coupling">coupling</a>
          <a href="/observatory/ghost">ghost</a>
          <a href="/">→ alice</a>
          <button class="obs-theme-toggle" id="obs-theme-toggle" aria-label="Toggle theme"></button>
        </nav>
      </header>

      <div id="entry-content">
        <div class="empty">loading…</div>
      </div>
    </div>

    <script type="module" define:vars={{ responseId }}>
      const BEHAVIORAL_DIMS = ['fluency','deliberation','revision','commitment','volatility','thermal','presence'];
      const SEMANTIC_DIMS = [
        'syntactic_complexity','interrogation','self_focus','uncertainty',
        'cognitive_processing',
        'nrc_anger','nrc_fear','nrc_joy','nrc_sadness','nrc_trust','nrc_anticipation',
      ];

      function fmtZ(v) {
        if (v == null) return '—';
        const sign = v >= 0 ? '+' : '';
        return sign + Number(v).toFixed(2);
      }
      function fmtMs(v) {
        if (v == null) return '—';
        if (v < 1000) return Math.round(v) + 'ms';
        return (v / 1000).toFixed(1) + 's';
      }
      function fmtMin(v) {
        if (v == null) return '—';
        return (v / 60000).toFixed(1) + 'min';
      }

      function resolveCssVar(el, v) {
        return getComputedStyle(el).getPropertyValue(v.replace('var(', '').replace(')', '').trim()) || v;
      }

      function drawRadar(canvas, dims, values, color) {
        const dpr = window.devicePixelRatio || 1;
        const size = 300;
        canvas.width = size * dpr;
        canvas.height = size * dpr;
        canvas.style.width = size + 'px';
        canvas.style.height = size + 'px';
        const ctx = canvas.getContext('2d');
        ctx.scale(dpr, dpr);

        const colBorder = resolveCssVar(canvas, 'var(--border)');
        const colBorderFocus = resolveCssVar(canvas, 'var(--border-focus)');
        const colFaint = resolveCssVar(canvas, 'var(--text-faint)');

        const cx = size / 2, cy = size / 2, maxR = 110;
        const n = dims.length;
        const angle = (2 * Math.PI) / n;
        const maxZ = 3;
        const r = (z) => ((Math.max(-maxZ, Math.min(maxZ, z)) + maxZ) / (2 * maxZ)) * maxR;

        // Reference rings
        for (const ring of [-2, -1, 0, 1, 2]) {
          ctx.strokeStyle = ring === 0 ? colBorderFocus : colBorder;
          ctx.lineWidth = ring === 0 ? 1 : 0.5;
          ctx.beginPath();
          for (let i = 0; i <= n; i++) {
            const a = -Math.PI / 2 + i * angle;
            const rr = r(ring);
            const x = cx + Math.cos(a) * rr;
            const y = cy + Math.sin(a) * rr;
            if (i === 0) ctx.moveTo(x, y);
            else ctx.lineTo(x, y);
          }
          ctx.stroke();
        }

        // Axes + labels
        for (let i = 0; i < n; i++) {
          const a = -Math.PI / 2 + i * angle;
          ctx.strokeStyle = colBorder;
          ctx.lineWidth = 0.5;
          ctx.beginPath();
          ctx.moveTo(cx, cy);
          ctx.lineTo(cx + Math.cos(a) * maxR, cy + Math.sin(a) * maxR);
          ctx.stroke();
          ctx.fillStyle = colFaint;
          ctx.font = '9px SF Mono, monospace';
          ctx.textAlign = 'center';
          ctx.textBaseline = 'middle';
          const lx = cx + Math.cos(a) * (maxR + 16);
          const ly = cy + Math.sin(a) * (maxR + 16);
          ctx.fillText(dims[i].slice(0, 7), lx, ly);
        }

        // Polygon
        ctx.fillStyle = color + '20';
        ctx.strokeStyle = color;
        ctx.lineWidth = 2;
        ctx.beginPath();
        for (let i = 0; i < n; i++) {
          const a = -Math.PI / 2 + i * angle;
          const v = values[i] ?? 0;
          const rr = r(v);
          const x = cx + Math.cos(a) * rr;
          const y = cy + Math.sin(a) * rr;
          if (i === 0) ctx.moveTo(x, y);
          else ctx.lineTo(x, y);
        }
        ctx.closePath();
        ctx.fill();
        ctx.stroke();
      }

      fetch(`/api/observatory/entry/${responseId}`).then(r => r.json()).then(data => {
        if (data.error) {
          document.getElementById('entry-content').innerHTML = `<div class="empty">${data.error}</div>`;
          return;
        }
        const { entryState, semanticState, sessionSummary, metadata, dynamicalSignals, motorSignals, processSignals, crossSessionSignals, semanticSignals, replay, navigation } = data;

        const navRow = `
          <div class="nav-row">
            ${navigation.prev ? `<a href="/observatory/entry/${navigation.prev}">← prev</a>` : ''}
            ${navigation.next ? `<a href="/observatory/entry/${navigation.next}">next →</a>` : ''}
            ${replay?.available ? `<a href="/observatory/replay/${entryState.question_id}" class="replay-cta">▶ replay this session</a>` : ''}
          </div>
        `;

        const questionBox = `
          <div class="question-box">
            <div class="question-meta">${entryState.date} · question ${entryState.question_id} · response ${entryState.response_id}</div>
            <p class="question-text">${entryState.question_text}</p>
          </div>
        `;

        const behVals = BEHAVIORAL_DIMS.map(d => entryState[d]);
        const semVals = semanticState ? SEMANTIC_DIMS.map(d => semanticState[d]) : null;

        const radars = `
          <div class="grid-two">
            <section class="panel">
              <h2>Behavioral 7D · z-score from baseline</h2>
              <canvas id="radar-beh"></canvas>
              <div class="stat-grid" style="margin-top:16px;">
                ${BEHAVIORAL_DIMS.map(d => `<div><div class="k">${d}</div><div class="v">${fmtZ(entryState[d])}</div></div>`).join('')}
                <div><div class="k">convergence</div><div class="v">${Number(entryState.convergence ?? 0).toFixed(2)}</div></div>
              </div>
            </section>
            <section class="panel">
              <h2>Semantic 11D · z-score from baseline</h2>
              ${semanticState ? '<canvas id="radar-sem"></canvas>' : '<div class="empty">no semantic state for this entry</div>'}
              ${semanticState ? `
                <div class="stat-grid" style="margin-top:16px;">
                  ${SEMANTIC_DIMS.map(d => `<div><div class="k">${d.replace(/_/g, ' ')}</div><div class="v">${fmtZ(semanticState[d])}</div></div>`).join('')}
                  <div><div class="k">semantic convergence</div><div class="v">${Number(semanticState.semantic_convergence ?? 0).toFixed(2)}</div></div>
                </div>
              ` : ''}
            </section>
          </div>
        `;

        const metaPills = [];
        if (metadata?.deletion_curve_type && metadata.deletion_curve_type !== 'none') {
          metaPills.push(`<span class="pill ${metadata.deletion_curve_type}">deletion: ${metadata.deletion_curve_type}</span>`);
        }
        if (metadata?.burst_trajectory_shape && metadata.burst_trajectory_shape !== 'none') {
          metaPills.push(`<span class="pill">burst: ${metadata.burst_trajectory_shape.replace(/_/g, ' ')}</span>`);
        }
        if (metadata?.rburst_trajectory_shape && metadata.rburst_trajectory_shape !== 'none') {
          metaPills.push(`<span class="pill">revision: ${metadata.rburst_trajectory_shape.replace(/_/g, ' ')}</span>`);
        }
        if (metadata?.hour_typicality != null) {
          const label = metadata.hour_typicality > 1 ? 'typical hour' : metadata.hour_typicality < -1 ? 'unusual hour' : 'avg hour';
          metaPills.push(`<span class="pill">${label} · z=${metadata.hour_typicality.toFixed(2)}</span>`);
        }
        if (metadata?.deletion_during_burst_count != null && metadata?.deletion_between_burst_count != null) {
          const total = (metadata.deletion_during_burst_count ?? 0) + (metadata.deletion_between_burst_count ?? 0);
          if (total > 0) {
            const pct = Math.round((metadata.deletion_during_burst_count / total) * 100);
            metaPills.push(`<span class="pill">${pct}% deletions inside bursts</span>`);
          }
        }

        const metadataPanel = `
          <section class="panel">
            <h2>Slice-3 metadata · deterministic per-session signals</h2>
            ${metaPills.length > 0
              ? `<div class="pill-row">${metaPills.join('')}</div>`
              : '<div class="empty">no metadata for this entry yet</div>'}
            ${metadata?.inter_burst_interval_mean_ms != null ? `
              <div class="stat-grid">
                <div><div class="k">inter-burst interval mean</div><div class="v">${fmtMs(metadata.inter_burst_interval_mean_ms)}</div></div>
                <div><div class="k">inter-burst interval std</div><div class="v">${fmtMs(metadata.inter_burst_interval_std_ms)}</div></div>
              </div>
            ` : ''}
          </section>
        `;

        const ds = dynamicalSignals;
        function dfaRegime(a) {
          if (a == null) return '';
          if (a < 0.6) return 'white noise';
          if (a < 0.85) return 'pink (1/f)';
          if (a < 1.1) return 'pink-brown';
          return 'brown noise';
        }
        function sig(v, d=3, u='') { return v != null ? Number(v).toFixed(d) + u : '—'; }
        function pct(v) { return v != null ? (v * 100).toFixed(1) + '%' : '—'; }
        function familyHeader(title) { return `<div style="grid-column:1/-1;margin-top:12px;"><div class="k" style="font-size:10px;letter-spacing:0.2em;color:var(--text-faint);">${title}</div></div>`; }

        const dynamicalPanel = ds ? `
          <section class="panel">
            <h2>Dynamical signals · nonlinear keystroke analysis</h2>
            <div class="stat-grid">
              ${familyHeader('SCALING & FRACTALITY')}
              <div><div class="k">permutation entropy</div><div class="v">${sig(ds.permutationEntropy)}</div></div>
              <div><div class="k">DFA alpha</div><div class="v">${ds.dfaAlpha != null ? sig(ds.dfaAlpha) + ' · ' + dfaRegime(ds.dfaAlpha) : '—'}</div></div>
              <div><div class="k">MF-DFA spectrum width</div><div class="v">${sig(ds.mfdfaSpectrumWidth)}</div></div>
              <div><div class="k">MF-DFA asymmetry</div><div class="v">${sig(ds.mfdfaAsymmetry)}</div></div>
              <div><div class="k">MF-DFA peak alpha</div><div class="v">${sig(ds.mfdfaPeakAlpha)}</div></div>
              <div><div class="k">temporal irreversibility</div><div class="v">${sig(ds.temporalIrreversibility, 4)}</div></div>

              ${familyHeader('SPECTRAL DECOMPOSITION')}
              <div><div class="k">PSD spectral slope</div><div class="v">${sig(ds.ikiPsdSpectralSlope)}</div></div>
              <div><div class="k">respiratory peak</div><div class="v">${ds.ikiPsdRespiratoryPeakHz != null ? sig(ds.ikiPsdRespiratoryPeakHz) + ' Hz' : '—'}</div></div>
              <div><div class="k">typing frequency</div><div class="v">${ds.peakTypingFrequencyHz != null ? sig(ds.peakTypingFrequencyHz) + ' Hz' : '—'}</div></div>
              <div><div class="k">LF/HF ratio</div><div class="v">${sig(ds.ikiPsdLfHfRatio)}</div></div>
              <div><div class="k">fast/slow variance</div><div class="v">${sig(ds.ikiPsdFastSlowVarianceRatio)}</div></div>

              ${familyHeader('ORDINAL PATTERN COMPLEXITY')}
              <div><div class="k">statistical complexity</div><div class="v">${sig(ds.statisticalComplexity, 4)}</div></div>
              <div><div class="k">forbidden patterns</div><div class="v">${pct(ds.forbiddenPatternFraction)}</div></div>
              <div><div class="k">weighted PE</div><div class="v">${sig(ds.weightedPe)}</div></div>
              <div><div class="k">Lempel-Ziv complexity</div><div class="v">${sig(ds.lempelZivComplexity)}</div></div>

              ${familyHeader('TRANSITION NETWORKS')}
              <div><div class="k">OPTN transition entropy</div><div class="v">${sig(ds.optnTransitionEntropy)} bits</div></div>
              <div><div class="k">OPTN forbidden transitions</div><div class="v">${ds.optnForbiddenTransitionCount ?? '—'}</div></div>

              ${familyHeader('RECURRENCE STRUCTURE')}
              <div><div class="k">RQA determinism</div><div class="v">${pct(ds.rqaDeterminism)}</div></div>
              <div><div class="k">RQA laminarity</div><div class="v">${pct(ds.rqaLaminarity)}</div></div>
              <div><div class="k">RQA trapping time</div><div class="v">${sig(ds.rqaTrappingTime, 1)}</div></div>
              <div><div class="k">RQA recurrence rate</div><div class="v">${pct(ds.rqaRecurrenceRate)}</div></div>
              <div><div class="k">recurrence time entropy</div><div class="v">${sig(ds.rqaRecurrenceTimeEntropy)} bits</div></div>
              <div><div class="k">mean recurrence time</div><div class="v">${sig(ds.rqaMeanRecurrenceTime, 1)}</div></div>
              <div><div class="k">network transitivity</div><div class="v">${sig(ds.recurrenceTransitivity)}</div></div>
              <div><div class="k">network avg path length</div><div class="v">${sig(ds.recurrenceAvgPathLength, 1)}</div></div>
              <div><div class="k">network clustering</div><div class="v">${sig(ds.recurrenceClustering)}</div></div>
              <div><div class="k">network assortativity</div><div class="v">${sig(ds.recurrenceAssortativity)}</div></div>

              ${familyHeader('CAUSAL ARCHITECTURE')}
              <div><div class="k">effective information</div><div class="v">${sig(ds.effectiveInformation)} bits</div></div>
              <div><div class="k">causal emergence index</div><div class="v">${sig(ds.causalEmergenceIndex)}</div></div>
              <div><div class="k">optimal causal scale</div><div class="v">${ds.optimalCausalScale ?? '—'}</div></div>
              <div><div class="k">PID synergy</div><div class="v">${sig(ds.pidSynergy, 4)} bits</div></div>
              <div><div class="k">PID redundancy</div><div class="v">${sig(ds.pidRedundancy, 4)} bits</div></div>
              <div><div class="k">branching ratio</div><div class="v">${sig(ds.branchingRatio)}</div></div>
              <div><div class="k">avalanche exponent</div><div class="v">${sig(ds.avalancheSizeExponent)}</div></div>

              ${familyHeader('DYNAMIC MODES')}
              <div><div class="k">DMD dominant frequency</div><div class="v">${ds.dmdDominantFrequency != null ? sig(ds.dmdDominantFrequency, 4) + ' Hz' : '—'}</div></div>
              <div><div class="k">DMD decay rate</div><div class="v">${sig(ds.dmdDominantDecayRate, 4)}</div></div>
              <div><div class="k">DMD mode count</div><div class="v">${ds.dmdModeCount ?? '—'}</div></div>
              <div><div class="k">DMD spectral entropy</div><div class="v">${sig(ds.dmdSpectralEntropy)}</div></div>

              ${familyHeader('PAUSE MIXTURE')}
              <div><div class="k">mixture components</div><div class="v">${ds.pauseMixtureComponentCount ?? '—'}</div></div>
              <div><div class="k">motor proportion</div><div class="v">${pct(ds.pauseMixtureMotorProportion)}</div></div>
              <div><div class="k">cognitive load index</div><div class="v">${sig(ds.pauseMixtureCognitiveLoadIndex)}</div></div>

              ${familyHeader('TRANSFER ENTROPY')}
              <div><div class="k">TE hold→flight</div><div class="v">${sig(ds.teHoldToFlight, 4)} bits</div></div>
              <div><div class="k">TE flight→hold</div><div class="v">${sig(ds.teFlightToHold, 4)} bits</div></div>
              <div><div class="k">TE dominance</div><div class="v">${ds.teDominance != null ? (ds.teDominance > 1 ? 'motor→cog ' + ds.teDominance.toFixed(2) + 'x' : 'cog→motor ' + (1/ds.teDominance).toFixed(2) + 'x') : '—'}</div></div>

              ${familyHeader('SERIES METADATA')}
              <div><div class="k">IKI series length</div><div class="v">${ds.ikiCount ?? '—'}</div></div>
              <div><div class="k">hold/flight pairs</div><div class="v">${ds.holdFlightCount ?? '—'}</div></div>
            </div>
          </section>
        ` : '';

        const ms = motorSignals;
        const motorPanel = ms ? `
          <section class="panel">
            <h2>Motor signals · ex-Gaussian decomposition + motor coordination</h2>
            <div class="stat-grid">
              ${familyHeader('EX-GAUSSIAN DECOMPOSITION')}
              <div><div class="k">ex-Gaussian tau</div><div class="v">${sig(ms.ex_gaussian_tau, 1, 'ms')}</div></div>
              <div><div class="k">ex-Gaussian mu</div><div class="v">${sig(ms.ex_gaussian_mu, 1, 'ms')}</div></div>
              <div><div class="k">ex-Gaussian sigma</div><div class="v">${sig(ms.ex_gaussian_sigma, 1, 'ms')}</div></div>
              <div><div class="k">tau proportion</div><div class="v">${pct(ms.tau_proportion)}</div></div>
              <div><div class="k">Fisher information trace</div><div class="v">${sig(ms.ex_gaussian_fisher_trace, 4)}</div></div>

              ${familyHeader('MULTISCALE ENTROPY')}
              <div><div class="k">complexity index</div><div class="v">${sig(ms.complexity_index)}</div></div>
              <div><div class="k">MSE series</div><div class="v">${ms.mse_series ? (typeof ms.mse_series === 'string' ? JSON.parse(ms.mse_series) : ms.mse_series).map(v => v != null ? v.toFixed(2) : '—').join(' → ') : '—'}</div></div>
              <div><div class="k">sample entropy</div><div class="v">${sig(ms.sample_entropy)}</div></div>

              ${familyHeader('MOTOR DYNAMICS')}
              <div><div class="k">motor jerk</div><div class="v">${sig(ms.motor_jerk, 1)}</div></div>
              <div><div class="k">lapse rate</div><div class="v">${ms.lapse_rate != null ? sig(ms.lapse_rate, 2, '/min') : '—'}</div></div>
              <div><div class="k">tempo drift</div><div class="v">${ms.tempo_drift != null ? (ms.tempo_drift > 0 ? '+' : '') + ms.tempo_drift.toFixed(1) + ' ms/q' : '—'}</div></div>
              <div><div class="k">compression ratio</div><div class="v">${sig(ms.iki_compression_ratio)}</div></div>
              <div><div class="k">adjacent hold-time cov</div><div class="v">${sig(ms.adjacent_hold_time_cov)}</div></div>
              <div><div class="k">hold-flight rank corr</div><div class="v">${sig(ms.hold_flight_rank_corr)}</div></div>
            </div>
          </section>
        ` : '';

        const summary = sessionSummary;
        const phase2Panel = summary ? `
          <section class="panel">
            <h2>Phase 2 signals · cursor, revision depth, punctuation, error correction</h2>
            <div class="stat-grid">
              <div><div class="k">cursor distance (pauses)</div><div class="v">${summary.cursorDistanceDuringPauses != null ? Math.round(summary.cursorDistanceDuringPauses) + ' px' : '—'}</div></div>
              <div><div class="k">cursor fidget ratio</div><div class="v">${summary.cursorFidgetRatio != null ? summary.cursorFidgetRatio.toFixed(4) + ' px/ms' : '—'}</div></div>
              <div><div class="k">cursor stillness</div><div class="v">${summary.cursorStillnessDuringPauses != null ? (summary.cursorStillnessDuringPauses * 100).toFixed(1) + '%' : '—'}</div></div>
              <div><div class="k">drift to submit</div><div class="v">${summary.driftToSubmitCount ?? '—'}</div></div>
              <div><div class="k">pause samples</div><div class="v">${summary.cursorPauseSampleCount ?? '—'}</div></div>
              <div><div class="k">deletion exec speed</div><div class="v">${summary.deletionExecutionSpeedMean != null ? Math.round(summary.deletionExecutionSpeedMean) + 'ms' : '—'}</div></div>
              <div><div class="k">postcorrection latency</div><div class="v">${summary.postcorrectionLatencyMean != null ? Math.round(summary.postcorrectionLatencyMean) + 'ms' : '—'}</div></div>
              <div><div class="k">mean revision distance</div><div class="v">${summary.meanRevisionDistance != null ? Math.round(summary.meanRevisionDistance) + ' chars' : '—'}</div></div>
              <div><div class="k">max revision distance</div><div class="v">${summary.maxRevisionDistance != null ? summary.maxRevisionDistance + ' chars' : '—'}</div></div>
              <div><div class="k">punctuation flight mean</div><div class="v">${summary.punctuationFlightMean != null ? Math.round(summary.punctuationFlightMean) + 'ms' : '—'}</div></div>
              <div><div class="k">punct / letter ratio</div><div class="v">${summary.punctuationLetterRatio != null ? summary.punctuationLetterRatio.toFixed(3) + 'x' : '—'}</div></div>
              <div><div class="k">confirmation latency</div><div class="v">${summary.confirmationLatencyMs != null ? (summary.confirmationLatencyMs / 1000).toFixed(1) + 's' : '—'}</div></div>
              <div><div class="k">leading edge ratio</div><div class="v">${summary.leadingEdgeRatio != null ? (summary.leadingEdgeRatio * 100).toFixed(1) + '%' : '—'}</div></div>
              <div><div class="k">contextual / pre-contextual revisions</div><div class="v">${summary.contextualRevisionCount ?? '—'} / ${summary.preContextualRevisionCount ?? '—'}</div></div>
              <div><div class="k">read-back / considered-and-kept</div><div class="v">${summary.readBackCount ?? '—'} / ${summary.consideredAndKeptCount ?? '—'}</div></div>
            </div>
          </section>
        ` : '';

        const summaryPanel = summary ? `
          <section class="panel">
            <h2>Session summary · keystroke + linguistic substrate</h2>
            <div class="stat-grid">
              <div><div class="k">duration</div><div class="v">${fmtMin(summary.totalDurationMs)}</div></div>
              <div><div class="k">active typing</div><div class="v">${fmtMin(summary.activeTypingMs)}</div></div>
              <div><div class="k">first keystroke</div><div class="v">${fmtMs(summary.firstKeystrokeMs)}</div></div>
              <div><div class="k">words / sentences</div><div class="v">${summary.wordCount ?? '—'} / ${summary.sentenceCount ?? '—'}</div></div>
              <div><div class="k">commitment ratio</div><div class="v">${summary.commitmentRatio != null ? (summary.commitmentRatio * 100).toFixed(0) + '%' : '—'}</div></div>
              <div><div class="k">chars/min</div><div class="v">${summary.charsPerMinute != null ? Math.round(summary.charsPerMinute) : '—'}</div></div>
              <div><div class="k">P-burst count / avg</div><div class="v">${summary.pBurstCount ?? '—'} / ${summary.avgPBurstLength != null ? Math.round(summary.avgPBurstLength) : '—'} chars</div></div>
              <div><div class="k">small / large deletions</div><div class="v">${summary.smallDeletionCount ?? '—'} / ${summary.largeDeletionCount ?? '—'}</div></div>
              <div><div class="k">deletion timing (1st / 2nd half)</div><div class="v">${summary.firstHalfDeletionChars ?? '—'} / ${summary.secondHalfDeletionChars ?? '—'} chars</div></div>
              <div><div class="k">pauses ≥30s</div><div class="v">${summary.pauseCount ?? '—'} (${fmtMin(summary.totalPauseMs)})</div></div>
              <div><div class="k">tab-aways</div><div class="v">${summary.tabAwayCount ?? '—'} (${fmtMin(summary.totalTabAwayMs)})</div></div>
              <div><div class="k">scroll-back / re-read</div><div class="v">${summary.scrollBackCount ?? '—'} / ${summary.questionRereadCount ?? '—'}</div></div>
              <div><div class="k">IKI mean / std</div><div class="v">${fmtMs(summary.interKeyIntervalMean)} / ${fmtMs(summary.interKeyIntervalStd)}</div></div>
              <div><div class="k">hold time mean / std</div><div class="v">${fmtMs(summary.holdTimeMean)} / ${fmtMs(summary.holdTimeStd)}</div></div>
              <div><div class="k">flight time mean / std</div><div class="v">${fmtMs(summary.flightTimeMean)} / ${fmtMs(summary.flightTimeStd)}</div></div>
              <div><div class="k">keystroke entropy</div><div class="v">${summary.keystrokeEntropy != null ? summary.keystrokeEntropy.toFixed(2) + ' bits' : '—'}</div></div>
              <div><div class="k">MATTR</div><div class="v">${summary.mattr != null ? summary.mattr.toFixed(3) : '—'}</div></div>
              <div><div class="k">avg sentence length</div><div class="v">${summary.avgSentenceLength != null ? summary.avgSentenceLength.toFixed(1) + ' words' : '—'}</div></div>
              <div><div class="k">revision chains</div><div class="v">${summary.revisionChainCount ?? '—'} × ${summary.revisionChainAvgLength != null ? summary.revisionChainAvgLength.toFixed(1) : '—'}</div></div>
              <div><div class="k">device / hour / day</div><div class="v">${summary.deviceType ?? '?'} / ${summary.hourOfDay ?? '?'}h / d${summary.dayOfWeek ?? '?'}</div></div>
            </div>
          </section>
        ` : '';

        const ps = processSignals;
        const processPanel = ps ? `
          <section class="panel">
            <h2>Process signals · writing process shape</h2>
            <div class="stat-grid">
              <div><div class="k">pauses within word</div><div class="v">${ps.pause_within_word ?? '—'}</div></div>
              <div><div class="k">pauses between words</div><div class="v">${ps.pause_between_word ?? '—'}</div></div>
              <div><div class="k">pauses between sentences</div><div class="v">${ps.pause_between_sentence ?? '—'}</div></div>
              <div><div class="k">abandoned thoughts</div><div class="v">${ps.abandoned_thought_count ?? '—'}</div></div>
              <div><div class="k">R-burst count</div><div class="v">${ps.r_burst_count ?? '—'}</div></div>
              <div><div class="k">I-burst count</div><div class="v">${ps.i_burst_count ?? '—'}</div></div>
              <div><div class="k">vocab expansion rate</div><div class="v">${sig(ps.vocab_expansion_rate)}</div></div>
              <div><div class="k">phase transition point</div><div class="v">${ps.phase_transition_point != null ? pct(ps.phase_transition_point) : '—'}</div></div>
              <div><div class="k">strategy shifts</div><div class="v">${ps.strategy_shift_count ?? '—'}</div></div>
            </div>
          </section>
        ` : '';

        const css = crossSessionSignals;
        const crossSessionPanel = css ? `
          <section class="panel">
            <h2>Cross-session signals · session-to-history relationship</h2>
            <div class="stat-grid">
              <div><div class="k">self-perplexity</div><div class="v">${sig(css.self_perplexity, 2)}</div></div>
              <div><div class="k">motor self-perplexity</div><div class="v">${sig(css.motor_self_perplexity, 2)}</div></div>
              <div><div class="k">NCD lag-1</div><div class="v">${sig(css.ncd_lag_1)}</div></div>
              <div><div class="k">NCD lag-3</div><div class="v">${sig(css.ncd_lag_3)}</div></div>
              <div><div class="k">NCD lag-7</div><div class="v">${sig(css.ncd_lag_7)}</div></div>
              <div><div class="k">NCD lag-30</div><div class="v">${sig(css.ncd_lag_30)}</div></div>
              <div><div class="k">vocab recurrence decay</div><div class="v">${sig(css.vocab_recurrence_decay, 4)}</div></div>
              <div><div class="k">digraph stability</div><div class="v">${sig(css.digraph_stability)}</div></div>
              <div><div class="k">text network density</div><div class="v">${sig(css.text_network_density, 4)}</div></div>
              <div><div class="k">text network communities</div><div class="v">${css.text_network_communities ?? '—'}</div></div>
              <div><div class="k">bridging ratio</div><div class="v">${sig(css.bridging_ratio)}</div></div>
            </div>
          </section>
        ` : '';

        const sem = semanticSignals;
        const discoursePanel = sem && sem.discourse_global_coherence != null ? `
          <section class="panel">
            <h2>Discourse coherence · text structural coherence</h2>
            <div class="stat-grid">
              <div><div class="k">global coherence</div><div class="v">${sig(sem.discourse_global_coherence)}</div></div>
              <div><div class="k">local coherence</div><div class="v">${sig(sem.discourse_local_coherence)}</div></div>
              <div><div class="k">global/local ratio</div><div class="v">${sig(sem.discourse_global_local_ratio)}</div></div>
              <div><div class="k">coherence decay slope</div><div class="v">${sig(sem.discourse_coherence_decay_slope, 4)}</div></div>
            </div>
          </section>
        ` : '';

        document.getElementById('entry-content').innerHTML =
          questionBox + navRow + radars + metadataPanel + dynamicalPanel + motorPanel + processPanel + crossSessionPanel + discoursePanel + phase2Panel + summaryPanel;

        // Draw radars after DOM is in place
        const behCanvas = document.getElementById('radar-beh');
        if (behCanvas) drawRadar(behCanvas, BEHAVIORAL_DIMS, behVals, '#7a5a44');
        if (semanticState) {
          const semCanvas = document.getElementById('radar-sem');
          if (semCanvas) drawRadar(semCanvas, SEMANTIC_DIMS, semVals, '#7a5a7a');
        }
      }).catch(err => {
        document.getElementById('entry-content').innerHTML = `<div class="empty">failed to load: ${err?.message ?? err}</div>`;
      });
    </script>
  </body>
</html>
