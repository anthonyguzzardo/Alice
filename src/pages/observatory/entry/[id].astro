---
/**
 * Observatory · Entry detail
 *
 * Per-entry snapshot of all live behavioral signals for one journal session.
 * Anchored on response_id from the URL. Computes 7D z-scored state on every
 * request via libStateEngine; surfaces motor / dynamical / process /
 * cross-session / discourse-coherence / session-metadata rows alongside.
 *
 * No interpretation. No artistic semantic 11D radar (those tables were
 * archived in INC-016). Designer-facing only.
 */
import '../../../styles/styObservatory.css';
const { id } = Astro.params;
const responseId = parseInt(id ?? '', 10);
---
<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Entry · Observatory · Alice</title>
    <script is:inline>
      (function () {
        var saved = localStorage.getItem('alice-theme');
        var t = saved || (window.matchMedia('(prefers-color-scheme: dark)').matches ? 'dark' : 'light');
        document.documentElement.setAttribute('data-theme', t);
        document.addEventListener('DOMContentLoaded', function () {
          var btn = document.getElementById('obs-theme-toggle');
          if (!btn) return;
          btn.textContent = t === 'dark' ? '\u2600' : '\u263E';
          btn.addEventListener('click', function () {
            var cur = document.documentElement.getAttribute('data-theme');
            var next = cur === 'dark' ? 'light' : 'dark';
            document.documentElement.setAttribute('data-theme', next);
            localStorage.setItem('alice-theme', next);
            btn.textContent = next === 'dark' ? '\u2600' : '\u263E';
          });
        });
      })();
    </script>
    <style is:global>
      .entry-meta {
        font-family: var(--mono);
        font-size: 11px;
        letter-spacing: 0.08em;
        color: var(--text-muted);
        margin: 0 0 0.75rem;
      }
      .entry-meta .sep { color: var(--text-faint); margin: 0 0.5rem; }
      .convergence-tag {
        font-family: var(--mono);
        font-size: 9px;
        letter-spacing: 0.16em;
        text-transform: uppercase;
        padding: 0.15rem 0.45rem;
        border: 1px solid var(--border);
        border-radius: 2px;
        margin-left: 0.5rem;
        color: var(--text-faint);
      }
      .convergence-tag.high     { color: var(--accent); border-color: var(--accent); }
      .convergence-tag.moderate { color: var(--text-muted); }
    </style>
  </head>
  <body>
    <div class="frame">
      <header>
        <h1>Entry</h1>
        <nav>
          <a href="/observatory">overview</a>
          <a href="/observatory/trajectory">trajectory</a>
          <a href="/observatory/scales">scales</a>
          <a href="/observatory/coupling">coupling</a>
          <a href="/observatory/ghost">ghost</a>
          <a href="/">→ alice</a>
          <button class="obs-theme-toggle" id="obs-theme-toggle" aria-label="Toggle theme"></button>
        </nav>
      </header>

      <div id="entry-content">loading…</div>
    </div>

    <script type="module" define:vars={{ responseId }}>
      const root = document.getElementById('entry-content');

      function resolveCssVar(el, v) {
        return getComputedStyle(el).getPropertyValue(v.replace('var(', '').replace(')', '').trim()) || v;
      }

      function drawRadar(canvas, dims, values, color) {
        const dpr = window.devicePixelRatio || 1;
        const size = 300;
        canvas.width = size * dpr;
        canvas.height = size * dpr;
        canvas.style.width = size + 'px';
        canvas.style.height = size + 'px';
        const ctx = canvas.getContext('2d');
        ctx.scale(dpr, dpr);

        const colBorder = resolveCssVar(canvas, 'var(--border)');
        const colBorderFocus = resolveCssVar(canvas, 'var(--border-focus)');
        const colFaint = resolveCssVar(canvas, 'var(--text-faint)');

        const cx = size / 2, cy = size / 2, maxR = 110;
        const n = dims.length;
        const angle = (2 * Math.PI) / n;
        const maxZ = 3;
        const r = (z) => ((Math.max(-maxZ, Math.min(maxZ, z)) + maxZ) / (2 * maxZ)) * maxR;

        // Reference rings (z = -2, -1, 0, +1, +2). The 0 ring is the personal baseline.
        for (const ring of [-2, -1, 0, 1, 2]) {
          ctx.strokeStyle = ring === 0 ? colBorderFocus : colBorder;
          ctx.lineWidth = ring === 0 ? 1 : 0.5;
          ctx.beginPath();
          for (let i = 0; i <= n; i++) {
            const a = -Math.PI / 2 + i * angle;
            const rr = r(ring);
            const x = cx + Math.cos(a) * rr;
            const y = cy + Math.sin(a) * rr;
            if (i === 0) ctx.moveTo(x, y);
            else ctx.lineTo(x, y);
          }
          ctx.stroke();
        }

        // Axes + labels
        for (let i = 0; i < n; i++) {
          const a = -Math.PI / 2 + i * angle;
          ctx.strokeStyle = colBorder;
          ctx.lineWidth = 0.5;
          ctx.beginPath();
          ctx.moveTo(cx, cy);
          ctx.lineTo(cx + Math.cos(a) * maxR, cy + Math.sin(a) * maxR);
          ctx.stroke();
          ctx.fillStyle = colFaint;
          ctx.font = '9px SF Mono, monospace';
          ctx.textAlign = 'center';
          ctx.textBaseline = 'middle';
          const lx = cx + Math.cos(a) * (maxR + 16);
          const ly = cy + Math.sin(a) * (maxR + 16);
          ctx.fillText(dims[i].slice(0, 7), lx, ly);
        }

        // Polygon for the entry's 7D vector
        ctx.fillStyle = color + '20';
        ctx.strokeStyle = color;
        ctx.lineWidth = 2;
        ctx.beginPath();
        for (let i = 0; i < n; i++) {
          const a = -Math.PI / 2 + i * angle;
          const v = values[i] ?? 0;
          const rr = r(v);
          const x = cx + Math.cos(a) * rr;
          const y = cy + Math.sin(a) * rr;
          if (i === 0) ctx.moveTo(x, y);
          else ctx.lineTo(x, y);
        }
        ctx.closePath();
        ctx.fill();
        ctx.stroke();
      }

      function fmtZ(v) {
        if (v == null || Number.isNaN(v)) return '—';
        const sign = v >= 0 ? '+' : '';
        return sign + Number(v).toFixed(2) + 'σ';
      }

      function fmtNum(v, digits = 3) {
        if (v == null || Number.isNaN(v)) return '—';
        const n = Number(v);
        if (!Number.isFinite(n)) return '—';
        if (Math.abs(n) >= 1000) return n.toFixed(0);
        if (Math.abs(n) >= 100) return n.toFixed(1);
        if (Math.abs(n) >= 10) return n.toFixed(2);
        return n.toFixed(digits);
      }

      function fmtStr(v) {
        if (v == null) return '—';
        return String(v);
      }

      function dotColor(z) {
        const s = getComputedStyle(document.documentElement);
        if (z == null) return s.getPropertyValue('--border').trim() || '#ddd';
        if (Math.abs(z) < 1) return s.getPropertyValue('--text-muted').trim() || '#555';
        if (z > 0) return s.getPropertyValue('--positive').trim() || '#6b8e6b';
        return s.getPropertyValue('--negative').trim() || '#b5603f';
      }

      function kpi(label, value, color = null) {
        const style = color ? `style="color:${color}"` : '';
        return `<div class="kpi"><span class="k">${label}</span><span class="v" ${style}>${value}</span></div>`;
      }

      function statRow(label, value) {
        return `<div class="k">${label}</div><div class="v">${value}</div>`;
      }

      function panel(title, body) {
        return `<section class="panel"><h2>${title}</h2>${body}</section>`;
      }

      function statGrid(pairs) {
        return `<div class="stat-grid">${pairs.map(([k, v]) => statRow(k, v)).join('')}</div>`;
      }

      function renderHeader(d) {
        const replay = d.replayAvailable
          ? `<a class="btn primary" href="/observatory/replay/${d.questionId}">▶ replay</a>`
          : '<span class="btn" style="opacity:0.5;cursor:default;">no replay</span>';
        const meta = `<div class="entry-meta">${d.date ?? '—'}<span class="sep">·</span>response ${d.responseId}<span class="sep">·</span>question ${d.questionId}</div>`;
        const question = d.question
          ? `<div class="question-box">${d.question}</div>`
          : '';
        return `<section class="panel">${meta}${question}<div style="margin-top:0.75rem;">${replay} <a class="btn" href="/observatory" style="margin-left:0.5rem;">← back</a></div></section>`;
      }

      const BEHAVIORAL_DIMS = ['fluency', 'deliberation', 'revision', 'commitment', 'volatility', 'thermal', 'presence'];

      function renderState(state) {
        if (!state) {
          return panel('Behavioral 7D · z-scores', '<div class="empty">insufficient history (≥3 entries required for personal baseline)</div>');
        }
        const cells = BEHAVIORAL_DIMS.map(d => kpi(d, fmtZ(state[d]), dotColor(state[d]))).join('');
        const tag = `<span class="convergence-tag ${state.convergenceLevel}">${state.convergenceLevel}</span>`;
        const conv = kpi('convergence', fmtNum(state.convergence) + tag);
        const radar = `<div style="display:flex;justify-content:center;margin:0.5rem 0 1rem;"><canvas id="radar-beh"></canvas></div>`;
        return panel('Behavioral 7D · z-scores (vs. personal baseline)', `${radar}<div class="kpi-row">${cells}${conv}</div>`);
      }

      function renderMotor(m) {
        if (!m) return panel('Motor signals', '<div class="empty">no motor signals computed for this entry</div>');
        return panel('Motor signals', statGrid([
          ['ex-Gaussian τ',          fmtNum(m.ex_gaussian_tau)],
          ['ex-Gaussian μ',          fmtNum(m.ex_gaussian_mu)],
          ['ex-Gaussian σ',          fmtNum(m.ex_gaussian_sigma)],
          ['τ proportion',           fmtNum(m.tau_proportion)],
          ['adjacent hold cov',      fmtNum(m.adjacent_hold_time_cov)],
          ['hold·flight rank corr',  fmtNum(m.hold_flight_rank_corr)],
          ['sample entropy',         fmtNum(m.sample_entropy)],
          ['complexity index',       fmtNum(m.complexity_index)],
          ['motor jerk',             fmtNum(m.motor_jerk)],
          ['lapse rate',             fmtNum(m.lapse_rate)],
          ['tempo drift',            fmtNum(m.tempo_drift)],
          ['IKI compression ratio',  fmtNum(m.iki_compression_ratio)],
        ]));
      }

      function renderDynamical(d) {
        if (!d) return panel('Dynamical signals', '<div class="empty">no dynamical signals computed for this entry</div>');
        return panel('Dynamical signals', statGrid([
          ['permutation entropy',     fmtNum(d.permutation_entropy)],
          ['weighted PE',             fmtNum(d.weighted_pe)],
          ['statistical complexity',  fmtNum(d.statistical_complexity)],
          ['DFA α',                   fmtNum(d.dfa_alpha)],
          ['MFDFA spectrum width',    fmtNum(d.mfdfa_spectrum_width)],
          ['Lempel-Ziv complexity',   fmtNum(d.lempel_ziv_complexity)],
          ['temporal irreversibility',fmtNum(d.temporal_irreversibility)],
          ['RQA determinism',         fmtNum(d.rqa_determinism)],
          ['RQA laminarity',          fmtNum(d.rqa_laminarity)],
          ['RQA recurrence rate',     fmtNum(d.rqa_recurrence_rate)],
          ['RQA trapping time',       fmtNum(d.rqa_trapping_time)],
          ['TE hold→flight',          fmtNum(d.te_hold_to_flight)],
          ['TE flight→hold',          fmtNum(d.te_flight_to_hold)],
          ['TE dominance',            fmtNum(d.te_dominance)],
          ['effective information',   fmtNum(d.effective_information)],
          ['causal emergence',        fmtNum(d.causal_emergence_index)],
          ['DMD dominant freq',       fmtNum(d.dmd_dominant_frequency)],
          ['DMD spectral entropy',    fmtNum(d.dmd_spectral_entropy)],
          ['IKI count',               fmtNum(d.iki_count)],
          ['hold·flight count',       fmtNum(d.hold_flight_count)],
        ]));
      }

      function renderProcess(p) {
        if (!p) return panel('Process structure', '<div class="empty">no process signals computed for this entry</div>');
        return panel('Process structure', statGrid([
          ['pause within word',        fmtNum(p.pause_within_word)],
          ['pause between word',       fmtNum(p.pause_between_word)],
          ['pause between sentence',   fmtNum(p.pause_between_sentence)],
          ['abandoned thought count',  fmtNum(p.abandoned_thought_count)],
          ['R-burst count',            fmtNum(p.r_burst_count)],
          ['I-burst count',            fmtNum(p.i_burst_count)],
          ['vocab expansion rate',     fmtNum(p.vocab_expansion_rate)],
          ['phase transition point',   fmtNum(p.phase_transition_point)],
          ['strategy shift count',     fmtNum(p.strategy_shift_count)],
        ]));
      }

      function renderCrossSession(c) {
        if (!c) return panel('Cross-session', '<div class="empty">no cross-session signals computed for this entry</div>');
        return panel('Cross-session', statGrid([
          ['self perplexity',          fmtNum(c.self_perplexity)],
          ['motor self perplexity',    fmtNum(c.motor_self_perplexity)],
          ['NCD lag-1',                fmtNum(c.ncd_lag_1)],
          ['NCD lag-3',                fmtNum(c.ncd_lag_3)],
          ['NCD lag-7',                fmtNum(c.ncd_lag_7)],
          ['NCD lag-30',               fmtNum(c.ncd_lag_30)],
          ['vocab recurrence decay',   fmtNum(c.vocab_recurrence_decay)],
          ['digraph stability',        fmtNum(c.digraph_stability)],
          ['text network density',     fmtNum(c.text_network_density)],
          ['text network communities', fmtNum(c.text_network_communities)],
          ['bridging ratio',           fmtNum(c.bridging_ratio)],
        ]));
      }

      function renderDiscourse(d) {
        if (!d) return panel('Discourse coherence', '<div class="empty">no discourse coherence computed for this entry</div>');
        return panel('Discourse coherence', statGrid([
          ['global coherence',         fmtNum(d.discourse_global_coherence)],
          ['local coherence',          fmtNum(d.discourse_local_coherence)],
          ['global÷local ratio',       fmtNum(d.discourse_global_local_ratio)],
          ['coherence decay slope',    fmtNum(d.discourse_coherence_decay_slope)],
        ]));
      }

      function renderMetadata(m) {
        if (!m) return panel('Session metadata', '<div class="empty">no metadata for this entry</div>');
        return panel('Session metadata', statGrid([
          ['hour typicality',           fmtNum(m.hour_typicality)],
          ['deletion curve type',       fmtStr(m.deletion_curve_type)],
          ['burst trajectory shape',    fmtStr(m.burst_trajectory_shape)],
          ['R-burst trajectory shape',  fmtStr(m.rburst_trajectory_shape)],
          ['inter-burst interval mean', fmtNum(m.inter_burst_interval_mean_ms)],
          ['inter-burst interval std',  fmtNum(m.inter_burst_interval_std_ms)],
          ['deletion during burst',     fmtNum(m.deletion_during_burst_count)],
          ['deletion between burst',    fmtNum(m.deletion_between_burst_count)],
        ]));
      }

      function render(d) {
        let html = '';
        html += renderHeader(d);
        html += renderState(d.entryState);
        html += renderMotor(d.motor);
        html += renderDynamical(d.dynamical);
        html += renderProcess(d.process);
        html += renderCrossSession(d.crossSession);
        html += renderDiscourse(d.discourse);
        html += renderMetadata(d.metadata);
        root.innerHTML = html;

        // Paint the radar after the DOM lands. accent ≈ var(--accent) — picked
        // to match the rest of the observatory palette.
        if (d.entryState) {
          const canvas = document.getElementById('radar-beh');
          if (canvas) {
            const accent = resolveCssVar(canvas, 'var(--accent)') || '#7a5a44';
            const vals = BEHAVIORAL_DIMS.map(k => d.entryState[k]);
            drawRadar(canvas, BEHAVIORAL_DIMS, vals, accent.trim());
          }
        }
      }

      fetch(`/api/observatory/entry/${responseId}`)
        .then(r => r.json())
        .then(data => {
          if (data.error) {
            root.innerHTML = `<section class="panel"><div class="empty">${data.error}</div></section>`;
            return;
          }
          render(data);
        })
        .catch(err => {
          root.innerHTML = `<section class="panel"><div class="empty">load failed: ${err?.message ?? err}</div></section>`;
        });
    </script>
  </body>
</html>
