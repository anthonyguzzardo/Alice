---
/**
 * Observatory · Designer-facing instrument view.
 *
 * Lists all entries with calibration drift, session integrity, and
 * per-entry replay links.
 *
 * No user surfaces. The /observatory/* tree is for the designer only.
 */
import '../../styles/styObservatory.css';
import ObsToolbar from '../../components/cmpObsToolbar.astro';
---
<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Observatory · Alice</title>
    <script is:inline>
      (function () {
        var saved = localStorage.getItem('alice-theme');
        var t = saved || (window.matchMedia('(prefers-color-scheme: dark)').matches ? 'dark' : 'light');
        document.documentElement.setAttribute('data-theme', t);
        document.addEventListener('DOMContentLoaded', function () {
          var btn = document.getElementById('obs-theme-toggle');
          if (!btn) return;
          btn.textContent = t === 'dark' ? '\u2600' : '\u263E';
          btn.addEventListener('click', function () {
            var cur = document.documentElement.getAttribute('data-theme');
            var next = cur === 'dark' ? 'light' : 'dark';
            document.documentElement.setAttribute('data-theme', next);
            localStorage.setItem('alice-theme', next);
            btn.textContent = next === 'dark' ? '\u2600' : '\u263E';
          });
        });
      })();
    </script>
    <style is:global>
      /* page-specific overrides go here */
    </style>
  </head>
  <body>
    <div class="frame">
      <header>
        <h1>Observatory</h1>
        <nav>
          <a href="/observatory" class="active">overview</a>
          <a href="/observatory/trajectory">trajectory</a>
          <a href="/observatory/scales">scales</a>
          <a href="/observatory/coupling">coupling</a>
          <a href="/observatory/ghost">ghost</a>
          <a href="/">→ alice</a>
          <button class="obs-theme-toggle" id="obs-theme-toggle" aria-label="Toggle theme"></button>
        </nav>
      </header>

      <ObsToolbar />

      <div class="meta-row" id="meta-row">
        <span id="counts">loading…</span>
      </div>

      <section class="panel">
        <h2>Calibration drift · designer-facing health metric</h2>
        <div id="cal-drift"></div>
      </section>

      <section class="panel">
        <h2>Session integrity · profile-based mediation detection</h2>
        <div id="integrity"></div>
      </section>

      <section class="panel">
        <h2>Entries · session metadata + replay</h2>
        <div id="entries-table"></div>
      </section>
    </div>

    <script type="module">
      function sparkline(values, color = null) {
        if (!color) color = getComputedStyle(document.documentElement).getPropertyValue('--accent').trim() || '#7a5a44';
        const n = values.length;
        if (n < 2) return '<span class="spark"></span>';
        const min = Math.min(...values);
        const max = Math.max(...values);
        const range = max - min || 1;
        const w = 80, h = 24;
        const pts = values.map((v, i) => {
          const x = (i / (n - 1)) * w;
          const y = h - ((v - min) / range) * (h - 2) - 1;
          return x.toFixed(1) + ',' + y.toFixed(1);
        }).join(' ');
        return `<svg class="spark" viewBox="0 0 ${w} ${h}" xmlns="http://www.w3.org/2000/svg"><polyline fill="none" stroke="${color}" stroke-width="1.5" points="${pts}"/></svg>`;
      }

      function renderEntries(states, container) {
        if (!states.length) {
          container.innerHTML = '<div class="empty">no entries yet — submit a session to populate</div>';
          return;
        }

        const cols = ['date', 'meta', 'replay'];
        const head = `<thead><tr>${cols.map(c => `<th>${c}</th>`).join('')}</tr></thead>`;
        const rows = states.map(s => {
          const metaParts = [];
          if (s.metadata?.deletion_curve_type && s.metadata.deletion_curve_type !== 'none')
            metaParts.push(`del:${s.metadata.deletion_curve_type}`);
          if (s.metadata?.burst_trajectory_shape && s.metadata.burst_trajectory_shape !== 'none')
            metaParts.push(`burst:${s.metadata.burst_trajectory_shape}`);
          if (s.metadata?.rburst_trajectory_shape && s.metadata.rburst_trajectory_shape !== 'none')
            metaParts.push(`rev:${s.metadata.rburst_trajectory_shape}`);
          if (s.metadata?.hour_typicality != null && Math.abs(s.metadata.hour_typicality) > 1)
            metaParts.push(`hr:${s.metadata.hour_typicality > 0 ? 'typical' : 'unusual'}`);
          const meta = metaParts.length ? metaParts.join(' · ') : '—';
          const replay = s.replayAvailable
            ? `<a class="action-btn" href="${window.__obsUrl('/observatory/replay/' + s.question_id)}">▶ replay</a>`
            : '<span class="action-btn-muted">—</span>';
          return `<tr>
            <td><a href="${window.__obsUrl('/observatory/entry/' + s.response_id)}">${s.date}</a></td>
            <td class="meta">${meta}</td>
            <td>${replay}</td>
          </tr>`;
        }).join('');

        container.innerHTML = `<table>${head}<tbody>${rows}</tbody></table>`;
      }

      function renderCalDrift(payload, container) {
        const global = payload.globalTrack || [];
        if (global.length === 0) {
          container.innerHTML = '<div class="empty">no calibration snapshots yet — run a free-write to seed</div>';
          return;
        }
        const drifts = global.map(g => g.drift_magnitude ?? 0).filter(d => d != null);
        const latest = global[global.length - 1];
        const avg = drifts.length ? (drifts.reduce((a,b)=>a+b,0) / drifts.length).toFixed(3) : '—';
        const latestDrift = latest.drift_magnitude != null ? latest.drift_magnitude.toFixed(3) : '—';
        container.innerHTML = `
          <div class="kpi-row">
            <div class="kpi">
              <div class="k">latest drift (z-norm L2)</div>
              <div class="v">${latestDrift}</div>
            </div>
            <div class="kpi">
              <div class="k">mean drift across ${drifts.length} snapshots</div>
              <div class="v">${avg}</div>
            </div>
            <div class="kpi flex1">
              <div class="k">drift trajectory</div>
              ${sparkline(drifts)}
            </div>
          </div>
        `;
      }

      function renderIntegrity(data, container) {
        if (data.error || !data.sessions || data.sessions.length === 0) {
          container.innerHTML = '<div class="empty">no integrity data yet</div>';
          return;
        }

        const s = data.summary;
        const lowProfile = s.count < 10;
        const flagLabel = lowProfile ? 'atypical' : 'flagged';
        const flagged = data.sessions.filter(r => r.flagged);

        let html = `
          <div class="kpi-row">
            <div class="kpi">
              <div class="k">sessions scored</div>
              <div class="v">${s.count}</div>
            </div>
            <div class="kpi">
              <div class="k">${flagLabel}${lowProfile ? ' (based on n=' + s.count + ' prior sessions)' : ''}</div>
              <div class="v">${s.flaggedCount}</div>
            </div>
            <div class="kpi">
              <div class="k">mean distance</div>
              <div class="v">${s.meanDistance != null ? s.meanDistance.toFixed(1) : '—'}</div>
            </div>
            <div class="kpi">
              <div class="k">std dev</div>
              <div class="v">${s.stdDevDistance != null ? s.stdDevDistance.toFixed(1) : '—'}</div>
            </div>
            <div class="kpi flex1">
              <div class="k">distance trajectory</div>
              ${sparkline(data.sessions.map(r => r.distance))}
            </div>
          </div>
        `;

        // Most deviant dimensions
        if (s.dimSummary && s.dimSummary.length > 0) {
          html += `<div style="margin-top:0.75rem;font-family:var(--mono);font-size:10px;letter-spacing:0.12em;text-transform:uppercase;color:var(--text-faint);">most deviant dimensions (mean |z|)</div>`;
          html += '<table><thead><tr><th>dimension</th><th>mean |z|</th><th>max |z|</th></tr></thead><tbody>';
          for (const d of s.dimSummary.slice(0, 6)) {
            html += `<tr>
              <td>${d.dim}</td>
              <td class="num">${d.meanAbsZ.toFixed(2)}</td>
              <td class="num">${d.maxAbsZ.toFixed(2)}</td>
            </tr>`;
          }
          html += '</tbody></table>';
        }

        // Flagged sessions
        if (flagged.length > 0) {
          html += `<div style="margin-top:0.75rem;font-family:var(--mono);font-size:10px;letter-spacing:0.12em;text-transform:uppercase;color:var(--text-faint);">${flagLabel} sessions</div>`;
          html += '<table><thead><tr><th>date</th><th>distance</th><th>dims</th><th>threshold</th></tr></thead><tbody>';
          for (const f of flagged) {
            html += `<tr>
              <td>${f.date ? f.date.slice(5) : '—'}</td>
              <td class="num sign-neg">${Number(f.distance).toFixed(1)}</td>
              <td class="num">${f.dimCount}</td>
              <td class="num">${f.threshold != null ? Number(f.threshold).toFixed(1) : '—'}</td>
            </tr>`;
          }
          html += '</tbody></table>';
        }

        container.innerHTML = html;
      }

      Promise.all([
        fetch(window.__obsUrl('/api/observatory/states')).then(r => r.json()),
        fetch(window.__obsUrl('/api/observatory/calibration-drift')).then(r => r.json()),
        fetch(window.__obsUrl('/api/observatory/integrity')).then(r => r.json()),
      ]).then(([st, cd, integ]) => {
        const states = st.states ?? [];
        document.getElementById('counts').textContent =
          `${states.length} entries · ${cd.totalSnapshots ?? 0} calibration snapshots`;
        renderCalDrift(cd, document.getElementById('cal-drift'));
        renderIntegrity(integ, document.getElementById('integrity'));
        renderEntries(states, document.getElementById('entries-table'));
      }).catch(err => {
        document.querySelector('.frame').innerHTML += `<div class="panel" style="border-color:var(--negative);color:var(--negative);">load failed: ${err?.message ?? err}</div>`;
      });
    </script>
  </body>
</html>
