---
/**
 * Observatory · Designer-facing instrument view.
 *
 * Lists all entries with their behavioral 7D + semantic 11D state vectors,
 * sustained trends, top couplings, calibration drift, and per-entry replay
 * links. No prediction scoreboard, no theory tables, no suppressed-question
 * panel — those layers were removed 2026-04-16.
 *
 * No user surfaces. The /observatory/* tree is for the designer only.
 */
---
<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Observatory · Alice</title>
    <style>
      :root {
        --bg: #fafaf8;
        --fg: #1a1a1a;
        --dim: #6e6e6e;
        --faint: #9b9b9b;
        --rule: #d8d4cc;
        --accent: #3a6ea5;
        --semantic: #7a5a7a;
        --emotion: #8a5a44;
        --positive: #4d7a4d;
        --negative: #a04545;
        --panel: #ffffff;
      }
      * { box-sizing: border-box; }
      body {
        margin: 0;
        font-family: -apple-system, BlinkMacSystemFont, 'SF Pro Text', sans-serif;
        background: var(--bg);
        color: var(--fg);
      }
      .frame { max-width: 1100px; margin: 32px auto; padding: 0 24px; }
      header {
        display: flex; justify-content: space-between; align-items: baseline;
        border-bottom: 1px solid var(--rule); padding-bottom: 16px; margin-bottom: 24px;
      }
      h1 { font-size: 18px; font-weight: 500; margin: 0; }
      nav { display: flex; gap: 16px; font-family: 'SF Mono', monospace; font-size: 12px; }
      nav a { color: var(--dim); text-decoration: none; }
      nav a:hover, nav a.active { color: var(--accent); }
      .meta-row {
        display: flex; gap: 24px; margin-bottom: 32px;
        font-family: 'SF Mono', monospace; font-size: 12px; color: var(--dim);
      }

      .panel {
        background: var(--panel); border: 1px solid var(--rule);
        border-radius: 4px; padding: 20px; margin-bottom: 20px;
      }
      .panel h2 {
        font-size: 11px; font-weight: 500; letter-spacing: 0.06em;
        text-transform: uppercase; color: var(--dim); margin: 0 0 14px;
      }
      .insights p { margin: 0 0 8px; line-height: 1.5; }
      .insights .src {
        display: inline-block; font-family: 'SF Mono', monospace; font-size: 10px;
        color: var(--faint); margin-right: 6px; vertical-align: middle;
      }

      .grid-two { display: grid; grid-template-columns: 1fr 1fr; gap: 20px; }
      @media (max-width: 720px) { .grid-two { grid-template-columns: 1fr; } }

      .arc, .discovery {
        padding: 10px 0; border-bottom: 1px solid var(--rule); font-size: 14px;
      }
      .arc:last-child, .discovery:last-child { border-bottom: none; }
      .discovery .ev {
        font-family: 'SF Mono', monospace; font-size: 11px; color: var(--dim);
      }

      table { width: 100%; border-collapse: collapse; font-size: 13px; }
      th, td {
        padding: 8px 10px; text-align: left;
        border-bottom: 1px solid var(--rule);
      }
      th { font-weight: 500; font-size: 11px; color: var(--dim); text-transform: uppercase; letter-spacing: 0.04em; }
      td.num { font-family: 'SF Mono', monospace; text-align: right; }
      td a { color: var(--accent); text-decoration: none; font-family: 'SF Mono', monospace; font-size: 12px; }
      td a:hover { text-decoration: underline; }

      .pill {
        display: inline-block; padding: 2px 8px; border-radius: 10px;
        font-family: 'SF Mono', monospace; font-size: 10px;
      }
      .pill.high { background: #f0e8d8; color: #6a5510; }
      .pill.mod  { background: #e8e4d8; color: var(--dim); }

      .spark {
        display: inline-block; height: 24px; width: 80px;
      }

      .empty {
        padding: 40px 20px; text-align: center; color: var(--dim);
        font-family: 'SF Mono', monospace; font-size: 12px;
      }
    </style>
  </head>
  <body>
    <div class="frame">
      <header>
        <h1>Observatory</h1>
        <nav>
          <a href="/observatory" class="active">overview</a>
          <a href="/observatory/coupling">coupling</a>
          <a href="/">→ alice</a>
        </nav>
      </header>

      <div class="meta-row" id="meta-row">
        <span id="counts">loading…</span>
      </div>

      <section class="panel">
        <h2>Right now — latest entry</h2>
        <div class="insights" id="right-now"></div>
      </section>

      <div class="grid-two">
        <section class="panel">
          <h2>Sustained trends</h2>
          <div id="arcs"></div>
        </section>
        <section class="panel">
          <h2>Discoveries · empirical couplings</h2>
          <div id="discoveries"></div>
        </section>
      </div>

      <section class="panel">
        <h2>Calibration drift · designer-facing health metric</h2>
        <div id="cal-drift"></div>
      </section>

      <section class="panel">
        <h2>Entries · per-entry state vectors + replay</h2>
        <div id="entries-table"></div>
      </section>
    </div>

    <script type="module">
      const BEHAVIORAL_DIMS = ['fluency','deliberation','revision','commitment','volatility','thermal','presence'];

      function fmtZ(v) {
        if (v == null) return '—';
        const sign = v >= 0 ? '+' : '';
        return sign + v.toFixed(2);
      }

      function dotColor(z) {
        if (z == null) return '#ddd';
        if (Math.abs(z) < 1) return '#555';
        if (z > 0) return '#4d7a4d';
        return '#a04545';
      }

      function renderInsights(insights, container) {
        container.innerHTML = insights.map(i => {
          const src = i.space ? `<span class="src">[${i.space}]</span>` : '';
          return `<p>${src}${i.text}</p>`;
        }).join('');
      }

      function renderArcs(arcs, container) {
        if (!arcs.length) {
          container.innerHTML = '<div class="empty">no sustained trends yet (need ≥4 entries with consistent direction)</div>';
          return;
        }
        container.innerHTML = arcs.map(a => `
          <div class="arc">
            <span class="src" style="font-family:'SF Mono',monospace;font-size:10px;color:var(--faint);margin-right:6px;">[${a.space}]</span>
            ${a.text}
          </div>
        `).join('');
      }

      function renderDiscoveries(discoveries, container) {
        if (!discoveries.length) {
          container.innerHTML = '<div class="empty">no couplings discovered yet (need ≥10 entries)</div>';
          return;
        }
        container.innerHTML = discoveries.map(d => `
          <div class="discovery">
            <div>${d.text}</div>
            <div class="ev">${d.evidence} · <span class="pill ${d.strength === 'strong' ? 'high' : 'mod'}">${d.strength}</span> · <span class="src">${d.source}</span></div>
          </div>
        `).join('');
      }

      function sparkline(values, color = '#3a6ea5') {
        const n = values.length;
        if (n < 2) return '<span class="spark"></span>';
        const min = Math.min(...values);
        const max = Math.max(...values);
        const range = max - min || 1;
        const w = 80, h = 24;
        const pts = values.map((v, i) => {
          const x = (i / (n - 1)) * w;
          const y = h - ((v - min) / range) * (h - 2) - 1;
          return x.toFixed(1) + ',' + y.toFixed(1);
        }).join(' ');
        return `<svg class="spark" viewBox="0 0 ${w} ${h}" xmlns="http://www.w3.org/2000/svg"><polyline fill="none" stroke="${color}" stroke-width="1.5" points="${pts}"/></svg>`;
      }

      function renderEntries(states, container) {
        if (!states.length) {
          container.innerHTML = '<div class="empty">no entries yet — submit a session to populate</div>';
          return;
        }

        const cols = ['date', 'flu', 'del', 'rev', 'com', 'vol', 'thm', 'prs', 'sem-conv', 'meta', 'replay'];
        const head = `<tr>${cols.map(c => `<th>${c}</th>`).join('')}</tr>`;
        const rows = states.map(s => {
          const beh = BEHAVIORAL_DIMS.map(d => `<td class="num" style="color:${dotColor(s[d])}">${fmtZ(s[d])}</td>`).join('');
          const semConv = s.semantic ? fmtZ(s.semantic.semantic_convergence) : '—';
          const metaParts = [];
          if (s.metadata?.deletion_curve_type && s.metadata.deletion_curve_type !== 'none')
            metaParts.push(`del:${s.metadata.deletion_curve_type}`);
          if (s.metadata?.burst_trajectory_shape && s.metadata.burst_trajectory_shape !== 'none')
            metaParts.push(`burst:${s.metadata.burst_trajectory_shape}`);
          if (s.metadata?.hour_typicality != null && Math.abs(s.metadata.hour_typicality) > 1)
            metaParts.push(`hr:${s.metadata.hour_typicality > 0 ? 'typical' : 'unusual'}`);
          const meta = metaParts.length ? metaParts.join(' · ') : '—';
          const replay = s.replayAvailable
            ? `<a href="/observatory/replay/${s.question_id}">replay</a>`
            : '<span style="color:var(--faint);font-size:11px;">—</span>';
          return `<tr>
            <td><a href="/observatory/entry/${s.response_id}">${s.date}</a></td>
            ${beh}
            <td class="num">${semConv}</td>
            <td style="font-family:'SF Mono',monospace;font-size:11px;color:var(--dim);">${meta}</td>
            <td>${replay}</td>
          </tr>`;
        }).join('');

        container.innerHTML = `<table>${head}${rows}</table>`;
      }

      function renderCalDrift(payload, container) {
        const global = payload.globalTrack || [];
        if (global.length === 0) {
          container.innerHTML = '<div class="empty">no calibration snapshots yet — run a free-write to seed</div>';
          return;
        }
        const drifts = global.map(g => g.drift_magnitude ?? 0).filter(d => d != null);
        const latest = global[global.length - 1];
        const avg = drifts.length ? (drifts.reduce((a,b)=>a+b,0) / drifts.length).toFixed(3) : '—';
        const latestDrift = latest.drift_magnitude != null ? latest.drift_magnitude.toFixed(3) : '—';
        container.innerHTML = `
          <div style="display:flex;align-items:center;gap:24px;">
            <div>
              <div style="font-family:'SF Mono',monospace;font-size:11px;color:var(--dim);">latest drift (z-norm L2)</div>
              <div style="font-family:'SF Mono',monospace;font-size:18px;">${latestDrift}</div>
            </div>
            <div>
              <div style="font-family:'SF Mono',monospace;font-size:11px;color:var(--dim);">mean drift across ${drifts.length} snapshots</div>
              <div style="font-family:'SF Mono',monospace;font-size:18px;">${avg}</div>
            </div>
            <div style="flex:1;">
              <div style="font-family:'SF Mono',monospace;font-size:11px;color:var(--dim);margin-bottom:4px;">drift trajectory</div>
              ${sparkline(drifts, '#8a5a44')}
            </div>
          </div>
        `;
      }

      Promise.all([
        fetch('/api/observatory/synthesis').then(r => r.json()),
        fetch('/api/observatory/states').then(r => r.json()),
        fetch('/api/observatory/calibration-drift').then(r => r.json()),
      ]).then(([syn, st, cd]) => {
        document.getElementById('counts').textContent =
          `${syn.behavioralCount} behavioral · ${syn.semanticCount} semantic · ${cd.totalSnapshots ?? 0} calibration snapshots${syn.latestDate ? ' · latest ' + syn.latestDate : ''}`;
        renderInsights(syn.rightNow ?? [], document.getElementById('right-now'));
        renderArcs(syn.arcs ?? [], document.getElementById('arcs'));
        renderDiscoveries(syn.discoveries ?? [], document.getElementById('discoveries'));
        renderCalDrift(cd, document.getElementById('cal-drift'));
        renderEntries(st.states ?? [], document.getElementById('entries-table'));
      }).catch(err => {
        document.querySelector('.frame').innerHTML += `<div class="panel" style="border-color:#a04545;color:#a04545;">load failed: ${err?.message ?? err}</div>`;
      });
    </script>
  </body>
</html>
