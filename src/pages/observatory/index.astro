---
/**
 * Observatory · Designer-facing instrument view.
 *
 * Lists all entries with their behavioral 7D + semantic 11D state vectors,
 * sustained trends, top couplings, calibration drift, and per-entry replay
 * links. No prediction scoreboard, no theory tables, no suppressed-question
 * panel — those layers were removed 2026-04-16.
 *
 * No user surfaces. The /observatory/* tree is for the designer only.
 */
import '../../styles/observatory.css';
---
<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Observatory · Alice</title>
    <script is:inline>
      (function () {
        var t = localStorage.getItem('alice-theme') || 'light';
        document.documentElement.setAttribute('data-theme', t);
      })();
    </script>
    <style is:global>
      /* page-specific overrides go here */
    </style>
  </head>
  <body>
    <div class="frame">
      <header>
        <h1>Observatory</h1>
        <nav>
          <a href="/observatory" class="active">overview</a>
          <a href="/observatory/coupling">coupling</a>
          <a href="/">→ alice</a>
        </nav>
      </header>

      <div class="meta-row" id="meta-row">
        <span id="counts">loading…</span>
      </div>

      <section class="panel">
        <h2>Right now — latest entry</h2>
        <div class="insights" id="right-now"></div>
      </section>

      <div class="grid-two">
        <section class="panel">
          <h2>Sustained trends</h2>
          <div id="arcs"></div>
        </section>
        <section class="panel">
          <h2>Discoveries · empirical couplings</h2>
          <div id="discoveries"></div>
        </section>
      </div>

      <section class="panel">
        <h2>Calibration drift · designer-facing health metric</h2>
        <div id="cal-drift"></div>
      </section>

      <section class="panel">
        <h2>Entries · per-entry state vectors + replay</h2>
        <div id="entries-table"></div>
      </section>
    </div>

    <script type="module">
      const BEHAVIORAL_DIMS = ['fluency','deliberation','revision','commitment','volatility','thermal','presence'];

      function fmtZ(v) {
        if (v == null) return '—';
        const sign = v >= 0 ? '+' : '';
        return sign + v.toFixed(2);
      }

      function dotColor(z) {
        if (z == null) return '#ddd';
        if (Math.abs(z) < 1) return '#555';
        if (z > 0) return '#6b8e6b';
        return '#b5603f';
      }

      function renderInsights(insights, container) {
        container.innerHTML = insights.map(i => {
          const src = i.space ? `<span class="src">[${i.space}]</span>` : '';
          return `<p>${src}${i.text}</p>`;
        }).join('');
      }

      function renderArcs(arcs, container, lowNNotice) {
        if (lowNNotice) {
          container.innerHTML = `<div class="empty">${lowNNotice}</div>`;
          return;
        }
        if (!arcs.length) {
          container.innerHTML = '<div class="empty">no sustained trends detected in recent sessions</div>';
          return;
        }
        container.innerHTML = arcs.map(a => `
          <div class="arc">
            <span class="src">[${a.space}]</span>
            ${a.text}
          </div>
        `).join('');
      }

      function renderDiscoveries(discoveries, container) {
        if (!discoveries.length) {
          container.innerHTML = '<div class="empty">no couplings discovered yet (need ≥10 entries)</div>';
          return;
        }
        container.innerHTML = discoveries.map(d => `
          <div class="discovery">
            <div>${d.text}</div>
            <div class="ev">${d.evidence} · <span class="pill ${d.strength === 'strong' ? 'high' : 'mod'}">${d.strength}</span> · <span class="src">${d.source}</span></div>
          </div>
        `).join('');
      }

      function sparkline(values, color = '#7a5a44') {
        const n = values.length;
        if (n < 2) return '<span class="spark"></span>';
        const min = Math.min(...values);
        const max = Math.max(...values);
        const range = max - min || 1;
        const w = 80, h = 24;
        const pts = values.map((v, i) => {
          const x = (i / (n - 1)) * w;
          const y = h - ((v - min) / range) * (h - 2) - 1;
          return x.toFixed(1) + ',' + y.toFixed(1);
        }).join(' ');
        return `<svg class="spark" viewBox="0 0 ${w} ${h}" xmlns="http://www.w3.org/2000/svg"><polyline fill="none" stroke="${color}" stroke-width="1.5" points="${pts}"/></svg>`;
      }

      function renderEntries(states, container) {
        if (!states.length) {
          container.innerHTML = '<div class="empty">no entries yet — submit a session to populate</div>';
          return;
        }

        const cols = ['date', 'flu', 'del', 'rev', 'com', 'vol', 'thm', 'prs', 'sem-conv', 'meta', 'replay'];
        const head = `<thead><tr>${cols.map(c => `<th>${c}</th>`).join('')}</tr></thead>`;
        const rows = states.map(s => {
          const semConv = s.semantic ? fmtZ(s.semantic.semantic_convergence) : '—';
          const metaParts = [];
          if (s.metadata?.deletion_curve_type && s.metadata.deletion_curve_type !== 'none')
            metaParts.push(`del:${s.metadata.deletion_curve_type}`);
          if (s.metadata?.burst_trajectory_shape && s.metadata.burst_trajectory_shape !== 'none')
            metaParts.push(`burst:${s.metadata.burst_trajectory_shape}`);
          if (s.metadata?.hour_typicality != null && Math.abs(s.metadata.hour_typicality) > 1)
            metaParts.push(`hr:${s.metadata.hour_typicality > 0 ? 'typical' : 'unusual'}`);
          const meta = metaParts.length ? metaParts.join(' · ') : '—';
          const replay = s.replayAvailable
            ? `<a class="action-btn" href="/observatory/replay/${s.question_id}">▶ replay</a>`
            : '<span class="action-btn-muted">—</span>';
          const link = (content) => `<a href="/observatory/entry/${s.response_id}">${content}</a>`;
          const behLinked = BEHAVIORAL_DIMS.map(d => `<td class="num" style="color:${dotColor(s[d])}">${link(fmtZ(s[d]))}</td>`).join('');
          return `<tr>
            <td>${link(s.date)}</td>
            ${behLinked}
            <td class="num">${link(semConv)}</td>
            <td class="meta">${link(meta)}</td>
            <td>${replay}</td>
          </tr>`;
        }).join('');

        container.innerHTML = `<table>${head}<tbody>${rows}</tbody></table>`;
      }

      function renderCalDrift(payload, container) {
        const global = payload.globalTrack || [];
        if (global.length === 0) {
          container.innerHTML = '<div class="empty">no calibration snapshots yet — run a free-write to seed</div>';
          return;
        }
        const drifts = global.map(g => g.drift_magnitude ?? 0).filter(d => d != null);
        const latest = global[global.length - 1];
        const avg = drifts.length ? (drifts.reduce((a,b)=>a+b,0) / drifts.length).toFixed(3) : '—';
        const latestDrift = latest.drift_magnitude != null ? latest.drift_magnitude.toFixed(3) : '—';
        container.innerHTML = `
          <div class="kpi-row">
            <div class="kpi">
              <div class="k">latest drift (z-norm L2)</div>
              <div class="v">${latestDrift}</div>
            </div>
            <div class="kpi">
              <div class="k">mean drift across ${drifts.length} snapshots</div>
              <div class="v">${avg}</div>
            </div>
            <div class="kpi flex1">
              <div class="k">drift trajectory</div>
              ${sparkline(drifts, '#8a5a44')}
            </div>
          </div>
        `;
      }

      Promise.all([
        fetch('/api/observatory/synthesis').then(r => r.json()),
        fetch('/api/observatory/states').then(r => r.json()),
        fetch('/api/observatory/calibration-drift').then(r => r.json()),
      ]).then(([syn, st, cd]) => {
        document.getElementById('counts').textContent =
          `${syn.behavioralCount} behavioral · ${syn.semanticCount} semantic · ${cd.totalSnapshots ?? 0} calibration snapshots${syn.latestDate ? ' · latest ' + syn.latestDate : ''}`;
        renderInsights(syn.rightNow ?? [], document.getElementById('right-now'));
        renderArcs(syn.arcs ?? [], document.getElementById('arcs'), syn.arcsLowN);
        renderDiscoveries(syn.discoveries ?? [], document.getElementById('discoveries'));
        renderCalDrift(cd, document.getElementById('cal-drift'));
        renderEntries(st.states ?? [], document.getElementById('entries-table'));
      }).catch(err => {
        document.querySelector('.frame').innerHTML += `<div class="panel" style="border-color:var(--negative);color:var(--negative);">load failed: ${err?.message ?? err}</div>`;
      });
    </script>
  </body>
</html>
