---
/**
 * Observatory
 *
 * Hero: prediction arc timeline — shows predictions as arcs from
 * origin to resolution. The visual proof that this system makes
 * falsifiable claims and tests them.
 *
 * Below: sparklines + theories + patterns for depth.
 */
---
<html lang="en">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title>Observatory</title>
  <script is:inline>
    (function() {
      var t = localStorage.getItem('alice-theme') || 'light';
      document.documentElement.setAttribute('data-theme', t);
    })();
  </script>
  <style>
    :root {
      --ob-bg: #f5f2ed;
      --ob-bg-card: #ebe7e1;
      --ob-bg-card-alt: #e2ded8;
      --ob-text: #1a1a1a;
      --ob-text-muted: #6b6560;
      --ob-text-faint: #9a9590;
      --ob-text-dim: #b5b0aa;
      --ob-border: #ccc5bc;
      --ob-border-subtle: #ddd8d2;
      --ob-confirmed: #2a7a2a;
      --ob-falsified: #9a3a3a;
      --ob-open: #7a7a7a;
      --ob-arc-confirmed: rgba(42, 122, 42, 0.6);
      --ob-arc-falsified: rgba(154, 58, 58, 0.5);
      --ob-arc-open: rgba(122, 122, 122, 0.35);
      --ob-spark-line: #3a6ea5;
      --ob-spark-dot: #2a5a8a;
      --ob-spark-zero: #ddd8d2;
      --ob-spark-ref: #eae6e0;
      --ob-heat-pos-r: 140; --ob-heat-pos-g: 90; --ob-heat-pos-b: 30;
      --ob-heat-neg-r: 40; --ob-heat-neg-g: 80; --ob-heat-neg-b: 160;
      --ob-heat-neutral: #e0dbd5;
      --ob-entry-border: #3a6ea5;
      --ob-frame-a: #3a6ea5;
      --ob-frame-b: #aa8833;
      --ob-frame-c: #4a7a4a;
      --ob-theory-active: #3a3a7a;
      --ob-theory-retired: #7a3a3a;
      --ob-score-bg: #ebe7e1;
    }
    [data-theme="dark"] {
      --ob-bg: #0a0a0a;
      --ob-bg-card: #0f0f0f;
      --ob-bg-card-alt: #141414;
      --ob-text: #cccccc;
      --ob-text-muted: #888;
      --ob-text-faint: #555;
      --ob-text-dim: #333;
      --ob-border: #1a1a1a;
      --ob-border-subtle: #151515;
      --ob-confirmed: #5a8a5a;
      --ob-falsified: #8a5a5a;
      --ob-open: #555;
      --ob-arc-confirmed: rgba(90, 138, 90, 0.55);
      --ob-arc-falsified: rgba(138, 90, 90, 0.45);
      --ob-arc-open: rgba(85, 85, 85, 0.3);
      --ob-spark-line: #3a6ea5;
      --ob-spark-dot: #5a9ed6;
      --ob-spark-zero: #1a1a1a;
      --ob-spark-ref: #111;
      --ob-heat-pos-r: 200; --ob-heat-pos-g: 130; --ob-heat-pos-b: 40;
      --ob-heat-neg-r: 35; --ob-heat-neg-g: 90; --ob-heat-neg-b: 180;
      --ob-heat-neutral: #141414;
      --ob-entry-border: #3a6ea5;
      --ob-frame-a: #3a6ea5;
      --ob-frame-b: #aa8833;
      --ob-frame-c: #5a7a5a;
      --ob-theory-active: #5a5a8a;
      --ob-theory-retired: #8a5a5a;
      --ob-score-bg: #111;
    }

    * { margin: 0; padding: 0; box-sizing: border-box; }
    body {
      background: var(--ob-bg);
      color: var(--ob-text-muted);
      font-family: 'SF Mono', 'Fira Code', 'Consolas', monospace;
      font-size: 11px;
    }

    /* ---- Nav ---- */
    .nav {
      display: flex;
      justify-content: space-between;
      align-items: center;
      padding: 16px 24px;
      border-bottom: 1px solid var(--ob-border);
    }
    .nav a, .theme-btn {
      color: var(--ob-text-faint);
      text-decoration: none;
      font-size: 11px;
      letter-spacing: 0.05em;
      background: none;
      border: none;
      font-family: inherit;
      cursor: pointer;
    }
    .nav a:hover, .theme-btn:hover { color: var(--ob-text-muted); }
    .nav-title {
      color: var(--ob-text-faint);
      font-size: 12px;
      letter-spacing: 0.1em;
      text-transform: uppercase;
    }
    .nav-right {
      display: flex;
      align-items: center;
      gap: 16px;
    }

    .container {
      max-width: 1000px;
      margin: 0 auto;
      padding: 0 24px 48px;
    }

    /* ---- Hero: prediction arcs ---- */
    .hero {
      padding: 24px 0 0;
    }
    .hero-tagline {
      color: var(--ob-text-faint);
      font-size: 10px;
      letter-spacing: 0.12em;
      text-transform: uppercase;
      margin-bottom: 12px;
    }
    .hero-canvas-wrap {
      position: relative;
      margin-bottom: 4px;
    }
    #arc-canvas {
      display: block;
      width: 100%;
      cursor: crosshair;
    }
    .hero-date-axis {
      position: relative;
      height: 14px;
      margin-bottom: 8px;
    }
    .hero-date-axis span {
      position: absolute;
      color: var(--ob-text-dim);
      font-size: 9px;
    }

    /* ---- Scoreboard ---- */
    .scoreboard {
      display: flex;
      gap: 1px;
      background: var(--ob-border);
      margin-bottom: 32px;
      border: 1px solid var(--ob-border);
    }
    .score-cell {
      flex: 1;
      padding: 16px 12px;
      background: var(--ob-score-bg);
      text-align: center;
    }
    .score-number {
      font-size: 24px;
      line-height: 1;
      margin-bottom: 4px;
    }
    .score-label {
      font-size: 8px;
      letter-spacing: 0.12em;
      text-transform: uppercase;
      color: var(--ob-text-dim);
    }
    .score-confirmed .score-number { color: var(--ob-confirmed); }
    .score-falsified .score-number { color: var(--ob-falsified); }
    .score-open .score-number { color: var(--ob-text-faint); }
    .score-entries .score-number { color: var(--ob-text-muted); }
    .score-total .score-number { color: var(--ob-text-faint); }

    /* ---- Section ---- */
    .section { margin-bottom: 32px; }
    .section-label {
      color: var(--ob-text-dim);
      font-size: 9px;
      letter-spacing: 0.15em;
      text-transform: uppercase;
      margin-bottom: 12px;
      padding-bottom: 6px;
      border-bottom: 1px solid var(--ob-border);
    }

    /* ---- Recent calls ---- */
    .call-card {
      background: var(--ob-bg-card);
      border: 1px solid var(--ob-border-subtle);
      padding: 12px 16px;
      margin-bottom: 6px;
    }
    .call-header {
      display: flex;
      justify-content: space-between;
      align-items: flex-start;
      gap: 12px;
    }
    .call-hypothesis {
      color: var(--ob-text-muted);
      font-size: 11px;
      line-height: 1.7;
      flex: 1;
    }
    .call-badge {
      font-size: 8px;
      letter-spacing: 0.05em;
      text-transform: uppercase;
      padding: 3px 8px;
      border-radius: 2px;
      flex-shrink: 0;
    }
    .call-badge-confirmed { background: rgba(42,122,42,0.1); color: var(--ob-confirmed); }
    .call-badge-falsified { background: rgba(154,58,58,0.1); color: var(--ob-falsified); }
    [data-theme="dark"] .call-badge-confirmed { background: rgba(90,138,90,0.15); }
    [data-theme="dark"] .call-badge-falsified { background: rgba(138,90,90,0.15); }
    .call-meta {
      color: var(--ob-text-dim);
      font-size: 9px;
      margin-top: 4px;
    }
    .call-rationale {
      color: var(--ob-text-faint);
      font-size: 10px;
      line-height: 1.6;
      margin-top: 6px;
      padding-top: 6px;
      border-top: 1px solid var(--ob-border-subtle);
    }

    /* ---- Theories ---- */
    .theory-card {
      background: var(--ob-bg-card);
      border: 1px solid var(--ob-border-subtle);
      padding: 12px 16px;
      margin-bottom: 6px;
    }
    .theory-header {
      display: flex;
      justify-content: space-between;
      align-items: center;
    }
    .theory-name { color: var(--ob-text-muted); font-size: 11px; }
    .theory-status {
      font-size: 8px;
      letter-spacing: 0.05em;
      text-transform: uppercase;
      padding: 2px 8px;
      border-radius: 2px;
    }
    .theory-active { background: rgba(58,58,122,0.12); color: var(--ob-theory-active); }
    .theory-retired { background: rgba(122,58,58,0.12); color: var(--ob-theory-retired); }
    .theory-desc { color: var(--ob-text-faint); font-size: 10px; line-height: 1.5; margin-top: 6px; }
    .theory-bar-wrap { margin-top: 8px; display: flex; align-items: center; gap: 10px; }
    .theory-bar-track { flex: 1; height: 4px; background: var(--ob-border-subtle); border-radius: 2px; overflow: hidden; }
    .theory-bar-fill { height: 100%; border-radius: 2px; }
    .theory-bar-label { color: var(--ob-text-dim); font-size: 9px; width: 80px; flex-shrink: 0; }

    /* ---- Sparklines ---- */
    .sparkline-stack { margin-bottom: 8px; }
    .sparkline-row {
      display: flex;
      align-items: center;
      height: 56px;
      border-bottom: 1px solid var(--ob-border-subtle);
    }
    .sparkline-row:last-child { border-bottom: none; }
    .dim-label {
      width: 90px;
      color: var(--ob-text-dim);
      font-size: 9px;
      letter-spacing: 0.05em;
      text-transform: uppercase;
      flex-shrink: 0;
    }
    .sparkline-canvas { flex: 1; height: 100%; cursor: crosshair; }
    .dim-value {
      width: 50px;
      text-align: right;
      color: var(--ob-text-faint);
      font-size: 10px;
      flex-shrink: 0;
    }

    /* ---- Heat strip ---- */
    .heatstrip-wrap { display: flex; align-items: stretch; }
    .heatstrip-labels {
      display: flex; flex-direction: column; flex-shrink: 0;
      width: 90px;
    }
    .heatstrip-label {
      flex: 1; display: flex; align-items: center;
      color: var(--ob-text-dim); font-size: 9px;
      letter-spacing: 0.05em; text-transform: uppercase;
    }
    .heatstrip-canvas-wrap { flex: 1; position: relative; }
    #heatstrip-canvas { display: block; width: 100%; cursor: crosshair; }
    .heatstrip-date-axis {
      margin-left: 90px; margin-top: 4px;
      position: relative; height: 14px;
    }
    .heatstrip-date-axis span {
      position: absolute; color: var(--ob-text-dim); font-size: 9px;
    }

    /* ---- Discoveries ---- */
    .discovery {
      padding: 10px 14px;
      background: var(--ob-bg-card);
      border-left: 3px solid var(--ob-border);
      line-height: 1.7;
      color: var(--ob-text-muted);
      font-size: 11px;
      margin-bottom: 6px;
    }
    .discovery-strong { border-left-color: var(--ob-spark-line); }
    .discovery-evidence {
      color: var(--ob-text-dim);
      font-size: 9px;
      margin-top: 4px;
    }

    /* ---- Inline entry panel ---- */
    .entry-panel {
      display: none;
      margin-top: 16px;
      padding: 20px;
      background: var(--ob-bg-card);
      border: 1px solid var(--ob-border);
    }
    .entry-panel.open { display: block; }
    .entry-panel-header {
      display: flex;
      justify-content: space-between;
      align-items: center;
      margin-bottom: 16px;
    }
    .entry-panel-date { color: var(--ob-text-faint); font-size: 10px; letter-spacing: 0.05em; }
    .entry-panel-nav { display: flex; gap: 12px; align-items: center; }
    .entry-nav-btn {
      color: var(--ob-text-dim); font-size: 10px; cursor: pointer;
      background: none; border: none; font-family: inherit; padding: 2px 6px;
    }
    .entry-nav-btn:hover { color: var(--ob-text-muted); }
    .entry-nav-btn:disabled { color: var(--ob-border-subtle); cursor: default; }
    .entry-panel-close {
      color: var(--ob-text-dim); font-size: 10px; cursor: pointer; padding: 4px 8px;
    }
    .entry-panel-close:hover { color: var(--ob-text-muted); }
    .entry-panel-question {
      color: var(--ob-text-muted);
      font-size: 13px;
      font-style: italic;
      line-height: 1.7;
      padding-bottom: 16px;
      border-bottom: 1px solid var(--ob-border-subtle);
      margin-bottom: 16px;
    }
    .entry-section-label {
      color: var(--ob-text-dim);
      font-size: 9px;
      letter-spacing: 0.12em;
      text-transform: uppercase;
      margin: 16px 0 10px;
    }
    .frame-card {
      background: var(--ob-bg-card-alt);
      border: 1px solid var(--ob-border-subtle);
      padding: 14px 18px;
      margin-bottom: 8px;
      line-height: 1.7;
      color: var(--ob-text-muted);
      font-size: 11px;
    }
    .frame-card-a { border-left: 3px solid var(--ob-frame-a); }
    .frame-card-b { border-left: 3px solid var(--ob-frame-b); }
    .frame-card-c { border-left: 3px solid var(--ob-frame-c); }
    .frame-label { font-size: 9px; letter-spacing: 0.1em; text-transform: uppercase; margin-bottom: 6px; }
    .frame-label-a { color: var(--ob-frame-a); }
    .frame-label-b { color: var(--ob-frame-b); }
    .frame-label-c { color: var(--ob-frame-c); }

    .prediction-card {
      background: var(--ob-bg-card-alt);
      border: 1px solid var(--ob-border-subtle);
      padding: 10px 14px;
      margin-bottom: 6px;
    }
    .prediction-header { display: flex; justify-content: space-between; align-items: center; gap: 12px; }
    .prediction-hypothesis { color: var(--ob-text-muted); line-height: 1.6; font-size: 10px; }
    .status-badge {
      font-size: 8px; letter-spacing: 0.05em; text-transform: uppercase;
      padding: 2px 6px; border-radius: 2px; flex-shrink: 0;
    }
    .status-open { background: var(--ob-border-subtle); color: var(--ob-text-faint); }
    .status-confirmed { background: rgba(42,122,42,0.1); color: var(--ob-confirmed); }
    .status-falsified { background: rgba(154,58,58,0.1); color: var(--ob-falsified); }
    .status-indeterminate { background: var(--ob-border-subtle); color: var(--ob-text-dim); }
    [data-theme="dark"] .status-confirmed { background: rgba(90,138,90,0.15); }
    [data-theme="dark"] .status-falsified { background: rgba(138,90,90,0.15); }
    .prediction-meta { color: var(--ob-text-dim); font-size: 9px; margin-top: 4px; }
    .prediction-rationale {
      color: var(--ob-text-faint); font-size: 10px; margin-top: 6px;
      padding-top: 6px; border-top: 1px solid var(--ob-border-subtle); line-height: 1.5;
    }
    .suppressed-block {
      background: var(--ob-bg-card-alt);
      border-left: 3px solid var(--ob-border);
      padding: 12px 16px;
      color: var(--ob-text-faint);
      font-style: italic;
      line-height: 1.6;
      font-size: 10px;
      margin-top: 12px;
    }
    .entry-radar-wrap { display: flex; justify-content: center; margin: 12px 0; }

    /* ---- Tooltip ---- */
    .tooltip {
      display: none;
      position: fixed;
      background: var(--ob-bg-card);
      border: 1px solid var(--ob-border);
      padding: 8px 12px;
      font-size: 10px;
      color: var(--ob-text-muted);
      pointer-events: none;
      z-index: 100;
      line-height: 1.5;
      max-width: 340px;
    }
    .tooltip-question { color: var(--ob-text-muted); font-style: italic; margin-bottom: 4px; }
    .tooltip-dim { color: var(--ob-text-faint); font-size: 9px; }

    .loading {
      color: var(--ob-text-dim);
      text-align: center;
      padding: 60px 0;
      letter-spacing: 0.1em;
    }
  </style>
</head>
<body>
  <div class="nav">
    <a href="/">&larr; journal</a>
    <span class="nav-title">observatory</span>
    <div class="nav-right">
      <a href="/observatory/coupling">data &rarr;</a>
      <button class="theme-btn" id="theme-toggle"></button>
    </div>
  </div>

  <div class="loading" id="loading">loading...</div>

  <div class="container" id="main" style="display:none">

    <!-- HERO: Prediction arc timeline -->
    <div class="hero">
      <div class="hero-tagline">predictions over time</div>
      <div class="hero-canvas-wrap">
        <canvas id="arc-canvas"></canvas>
      </div>
      <div class="hero-date-axis" id="arc-dates"></div>
    </div>

    <!-- SCOREBOARD -->
    <div class="scoreboard" id="scoreboard"></div>

    <!-- RECENT CALLS -->
    <div class="section" id="section-calls">
      <div class="section-label">recent calls</div>
      <div id="calls-list"></div>
    </div>

    <!-- THEORIES -->
    <div class="section" id="section-theories" style="display:none">
      <div class="section-label">running theories</div>
      <div id="theories-list"></div>
    </div>

    <!-- SPARKLINES -->
    <div class="section">
      <div class="section-label">behavioral dimensions</div>
      <div class="sparkline-stack" id="sparkline-stack"></div>
    </div>

    <!-- HEAT STRIP -->
    <div class="section">
      <div class="section-label">behavioral heatmap</div>
      <div class="heatstrip-wrap">
        <div class="heatstrip-labels" id="heatstrip-labels"></div>
        <div class="heatstrip-canvas-wrap">
          <canvas id="heatstrip-canvas"></canvas>
        </div>
      </div>
      <div class="heatstrip-date-axis" id="heatstrip-dates"></div>
    </div>

    <!-- INLINE ENTRY PANEL -->
    <div class="entry-panel" id="entry-panel">
      <div class="entry-panel-header">
        <span class="entry-panel-date" id="entry-panel-date"></span>
        <div class="entry-panel-nav">
          <button class="entry-nav-btn" id="entry-prev">&larr;</button>
          <button class="entry-nav-btn" id="entry-next">&rarr;</button>
          <span class="entry-panel-close" id="entry-panel-close">close</span>
        </div>
      </div>
      <div class="entry-panel-question" id="entry-panel-question"></div>
      <div id="entry-panel-body"></div>
    </div>

    <!-- PATTERNS -->
    <div class="section" id="section-discoveries" style="display:none">
      <div class="section-label">patterns</div>
      <div id="discoveries-list"></div>
    </div>

  </div>

  <div class="tooltip" id="tooltip"></div>

  <script>
    const DIMS = ['fluency', 'deliberation', 'revision', 'expression', 'commitment', 'volatility', 'thermal', 'presence'];

    interface EntryState {
      response_id: number; date: string; question: string;
      fluency: number; deliberation: number; revision: number; expression: number;
      commitment: number; volatility: number; thermal: number; presence: number;
      convergence: number; events?: any[];
    }

    let allStates: EntryState[] = [];
    let allPredictions: any[] = [];
    let selectedIdx: number | null = null;

    // ---- Theme toggle ----
    const themeBtn = document.getElementById('theme-toggle')!;
    const savedTheme = localStorage.getItem('alice-theme') || 'light';
    document.documentElement.setAttribute('data-theme', savedTheme);
    themeBtn.textContent = savedTheme === 'dark' ? '\u2600' : '\u263E';
    themeBtn.addEventListener('click', () => {
      const current = document.documentElement.getAttribute('data-theme');
      const next = current === 'dark' ? 'light' : 'dark';
      document.documentElement.setAttribute('data-theme', next);
      localStorage.setItem('alice-theme', next);
      themeBtn.textContent = next === 'dark' ? '\u2600' : '\u263E';
      // Redraw canvases with new colors
      if (allStates.length > 0) {
        drawArcTimeline(allStates, allPredictions);
        drawAllSparklines(allStates);
        drawHeatStrip(allStates);
      }
    });

    // ---- CSS variable reader ----
    function cssVar(name: string): string {
      return getComputedStyle(document.documentElement).getPropertyValue(name).trim();
    }
    function cssVarNum(name: string): number {
      return parseFloat(cssVar(name)) || 0;
    }

    // ---- Scoreboard ----
    function renderScoreboard(preds: any[], entryCount: number) {
      const confirmed = preds.filter(p => p.status === 'confirmed').length;
      const falsified = preds.filter(p => p.status === 'falsified').length;
      const open = preds.filter(p => p.status === 'open').length;
      document.getElementById('scoreboard')!.innerHTML = `
        <div class="score-cell score-entries"><div class="score-number">${entryCount}</div><div class="score-label">entries</div></div>
        <div class="score-cell score-total"><div class="score-number">${preds.length}</div><div class="score-label">predictions</div></div>
        <div class="score-cell score-confirmed"><div class="score-number">${confirmed}</div><div class="score-label">confirmed</div></div>
        <div class="score-cell score-falsified"><div class="score-number">${falsified}</div><div class="score-label">falsified</div></div>
        <div class="score-cell score-open"><div class="score-number">${open}</div><div class="score-label">open</div></div>
      `;
    }

    // ---- Prediction arc timeline ----
    function drawArcTimeline(states: EntryState[], preds: any[]) {
      const canvas = document.getElementById('arc-canvas') as HTMLCanvasElement;
      const wrap = canvas.parentElement!;
      const wrapW = wrap.getBoundingClientRect().width;

      const resolved = preds.filter(p => p.status === 'confirmed' || p.status === 'falsified');
      const openPreds = preds.filter(p => p.status === 'open');
      const allArcs = [...resolved, ...openPreds];

      const arcH = Math.min(220, Math.max(140, allArcs.length * 5));
      const baselineY = arcH + 20;
      const totalH = baselineY + 30;

      const dpr = window.devicePixelRatio || 1;
      canvas.width = wrapW * dpr;
      canvas.height = totalH * dpr;
      canvas.style.width = wrapW + 'px';
      canvas.style.height = totalH + 'px';

      const ctx = canvas.getContext('2d')!;
      ctx.scale(dpr, dpr);

      const n = states.length;
      if (n === 0) return;

      const pad = { left: 10, right: 10 };
      const plotW = wrapW - pad.left - pad.right;
      const xStep = n > 1 ? plotW / (n - 1) : plotW;

      // Date → x mapping
      const dateToX = new Map<string, number>();
      for (let i = 0; i < n; i++) {
        dateToX.set(states[i].date, pad.left + i * xStep);
      }

      // Nearest date x-position finder
      function nearestX(dateStr: string): number {
        if (dateToX.has(dateStr)) return dateToX.get(dateStr)!;
        const d = dateStr.slice(0, 10);
        if (dateToX.has(d)) return dateToX.get(d)!;
        // Find nearest
        let bestDist = Infinity, bestX = pad.left + plotW;
        for (const [sd, sx] of dateToX) {
          const dist = Math.abs(new Date(sd).getTime() - new Date(d).getTime());
          if (dist < bestDist) { bestDist = dist; bestX = sx; }
        }
        return bestX;
      }

      // Baseline
      ctx.strokeStyle = cssVar('--ob-border');
      ctx.lineWidth = 1;
      ctx.beginPath();
      ctx.moveTo(pad.left, baselineY);
      ctx.lineTo(wrapW - pad.right, baselineY);
      ctx.stroke();

      // Entry dots
      const dotColor = cssVar('--ob-text-faint');
      for (let i = 0; i < n; i++) {
        const x = pad.left + i * xStep;
        ctx.fillStyle = dotColor;
        ctx.beginPath();
        ctx.arc(x, baselineY, 3, 0, Math.PI * 2);
        ctx.fill();
      }

      // Sort arcs: longer spans get higher arcs
      const arcData = allArcs.map(p => {
        const originX = nearestX(p.origin_date);
        const isOpen = p.status === 'open';
        const resolveX = isOpen ? wrapW - pad.right : nearestX((p.dttm_graded_utc || '').slice(0, 10));
        const span = Math.abs(resolveX - originX);
        return { ...p, originX, resolveX, span, isOpen };
      }).sort((a, b) => a.span - b.span);

      // Draw arcs
      const maxSpan = Math.max(1, ...arcData.map(a => a.span));
      for (const arc of arcData) {
        const midX = (arc.originX + arc.resolveX) / 2;
        const heightRatio = Math.max(0.15, arc.span / maxSpan);
        const cpY = baselineY - heightRatio * arcH;

        if (arc.status === 'confirmed') {
          ctx.strokeStyle = cssVar('--ob-arc-confirmed');
        } else if (arc.status === 'falsified') {
          ctx.strokeStyle = cssVar('--ob-arc-falsified');
        } else {
          ctx.strokeStyle = cssVar('--ob-arc-open');
        }

        ctx.lineWidth = arc.isOpen ? 1 : 1.5;
        if (arc.isOpen) ctx.setLineDash([4, 4]);
        else ctx.setLineDash([]);

        ctx.beginPath();
        ctx.moveTo(arc.originX, baselineY);
        ctx.quadraticCurveTo(midX, cpY, arc.resolveX, baselineY);
        ctx.stroke();

        // Endpoint marker for resolved
        if (!arc.isOpen) {
          ctx.fillStyle = arc.status === 'confirmed' ? cssVar('--ob-confirmed') : cssVar('--ob-falsified');
          ctx.beginPath();
          ctx.arc(arc.resolveX, baselineY, 4, 0, Math.PI * 2);
          ctx.fill();
        }
      }
      ctx.setLineDash([]);

      // Date axis
      const datesEl = document.getElementById('arc-dates')!;
      datesEl.innerHTML = '';
      const labelEvery = Math.max(1, Math.ceil(n / 12));
      for (let i = 0; i < n; i += labelEvery) {
        const span = document.createElement('span');
        span.textContent = states[i].date.slice(5);
        span.style.left = (pad.left + i * xStep) + 'px';
        datesEl.appendChild(span);
      }
      if ((n - 1) % labelEvery !== 0) {
        const span = document.createElement('span');
        span.textContent = states[n - 1].date.slice(5);
        span.style.left = (pad.left + (n - 1) * xStep) + 'px';
        datesEl.appendChild(span);
      }

      // Hover
      canvas.onmousemove = (e) => {
        const rect = canvas.getBoundingClientRect();
        const mx = e.clientX - rect.left;
        const my = e.clientY - rect.top;

        // Check if near an arc endpoint
        let found = false;
        for (const arc of arcData) {
          if (!arc.isOpen) {
            const dx = mx - arc.resolveX, dy = my - baselineY;
            if (dx * dx + dy * dy < 100) {
              const tt = document.getElementById('tooltip')!;
              const label = arc.status === 'confirmed' ? '\u2713 confirmed' : '\u2717 falsified';
              tt.innerHTML = `<div style="margin-bottom:4px">${label}</div><div>${truncate(arc.hypothesis, 150)}</div>`;
              tt.style.display = 'block';
              tt.style.left = (e.clientX + 12) + 'px';
              tt.style.top = (e.clientY - 10) + 'px';
              found = true;
              break;
            }
          }
        }
        // Check if near an entry dot
        if (!found) {
          const col = Math.round((mx - pad.left) / xStep);
          if (col >= 0 && col < n && Math.abs(my - baselineY) < 15) {
            const state = states[col];
            const tt = document.getElementById('tooltip')!;
            tt.innerHTML = `<div class="tooltip-question">"${state.question}"</div><div class="tooltip-dim">${state.date}</div>`;
            tt.style.display = 'block';
            tt.style.left = (e.clientX + 12) + 'px';
            tt.style.top = (e.clientY - 10) + 'px';
            found = true;
          }
        }
        if (!found) document.getElementById('tooltip')!.style.display = 'none';
      };
      canvas.onmouseleave = () => { document.getElementById('tooltip')!.style.display = 'none'; };

      // Click entry dot
      canvas.onclick = (e) => {
        const rect = canvas.getBoundingClientRect();
        const mx = e.clientX - rect.left;
        const col = Math.round((mx - pad.left) / xStep);
        if (col >= 0 && col < n) selectEntry(col);
      };
    }

    // ---- Recent calls ----
    function renderCalls(preds: any[]) {
      const resolved = preds
        .filter(p => p.status === 'confirmed' || p.status === 'falsified')
        .sort((a, b) => (b.dttm_graded_utc || '').localeCompare(a.dttm_graded_utc || ''))
        .slice(0, 6);

      const el = document.getElementById('calls-list')!;
      if (resolved.length === 0) {
        el.innerHTML = '<div style="color:var(--ob-text-dim);font-size:10px;">No predictions resolved yet.</div>';
        return;
      }
      el.innerHTML = resolved.map(p => {
        const cls = p.status === 'confirmed' ? 'call-badge-confirmed' : 'call-badge-falsified';
        return `<div class="call-card">
          <div class="call-header">
            <div class="call-hypothesis">${p.hypothesis}</div>
            <span class="call-badge ${cls}">${p.status}</span>
          </div>
          <div class="call-meta">predicted ${p.origin_date || ''} &middot; resolved ${(p.dttm_graded_utc || '').slice(0, 10)}</div>
          ${p.grade_rationale ? `<div class="call-rationale">${truncate(p.grade_rationale, 200)}</div>` : ''}
        </div>`;
      }).join('');
    }

    // ---- Theories ----
    function renderTheories(theories: any[]) {
      if (!theories || theories.length === 0) return;
      document.getElementById('section-theories')!.style.display = '';
      document.getElementById('theories-list')!.innerHTML = theories.map(t => {
        const pm = t.alpha / (t.alpha + t.beta);
        const pct = (pm * 100).toFixed(0) + '%';
        const barW = Math.round(pm * 100);
        const statusCls = `theory-${t.status}`;
        const barColor = t.status === 'retired' ? 'var(--ob-falsified)' : 'var(--ob-theory-active)';
        const parts = t.theory_key.split(':');
        const name = parts.length === 2 ? parts[1].replace(/_/g, ' ') : t.theory_key.replace(/_/g, ' ');
        const frame = parts.length === 2 ? ` (frame ${parts[0]})` : '';
        return `<div class="theory-card">
          <div class="theory-header">
            <span class="theory-name">${name}<span style="color:var(--ob-text-dim)">${frame}</span></span>
            <span class="theory-status ${statusCls}">${t.status}</span>
          </div>
          <div class="theory-desc">${t.description}</div>
          <div class="theory-bar-wrap">
            <div class="theory-bar-track"><div class="theory-bar-fill" style="width:${barW}%;background:${barColor}"></div></div>
            <span class="theory-bar-label">${pct} after ${t.total_predictions}</span>
          </div>
        </div>`;
      }).join('');
    }

    // ---- Sparklines ----
    const sparkHitTargets: Map<string, Array<{ x: number; idx: number; value: number }>> = new Map();

    function drawAllSparklines(states: EntryState[]) {
      const stack = document.getElementById('sparkline-stack')!;
      // Only rebuild DOM if empty
      if (stack.children.length === 0) {
        for (const dim of DIMS) {
          const row = document.createElement('div');
          row.className = 'sparkline-row';
          const label = document.createElement('span');
          label.className = 'dim-label';
          label.textContent = dim;
          const canvas = document.createElement('canvas');
          canvas.className = 'sparkline-canvas';
          canvas.id = `spark-${dim}`;
          const val = document.createElement('span');
          val.className = 'dim-value';
          val.id = `sparkval-${dim}`;
          row.appendChild(label);
          row.appendChild(canvas);
          row.appendChild(val);
          stack.appendChild(row);

          canvas.addEventListener('click', (e) => {
            const targets = sparkHitTargets.get(dim);
            if (!targets) return;
            const rect = canvas.getBoundingClientRect();
            const mx = e.clientX - rect.left;
            let best = targets[0], bestD = Infinity;
            for (const t of targets) { const d = Math.abs(mx - t.x); if (d < bestD) { bestD = d; best = t; } }
            if (bestD < 30) selectEntry(best.idx);
          });

          canvas.addEventListener('mousemove', (e) => {
            const targets = sparkHitTargets.get(dim);
            if (!targets) return;
            const rect = canvas.getBoundingClientRect();
            const mx = e.clientX - rect.left;
            let best = targets[0], bestD = Infinity;
            for (const t of targets) { const d = Math.abs(mx - t.x); if (d < bestD) { bestD = d; best = t; } }
            if (bestD < 20) {
              const state = states[best.idx];
              const tt = document.getElementById('tooltip')!;
              tt.innerHTML = `<div class="tooltip-question">"${state.question}"</div><div class="tooltip-dim">${dim}: ${best.value >= 0 ? '+' : ''}${best.value.toFixed(2)}\u03c3 &middot; ${state.date.slice(5)}</div>`;
              tt.style.display = 'block';
              tt.style.left = (e.clientX + 12) + 'px';
              tt.style.top = (e.clientY - 10) + 'px';
            } else {
              document.getElementById('tooltip')!.style.display = 'none';
            }
          });
          canvas.addEventListener('mouseleave', () => { document.getElementById('tooltip')!.style.display = 'none'; });
        }
      }

      for (const dim of DIMS) {
        drawSparkline(document.getElementById(`spark-${dim}`) as HTMLCanvasElement, dim, states);
      }
    }

    function drawSparkline(canvas: HTMLCanvasElement, dim: string, states: EntryState[]) {
      const rect = canvas.getBoundingClientRect();
      const dpr = window.devicePixelRatio || 1;
      canvas.width = rect.width * dpr;
      canvas.height = rect.height * dpr;
      const ctx = canvas.getContext('2d')!;
      ctx.scale(dpr, dpr);

      const w = rect.width, h = rect.height;
      const pad = { left: 4, right: 4, top: 6, bottom: 6 };
      const plotW = w - pad.left - pad.right;
      const plotH = h - pad.top - pad.bottom;

      const values = states.map(s => (s as any)[dim] as number);
      const maxAbs = Math.max(3, ...values.map(Math.abs));
      const xStep = states.length > 1 ? plotW / (states.length - 1) : plotW;
      const toY = (v: number) => pad.top + plotH / 2 - (v / maxAbs) * (plotH / 2);
      const toX = (i: number) => pad.left + i * xStep;

      // Zero line
      ctx.strokeStyle = cssVar('--ob-spark-zero');
      ctx.lineWidth = 1;
      ctx.beginPath(); ctx.moveTo(pad.left, toY(0)); ctx.lineTo(w - pad.right, toY(0)); ctx.stroke();

      // +/- 1σ refs
      ctx.strokeStyle = cssVar('--ob-spark-ref');
      ctx.setLineDash([2, 4]);
      for (const ref of [1, -1]) {
        ctx.beginPath(); ctx.moveTo(pad.left, toY(ref)); ctx.lineTo(w - pad.right, toY(ref)); ctx.stroke();
      }
      ctx.setLineDash([]);

      // Line
      ctx.strokeStyle = cssVar('--ob-spark-line');
      ctx.lineWidth = 1.5;
      ctx.beginPath();
      for (let i = 0; i < values.length; i++) {
        const x = toX(i), y = toY(values[i]);
        i === 0 ? ctx.moveTo(x, y) : ctx.lineTo(x, y);
      }
      ctx.stroke();

      // Dots + hit targets
      const targets: Array<{ x: number; idx: number; value: number }> = [];
      const dotFill = cssVar('--ob-spark-dot');
      for (let i = 0; i < values.length; i++) {
        const x = toX(i), y = toY(values[i]);
        ctx.fillStyle = dotFill;
        ctx.beginPath(); ctx.arc(x, y, 2.5, 0, Math.PI * 2); ctx.fill();
        targets.push({ x, idx: i, value: values[i] });
      }
      sparkHitTargets.set(dim, targets);

      // Current value label
      const latest = values[values.length - 1];
      const valEl = document.getElementById(`sparkval-${dim}`)!;
      valEl.textContent = (latest >= 0 ? '+' : '') + latest.toFixed(2);
      valEl.style.color = cssVar('--ob-spark-line');
    }

    // ---- Heat strip ----
    function drawHeatStrip(states: EntryState[]) {
      const labelsEl = document.getElementById('heatstrip-labels')!;
      labelsEl.innerHTML = DIMS.map(d => `<div class="heatstrip-label">${d}</div>`).join('');

      const canvas = document.getElementById('heatstrip-canvas') as HTMLCanvasElement;
      const wrap = canvas.parentElement!;
      const wrapW = wrap.getBoundingClientRect().width;
      const rowH = 24;
      const totalH = DIMS.length * rowH;

      const dpr = window.devicePixelRatio || 1;
      canvas.width = wrapW * dpr;
      canvas.height = totalH * dpr;
      canvas.style.width = wrapW + 'px';
      canvas.style.height = totalH + 'px';

      const ctx = canvas.getContext('2d')!;
      ctx.scale(dpr, dpr);

      const n = states.length;
      if (n === 0) return;
      const cellW = wrapW / n;

      const posR = cssVarNum('--ob-heat-pos-r'), posG = cssVarNum('--ob-heat-pos-g'), posB = cssVarNum('--ob-heat-pos-b');
      const negR = cssVarNum('--ob-heat-neg-r'), negG = cssVarNum('--ob-heat-neg-g'), negB = cssVarNum('--ob-heat-neg-b');
      const neutralColor = cssVar('--ob-heat-neutral');

      for (let row = 0; row < DIMS.length; row++) {
        const dim = DIMS[row];
        for (let col = 0; col < n; col++) {
          const val = (states[col] as any)[dim] as number;
          const x = col * cellW, y = row * rowH;
          const absVal = Math.min(Math.abs(val), 3);
          const t = absVal / 3;

          if (Math.abs(val) < 0.05) {
            ctx.fillStyle = neutralColor;
          } else if (val > 0) {
            ctx.fillStyle = `rgba(${posR}, ${posG}, ${posB}, ${0.2 + t * 0.8})`;
          } else {
            ctx.fillStyle = `rgba(${negR}, ${negG}, ${negB}, ${0.2 + t * 0.8})`;
          }
          ctx.fillRect(x, y, cellW + 0.5, rowH);

          ctx.strokeStyle = cssVar('--ob-bg');
          ctx.lineWidth = 0.5;
          ctx.strokeRect(x, y, cellW + 0.5, rowH);
        }
      }

      if (selectedIdx !== null) {
        ctx.strokeStyle = cssVar('--ob-entry-border');
        ctx.lineWidth = 2;
        ctx.strokeRect(selectedIdx * cellW, 0, cellW, totalH);
      }

      // Date axis
      const datesEl = document.getElementById('heatstrip-dates')!;
      datesEl.innerHTML = '';
      const labelEvery = Math.max(1, Math.ceil(n / 12));
      for (let i = 0; i < n; i += labelEvery) {
        const span = document.createElement('span');
        span.textContent = states[i].date.slice(5);
        span.style.left = (i * cellW) + 'px';
        datesEl.appendChild(span);
      }
      if ((n - 1) % labelEvery !== 0) {
        const span = document.createElement('span');
        span.textContent = states[n - 1].date.slice(5);
        span.style.left = ((n - 1) * cellW) + 'px';
        datesEl.appendChild(span);
      }

      canvas.onmousemove = (e) => {
        const rect = canvas.getBoundingClientRect();
        const col = Math.floor((e.clientX - rect.left) / cellW);
        const row = Math.floor((e.clientY - rect.top) / rowH);
        if (col >= 0 && col < n && row >= 0 && row < DIMS.length) {
          const state = states[col];
          const dim = DIMS[row];
          const val = (state as any)[dim] as number;
          const tt = document.getElementById('tooltip')!;
          tt.innerHTML = `<div class="tooltip-question">"${state.question}"</div><div class="tooltip-dim">${dim}: ${val >= 0 ? '+' : ''}${val.toFixed(2)}\u03c3 &middot; ${state.date.slice(5)}</div>`;
          tt.style.display = 'block';
          tt.style.left = (e.clientX + 12) + 'px';
          tt.style.top = (e.clientY - 10) + 'px';
        } else {
          document.getElementById('tooltip')!.style.display = 'none';
        }
      };
      canvas.onmouseleave = () => { document.getElementById('tooltip')!.style.display = 'none'; };
      canvas.onclick = (e) => {
        const rect = canvas.getBoundingClientRect();
        const col = Math.floor((e.clientX - rect.left) / cellW);
        if (col >= 0 && col < n) selectEntry(col);
      };
    }

    // ---- Discoveries ----
    function renderDiscoveries(discoveries: any[]) {
      if (!discoveries || discoveries.length === 0) return;
      document.getElementById('section-discoveries')!.style.display = '';
      document.getElementById('discoveries-list')!.innerHTML = discoveries.map(d =>
        `<div class="discovery ${d.strength === 'strong' ? 'discovery-strong' : ''}">
          ${d.text}
          <div class="discovery-evidence">${d.evidence}</div>
        </div>`
      ).join('');
    }

    // ---- Entry selection ----
    async function selectEntry(idx: number) {
      selectedIdx = idx;
      const state = allStates[idx];
      drawHeatStrip(allStates);

      const panel = document.getElementById('entry-panel')!;
      panel.classList.add('open');
      document.getElementById('entry-panel-date')!.textContent = state.date;
      document.getElementById('entry-panel-question')!.textContent = state.question;
      document.getElementById('entry-panel-body')!.innerHTML = '<div style="color:var(--ob-text-dim);font-size:10px;">loading...</div>';

      (document.getElementById('entry-prev') as HTMLButtonElement).disabled = idx <= 0;
      (document.getElementById('entry-next') as HTMLButtonElement).disabled = idx >= allStates.length - 1;

      try {
        const res = await fetch(`/api/observatory/entry/${state.response_id}`);
        if (!res.ok) throw new Error('fail');
        renderEntryPanel(await res.json());
      } catch {
        document.getElementById('entry-panel-body')!.innerHTML = '<div style="color:var(--ob-text-dim);">could not load</div>';
      }
      panel.scrollIntoView({ behavior: 'smooth', block: 'nearest' });
    }

    function renderEntryPanel(data: any) {
      const body = document.getElementById('entry-panel-body')!;
      let html = '';
      if (data.observation) {
        html += '<div class="entry-section-label">observation</div>';
        html += parseFrames(data.observation.observation_text).map(f =>
          `<div class="frame-card ${f.cls}"><div class="frame-label ${f.labelCls}">${f.label}</div>${f.body}</div>`
        ).join('');
      }
      if (data.predictions && data.predictions.length > 0) {
        html += '<div class="entry-section-label">predictions from this entry</div>';
        html += data.predictions.map((p: any) =>
          `<div class="prediction-card">
            <div class="prediction-header">
              <span class="prediction-hypothesis">${p.hypothesis}</span>
              <span class="status-badge status-${p.statusCode}">${p.statusCode}</span>
            </div>
            ${p.favoredFrame ? `<div class="prediction-meta">Frame ${p.favoredFrame}${p.targetTopic ? ' \u00b7 ' + p.targetTopic : ''}</div>` : ''}
            ${p.gradeRationale ? `<div class="prediction-rationale">${p.gradeRationale}</div>` : ''}
          </div>`
        ).join('');
      }
      if (data.suppressedQuestion) {
        html += `<div class="suppressed-block">
          <div style="font-style:normal;color:var(--ob-text-dim);font-size:9px;letter-spacing:0.12em;text-transform:uppercase;margin-bottom:6px;">what alice wanted to ask but didn't</div>
          ${data.suppressedQuestion.suppressed_text}
        </div>`;
      }
      if (data.entryState) {
        html += '<div class="entry-section-label">behavioral shape</div>';
        html += '<div class="entry-radar-wrap"><canvas id="entry-radar" width="280" height="280"></canvas></div>';
      }
      body.innerHTML = html;
      if (data.entryState) drawMiniRadar(data.entryState);
    }

    function drawMiniRadar(es: any) {
      const canvas = document.getElementById('entry-radar') as HTMLCanvasElement;
      if (!canvas) return;
      const dpr = window.devicePixelRatio || 1;
      const size = 280;
      canvas.width = size * dpr; canvas.height = size * dpr;
      canvas.style.width = size + 'px'; canvas.style.height = size + 'px';
      const ctx = canvas.getContext('2d')!;
      ctx.scale(dpr, dpr);

      const cx = size / 2, cy = size / 2, maxR = 110;
      const n = DIMS.length, step = (2 * Math.PI) / n, maxZ = 3;
      const toR = (z: number) => ((z + maxZ) / (2 * maxZ)) * maxR;

      for (const ring of [-2, -1, 0, 1, 2]) {
        const r = toR(ring);
        ctx.strokeStyle = ring === 0 ? cssVar('--ob-border') : cssVar('--ob-border-subtle');
        ctx.lineWidth = ring === 0 ? 1 : 0.5;
        ctx.beginPath();
        for (let i = 0; i <= n; i++) {
          const a = -Math.PI / 2 + i * step;
          i === 0 ? ctx.moveTo(cx + Math.cos(a) * r, cy + Math.sin(a) * r) : ctx.lineTo(cx + Math.cos(a) * r, cy + Math.sin(a) * r);
        }
        ctx.stroke();
      }
      for (let i = 0; i < n; i++) {
        const a = -Math.PI / 2 + i * step;
        ctx.strokeStyle = cssVar('--ob-border-subtle'); ctx.lineWidth = 0.5;
        ctx.beginPath(); ctx.moveTo(cx, cy);
        ctx.lineTo(cx + Math.cos(a) * maxR, cy + Math.sin(a) * maxR); ctx.stroke();
        ctx.fillStyle = cssVar('--ob-text-faint'); ctx.font = '8px SF Mono, monospace';
        ctx.textAlign = 'center'; ctx.textBaseline = 'middle';
        ctx.fillText(DIMS[i], cx + Math.cos(a) * (maxR + 14), cy + Math.sin(a) * (maxR + 14));
      }
      const vals = DIMS.map(d => es[d] as number);
      ctx.fillStyle = 'rgba(58,110,165,0.12)'; ctx.strokeStyle = cssVar('--ob-spark-line'); ctx.lineWidth = 1.5;
      ctx.beginPath();
      for (let i = 0; i < n; i++) {
        const a = -Math.PI / 2 + i * step;
        const r = toR(Math.max(-maxZ, Math.min(maxZ, vals[i])));
        i === 0 ? ctx.moveTo(cx + Math.cos(a) * r, cy + Math.sin(a) * r) : ctx.lineTo(cx + Math.cos(a) * r, cy + Math.sin(a) * r);
      }
      ctx.closePath(); ctx.fill(); ctx.stroke();
      for (let i = 0; i < n; i++) {
        const a = -Math.PI / 2 + i * step;
        const r = toR(Math.max(-maxZ, Math.min(maxZ, vals[i])));
        ctx.fillStyle = cssVar('--ob-spark-dot'); ctx.beginPath();
        ctx.arc(cx + Math.cos(a) * r, cy + Math.sin(a) * r, 2.5, 0, Math.PI * 2); ctx.fill();
      }
    }

    function parseFrames(text: string) {
      const frames: Array<{ label: string; cls: string; labelCls: string; body: string }> = [];
      const pats = [
        { marker: '**FRAME A', label: 'Frame A \u2014 Charitable', cls: 'frame-card-a', labelCls: 'frame-label-a' },
        { marker: '**FRAME B', label: 'Frame B \u2014 Avoidance', cls: 'frame-card-b', labelCls: 'frame-label-b' },
        { marker: '**FRAME C', label: 'Frame C \u2014 Mundane', cls: 'frame-card-c', labelCls: 'frame-label-c' },
      ];
      for (let i = 0; i < pats.length; i++) {
        const idx = text.indexOf(pats[i].marker);
        if (idx === -1) continue;
        let end = text.length;
        for (let j = i + 1; j < pats.length; j++) { const ni = text.indexOf(pats[j].marker); if (ni !== -1) { end = ni; break; } }
        let body = text.slice(idx, end).trim();
        const ci = body.indexOf(':');
        if (ci !== -1) { body = body.slice(ci + 1).trim().replace(/^\*\*\s*/, ''); }
        frames.push({ ...pats[i], body });
      }
      if (frames.length === 0) frames.push({ label: 'Observation', cls: '', labelCls: '', body: text });
      return frames;
    }

    function truncate(s: string, n: number): string {
      return s.length > n ? s.slice(0, n) + '\u2026' : s;
    }

    // ---- Load ----
    async function load() {
      const [statesRes, predsRes, couplingRes, synthRes] = await Promise.all([
        fetch('/api/observatory/states'),
        fetch('/api/observatory/predictions'),
        fetch('/api/observatory/coupling'),
        fetch('/api/observatory/synthesis'),
      ]);

      const { states } = await statesRes.json();
      const { predictions } = await predsRes.json();
      const coupling = await couplingRes.json();
      const synthesis = await synthRes.json();

      allStates = states;
      allPredictions = predictions;

      renderScoreboard(predictions, states.length);
      drawArcTimeline(states, predictions);
      renderCalls(predictions);
      renderTheories(coupling.theories);
      drawAllSparklines(states);
      drawHeatStrip(states);
      renderDiscoveries(synthesis.discoveries);

      document.getElementById('loading')!.style.display = 'none';
      document.getElementById('main')!.style.display = '';
    }

    load();

    // Controls
    document.getElementById('entry-panel-close')!.onclick = () => {
      document.getElementById('entry-panel')!.classList.remove('open');
      selectedIdx = null; drawHeatStrip(allStates);
    };
    document.getElementById('entry-prev')!.onclick = () => { if (selectedIdx !== null && selectedIdx > 0) selectEntry(selectedIdx - 1); };
    document.getElementById('entry-next')!.onclick = () => { if (selectedIdx !== null && selectedIdx < allStates.length - 1) selectEntry(selectedIdx + 1); };
    document.addEventListener('keydown', (e) => {
      if (e.key === 'Escape') {
        document.getElementById('entry-panel')!.classList.remove('open');
        selectedIdx = null; drawHeatStrip(allStates);
      } else if (e.key === 'ArrowLeft' && selectedIdx !== null && selectedIdx > 0) selectEntry(selectedIdx - 1);
      else if (e.key === 'ArrowRight' && selectedIdx !== null && selectedIdx < allStates.length - 1) selectEntry(selectedIdx + 1);
    });

    let resizeTimer: number;
    window.addEventListener('resize', () => {
      clearTimeout(resizeTimer);
      resizeTimer = setTimeout(() => {
        if (allStates.length > 0) {
          drawArcTimeline(allStates, allPredictions);
          drawAllSparklines(allStates);
          drawHeatStrip(allStates);
        }
      }, 100);
    });
  </script>
</body>
</html>
