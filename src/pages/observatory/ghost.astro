---
/**
 * Observatory · Ghost in the Shell
 *
 * Reconstruction residual view. The ghost is a Markov avatar that writes
 * alongside you using your own statistical profile. Everything it gets
 * right is pattern. Everything it gets wrong is cognition.
 *
 * Shows: convergence trajectory, per-family norms, calibration vs journal
 * gap, perplexity comparison, PE spectrum residuals, per-signal breakdown.
 */
import '../../styles/styObservatory.css';
import ObsToolbar from '../../components/cmpObsToolbar.astro';
---
<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Ghost in the Shell · Observatory · Alice</title>
    <script is:inline>
      (function () {
        var saved = localStorage.getItem('alice-theme');
        var t = saved || (window.matchMedia('(prefers-color-scheme: dark)').matches ? 'dark' : 'light');
        document.documentElement.setAttribute('data-theme', t);
        document.addEventListener('DOMContentLoaded', function () {
          var btn = document.getElementById('obs-theme-toggle');
          if (!btn) return;
          btn.textContent = t === 'dark' ? '\u2600' : '\u263E';
          btn.addEventListener('click', function () {
            var cur = document.documentElement.getAttribute('data-theme');
            var next = cur === 'dark' ? 'light' : 'dark';
            document.documentElement.setAttribute('data-theme', next);
            localStorage.setItem('alice-theme', next);
            btn.textContent = next === 'dark' ? '\u2600' : '\u263E';
          });
        });
      })();
    </script>
    <style is:global>
      .ghost-chart {
        width: 100%;
        height: 140px;
        display: block;
      }
      .ghost-chart.tall {
        height: 200px;
      }
      .chart-row {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 1rem;
      }
      .chart-row.three {
        grid-template-columns: 1fr 1fr 1fr;
      }
      @media (max-width: 820px) {
        .chart-row, .chart-row.three { grid-template-columns: 1fr; }
      }
      .chart-panel {
        background: var(--bg-panel);
        border: 1px solid var(--border);
        border-radius: 2px;
        padding: 1rem 1.25rem 0.75rem;
        margin-bottom: 0.5rem;
      }
      .chart-panel h3 {
        font-family: var(--mono);
        font-size: 10px;
        font-weight: 500;
        letter-spacing: 0.16em;
        text-transform: uppercase;
        color: var(--text-faint);
        margin: 0 0 0.5rem;
      }
      .chart-panel .latest-reading {
        font-family: var(--mono);
        font-size: 11px;
        color: var(--text-muted);
        margin-top: 0.25rem;
        letter-spacing: 0.08em;
      }
      .chart-panel .latest-reading .val {
        color: var(--text);
        font-weight: 500;
      }
      .section-label {
        font-family: var(--mono);
        font-size: 10px;
        font-weight: 500;
        letter-spacing: 0.2em;
        text-transform: uppercase;
        color: var(--text-faint);
        margin: 2rem 0 0.75rem;
        padding-bottom: 0.5rem;
        border-bottom: 1px solid var(--border);
      }
      .variant-tab {
        font-family: var(--mono);
        font-size: 10px;
        font-weight: 500;
        letter-spacing: 0.14em;
        text-transform: uppercase;
        color: var(--text-faint);
        text-decoration: none;
        padding: 0.4rem 0.75rem;
        margin-right: 0.25rem;
        border-radius: 2px;
        transition: color 0.15s, background 0.15s;
      }
      .variant-tab:hover {
        color: var(--text-muted);
        background: var(--bg-panel);
      }
      .variant-tab.active {
        color: var(--text);
        background: var(--bg-panel);
        border: 1px solid var(--border);
      }
      .insufficient {
        font-family: var(--sans);
        font-size: 13px;
        color: var(--text-muted);
        padding: 2rem 0;
      }
      .legend {
        display: flex;
        gap: 1.2rem;
        margin-top: 0.4rem;
        font-family: var(--mono);
        font-size: 9px;
        letter-spacing: 0.12em;
        text-transform: uppercase;
        color: var(--text-faint);
      }
      .legend-dot {
        display: inline-block;
        width: 8px;
        height: 8px;
        border-radius: 50%;
        margin-right: 4px;
        vertical-align: middle;
      }
      .signal-table td.signal-name {
        font-family: var(--mono);
        font-size: 10px;
        letter-spacing: 0.06em;
        color: var(--text-muted);
      }
      .signal-table td.residual-val {
        font-family: var(--mono);
        font-size: 11px;
        font-variant-numeric: tabular-nums;
      }
      .signal-table .family-header td {
        font-family: var(--mono);
        font-size: 9px;
        font-weight: 500;
        letter-spacing: 0.16em;
        text-transform: uppercase;
        color: var(--text-faint);
        padding-top: 1rem;
      }
    </style>
  </head>
  <body>
    <div class="frame">
      <header>
        <h1>Ghost in the Shell</h1>
        <nav>
          <a href="/observatory">overview</a>
          <a href="/observatory/trajectory">trajectory</a>
          <a href="/observatory/scales">scales</a>
          <a href="/observatory/ghost" class="active">ghost</a>
          <a href="/">→ alice</a>
          <a href="#" data-logout>logout</a>
          <button class="obs-theme-toggle" id="obs-theme-toggle" aria-label="Toggle theme"></button>
        </nav>
      </header>

      <ObsToolbar />

      <div class="meta-row" id="meta-row">
        <span id="counts">loading…</span>
      </div>

      <nav id="variant-tabs" style="display:none; margin-bottom: 1.5rem; border-bottom: 1px solid var(--border); padding-bottom: 0.5rem;">
        <a href="#baseline" class="variant-tab active" data-variant="1">BASELINE</a>
        <a href="#conditional" class="variant-tab" data-variant="2">CONDITIONAL</a>
        <a href="#copula" class="variant-tab" data-variant="3">COPULA</a>
        <a href="#ppm" class="variant-tab" data-variant="4">PPM</a>
        <a href="#full" class="variant-tab" data-variant="5">FULL</a>
        <a href="#comparison" class="variant-tab" data-variant="0">COMPARISON</a>
      </nav>

      <div id="ghost-content">
        <div class="empty">loading…</div>
      </div>
    </div>

    <script type="module">
      function resolveCssVar(el, v) {
        return getComputedStyle(el).getPropertyValue(v.replace('var(', '').replace(')', '').trim()) || v;
      }

      function fmtVal(v, decimals = 2) {
        if (v == null || !Number.isFinite(v)) return '—';
        return Number(v).toFixed(decimals);
      }

      // ── Chart: single line (raw values, mean reference) ──────────────

      function drawRawChart(canvas, values, color, labels) {
        const dpr = window.devicePixelRatio || 1;
        const rect = canvas.getBoundingClientRect();
        const w = rect.width, h = rect.height;
        canvas.width = w * dpr;
        canvas.height = h * dpr;
        canvas.style.width = w + 'px';
        canvas.style.height = h + 'px';
        const ctx = canvas.getContext('2d');
        ctx.scale(dpr, dpr);

        const colBorder = resolveCssVar(canvas, 'var(--border)');
        const colFaint = resolveCssVar(canvas, 'var(--text-faint)');
        const colLine = resolveCssVar(canvas, color);

        const padL = 44, padR = 8, padT = 8, padB = 20;
        const chartW = w - padL - padR, chartH = h - padT - padB;

        const valid = values.filter(v => v != null && Number.isFinite(v));
        if (valid.length === 0) return;
        const minV = Math.min(...valid), maxV = Math.max(...valid);
        const range = maxV - minV || 1;
        const yMin = minV - range * 0.1, yMax = maxV + range * 0.1;
        const yRange = yMax - yMin;

        // Mean reference line
        const meanV = valid.reduce((a,b) => a+b, 0) / valid.length;
        const meanY = padT + chartH * (1 - (meanV - yMin) / yRange);
        ctx.strokeStyle = colBorder;
        ctx.lineWidth = 0.5;
        ctx.setLineDash([3, 3]);
        ctx.beginPath();
        ctx.moveTo(padL, meanY);
        ctx.lineTo(padL + chartW, meanY);
        ctx.stroke();
        ctx.setLineDash([]);

        // Y-axis labels
        ctx.fillStyle = colFaint;
        ctx.font = '9px SF Mono, Menlo, monospace';
        ctx.textAlign = 'right';
        ctx.textBaseline = 'middle';
        const fmt = (v) => Math.abs(v) >= 100 ? Math.round(v) : v.toFixed(1);
        ctx.fillText(fmt(yMax), padL - 4, padT);
        ctx.fillText(fmt(yMin), padL - 4, padT + chartH);

        // Plot
        const pts = [];
        for (let i = 0; i < values.length; i++) {
          if (values[i] != null && Number.isFinite(values[i])) {
            const x = padL + (values.length === 1 ? chartW / 2 : (i / (values.length - 1)) * chartW);
            const y = padT + chartH * (1 - (values[i] - yMin) / yRange);
            pts.push({ x, y, i });
          }
        }
        if (pts.length === 1) {
          ctx.beginPath(); ctx.arc(pts[0].x, pts[0].y, 3, 0, Math.PI * 2);
          ctx.fillStyle = colLine; ctx.fill(); return;
        }
        if (pts.length < 2) return;

        // Fill area under curve
        ctx.beginPath();
        ctx.moveTo(pts[0].x, meanY);
        for (const p of pts) ctx.lineTo(p.x, p.y);
        ctx.lineTo(pts[pts.length - 1].x, meanY);
        ctx.closePath();
        ctx.fillStyle = colLine + '18';
        ctx.fill();

        // Stroke
        ctx.strokeStyle = colLine; ctx.lineWidth = 1.5; ctx.lineJoin = 'round';
        ctx.beginPath();
        for (let i = 0; i < pts.length; i++) {
          if (i === 0) ctx.moveTo(pts[i].x, pts[i].y);
          else ctx.lineTo(pts[i].x, pts[i].y);
        }
        ctx.stroke();

        // Dots
        for (const p of pts) {
          ctx.beginPath(); ctx.arc(p.x, p.y, 2.5, 0, Math.PI * 2);
          ctx.fillStyle = colLine; ctx.fill();
        }

        // Date labels
        if (labels && labels.length > 0) {
          ctx.fillStyle = colFaint; ctx.font = '9px SF Mono, Menlo, monospace';
          ctx.textAlign = 'left'; ctx.textBaseline = 'top';
          ctx.fillText(labels[0] || '', padL, padT + chartH + 4);
          if (labels.length > 1) {
            ctx.textAlign = 'right';
            ctx.fillText(labels[labels.length - 1] || '', padL + chartW, padT + chartH + 4);
          }
        }
      }

      // ── Chart: dual line (two series, same axes) ─────────────────────

      function drawDualChart(canvas, vals1, vals2, color1, color2, labels) {
        const dpr = window.devicePixelRatio || 1;
        const rect = canvas.getBoundingClientRect();
        const w = rect.width, h = rect.height;
        canvas.width = w * dpr;
        canvas.height = h * dpr;
        canvas.style.width = w + 'px';
        canvas.style.height = h + 'px';
        const ctx = canvas.getContext('2d');
        ctx.scale(dpr, dpr);

        const colBorder = resolveCssVar(canvas, 'var(--border)');
        const colFaint = resolveCssVar(canvas, 'var(--text-faint)');
        const col1 = resolveCssVar(canvas, color1);
        const col2 = resolveCssVar(canvas, color2);

        const padL = 44, padR = 8, padT = 8, padB = 20;
        const chartW = w - padL - padR, chartH = h - padT - padB;

        const all = [...vals1, ...vals2].filter(v => v != null && Number.isFinite(v));
        if (all.length === 0) return;
        const minV = Math.min(...all), maxV = Math.max(...all);
        const range = maxV - minV || 1;
        const yMin = minV - range * 0.1, yMax = maxV + range * 0.1;
        const yRange = yMax - yMin;

        // Y-axis labels
        ctx.fillStyle = colFaint;
        ctx.font = '9px SF Mono, Menlo, monospace';
        ctx.textAlign = 'right';
        ctx.textBaseline = 'middle';
        const fmt = (v) => Math.abs(v) >= 100 ? Math.round(v) : v.toFixed(1);
        ctx.fillText(fmt(yMax), padL - 4, padT);
        ctx.fillText(fmt(yMin), padL - 4, padT + chartH);

        function plotLine(values, col) {
          const pts = [];
          for (let i = 0; i < values.length; i++) {
            if (values[i] != null && Number.isFinite(values[i])) {
              const x = padL + (values.length === 1 ? chartW / 2 : (i / (values.length - 1)) * chartW);
              const y = padT + chartH * (1 - (values[i] - yMin) / yRange);
              pts.push({ x, y });
            }
          }
          if (pts.length === 1) {
            ctx.beginPath(); ctx.arc(pts[0].x, pts[0].y, 3, 0, Math.PI * 2);
            ctx.fillStyle = col; ctx.fill(); return;
          }
          if (pts.length < 2) return;

          ctx.strokeStyle = col; ctx.lineWidth = 1.5; ctx.lineJoin = 'round';
          ctx.beginPath();
          for (let i = 0; i < pts.length; i++) {
            if (i === 0) ctx.moveTo(pts[i].x, pts[i].y);
            else ctx.lineTo(pts[i].x, pts[i].y);
          }
          ctx.stroke();
          for (const p of pts) {
            ctx.beginPath(); ctx.arc(p.x, p.y, 2.5, 0, Math.PI * 2);
            ctx.fillStyle = col; ctx.fill();
          }
        }

        plotLine(vals1, col1);
        plotLine(vals2, col2);

        if (labels && labels.length > 0) {
          ctx.fillStyle = colFaint; ctx.font = '9px SF Mono, Menlo, monospace';
          ctx.textAlign = 'left'; ctx.textBaseline = 'top';
          ctx.fillText(labels[0] || '', padL, padT + chartH + 4);
          if (labels.length > 1) {
            ctx.textAlign = 'right';
            ctx.fillText(labels[labels.length - 1] || '', padL + chartW, padT + chartH + 4);
          }
        }
      }

      // ── Chart: PE spectrum (5 lines, one per order) ──────────────────

      function drawSpectrumChart(canvas, spectrumData, labels) {
        const dpr = window.devicePixelRatio || 1;
        const rect = canvas.getBoundingClientRect();
        const w = rect.width, h = rect.height;
        canvas.width = w * dpr;
        canvas.height = h * dpr;
        canvas.style.width = w + 'px';
        canvas.style.height = h + 'px';
        const ctx = canvas.getContext('2d');
        ctx.scale(dpr, dpr);

        const colBorder = resolveCssVar(canvas, 'var(--border)');
        const colFaint = resolveCssVar(canvas, 'var(--text-faint)');

        const padL = 44, padR = 8, padT = 8, padB = 20;
        const chartW = w - padL - padR, chartH = h - padT - padB;

        // spectrumData: array of arrays (one per session), each inner array has 5 values (orders 3-7)
        const allVals = spectrumData.flat().filter(v => v != null && Number.isFinite(v));
        if (allVals.length === 0) return;
        const minV = Math.min(...allVals), maxV = Math.max(...allVals);
        const range = maxV - minV || 0.01;
        const yMin = minV - range * 0.1, yMax = maxV + range * 0.1;
        const yRange = yMax - yMin;

        // Zero line
        if (yMin < 0 && yMax > 0) {
          const zeroY = padT + chartH * (1 - (0 - yMin) / yRange);
          ctx.strokeStyle = colBorder;
          ctx.lineWidth = 0.5;
          ctx.setLineDash([3, 3]);
          ctx.beginPath();
          ctx.moveTo(padL, zeroY);
          ctx.lineTo(padL + chartW, zeroY);
          ctx.stroke();
          ctx.setLineDash([]);
        }

        // Y-axis labels
        ctx.fillStyle = colFaint;
        ctx.font = '9px SF Mono, Menlo, monospace';
        ctx.textAlign = 'right';
        ctx.textBaseline = 'middle';
        ctx.fillText(yMax.toFixed(3), padL - 4, padT);
        ctx.fillText(yMin.toFixed(3), padL - 4, padT + chartH);

        // Order colors: gradient from warm to cool
        const orderColors = ['#b5603f', '#c9a55e', '#7a5a44', '#6b8e6b', '#7a5a7a'];
        const n = spectrumData.length;

        for (let order = 0; order < 5; order++) {
          const col = orderColors[order];
          const pts = [];
          for (let i = 0; i < n; i++) {
            const spec = spectrumData[i];
            if (spec && spec[order] != null && Number.isFinite(spec[order])) {
              const x = padL + (n === 1 ? chartW / 2 : (i / (n - 1)) * chartW);
              const y = padT + chartH * (1 - (spec[order] - yMin) / yRange);
              pts.push({ x, y });
            }
          }
          if (pts.length < 2) continue;

          ctx.strokeStyle = col;
          ctx.lineWidth = 1.2;
          ctx.lineJoin = 'round';
          ctx.globalAlpha = 0.8;
          ctx.beginPath();
          for (let i = 0; i < pts.length; i++) {
            if (i === 0) ctx.moveTo(pts[i].x, pts[i].y);
            else ctx.lineTo(pts[i].x, pts[i].y);
          }
          ctx.stroke();
          ctx.globalAlpha = 1;
        }

        if (labels && labels.length > 0) {
          ctx.fillStyle = colFaint; ctx.font = '9px SF Mono, Menlo, monospace';
          ctx.textAlign = 'left'; ctx.textBaseline = 'top';
          ctx.fillText(labels[0] || '', padL, padT + chartH + 4);
          if (labels.length > 1) {
            ctx.textAlign = 'right';
            ctx.fillText(labels[labels.length - 1] || '', padL + chartW, padT + chartH + 4);
          }
        }
      }

      // ── Chart: split series (journal vs calibration on same axes) ────

      function drawSplitChart(canvas, journalVals, journalIdx, calVals, calIdx, totalLen, labels) {
        const dpr = window.devicePixelRatio || 1;
        const rect = canvas.getBoundingClientRect();
        const w = rect.width, h = rect.height;
        canvas.width = w * dpr;
        canvas.height = h * dpr;
        canvas.style.width = w + 'px';
        canvas.style.height = h + 'px';
        const ctx = canvas.getContext('2d');
        ctx.scale(dpr, dpr);

        const colBorder = resolveCssVar(canvas, 'var(--border)');
        const colFaint = resolveCssVar(canvas, 'var(--text-faint)');
        const colAccent = resolveCssVar(canvas, 'var(--accent)');
        const colSemantic = resolveCssVar(canvas, 'var(--semantic)');

        const padL = 44, padR = 8, padT = 8, padB = 20;
        const chartW = w - padL - padR, chartH = h - padT - padB;

        const all = [...journalVals, ...calVals].filter(v => v != null && Number.isFinite(v));
        if (all.length === 0) return;
        const minV = Math.min(...all), maxV = Math.max(...all);
        const range = maxV - minV || 1;
        const yMin = minV - range * 0.15, yMax = maxV + range * 0.15;
        const yRange = yMax - yMin;

        // Y-axis
        ctx.fillStyle = colFaint;
        ctx.font = '9px SF Mono, Menlo, monospace';
        ctx.textAlign = 'right';
        ctx.textBaseline = 'middle';
        const fmt = (v) => Math.abs(v) >= 100 ? Math.round(v) : v.toFixed(1);
        ctx.fillText(fmt(yMax), padL - 4, padT);
        ctx.fillText(fmt(yMin), padL - 4, padT + chartH);

        // Mean lines
        function drawMean(vals, col) {
          const valid = vals.filter(v => v != null && Number.isFinite(v));
          if (valid.length === 0) return;
          const mean = valid.reduce((a,b) => a+b,0) / valid.length;
          const meanY = padT + chartH * (1 - (mean - yMin) / yRange);
          ctx.strokeStyle = col;
          ctx.lineWidth = 0.5;
          ctx.globalAlpha = 0.4;
          ctx.setLineDash([3, 3]);
          ctx.beginPath();
          ctx.moveTo(padL, meanY);
          ctx.lineTo(padL + chartW, meanY);
          ctx.stroke();
          ctx.setLineDash([]);
          ctx.globalAlpha = 1;
        }
        drawMean(journalVals, colAccent);
        drawMean(calVals, colSemantic);

        // Plot dots (no connecting lines, since series are interleaved)
        function plotDots(vals, indices, col) {
          for (let j = 0; j < vals.length; j++) {
            const v = vals[j];
            if (v == null || !Number.isFinite(v)) continue;
            const i = indices[j];
            const x = padL + (totalLen === 1 ? chartW / 2 : (i / (totalLen - 1)) * chartW);
            const y = padT + chartH * (1 - (v - yMin) / yRange);
            ctx.beginPath(); ctx.arc(x, y, 3.5, 0, Math.PI * 2);
            ctx.fillStyle = col; ctx.fill();
          }
        }

        plotDots(calVals, calIdx, colSemantic);
        plotDots(journalVals, journalIdx, colAccent);

        if (labels && labels.length > 0) {
          ctx.fillStyle = colFaint; ctx.font = '9px SF Mono, Menlo, monospace';
          ctx.textAlign = 'left'; ctx.textBaseline = 'top';
          ctx.fillText(labels[0] || '', padL, padT + chartH + 4);
          if (labels.length > 1) {
            ctx.textAlign = 'right';
            ctx.fillText(labels[labels.length - 1] || '', padL + chartW, padT + chartH + 4);
          }
        }
      }

      // ── Chart: grouped dot plot by category ──────────────────────────

      function drawGroupedDots(canvas, groups, yLabel) {
        const dpr = window.devicePixelRatio || 1;
        const rect = canvas.getBoundingClientRect();
        const w = rect.width, h = rect.height;
        canvas.width = w * dpr;
        canvas.height = h * dpr;
        canvas.style.width = w + 'px';
        canvas.style.height = h + 'px';
        const ctx = canvas.getContext('2d');
        ctx.scale(dpr, dpr);

        const colBorder = resolveCssVar(canvas, 'var(--border)');
        const colFaint = resolveCssVar(canvas, 'var(--text-faint)');
        const colText = resolveCssVar(canvas, 'var(--text-muted)');

        const padL = 44, padR = 12, padT = 12, padB = 28;
        const chartW = w - padL - padR, chartH = h - padT - padB;

        // groups: [{ label, values[], color, mean }]
        const allVals = groups.flatMap(g => g.values).filter(v => v != null && Number.isFinite(v));
        if (allVals.length === 0) return;
        const minV = Math.min(...allVals), maxV = Math.max(...allVals);
        const range = maxV - minV || 1;
        const yMin = minV - range * 0.15, yMax = maxV + range * 0.15;
        const yRange = yMax - yMin;

        // Y-axis
        ctx.fillStyle = colFaint;
        ctx.font = '9px SF Mono, Menlo, monospace';
        ctx.textAlign = 'right';
        ctx.textBaseline = 'middle';
        const fmt = (v) => Math.abs(v) >= 100 ? Math.round(v) : v.toFixed(1);
        ctx.fillText(fmt(yMax), padL - 4, padT);
        ctx.fillText(fmt(yMin), padL - 4, padT + chartH);

        const groupW = chartW / groups.length;

        for (let g = 0; g < groups.length; g++) {
          const group = groups[g];
          const cx = padL + groupW * g + groupW / 2;
          const col = resolveCssVar(canvas, group.color);

          // Mean line
          if (group.mean != null && Number.isFinite(group.mean)) {
            const meanY = padT + chartH * (1 - (group.mean - yMin) / yRange);
            ctx.strokeStyle = col;
            ctx.lineWidth = 1.5;
            ctx.globalAlpha = 0.4;
            ctx.beginPath();
            ctx.moveTo(cx - groupW * 0.3, meanY);
            ctx.lineTo(cx + groupW * 0.3, meanY);
            ctx.stroke();
            ctx.globalAlpha = 1;
          }

          // Dots (jitter horizontally)
          for (let i = 0; i < group.values.length; i++) {
            const v = group.values[i];
            if (v == null || !Number.isFinite(v)) continue;
            const jitter = (Math.random() - 0.5) * groupW * 0.3;
            const x = cx + jitter;
            const y = padT + chartH * (1 - (v - yMin) / yRange);
            ctx.beginPath();
            ctx.arc(x, y, 3.5, 0, Math.PI * 2);
            ctx.fillStyle = col;
            ctx.globalAlpha = 0.7;
            ctx.fill();
            ctx.globalAlpha = 1;
          }

          // Label
          ctx.fillStyle = colText;
          ctx.font = '10px SF Mono, Menlo, monospace';
          ctx.textAlign = 'center';
          ctx.textBaseline = 'top';
          ctx.fillText(group.label.toUpperCase(), cx, padT + chartH + 6);
        }
      }

      // ── Chart: scatter with continuous x ───────────────────────────────

      function drawScatter(canvas, points, xLabel, color) {
        const dpr = window.devicePixelRatio || 1;
        const rect = canvas.getBoundingClientRect();
        const w = rect.width, h = rect.height;
        canvas.width = w * dpr;
        canvas.height = h * dpr;
        canvas.style.width = w + 'px';
        canvas.style.height = h + 'px';
        const ctx = canvas.getContext('2d');
        ctx.scale(dpr, dpr);

        const colBorder = resolveCssVar(canvas, 'var(--border)');
        const colFaint = resolveCssVar(canvas, 'var(--text-faint)');
        const col = resolveCssVar(canvas, color);

        const padL = 44, padR = 12, padT = 12, padB = 28;
        const chartW = w - padL - padR, chartH = h - padT - padB;

        const xs = points.map(p => p.x).filter(v => v != null && Number.isFinite(v));
        const ys = points.map(p => p.y).filter(v => v != null && Number.isFinite(v));
        if (xs.length === 0 || ys.length === 0) return;

        const xMin = Math.min(...xs), xMax = Math.max(...xs);
        const yMin = Math.min(...ys), yMax = Math.max(...ys);
        const xRange = (xMax - xMin) || 0.01;
        const yRange = (yMax - yMin) || 1;
        const xPad = xRange * 0.1, yPad = yRange * 0.15;

        // Y-axis labels
        ctx.fillStyle = colFaint;
        ctx.font = '9px SF Mono, Menlo, monospace';
        ctx.textAlign = 'right';
        ctx.textBaseline = 'middle';
        ctx.fillText((yMax + yPad).toFixed(0), padL - 4, padT);
        ctx.fillText((yMin - yPad).toFixed(0), padL - 4, padT + chartH);

        // X-axis labels
        ctx.textAlign = 'left';
        ctx.textBaseline = 'top';
        ctx.fillText(xMin.toFixed(3), padL, padT + chartH + 6);
        ctx.textAlign = 'right';
        ctx.fillText(xMax.toFixed(3), padL + chartW, padT + chartH + 6);
        ctx.textAlign = 'center';
        ctx.fillText(xLabel, padL + chartW / 2, padT + chartH + 14);

        // Dots
        for (const p of points) {
          if (p.x == null || p.y == null || !Number.isFinite(p.x) || !Number.isFinite(p.y)) continue;
          const px = padL + ((p.x - (xMin - xPad)) / (xRange + 2 * xPad)) * chartW;
          const py = padT + chartH * (1 - (p.y - (yMin - yPad)) / (yRange + 2 * yPad));
          ctx.beginPath();
          ctx.arc(px, py, 4, 0, Math.PI * 2);
          ctx.fillStyle = col;
          ctx.globalAlpha = 0.65;
          ctx.fill();
          ctx.globalAlpha = 1;
        }
      }

