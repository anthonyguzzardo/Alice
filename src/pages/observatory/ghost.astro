          );
          drawRawChart(
            document.getElementById('chart-te-real'),
            teRealSafe,
            'var(--accent)',
            labels
          );
        }

        // ── Redraw all on resize ─────────────────────────────────────
        function drawAll() {
          drawRawChart(document.getElementById('chart-convergence'), sessions.map(s => s.totalL2), 'var(--accent)', labels);
          drawRawChart(document.getElementById('chart-dyn'), sessions.map(s => s.dynL2), 'var(--warn)', labels);
          drawRawChart(document.getElementById('chart-mot'), sessions.map(s => s.motL2), 'var(--negative)', labels);
          drawRawChart(document.getElementById('chart-sem'), sessions.map(s => s.semL2), 'var(--semantic)', labels);
          drawSplitChart(document.getElementById('chart-split'), journalVals, journalIdx, calVals, calIdx, sessions.length, labels);
          drawDualChart(document.getElementById('chart-perplexity'), sessions.map(s => s.realPerplexity), sessions.map(s => s.avatarPerplexity), 'var(--accent)', 'var(--negative)', labels);
          drawRawChart(document.getElementById('chart-perp-residual'), sessions.map(s => s.perplexityResidual), 'var(--negative)', labels);
          if (hasSpectrum) drawSpectrumChart(document.getElementById('chart-spectrum'), spectrumData, labels);
          if (hasTrigram) {
            drawDualChart(document.getElementById('chart-two-scale'), sessions.map(s => s.realPerplexity), sessions.map(s => s.selfPerplexity), 'var(--accent)', 'var(--positive)', labels);
            const perpRatio = sessions.map(s => (s.realPerplexity != null && s.selfPerplexity != null && s.selfPerplexity > 0) ? s.realPerplexity / s.selfPerplexity : null);
            drawRawChart(document.getElementById('chart-perp-ratio'), perpRatio, 'var(--warn)', labels);
          }
          if (teFinite.length > 0) {
            drawRawChart(document.getElementById('chart-te-residual'), sessions.map(s => (s.resTEDom != null && Number.isFinite(s.resTEDom)) ? s.resTEDom : null), 'var(--warn)', labels);
            drawRawChart(document.getElementById('chart-te-real'), sessions.map(s => (s.realTEDom != null && Number.isFinite(s.realTEDom)) ? s.realTEDom : null), 'var(--accent)', labels);
          }
        }

        let resizeTimer;
        window.addEventListener('resize', () => {
          clearTimeout(resizeTimer);
          resizeTimer = setTimeout(drawAll, 150);
        });

      } // end renderVariant

      // ── Tab switching ─────────────────────────────────────────────
      document.querySelectorAll('.variant-tab').forEach(tab => {
        tab.addEventListener('click', (e) => {
          e.preventDefault();
          document.querySelectorAll('.variant-tab').forEach(t => t.classList.remove('active'));
          tab.classList.add('active');
          const vid = parseInt(tab.dataset.variant, 10);
          activeVariant = vid;

          if (!allVariantData) return;

          if (vid === 0) {
            renderComparison(allVariantData);
          } else {
            const v = allVariantData.variants?.find(v => v.id === vid);
            if (v) {
              renderVariant(v.sessions, v.summary);
            } else {
              document.getElementById('ghost-content').innerHTML =
                '<div class="insufficient">No data for this variant yet.</div>';
            }
          }
        });
      });

      // ── Initial fetch ─────────────────────────────────────────────
      fetch(window.__obsUrl('/api/observatory/ghost?variant=all')).then(r => r.json()).then(data => {
        if (data.error) {
          document.getElementById('ghost-content').innerHTML = `<div class="empty">${data.error}</div>`;
          return;
        }

        allVariantData = data;

        // Show tabs if any variant has data
        const hasData = data.variants?.some(v => v.sessions.length > 0);
        if (hasData) {
          document.getElementById('variant-tabs').style.display = 'flex';
        }

        // Check hash for initial tab
        const hash = window.location.hash.replace('#', '');
        const hashMap = { baseline: 1, conditional: 2, copula: 3, ppm: 4, full: 5, comparison: 0 };
        if (hash && hashMap[hash] !== undefined) {
          activeVariant = hashMap[hash];
          document.querySelectorAll('.variant-tab').forEach(t => {
            t.classList.toggle('active', parseInt(t.dataset.variant, 10) === activeVariant);
          });
        }

        if (activeVariant === 0) {
          renderComparison(data);
        } else {
          const v = data.variants?.find(v => v.id === activeVariant);
          if (v && v.sessions.length > 0) {
            renderVariant(v.sessions, v.summary);
          } else {
            // Fall back to baseline
            const baseline = data.variants?.find(v => v.id === 1);
            if (baseline && baseline.sessions.length > 0) {
              renderVariant(baseline.sessions, baseline.summary);
            } else {
              document.getElementById('ghost-content').innerHTML =
                '<div class="insufficient">No reconstruction residuals yet. The ghost appears after your next session.</div>';
            }
          }
        }
      }).catch(err => {
        document.getElementById('ghost-content').innerHTML = `<div class="empty">failed to load: ${err?.message ?? err}</div>`;
      });

      // ── Difficulty-residual correlation (second fetch) ──────────────
      fetch(window.__obsUrl('/api/observatory/difficulty')).then(r => r.json()).then(data => {
        const el = document.getElementById('difficulty-section');
        if (!el || data.error) return;

        const { sessions: dSessions, summary: dSummary } = data;
        if (!dSessions || dSessions.length === 0) {
          el.innerHTML = `
            <div class="section-label">Adaptive difficulty · does harder questioning produce larger ghosts?</div>
            <p class="insufficient">Awaiting data. Difficulty classification will be logged with future question generations.</p>
          `;
          return;
        }

        const levels = ['low', 'moderate', 'high'];
        const levelColors = { low: 'var(--semantic)', moderate: 'var(--warn)', high: 'var(--negative)' };

        let dHtml = `
          <div class="section-label">Adaptive difficulty · does harder questioning produce larger ghosts?</div>
        `;

        // KPI row by difficulty level
        dHtml += `<div class="kpi-row" style="margin-bottom: 1rem;">`;
        for (const level of levels) {
          const s = dSummary[level];
          if (!s) {
            dHtml += `<div class="kpi"><div class="k">${level}</div><div class="v">—</div></div>`;
            continue;
          }
          dHtml += `
            <div class="kpi">
              <div class="k">${level} (n=${s.count})</div>
              <div class="v">${fmtVal(s.avgTotalL2, 1)}</div>
            </div>
          `;
        }
        dHtml += `</div>`;

        // Grouped dot plot: difficulty level -> total L2
        dHtml += `
          <div class="chart-row">
            <div class="chart-panel">
              <h3>Total L2 by difficulty level</h3>
              <canvas class="ghost-chart tall" id="chart-diff-group"></canvas>
            </div>
            <div class="chart-panel">
              <h3>MATTR vs total L2</h3>
              <canvas class="ghost-chart tall" id="chart-diff-mattr"></canvas>
            </div>
          </div>
        `;

        el.innerHTML = dHtml;

        // Grouped dot plot
        const groups = levels
          .filter(level => dSummary[level])
          .map(level => ({
            label: level,
            values: dSessions
              .filter(s => s.difficultyLevel === level)
              .map(s => s.totalL2)
              .filter(v => v != null && Number.isFinite(v)),
            color: levelColors[level],
            mean: dSummary[level]?.avgTotalL2 ?? null,
          }));
        if (groups.length > 0) {
          drawGroupedDots(document.getElementById('chart-diff-group'), groups);
        }

        // MATTR scatter
        const mattrPoints = dSessions
          .filter(s => s.difficultyInputs?.avgMATTR != null && s.totalL2 != null)
          .map(s => ({ x: s.difficultyInputs.avgMATTR, y: s.totalL2 }));
        if (mattrPoints.length > 0) {
          drawScatter(document.getElementById('chart-diff-mattr'), mattrPoints, 'MATTR', 'var(--accent)');
        }

      }).catch(() => {});
    </script>
  </body>
</html>
