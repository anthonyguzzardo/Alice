---
/**
 * Observatory · Coupling
 *
 * Emotion-behavior coupling stability analysis: rolling-window convergence
 * test for whether emotion → behavior couplings are a stable within-person
 * characteristic. Computed live from raw signals, not from frozen tables.
 */
import '../../styles/styObservatory.css';
import ObsToolbar from '../../components/cmpObsToolbar.astro';
---
<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Coupling · Observatory · Alice</title>
    <script is:inline>
      (function () {
        var saved = localStorage.getItem('alice-theme');
        var t = saved || (window.matchMedia('(prefers-color-scheme: dark)').matches ? 'dark' : 'light');
        document.documentElement.setAttribute('data-theme', t);
        document.addEventListener('DOMContentLoaded', function () {
          var btn = document.getElementById('obs-theme-toggle');
          if (!btn) return;
          btn.textContent = t === 'dark' ? '\u2600' : '\u263E';
          btn.addEventListener('click', function () {
            var cur = document.documentElement.getAttribute('data-theme');
            var next = cur === 'dark' ? 'light' : 'dark';
            document.documentElement.setAttribute('data-theme', next);
            localStorage.setItem('alice-theme', next);
            btn.textContent = next === 'dark' ? '\u2600' : '\u263E';
          });
        });
      })();
    </script>
  </head>
  <body>
    <div class="frame">
      <header>
        <h1>Observatory · Coupling</h1>
        <nav>
          <a href="/observatory">overview</a>
          <a href="/observatory/trajectory">trajectory</a>
          <a href="/observatory/scales">scales</a>
          <a href="/observatory/coupling" class="active">coupling</a>
          <a href="/observatory/ghost">ghost</a>
          <a href="/">→ alice</a>
          <a href="#" data-logout>logout</a>
          <button class="obs-theme-toggle" id="obs-theme-toggle" aria-label="Toggle theme"></button>
        </nav>
      </header>

      <ObsToolbar />

      <section class="panel" id="stability-section">
        <h2>Coupling stability · within-person convergence</h2>
        <div id="stability-content">loading…</div>
      </section>
    </div>

    <script type="module">
      function resolveCssVar(el, v) {
        return getComputedStyle(el).getPropertyValue(v.replace('var(', '').replace(')', '').trim()) || v;
      }

      function drawConvergenceChart(canvas, trajectories) {
        const dpr = window.devicePixelRatio || 1;
        const rect = canvas.getBoundingClientRect();
        const w = rect.width, h = rect.height;
        canvas.width = w * dpr;
        canvas.height = h * dpr;
        canvas.style.width = w + 'px';
        canvas.style.height = h + 'px';
        const ctx = canvas.getContext('2d');
        ctx.scale(dpr, dpr);

        const colBorder = resolveCssVar(canvas, '--border');
        const colFaint = resolveCssVar(canvas, '--text-faint');

        const padL = 44, padR = 12, padT = 12, padB = 24;
        const chartW = w - padL - padR, chartH = h - padT - padB;

        const allR = trajectories.flatMap(t => t.trajectory.map(p => Math.abs(p.r)));
        const allN = trajectories.flatMap(t => t.trajectory.map(p => p.n));
        if (allR.length === 0) return;

        const yMax = Math.min(1, Math.max(...allR) + 0.05);
        const yMin = Math.max(0, Math.min(...allR) - 0.05);
        const yRange = yMax - yMin || 0.1;
        const xMin = Math.min(...allN), xMax = Math.max(...allN);
        const xRange = xMax - xMin || 1;

        const threshY = padT + chartH * (1 - (0.3 - yMin) / yRange);
        ctx.strokeStyle = colBorder;
        ctx.lineWidth = 0.5;
        ctx.setLineDash([3, 3]);
        ctx.beginPath();
        ctx.moveTo(padL, threshY);
        ctx.lineTo(padL + chartW, threshY);
        ctx.stroke();
        ctx.setLineDash([]);

        ctx.fillStyle = colFaint;
        ctx.font = '9px SF Mono, Menlo, monospace';
        ctx.textAlign = 'right';
        ctx.textBaseline = 'middle';
        ctx.fillText(yMax.toFixed(2), padL - 4, padT);
        ctx.fillText(yMin.toFixed(2), padL - 4, padT + chartH);

        ctx.textAlign = 'left';
        ctx.textBaseline = 'top';
        ctx.fillText('n=' + xMin, padL, padT + chartH + 4);
        ctx.textAlign = 'right';
        ctx.fillText('n=' + xMax, padL + chartW, padT + chartH + 4);

        const colors = [
          '#b5603f', '#c9a55e', '#7a5a44', '#6b8e6b', '#7a5a7a',
          '#5a7a8e', '#8e6b5a', '#5a8e6b', '#8e5a7a', '#6b5a8e',
        ];

        for (let ti = 0; ti < trajectories.length; ti++) {
          const t = trajectories[ti];
          const col = colors[ti % colors.length];
          const pts = t.trajectory.map(p => ({
            x: padL + ((p.n - xMin) / xRange) * chartW,
            y: padT + chartH * (1 - (Math.abs(p.r) - yMin) / yRange),
          }));

          if (pts.length < 2) continue;

          ctx.strokeStyle = col;
          ctx.lineWidth = t.isStable ? 1.5 : 0.8;
          ctx.globalAlpha = t.isStable ? 0.9 : 0.4;
          ctx.lineJoin = 'round';
          ctx.beginPath();
          for (let i = 0; i < pts.length; i++) {
            if (i === 0) ctx.moveTo(pts[i].x, pts[i].y);
            else ctx.lineTo(pts[i].x, pts[i].y);
          }
          ctx.stroke();

          const last = pts[pts.length - 1];
          ctx.beginPath();
          ctx.arc(last.x, last.y, t.isStable ? 3 : 2, 0, Math.PI * 2);
          ctx.fillStyle = col;
          ctx.fill();
          ctx.globalAlpha = 1;
        }
      }

      fetch(window.__obsUrl('/api/observatory/coupling-stability')).then(r => r.json()).then(data => {
        const el = document.getElementById('stability-content');
        if (data.error) {
          el.innerHTML = `<div class="empty">${data.error}</div>`;
          return;
        }

        if (data.entryCount < 10) {
          el.innerHTML = `<div class="empty">Need at least 10 entries for stability analysis (have ${data.entryCount})</div>`;
          return;
        }

        if (data.totalPairs === 0) {
          el.innerHTML = `<div class="empty">No emotion→behavior couplings exceed threshold (r ≥ 0.3) at any window size. ${data.entryCount} entries analyzed across ${data.windowCount} windows.</div>`;
          return;
        }

        let html = '';

        html += `
          <div class="kpi-row" style="margin-bottom: 1rem;">
            <div class="kpi">
              <div class="k">entries analyzed</div>
              <div class="v">${data.entryCount}</div>
            </div>
            <div class="kpi">
              <div class="k">window sizes tested</div>
              <div class="v">${data.windowCount}</div>
            </div>
            <div class="kpi">
              <div class="k">stable / total pairs</div>
              <div class="v">${data.stableCount} / ${data.totalPairs}</div>
            </div>
            <div class="kpi">
              <div class="k">stability rate</div>
              <div class="v">${(data.stabilityRate * 100).toFixed(0)}%</div>
            </div>
          </div>
        `;

        const allTrajectories = [...(data.stable || []), ...(data.unstable || [])];
        html += `
          <div style="margin-bottom: 1rem;">
            <canvas id="chart-convergence-coupling" style="width:100%;height:200px;display:block;"></canvas>
            <div style="font-family:var(--mono);font-size:9px;letter-spacing:0.1em;color:var(--text-faint);margin-top:4px;">
              |r| over growing window size. Thick lines = stable (CV &lt; 0.5). Dashed = threshold (0.3).
            </div>
          </div>
        `;

        if (data.stable && data.stable.length > 0) {
          const rows = data.stable.map(p => {
            const sign = p.finalDirection > 0 ? '+' : '\u2212';
            const cls = p.finalDirection > 0 ? 'sign-pos' : 'sign-neg';
            const lag = p.finalLag === 0 ? 'concurrent' : `lag ${p.finalLag}`;
            return `<tr>
              <td>${p.emotionDim}</td>
              <td>\u2192</td>
              <td>${p.behaviorDim}</td>
              <td class="num ${cls}">${sign}${Math.abs(p.finalCorrelation).toFixed(2)}</td>
              <td>${lag}</td>
              <td class="num">${p.cv.toFixed(2)}</td>
              <td class="num">${p.trendSlope >= 0 ? '+' : ''}${p.trendSlope.toFixed(4)}</td>
            </tr>`;
          }).join('');
          html += `
            <h3 style="font-family:var(--mono);font-size:10px;letter-spacing:0.16em;text-transform:uppercase;color:var(--text-faint);margin:1rem 0 0.5rem;">Stable couplings (CV &lt; 0.5)</h3>
            <table>
              <thead><tr><th>emotion</th><th></th><th>behavior</th><th>r</th><th>lag</th><th>CV</th><th>trend</th></tr></thead>
              <tbody>${rows}</tbody>
            </table>
          `;
        }

        if (data.unstable && data.unstable.length > 0) {
          const rows = data.unstable.map(p => {
            const sign = p.finalDirection > 0 ? '+' : '\u2212';
            const cls = p.finalDirection > 0 ? 'sign-pos' : 'sign-neg';
            const lag = p.finalLag === 0 ? 'concurrent' : `lag ${p.finalLag}`;
            return `<tr>
              <td>${p.emotionDim}</td>
              <td>\u2192</td>
              <td>${p.behaviorDim}</td>
              <td class="num ${cls}">${sign}${Math.abs(p.finalCorrelation).toFixed(2)}</td>
              <td>${lag}</td>
              <td class="num">${p.cv.toFixed(2)}</td>
              <td class="num">${p.trendSlope >= 0 ? '+' : ''}${p.trendSlope.toFixed(4)}</td>
            </tr>`;
          }).join('');
          html += `
            <h3 style="font-family:var(--mono);font-size:10px;letter-spacing:0.16em;text-transform:uppercase;color:var(--text-faint);margin:1rem 0 0.5rem;">Unstable couplings (CV &ge; 0.5)</h3>
            <table>
              <thead><tr><th>emotion</th><th></th><th>behavior</th><th>r</th><th>lag</th><th>CV</th><th>trend</th></tr></thead>
              <tbody>${rows}</tbody>
            </table>
          `;
        }

        el.innerHTML = html;

        if (allTrajectories.length > 0) {
          drawConvergenceChart(
            document.getElementById('chart-convergence-coupling'),
            allTrajectories
          );
        }
      }).catch(err => {
        document.getElementById('stability-content').innerHTML = `<div class="empty">load failed: ${err?.message ?? err}</div>`;
      });
    </script>
  </body>
</html>
