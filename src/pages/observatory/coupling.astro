---
/**
 * Observatory · Coupling
 *
 * Behavioral 7D + semantic 11D dynamics + couplings, plus the cross-domain
 * emotion → behavior coupling layer. Designer-facing only.
 */
---
<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Coupling · Observatory · Alice</title>
    <style>
      :root {
        --bg: #fafaf8;
        --fg: #1a1a1a;
        --dim: #6e6e6e;
        --faint: #9b9b9b;
        --rule: #d8d4cc;
        --accent: #3a6ea5;
        --semantic: #7a5a7a;
        --emotion: #8a5a44;
        --positive: #4d7a4d;
        --negative: #a04545;
        --panel: #ffffff;
      }
      * { box-sizing: border-box; }
      body {
        margin: 0;
        font-family: -apple-system, BlinkMacSystemFont, 'SF Pro Text', sans-serif;
        background: var(--bg); color: var(--fg);
      }
      .frame { max-width: 1100px; margin: 32px auto; padding: 0 24px; }
      header {
        display: flex; justify-content: space-between; align-items: baseline;
        border-bottom: 1px solid var(--rule); padding-bottom: 16px; margin-bottom: 24px;
      }
      h1 { font-size: 18px; font-weight: 500; margin: 0; }
      nav { display: flex; gap: 16px; font-family: 'SF Mono', monospace; font-size: 12px; }
      nav a { color: var(--dim); text-decoration: none; }
      nav a:hover, nav a.active { color: var(--accent); }
      .meta-row {
        display: flex; gap: 24px; margin-bottom: 32px;
        font-family: 'SF Mono', monospace; font-size: 12px; color: var(--dim);
      }
      .panel {
        background: var(--panel); border: 1px solid var(--rule);
        border-radius: 4px; padding: 20px; margin-bottom: 20px;
      }
      .panel h2 {
        font-size: 11px; font-weight: 500; letter-spacing: 0.06em;
        text-transform: uppercase; color: var(--dim); margin: 0 0 14px;
      }
      table { width: 100%; border-collapse: collapse; font-size: 13px; }
      th, td { padding: 8px 10px; text-align: left; border-bottom: 1px solid var(--rule); }
      th { font-weight: 500; font-size: 11px; color: var(--dim); text-transform: uppercase; letter-spacing: 0.04em; }
      td.num { font-family: 'SF Mono', monospace; text-align: right; }
      .sign-pos { color: var(--positive); }
      .sign-neg { color: var(--negative); }
      .grid-two { display: grid; grid-template-columns: 1fr 1fr; gap: 20px; }
      @media (max-width: 720px) { .grid-two { grid-template-columns: 1fr; } }
      .empty {
        padding: 40px 20px; text-align: center; color: var(--dim);
        font-family: 'SF Mono', monospace; font-size: 12px;
      }
      .badge {
        display: inline-block; padding: 2px 6px; border-radius: 3px;
        font-family: 'SF Mono', monospace; font-size: 10px;
        background: #e8e4d8; color: var(--dim); text-transform: uppercase; letter-spacing: 0.04em;
      }
    </style>
  </head>
  <body>
    <div class="frame">
      <header>
        <h1>Observatory · Coupling</h1>
        <nav>
          <a href="/observatory">overview</a>
          <a href="/observatory/coupling" class="active">coupling</a>
          <a href="/">→ alice</a>
        </nav>
      </header>

      <div class="meta-row">
        <span id="counts">loading…</span>
      </div>

      <div class="grid-two">
        <section class="panel">
          <h2>Behavioral dynamics (7D PersDyn) · latest</h2>
          <div id="beh-dyn"></div>
        </section>
        <section class="panel">
          <h2>Semantic dynamics (11D PersDyn) · latest</h2>
          <div id="sem-dyn"></div>
        </section>
      </div>

      <div class="grid-two">
        <section class="panel">
          <h2>Behavioral coupling · 7D pairs</h2>
          <div id="beh-coupling"></div>
        </section>
        <section class="panel">
          <h2>Semantic coupling · 11D pairs</h2>
          <div id="sem-coupling"></div>
        </section>
      </div>

      <section class="panel">
        <h2>Emotion → behavior · cross-domain coupling</h2>
        <div id="emo-coupling"></div>
      </section>
    </div>

    <script type="module">
      function fmtZ(v) {
        if (v == null) return '—';
        const sign = v >= 0 ? '+' : '';
        return sign + Number(v).toFixed(2);
      }

      function attractorBadge(v) {
        if (v == null) return '';
        if (v >= 0.7) return '<span class="badge">rigid</span>';
        if (v >= 0.4) return '<span class="badge">moderate</span>';
        return '<span class="badge">malleable</span>';
      }

      function renderDynamicsTable(dynamics, container) {
        if (!dynamics || dynamics.length === 0) {
          container.innerHTML = '<div class="empty">no dynamics yet (need ≥5 entries)</div>';
          return;
        }
        const rows = dynamics.map(d => `
          <tr>
            <td>${d.dimension}</td>
            <td class="num">${fmtZ(d.baseline)}</td>
            <td class="num">${Number(d.variability).toFixed(2)}</td>
            <td class="num">${Number(d.attractor_force).toFixed(2)} ${attractorBadge(d.attractor_force)}</td>
            <td class="num">${fmtZ(d.current_state)}</td>
            <td class="num">${fmtZ(d.deviation)}σ</td>
          </tr>
        `).join('');
        container.innerHTML = `<table>
          <tr><th>dim</th><th>baseline</th><th>variab</th><th>attractor</th><th>current</th><th>dev</th></tr>
          ${rows}
        </table>`;
      }

      function renderCouplingTable(couplings, container) {
        if (!couplings || couplings.length === 0) {
          container.innerHTML = '<div class="empty">no couplings yet (need ≥10 entries)</div>';
          return;
        }
        const rows = couplings.map(c => {
          const r = Number(c.correlation);
          const sign = c.direction > 0 ? '+' : '−';
          const cls = c.direction > 0 ? 'sign-pos' : 'sign-neg';
          const lag = c.lag_sessions === 0 ? 'concurrent' : `lag ${c.lag_sessions}`;
          return `<tr>
            <td>${c.leader}</td>
            <td>→</td>
            <td>${c.follower}</td>
            <td class="num ${cls}">${sign}${r.toFixed(2)}</td>
            <td>${lag}</td>
          </tr>`;
        }).join('');
        container.innerHTML = `<table>
          <tr><th>leader</th><th></th><th>follower</th><th>r</th><th>lag</th></tr>
          ${rows}
        </table>`;
      }

      function renderEmotionCoupling(rows, container) {
        if (!rows || rows.length === 0) {
          container.innerHTML = '<div class="empty">no emotion → behavior couplings yet (need ≥10 entries)</div>';
          return;
        }
        const tableRows = rows.map(c => {
          const r = Number(c.correlation);
          const sign = c.direction > 0 ? '+' : '−';
          const cls = c.direction > 0 ? 'sign-pos' : 'sign-neg';
          const lag = c.lag_sessions === 0 ? 'concurrent' : `lag ${c.lag_sessions}`;
          return `<tr>
            <td>${c.emotion_dim}</td>
            <td>→</td>
            <td>${c.behavior_dim}</td>
            <td class="num ${cls}">${sign}${r.toFixed(2)}</td>
            <td>${lag}</td>
          </tr>`;
        }).join('');
        container.innerHTML = `<table>
          <tr><th>emotion</th><th></th><th>behavior dim</th><th>r</th><th>lag</th></tr>
          ${tableRows}
        </table>`;
      }

      fetch('/api/observatory/coupling').then(r => r.json()).then(data => {
        document.getElementById('counts').textContent =
          `${data.behavioralCount} behavioral · ${data.semanticCount} semantic`;
        renderDynamicsTable(data.behavioralDynamics, document.getElementById('beh-dyn'));
        renderDynamicsTable(data.semanticDynamics, document.getElementById('sem-dyn'));
        renderCouplingTable(data.behavioralCouplings, document.getElementById('beh-coupling'));
        renderCouplingTable(data.semanticCouplings, document.getElementById('sem-coupling'));
        renderEmotionCoupling(data.emotionCouplings, document.getElementById('emo-coupling'));
      }).catch(err => {
        document.querySelector('.frame').innerHTML += `<div class="panel" style="border-color:#a04545;color:#a04545;">load failed: ${err?.message ?? err}</div>`;
      });
    </script>
  </body>
</html>
