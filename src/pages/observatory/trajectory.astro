---
/**
 * Observatory · Trajectory
 *
 * Time-series view of motor, process, cross-session, and discourse signals
 * across all entries. Shows how signals move over sessions, not just what
 * they are in one session.
 *
 * No interpretation. Designer-facing only.
 */
import '../../styles/styObservatory.css';
import ObsToolbar from '../../components/cmpObsToolbar.astro';
---
<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Trajectory · Observatory · Alice</title>
    <script is:inline>
      (function () {
        var saved = localStorage.getItem('alice-theme');
        var t = saved || (window.matchMedia('(prefers-color-scheme: dark)').matches ? 'dark' : 'light');
        document.documentElement.setAttribute('data-theme', t);
        document.addEventListener('DOMContentLoaded', function () {
          var btn = document.getElementById('obs-theme-toggle');
          if (!btn) return;
          btn.textContent = t === 'dark' ? '\u2600' : '\u263E';
          btn.addEventListener('click', function () {
            var cur = document.documentElement.getAttribute('data-theme');
            var next = cur === 'dark' ? 'light' : 'dark';
            document.documentElement.setAttribute('data-theme', next);
            localStorage.setItem('alice-theme', next);
            btn.textContent = next === 'dark' ? '\u2600' : '\u263E';
          });
        });
      })();
    </script>
    <style is:global>
      .trajectory-chart {
        width: 100%;
        height: 120px;
        display: block;
      }
      .chart-row {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 1rem;
      }
      @media (max-width: 820px) {
        .chart-row { grid-template-columns: 1fr; }
      }
      .chart-panel {
        background: var(--bg-panel);
        border: 1px solid var(--border);
        border-radius: 2px;
        padding: 1rem 1.25rem 0.75rem;
        margin-bottom: 0.5rem;
      }
      .chart-panel h3 {
        font-family: var(--mono);
        font-size: 10px;
        font-weight: 500;
        letter-spacing: 0.16em;
        text-transform: uppercase;
        color: var(--text-faint);
        margin: 0 0 0.5rem;
      }
      .chart-panel .latest-reading {
        font-family: var(--mono);
        font-size: 11px;
        color: var(--text-muted);
        margin-top: 0.25rem;
        letter-spacing: 0.08em;
      }
      .chart-panel .latest-reading .val {
        color: var(--text);
        font-weight: 500;
      }
      .section-label {
        font-family: var(--mono);
        font-size: 10px;
        font-weight: 500;
        letter-spacing: 0.2em;
        text-transform: uppercase;
        color: var(--text-faint);
        margin: 2rem 0 0.75rem;
        padding-bottom: 0.5rem;
        border-bottom: 1px solid var(--border);
      }
      .insufficient {
        font-family: var(--sans);
        font-size: 13px;
        color: var(--text-muted);
        padding: 2rem 0;
      }
    </style>
  </head>
  <body>
    <div class="frame">
      <header>
        <h1>Trajectory</h1>
        <nav>
          <a href="/observatory">overview</a>
          <a href="/observatory/trajectory" class="active">trajectory</a>
          <a href="/observatory/scales">scales</a>
          <a href="/observatory/coupling">coupling</a>
          <a href="/observatory/ghost">ghost</a>
          <a href="/">→ alice</a>
          <button class="obs-theme-toggle" id="obs-theme-toggle" aria-label="Toggle theme"></button>
        </nav>
      </header>

      <ObsToolbar />

      <div id="trajectory-content">
        <div class="empty">loading…</div>
      </div>
    </div>

    <script type="module">
      const MOTOR_DIMS = [
        { key: 'ex_gaussian_tau', label: 'Ex-Gaussian tau', color: 'var(--accent)', unit: 'ms' },
        { key: 'tau_proportion', label: 'Tau proportion', color: 'var(--accent)', unit: '%' },
        { key: 'adjacent_hold_time_cov', label: 'Adjacent hold cov', color: 'var(--accent)', unit: '' },
        { key: 'sample_entropy', label: 'Sample entropy', color: 'var(--accent)', unit: '' },
        { key: 'lapse_rate', label: 'Lapse rate', color: 'var(--negative)', unit: '/min' },
        { key: 'tempo_drift', label: 'Tempo drift', color: 'var(--warn)', unit: 'ms/q' },
      ];

      const PHASE2_DIMS = [
        { key: 'cursor_fidget_ratio', label: 'Cursor fidget', color: 'var(--semantic)', unit: 'px/ms' },
        { key: 'cursor_stillness_during_pauses', label: 'Cursor stillness', color: 'var(--semantic)', unit: '%' },
        { key: 'deletion_execution_speed_mean', label: 'Deletion exec speed', color: 'var(--warn)', unit: 'ms' },
        { key: 'postcorrection_latency_mean', label: 'Postcorrection latency', color: 'var(--warn)', unit: 'ms' },
        { key: 'punctuation_letter_ratio', label: 'Punct/letter ratio', color: 'var(--semantic)', unit: 'x' },
      ];

      const CROSS_SESSION_DIMS = [
        { key: 'self_perplexity', label: 'Self-perplexity', color: 'var(--accent)', unit: '' },
        { key: 'motor_self_perplexity', label: 'Motor self-perplexity', color: 'var(--accent)', unit: '' },
        { key: 'ncd_lag_1', label: 'NCD lag-1', color: 'var(--semantic)', unit: '' },
        { key: 'digraph_stability', label: 'Digraph stability', color: 'var(--semantic)', unit: '' },
        { key: 'text_network_density', label: 'Text network density', color: 'var(--semantic)', unit: '' },
        { key: 'vocab_recurrence_decay', label: 'Vocab recurrence decay', color: 'var(--warn)', unit: '' },
        { key: 'bridging_ratio', label: 'Bridging ratio', color: 'var(--accent)', unit: '' },
      ];

      const DISCOURSE_DIMS = [
        { key: 'discourse_global_coherence', label: 'Global coherence', color: 'var(--semantic)', unit: '' },
        { key: 'discourse_local_coherence', label: 'Local coherence', color: 'var(--semantic)', unit: '' },
        { key: 'discourse_global_local_ratio', label: 'Global/local ratio', color: 'var(--semantic)', unit: '' },
        { key: 'discourse_coherence_decay_slope', label: 'Coherence decay slope', color: 'var(--warn)', unit: '' },
      ];

      const PROCESS_DIMS = [
        { key: 'pause_within_word', label: 'Pauses within word', color: 'var(--accent)', unit: '' },
        { key: 'pause_between_word', label: 'Pauses between words', color: 'var(--accent)', unit: '' },
        { key: 'pause_between_sentence', label: 'Pauses between sentences', color: 'var(--accent)', unit: '' },
        { key: 'abandoned_thought_count', label: 'Abandoned thoughts', color: 'var(--negative)', unit: '' },
        { key: 'vocab_expansion_rate', label: 'Vocab expansion rate', color: 'var(--semantic)', unit: '' },
        { key: 'phase_transition_point', label: 'Phase transition point', color: 'var(--warn)', unit: '' },
      ];

      function fmtRaw(v, unit) {
        if (v == null) return '—';
        if (unit === '%') return (v * 100).toFixed(1) + '%';
        if (unit === 'ms') return Math.round(v) + 'ms';
        if (unit === '/min') return v.toFixed(2) + '/min';
        if (unit === 'ms/q') return (v > 0 ? '+' : '') + v.toFixed(1) + 'ms/q';
        if (unit === 'px/ms') return v.toFixed(4);
        if (unit === 'x') return v.toFixed(3) + 'x';
        return Number(v).toFixed(3);
      }

      function resolveCssVar(el, v) {
        return getComputedStyle(el).getPropertyValue(v.replace('var(', '').replace(')', '').trim()) || v;
      }

      function drawChart(canvas, values, color, dates) {
        const dpr = window.devicePixelRatio || 1;
        const rect = canvas.getBoundingClientRect();
        const w = rect.width;
        const h = rect.height;
        canvas.width = w * dpr;
        canvas.height = h * dpr;
        canvas.style.width = w + 'px';
        canvas.style.height = h + 'px';
        const ctx = canvas.getContext('2d');
        ctx.scale(dpr, dpr);

        // Resolve CSS variables for canvas (Canvas 2D doesn't understand var())
        const colBorder = resolveCssVar(canvas, 'var(--border)');
        const colFaint = resolveCssVar(canvas, 'var(--text-faint)');
        const colLine = resolveCssVar(canvas, color);

        const padL = 32, padR = 8, padT = 8, padB = 20;
        const chartW = w - padL - padR;
        const chartH = h - padT - padB;

        // Compute scale: symmetric around 0, at least ±1
        const maxAbs = Math.max(1, ...values.filter(v => v != null).map(v => Math.abs(v)));
        const yRange = Math.ceil(maxAbs);

        // Zero line
        const zeroY = padT + chartH / 2;
        ctx.strokeStyle = colBorder;
        ctx.lineWidth = 1;
        ctx.setLineDash([3, 3]);
        ctx.beginPath();
        ctx.moveTo(padL, zeroY);
        ctx.lineTo(padL + chartW, zeroY);
        ctx.stroke();
        ctx.setLineDash([]);

        // ±1σ reference lines
        const oneUp = padT + chartH * (1 - (1 + yRange) / (2 * yRange));
        const oneDown = padT + chartH * (1 - (-1 + yRange) / (2 * yRange));
        ctx.strokeStyle = colBorder;
        ctx.lineWidth = 0.5;
        ctx.setLineDash([2, 4]);
        ctx.beginPath();
        ctx.moveTo(padL, oneUp);
        ctx.lineTo(padL + chartW, oneUp);
        ctx.moveTo(padL, oneDown);
        ctx.lineTo(padL + chartW, oneDown);
        ctx.stroke();
        ctx.setLineDash([]);

        // Y-axis labels
        ctx.fillStyle = colFaint;
        ctx.font = '9px SF Mono, Menlo, monospace';
        ctx.textAlign = 'right';
        ctx.textBaseline = 'middle';
        ctx.fillText('+' + yRange, padL - 4, padT);
        ctx.fillText('0', padL - 4, zeroY);
        ctx.fillText('-' + yRange, padL - 4, padT + chartH);

        // Plot line
        const validPoints = [];
        for (let i = 0; i < values.length; i++) {
          if (values[i] != null) {
            const x = padL + (values.length === 1 ? chartW / 2 : (i / (values.length - 1)) * chartW);
            const y = padT + chartH * (1 - (values[i] + yRange) / (2 * yRange));
            validPoints.push({ x, y, i });
          }
        }

        // Single point: draw a dot only
        if (validPoints.length === 1) {
          ctx.beginPath();
          ctx.arc(validPoints[0].x, validPoints[0].y, 3, 0, Math.PI * 2);
          ctx.fillStyle = colLine;
          ctx.fill();
          return;
        }

        if (validPoints.length < 2) return;

        // Below 5 data points: dots only, no lines or fill area
        if (validPoints.length < 5) {
          for (const p of validPoints) {
            ctx.beginPath();
            ctx.arc(p.x, p.y, 3, 0, Math.PI * 2);
            ctx.fillStyle = colLine;
            ctx.fill();
          }
          return;
        }

        // Fill area
        ctx.beginPath();
        ctx.moveTo(validPoints[0].x, zeroY);
        for (const p of validPoints) ctx.lineTo(p.x, p.y);
        ctx.lineTo(validPoints[validPoints.length - 1].x, zeroY);
        ctx.closePath();
        ctx.fillStyle = colLine + '18';
        ctx.fill();

        // Stroke
        ctx.strokeStyle = colLine;
        ctx.lineWidth = 1.5;
        ctx.lineJoin = 'round';
        ctx.beginPath();
        for (let i = 0; i < validPoints.length; i++) {
          if (i === 0) ctx.moveTo(validPoints[i].x, validPoints[i].y);
          else ctx.lineTo(validPoints[i].x, validPoints[i].y);
        }
        ctx.stroke();

        // Dots
        for (const p of validPoints) {
          ctx.beginPath();
          ctx.arc(p.x, p.y, 2.5, 0, Math.PI * 2);
          ctx.fillStyle = colLine;
          ctx.fill();
        }

        // Date labels (first and last)
        ctx.fillStyle = colFaint;
        ctx.font = '9px SF Mono, Menlo, monospace';
        ctx.textAlign = 'left';
        ctx.textBaseline = 'top';
        if (dates.length > 0) {
          ctx.fillText(dates[0], padL, padT + chartH + 4);
          if (dates.length > 1) {
            ctx.textAlign = 'right';
            ctx.fillText(dates[dates.length - 1], padL + chartW, padT + chartH + 4);
          }
        }
      }

      function renderRawSection(label, dims, states, getVal) {
        let html = `<div class="section-label">${label}</div><div class="chart-row">`;
        for (const dim of dims) {
          const values = states.map(s => getVal(s, dim.key));
          const latest = values[values.length - 1];
          html += `
            <div class="chart-panel">
              <h3>${dim.label}</h3>
              <canvas class="trajectory-chart raw-chart" data-dim="${dim.key}" data-color="${dim.color}"></canvas>
              <div class="latest-reading">latest: <span class="val">${fmtRaw(latest, dim.unit)}</span></div>
            </div>
          `;
        }
        html += '</div>';
        return html;
      }

      fetch(window.__obsUrl('/api/observatory/states')).then(r => r.json()).then(data => {
        if (data.error) {
          document.getElementById('trajectory-content').innerHTML = `<div class="empty">${data.error}</div>`;
          return;
        }

        const states = data.states;
        if (states.length < 2) {
          document.getElementById('trajectory-content').innerHTML =
            '<div class="insufficient">Need at least 2 entries to show trajectory. Keep writing.</div>';
          return;
        }

        const dates = states.map(s => s.date);

        let html = '';

        // Motor signals trajectory (Phase 2)
        const hasMotor = states.some(s => s.motor != null);
        if (hasMotor) {
          html += renderRawSection(
            'Motor signals · ex-Gaussian + rhythm + fatigue',
            MOTOR_DIMS,
            states,
            (s, key) => s.motor?.[key] ?? null
          );
        }

        // Phase 2 cursor/revision/punctuation trajectory
        const hasPhase2 = states.some(s => s.phase2 != null);
        if (hasPhase2) {
          html += renderRawSection(
            'Phase 2 · cursor, error correction, punctuation',
            PHASE2_DIMS,
            states,
            (s, key) => s.phase2?.[key] ?? null
          );
        }

        // Cross-session signals trajectory
        const hasCrossSession = states.some(s => s.crossSession != null);
        if (hasCrossSession) {
          html += renderRawSection(
            'Cross-session · session-to-history relationship',
            CROSS_SESSION_DIMS,
            states,
            (s, key) => s.crossSession?.[key] ?? null
          );
        }

        // Discourse coherence trajectory
        const hasDiscourse = states.some(s => s.discourse != null);
        if (hasDiscourse) {
          html += renderRawSection(
            'Discourse coherence · text structural coherence',
            DISCOURSE_DIMS,
            states,
            (s, key) => s.discourse?.[key] ?? null
          );
        }

        // Process signals trajectory
        const hasProcess = states.some(s => s.process != null);
        if (hasProcess) {
          html += renderRawSection(
            'Process structure · writing process shape',
            PROCESS_DIMS,
            states,
            (s, key) => s.process?.[key] ?? null
          );
        }

        document.getElementById('trajectory-content').innerHTML = html;

        // Draw all charts
        const allValues = {};
        if (hasMotor) {
          for (const dim of MOTOR_DIMS) {
            allValues[dim.key] = { values: states.map(s => s.motor?.[dim.key] ?? null), color: dim.color };
          }
        }
        if (hasPhase2) {
          for (const dim of PHASE2_DIMS) {
            allValues[dim.key] = { values: states.map(s => s.phase2?.[dim.key] ?? null), color: dim.color };
          }
        }
        if (hasCrossSession) {
          for (const dim of CROSS_SESSION_DIMS) {
            allValues[dim.key] = { values: states.map(s => s.crossSession?.[dim.key] ?? null), color: dim.color };
          }
        }
        if (hasDiscourse) {
          for (const dim of DISCOURSE_DIMS) {
            allValues[dim.key] = { values: states.map(s => s.discourse?.[dim.key] ?? null), color: dim.color };
          }
        }
        if (hasProcess) {
          for (const dim of PROCESS_DIMS) {
            allValues[dim.key] = { values: states.map(s => s.process?.[dim.key] ?? null), color: dim.color };
          }
        }

        function drawRawChart(canvas, values, color, dates) {
          const dpr = window.devicePixelRatio || 1;
          const rect = canvas.getBoundingClientRect();
          const w = rect.width, h = rect.height;
          canvas.width = w * dpr;
          canvas.height = h * dpr;
          canvas.style.width = w + 'px';
          canvas.style.height = h + 'px';
          const ctx = canvas.getContext('2d');
          ctx.scale(dpr, dpr);

          const colBorder = resolveCssVar(canvas, 'var(--border)');
          const colFaint = resolveCssVar(canvas, 'var(--text-faint)');
          const colLine = resolveCssVar(canvas, color);

          const padL = 40, padR = 8, padT = 8, padB = 20;
          const chartW = w - padL - padR, chartH = h - padT - padB;

          const valid = values.filter(v => v != null);
          if (valid.length === 0) return;
          const minV = Math.min(...valid), maxV = Math.max(...valid);
          const range = maxV - minV || 1;
          const yMin = minV - range * 0.1, yMax = maxV + range * 0.1;
          const yRange = yMax - yMin;

          // Mean reference line
          const meanV = valid.reduce((a,b) => a+b, 0) / valid.length;
          const meanY = padT + chartH * (1 - (meanV - yMin) / yRange);
          ctx.strokeStyle = colBorder;
          ctx.lineWidth = 0.5;
          ctx.setLineDash([3, 3]);
          ctx.beginPath();
          ctx.moveTo(padL, meanY);
          ctx.lineTo(padL + chartW, meanY);
          ctx.stroke();
          ctx.setLineDash([]);

          // Y-axis labels
          ctx.fillStyle = colFaint;
          ctx.font = '9px SF Mono, Menlo, monospace';
          ctx.textAlign = 'right';
          ctx.textBaseline = 'middle';
          const fmt = (v) => Math.abs(v) >= 100 ? Math.round(v) : v.toFixed(1);
          ctx.fillText(fmt(yMax), padL - 4, padT);
          ctx.fillText(fmt(yMin), padL - 4, padT + chartH);

          // Plot
          const pts = [];
          for (let i = 0; i < values.length; i++) {
            if (values[i] != null) {
              const x = padL + (values.length === 1 ? chartW / 2 : (i / (values.length - 1)) * chartW);
              const y = padT + chartH * (1 - (values[i] - yMin) / yRange);
              pts.push({ x, y });
            }
          }
          if (pts.length === 1) {
            ctx.beginPath(); ctx.arc(pts[0].x, pts[0].y, 3, 0, Math.PI * 2);
            ctx.fillStyle = colLine; ctx.fill(); return;
          }
          if (pts.length < 2) return;

          ctx.strokeStyle = colLine; ctx.lineWidth = 1.5; ctx.lineJoin = 'round';
          ctx.beginPath();
          for (let i = 0; i < pts.length; i++) {
            if (i === 0) ctx.moveTo(pts[i].x, pts[i].y);
            else ctx.lineTo(pts[i].x, pts[i].y);
          }
          ctx.stroke();
          for (const p of pts) {
            ctx.beginPath(); ctx.arc(p.x, p.y, 2.5, 0, Math.PI * 2);
            ctx.fillStyle = colLine; ctx.fill();
          }
          if (dates.length > 0) {
            ctx.fillStyle = colFaint; ctx.font = '9px SF Mono, Menlo, monospace';
            ctx.textAlign = 'left'; ctx.textBaseline = 'top';
            ctx.fillText(dates[0], padL, padT + chartH + 4);
            if (dates.length > 1) {
              ctx.textAlign = 'right';
              ctx.fillText(dates[dates.length - 1], padL + chartW, padT + chartH + 4);
            }
          }
        }

        function drawAll() {
          document.querySelectorAll('.trajectory-chart').forEach(canvas => {
            const dim = canvas.dataset.dim;
            const color = canvas.dataset.color;
            const entry = allValues[dim];
            if (entry) {
              if (canvas.classList.contains('raw-chart')) {
                drawRawChart(canvas, entry.values, color, dates);
              } else {
                drawChart(canvas, entry.values, color, dates);
              }
            }
          });
        }

        drawAll();

        let resizeTimer;
        window.addEventListener('resize', () => {
          clearTimeout(resizeTimer);
          resizeTimer = setTimeout(drawAll, 150);
        });
      }).catch(err => {
        document.getElementById('trajectory-content').innerHTML = `<div class="empty">failed to load: ${err?.message ?? err}</div>`;
      });
    </script>
  </body>
</html>
