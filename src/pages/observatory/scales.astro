---
/**
 * Observatory · Scales
 *
 * Multi-scale structure of keystroke dynamics. Organizes all Phase 1-5
 * dynamical and motor complexity signals by theoretical family.
 *
 * Unique visualizations:
 *   - PE Spectrum (orders 3-7) + MSE Curve (scales 1-5) overlay portrait
 *   - Per-family time-series trajectories
 *   - Ergodicity classification panel (Mangalam et al. 2022)
 *
 * No interpretation. Designer-facing only.
 */
import '../../styles/styObservatory.css';
import ObsToolbar from '../../components/cmpObsToolbar.astro';
---
<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Scales · Observatory · Alice</title>
    <script is:inline>
      (function () {
        var saved = localStorage.getItem('alice-theme');
        var t = saved || (window.matchMedia('(prefers-color-scheme: dark)').matches ? 'dark' : 'light');
        document.documentElement.setAttribute('data-theme', t);
        document.addEventListener('DOMContentLoaded', function () {
          var btn = document.getElementById('obs-theme-toggle');
          if (!btn) return;
          btn.textContent = t === 'dark' ? '\u2600' : '\u263E';
          btn.addEventListener('click', function () {
            var cur = document.documentElement.getAttribute('data-theme');
            var next = cur === 'dark' ? 'light' : 'dark';
            document.documentElement.setAttribute('data-theme', next);
            localStorage.setItem('alice-theme', next);
            btn.textContent = next === 'dark' ? '\u2600' : '\u263E';
          });
        });
      })();
    </script>
    <style is:global>
      .trajectory-chart { width: 100%; height: 120px; display: block; }
      .portrait-chart { width: 100%; height: 180px; display: block; }
      .chart-row { display: grid; grid-template-columns: 1fr 1fr; gap: 1rem; }
      @media (max-width: 820px) { .chart-row { grid-template-columns: 1fr; } }
      .chart-panel {
        background: var(--bg-panel);
        border: 1px solid var(--border);
        border-radius: 2px;
        padding: 1rem 1.25rem 0.75rem;
        margin-bottom: 0.5rem;
      }
      .chart-panel h3 {
        font-family: var(--mono);
        font-size: 10px;
        font-weight: 500;
        letter-spacing: 0.16em;
        text-transform: uppercase;
        color: var(--text-faint);
        margin: 0 0 0.5rem;
      }
      .chart-panel .latest-reading {
        font-family: var(--mono);
        font-size: 11px;
        color: var(--text-muted);
        margin-top: 0.25rem;
        letter-spacing: 0.08em;
      }
      .chart-panel .latest-reading .val { color: var(--text); font-weight: 500; }
      .section-label {
        font-family: var(--mono);
        font-size: 10px;
        font-weight: 500;
        letter-spacing: 0.2em;
        text-transform: uppercase;
        color: var(--text-faint);
        margin: 2rem 0 0.75rem;
        padding-bottom: 0.5rem;
        border-bottom: 1px solid var(--border);
      }
      .section-desc {
        font-family: var(--sans);
        font-size: 12px;
        color: var(--text-muted);
        margin: -0.5rem 0 0.75rem;
        line-height: 1.5;
      }
      .ergo-table { width: 100%; border-collapse: collapse; margin-top: 1rem; }
      .ergo-table th {
        font-family: var(--mono);
        font-size: 10px;
        font-weight: 500;
        letter-spacing: 0.16em;
        text-transform: uppercase;
        color: var(--text-faint);
        padding: 0.5rem;
        text-align: left;
        border-bottom: 1px solid var(--border);
      }
      .ergo-table td {
        font-family: var(--mono);
        font-size: 10px;
        padding: 0.3rem 0.5rem;
        color: var(--text-muted);
        vertical-align: top;
      }
      .ergo-table td .family-tag {
        font-size: 9px;
        color: var(--text-faint);
        margin-left: 0.5em;
      }
    </style>
  </head>
  <body>
    <div class="frame">
      <header>
        <h1>Scales</h1>
        <nav>
          <a href="/observatory">overview</a>
          <a href="/observatory/trajectory">trajectory</a>
          <a href="/observatory/scales" class="active">scales</a>
          <a href="/observatory/coupling">coupling</a>
          <a href="/observatory/ghost">ghost</a>
          <a href="/">→ alice</a>
          <a href="#" data-logout>logout</a>
          <button class="obs-theme-toggle" id="obs-theme-toggle" aria-label="Toggle theme"></button>
        </nav>
      </header>

      <ObsToolbar />

      <div id="scales-content">
        <div class="empty">loading…</div>
      </div>
    </div>

    <script type="module">
      // ── Signal families ─────────────────────────────────────────────
      const FAMILIES = [
        {
          id: 'scaling', label: 'Scaling & Fractality',
          desc: 'Structure across time scales. DFA alpha reveals noise color; MF-DFA reveals the richness of multifractal scaling.',
          dims: [
            { key: 'dfa_alpha', label: 'DFA alpha' },
            { key: 'mfdfa_spectrum_width', label: 'MF-DFA spectrum width' },
            { key: 'mfdfa_asymmetry', label: 'MF-DFA asymmetry' },
            { key: 'temporal_irreversibility', label: 'Temporal irreversibility' },
          ],
        },
        {
          id: 'spectral', label: 'Spectral Decomposition',
          desc: 'Frequency content of IKI dynamics. Slope reveals noise color; respiratory peak detects physiological entrainment.',
          dims: [
            { key: 'iki_psd_spectral_slope', label: 'PSD spectral slope' },
            { key: 'iki_psd_respiratory_peak_hz', label: 'Respiratory peak (Hz)' },
            { key: 'iki_psd_lf_hf_ratio', label: 'LF/HF ratio' },
            { key: 'iki_psd_fast_slow_variance_ratio', label: 'Fast/slow variance' },
          ],
        },
        {
          id: 'ordinal', label: 'Ordinal Pattern Complexity',
          desc: 'Temporal pattern structure beyond permutation entropy. Statistical complexity measures prediction cost; LZ measures compressibility.',
          dims: [
            { key: 'statistical_complexity', label: 'Statistical complexity (CECP)' },
            { key: 'forbidden_pattern_fraction', label: 'Forbidden patterns' },
            { key: 'weighted_pe', label: 'Weighted PE' },
            { key: 'lempel_ziv_complexity', label: 'Lempel-Ziv complexity' },
            { key: 'optn_transition_entropy', label: 'OPTN transition entropy' },
          ],
        },
        {
          id: 'recurrence', label: 'Recurrence Structure',
          desc: 'Phase space topology. Network metrics turn the recurrence plot into a graph and measure its connectivity and clustering.',
          dims: [
            { key: 'rqa_determinism', label: 'RQA determinism' },
            { key: 'rqa_recurrence_time_entropy', label: 'Recurrence time entropy' },
            { key: 'recurrence_transitivity', label: 'Network transitivity' },
            { key: 'recurrence_clustering', label: 'Network clustering' },
            { key: 'recurrence_avg_path_length', label: 'Avg path length' },
            { key: 'recurrence_assortativity', label: 'Assortativity' },
          ],
        },
        {
          id: 'causal', label: 'Causal Architecture',
          desc: 'Emergence, information decomposition, criticality. Positive causal emergence means macro-level dynamics are more predictive than micro.',
          dims: [
            { key: 'effective_information', label: 'Effective information' },
            { key: 'causal_emergence_index', label: 'Causal emergence index' },
            { key: 'pid_synergy', label: 'PID synergy' },
            { key: 'pid_redundancy', label: 'PID redundancy' },
            { key: 'branching_ratio', label: 'Branching ratio' },
            { key: 'avalanche_size_exponent', label: 'Avalanche exponent' },
          ],
        },
        {
          id: 'dmd', label: 'Dynamic Modes',
          desc: 'Oscillatory modes in the IKI embedding. Frequency reveals dominant rhythm; decay rate reveals mode stability.',
          dims: [
            { key: 'dmd_dominant_frequency', label: 'Dominant frequency (Hz)' },
            { key: 'dmd_dominant_decay_rate', label: 'Decay rate' },
            { key: 'dmd_spectral_entropy', label: 'DMD spectral entropy' },
          ],
        },
        {
          id: 'pause', label: 'Pause Mixture',
          desc: 'Latent pause structure. Gaussian mixture separates motor pauses (fast) from cognitive pauses (slow).',
          dims: [
            { key: 'pause_mixture_motor_proportion', label: 'Motor proportion' },
            { key: 'pause_mixture_cognitive_load_index', label: 'Cognitive load index' },
          ],
        },
        {
          id: 'motor_complexity', label: 'Motor Complexity',
          desc: 'Multi-scale entropy and measurement informativeness. Healthy complexity stays high across coarse-graining scales.',
          dims: [
            { key: 'complexity_index', label: 'MSE complexity index' },
            { key: 'ex_gaussian_fisher_trace', label: 'Fisher information trace' },
          ],
        },
        {
          id: 'te', label: 'Transfer Entropy',
          desc: 'Directional information flow between hold and flight channels. Dominance reveals which channel leads.',
          dims: [
            { key: 'te_hold_to_flight', label: 'TE hold→flight' },
            { key: 'te_flight_to_hold', label: 'TE flight→hold' },
            { key: 'te_dominance', label: 'TE dominance ratio' },
          ],
        },
      ];

      // ── Chart rendering ─────────────────────────────────────────────
      function resolveCssVar(el, v) {
        return getComputedStyle(el).getPropertyValue(v.replace('var(', '').replace(')', '').trim()) || v;
      }

      function drawRawChart(canvas, values, colorVar, dates) {
        const dpr = window.devicePixelRatio || 1;
        const rect = canvas.getBoundingClientRect();
        const w = rect.width, h = rect.height;
        canvas.width = w * dpr;
        canvas.height = h * dpr;
        canvas.style.width = w + 'px';
        canvas.style.height = h + 'px';
        const ctx = canvas.getContext('2d');
        ctx.scale(dpr, dpr);

        const colBorder = resolveCssVar(canvas, 'var(--border)');
        const colFaint = resolveCssVar(canvas, 'var(--text-faint)');
        const colLine = resolveCssVar(canvas, colorVar);

        const padL = 48, padR = 8, padT = 8, padB = 20;
        const cW = w - padL - padR, cH = h - padT - padB;

        const valid = values.filter(v => v != null);
        if (valid.length < 2) {
          ctx.fillStyle = colFaint;
          ctx.font = '10px SF Mono, monospace';
          ctx.fillText('insufficient data', w / 2 - 40, h / 2);
          return;
        }

        const minV = Math.min(...valid), maxV = Math.max(...valid);
        const range = maxV - minV || 1;
        const mean = valid.reduce((a, b) => a + b, 0) / valid.length;

        // Mean reference line
        const meanY = padT + cH * (1 - (mean - minV) / range);
        ctx.strokeStyle = colBorder;
        ctx.lineWidth = 0.5;
        ctx.setLineDash([2, 4]);
        ctx.beginPath();
        ctx.moveTo(padL, meanY);
        ctx.lineTo(padL + cW, meanY);
        ctx.stroke();
        ctx.setLineDash([]);

        // Y-axis labels
        ctx.fillStyle = colFaint;
        ctx.font = '9px SF Mono, monospace';
        ctx.textAlign = 'right';
        ctx.textBaseline = 'middle';
        ctx.fillText(maxV.toPrecision(3), padL - 4, padT + 4);
        ctx.fillText(minV.toPrecision(3), padL - 4, padT + cH - 4);

        // Plot
        const pts = [];
        for (let i = 0; i < values.length; i++) {
          if (values[i] != null) {
            const x = padL + (values.length === 1 ? cW / 2 : (i / (values.length - 1)) * cW);
            const y = padT + cH * (1 - (values[i] - minV) / range);
            pts.push({ x, y });
          }
        }
        if (pts.length > 0) {
          ctx.strokeStyle = colLine;
          ctx.lineWidth = 1.5;
          ctx.beginPath();
          pts.forEach((p, i) => i === 0 ? ctx.moveTo(p.x, p.y) : ctx.lineTo(p.x, p.y));
          ctx.stroke();
          // Latest dot
          const last = pts[pts.length - 1];
          ctx.fillStyle = colLine;
          ctx.beginPath();
          ctx.arc(last.x, last.y, 3, 0, Math.PI * 2);
          ctx.fill();
        }

        // Date labels
        if (dates && dates.length > 0) {
          ctx.fillStyle = colFaint;
          ctx.font = '8px SF Mono, monospace';
          ctx.textAlign = 'left';
          ctx.fillText(dates[0] ?? '', padL, padT + cH + 14);
          ctx.textAlign = 'right';
          ctx.fillText(dates[dates.length - 1] ?? '', padL + cW, padT + cH + 14);
        }
      }

      function drawMultiScaleChart(canvas, latestArr, priorArrs, labels, colorVar, title) {
        const dpr = window.devicePixelRatio || 1;
        const rect = canvas.getBoundingClientRect();
        const w = rect.width, h = rect.height;
        canvas.width = w * dpr;
        canvas.height = h * dpr;
        canvas.style.width = w + 'px';
        canvas.style.height = h + 'px';
        const ctx = canvas.getContext('2d');
        ctx.scale(dpr, dpr);

        const colBorder = resolveCssVar(canvas, 'var(--border)');
        const colFaint = resolveCssVar(canvas, 'var(--text-faint)');
        const colLine = resolveCssVar(canvas, colorVar);

        const padL = 48, padR = 16, padT = 24, padB = 28;
        const cW = w - padL - padR, cH = h - padT - padB;

        // Title
        ctx.fillStyle = colFaint;
        ctx.font = '10px SF Mono, monospace';
        ctx.textAlign = 'left';
        ctx.fillText(title, padL, 14);

        // Collect all values for y-range
        const allVals = [latestArr, ...priorArrs].flat().filter(v => v != null && Number.isFinite(v));
        if (allVals.length === 0) {
          ctx.fillStyle = colFaint;
          ctx.fillText('no data', w / 2 - 20, h / 2);
          return;
        }
        const minV = Math.min(...allVals), maxV = Math.max(...allVals);
        const range = maxV - minV || 0.1;
        const n = latestArr.length;

        const toX = (i) => padL + (i / (n - 1)) * cW;
        const toY = (v) => padT + cH * (1 - (v - minV) / range);

        // Y-axis
        ctx.fillStyle = colFaint;
        ctx.font = '9px SF Mono, monospace';
        ctx.textAlign = 'right';
        ctx.fillText(maxV.toFixed(2), padL - 4, padT + 4);
        ctx.fillText(minV.toFixed(2), padL - 4, padT + cH - 4);

        // X-axis labels
        ctx.textAlign = 'center';
        for (let i = 0; i < n; i++) {
          ctx.fillText(labels[i] ?? String(i + 1), toX(i), padT + cH + 16);
        }

        // Prior session traces (faint)
        for (const arr of priorArrs) {
          ctx.strokeStyle = colLine;
          ctx.globalAlpha = 0.15;
          ctx.lineWidth = 1;
          ctx.beginPath();
          arr.forEach((v, i) => {
            if (v == null) return;
            const x = toX(i), y = toY(v);
            i === 0 ? ctx.moveTo(x, y) : ctx.lineTo(x, y);
          });
          ctx.stroke();
          ctx.globalAlpha = 1;
        }

        // Latest session (bold)
        ctx.strokeStyle = colLine;
        ctx.lineWidth = 2.5;
        ctx.beginPath();
        latestArr.forEach((v, i) => {
          if (v == null) return;
          const x = toX(i), y = toY(v);
          i === 0 ? ctx.moveTo(x, y) : ctx.lineTo(x, y);
        });
        ctx.stroke();

        // Dots on latest
        latestArr.forEach((v, i) => {
          if (v == null) return;
          ctx.fillStyle = colLine;
          ctx.beginPath();
          ctx.arc(toX(i), toY(v), 3.5, 0, Math.PI * 2);
          ctx.fill();
        });
      }

      function fmtRaw(v) {
        if (v == null) return '—';
        return Number(v).toPrecision(4);
      }

      // ── Main ────────────────────────────────────────────────────────
      fetch(window.__obsUrl('/api/observatory/scales')).then(r => r.json()).then(data => {
        if (data.error) {
          document.getElementById('scales-content').innerHTML = `<div class="empty">${data.error}</div>`;
          return;
        }
        const sessions = data.sessions;
        if (!sessions || sessions.length === 0) {
          document.getElementById('scales-content').innerHTML = `<div class="empty">no dynamical signal data yet</div>`;
          return;
        }

        const dates = sessions.map(s => s.date);
        const latest = sessions[sessions.length - 1];
        const priorSessions = sessions.slice(-6, -1);

        // ── Multi-scale portrait ──────────────────────────────────────
        const peLatest = latest.pe_spectrum;
        const peValid = Array.isArray(peLatest) && peLatest.length >= 3;
        const mseLatest = latest.mse_series;
        const mseValid = Array.isArray(mseLatest) && mseLatest.length >= 2;

        let portraitHtml = '<div class="section-label">Multi-scale portrait</div>';
        portraitHtml += '<div class="section-desc">PE Spectrum reveals ordinal complexity across embedding dimensions. MSE Curve reveals entropy across coarse-graining scales. Faint traces show the 5 preceding sessions.</div>';
        portraitHtml += '<div class="chart-row">';

        if (peValid) {
          portraitHtml += `<div class="chart-panel"><canvas class="portrait-chart" id="pe-portrait"></canvas>
            <div class="latest-reading">latest: <span class="val">${peLatest.map(v => v != null ? v.toFixed(3) : '—').join(' ')}</span></div></div>`;
        } else {
          portraitHtml += '<div class="chart-panel"><div class="empty">PE spectrum unavailable</div></div>';
        }

        if (mseValid) {
          portraitHtml += `<div class="chart-panel"><canvas class="portrait-chart" id="mse-portrait"></canvas>
            <div class="latest-reading">latest: <span class="val">${mseLatest.map(v => v != null ? v.toFixed(3) : '—').join(' ')}</span></div></div>`;
        } else {
          portraitHtml += '<div class="chart-panel"><div class="empty">MSE curve unavailable</div></div>';
        }
        portraitHtml += '</div>';

        // KPI strip
        portraitHtml += '<div class="kpi-row" style="margin-top:1rem;">';
        portraitHtml += `<div class="kpi"><div class="k">COMPLEXITY INDEX</div><div class="v">${latest.complexity_index != null ? Number(latest.complexity_index).toFixed(3) : '—'}</div></div>`;
        portraitHtml += `<div class="kpi"><div class="k">LEMPEL-ZIV</div><div class="v">${latest.lempel_ziv_complexity != null ? Number(latest.lempel_ziv_complexity).toFixed(3) : '—'}</div></div>`;
        portraitHtml += `<div class="kpi"><div class="k">STATISTICAL COMPLEXITY</div><div class="v">${latest.statistical_complexity != null ? Number(latest.statistical_complexity).toFixed(4) : '—'}</div></div>`;
        portraitHtml += `<div class="kpi"><div class="k">PERMUTATION ENTROPY</div><div class="v">${latest.permutation_entropy != null ? Number(latest.permutation_entropy).toFixed(3) : '—'}</div></div>`;
        portraitHtml += '</div>';

        // ── Family trajectory sections ────────────────────────────────
        let familiesHtml = '';
        const chartIds = [];

        for (const fam of FAMILIES) {
          familiesHtml += `<div class="section-label">${fam.label}</div>`;
          familiesHtml += `<div class="section-desc">${fam.desc}</div>`;
          familiesHtml += '<div class="chart-row">';

          for (const dim of fam.dims) {
            const cid = `chart-${fam.id}-${dim.key}`;
            chartIds.push({ id: cid, key: dim.key });
            const latestVal = latest[dim.key];
            familiesHtml += `<div class="chart-panel">
              <h3>${dim.label}</h3>
              <canvas class="trajectory-chart" id="${cid}"></canvas>
              <div class="latest-reading">latest: <span class="val">${fmtRaw(latestVal)}</span></div>
            </div>`;
          }

          familiesHtml += '</div>';
        }

        // ── Ergodicity classification ─────────────────────────────────
        const ergoHtml = `
          <div class="section-label">Ergodicity classification</div>
          <div class="section-desc">Mangalam et al. 2022 (J. Royal Society Interface). Determines which signals are trustworthy as longitudinal trend estimators vs. valid only within-session.</div>
          <section class="panel">
            <table class="ergo-table">
              <thead>
                <tr>
                  <th>Ergodic (safe for trends)</th>
                  <th>Per-session (weight 0.5)</th>
                  <th>Structural (counts)</th>
                </tr>
              </thead>
              <tbody><tr>
                <td>
                  permutation_entropy<br>
                  dfa_alpha<br>
                  mfdfa_spectrum_width<br>
                  mfdfa_asymmetry<br>
                  temporal_irreversibility<br>
                  statistical_complexity<br>
                  forbidden_pattern_fraction<br>
                  weighted_pe<br>
                  lempel_ziv_complexity<br>
                  optn_transition_entropy<br>
                  rqa_determinism<br>
                  rqa_laminarity<br>
                  recurrence_transitivity<br>
                  recurrence_clustering<br>
                  causal_emergence_index<br>
                  pid_synergy<br>
                  pid_redundancy<br>
                  branching_ratio<br>
                  dmd_spectral_entropy<br>
                  complexity_index<br>
                  te_dominance<br>
                  commitment_ratio<br>
                  first_person_density<br>
                  cognitive_density<br>
                  hedging_density
                </td>
                <td>
                  iki_psd_spectral_slope<br>
                  iki_psd_lf_hf_ratio<br>
                  iki_psd_respiratory_peak_hz<br>
                  peak_typing_frequency_hz<br>
                  chars_per_minute<br>
                  inter_key_interval_mean<br>
                  hold_time_mean<br>
                  flight_time_mean<br>
                  ex_gaussian_tau<br>
                  ex_gaussian_mu<br>
                  motor_jerk<br>
                  tempo_drift<br>
                  sample_entropy<br>
                  dmd_dominant_frequency<br>
                  dmd_dominant_decay_rate
                </td>
                <td>
                  pause_mixture_component_count<br>
                  optn_forbidden_transition_count<br>
                  optimal_causal_scale<br>
                  dmd_mode_count<br>
                  pause_within_word<br>
                  pause_between_word<br>
                  pause_between_sentence<br>
                  abandoned_thought_count<br>
                  r_burst_count<br>
                  i_burst_count<br>
                  strategy_shift_count<br>
                  large_deletion_count
                </td>
              </tr></tbody>
            </table>
          </section>
        `;

        // Signal coverage
        const totalSignals = Object.keys(latest).filter(k => k !== 'question_id' && k !== 'date').length;
        const populated = Object.entries(latest).filter(([k, v]) => k !== 'question_id' && k !== 'date' && v != null).length;

        let coverageHtml = `<div class="kpi-row" style="margin-bottom:1.5rem;">`;
        coverageHtml += `<div class="kpi"><div class="k">SESSIONS</div><div class="v">${sessions.length}</div></div>`;
        coverageHtml += `<div class="kpi"><div class="k">LATEST SIGNAL COVERAGE</div><div class="v">${populated} / ${totalSignals}</div></div>`;
        coverageHtml += `<div class="kpi"><div class="k">LATEST DATE</div><div class="v">${latest.date ?? '—'}</div></div>`;
        coverageHtml += `</div>`;

        // Assemble
        document.getElementById('scales-content').innerHTML =
          coverageHtml + portraitHtml + familiesHtml + ergoHtml;

        // ── Draw charts ───────────────────────────────────────────────
        // PE Spectrum portrait
        if (peValid) {
          const peCanvas = document.getElementById('pe-portrait');
          const priorPE = priorSessions.map(s => s.pe_spectrum).filter(a => Array.isArray(a));
          drawMultiScaleChart(peCanvas, peLatest, priorPE, ['3','4','5','6','7'], 'var(--accent)', 'PE SPECTRUM (ORDERS 3-7)');
        }

        // MSE portrait
        if (mseValid) {
          const mseCanvas = document.getElementById('mse-portrait');
          const priorMSE = priorSessions.map(s => s.mse_series).filter(a => Array.isArray(a));
          drawMultiScaleChart(mseCanvas, mseLatest, priorMSE, ['1','2','3','4','5'], 'var(--semantic)', 'MSE CURVE (SCALES 1-5)');
        }

        // Family trajectories
        for (const { id, key } of chartIds) {
          const canvas = document.getElementById(id);
          if (!canvas) continue;
          const values = sessions.map(s => s[key] != null ? Number(s[key]) : null);
          drawRawChart(canvas, values, 'var(--accent)', dates);
        }
      }).catch(err => {
        document.getElementById('scales-content').innerHTML = `<div class="empty">failed to load: ${err?.message ?? err}</div>`;
      });
    </script>
  </body>
</html>
