---
import PublicLayout from '../../layouts/layPublic.astro';
import { getLogEntry } from '../../lib/libLog.ts';

const { slug } = Astro.params;
const entry = getLogEntry(slug!);

if (!entry) {
  return Astro.redirect('/log');
}
---

<PublicLayout title={`Alice -- ${entry.title}`} active="log" description={entry.excerpt}>

<article class="log-entry">

  <header class="le-header">
    <a href="/log" class="le-back">Log</a>
    <time class="le-date">{entry.date}</time>
    {entry.tags.length > 0 && (
      <span class="le-tags">{entry.tags.join(' / ')}</span>
    )}
    <h1 class="le-title">{entry.title}</h1>
  </header>

  <div class="le-body" set:html={entry.html} />

  <footer class="le-footer">
    <a href="/log">Back to log</a>
  </footer>

</article>

</PublicLayout>

<style is:global>
  .log-entry {
    padding-bottom: 4rem;
    max-width: 720px;
  }

  .le-header {
    padding: 5rem 0 2rem;
  }

  .le-back {
    font-family: var(--mono);
    font-size: 0.7rem;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--text-faint);
    text-decoration: none;
    transition: color 0.2s ease;
  }

  .le-back:hover {
    color: var(--text-muted);
  }

  .le-date {
    display: block;
    font-family: var(--mono);
    font-size: 0.7rem;
    letter-spacing: 0.08em;
    color: var(--text-faint);
    text-transform: uppercase;
    margin-top: 1.5rem;
  }

  .le-tags {
    font-family: var(--mono);
    font-size: 0.65rem;
    letter-spacing: 0.06em;
    color: var(--text-faint);
    margin-left: 0.75rem;
    text-transform: lowercase;
  }

  .le-title {
    font-family: var(--serif-display);
    font-size: 2rem;
    font-weight: 400;
    line-height: 1.35;
    color: var(--text);
    margin-top: 0.75rem;
  }

  /* --- Body (rendered markdown) --- */
  .le-body {
    padding-top: 2rem;
    border-top: 1px solid var(--border);
  }

  .le-body h2 {
    font-family: var(--serif-display);
    font-size: 1.4rem;
    font-weight: 400;
    color: var(--text);
    margin-top: 2.5rem;
    margin-bottom: 1rem;
  }

  .le-body h3 {
    font-family: var(--serif-display);
    font-size: 1.15rem;
    font-weight: 400;
    color: var(--text);
    margin-top: 2rem;
    margin-bottom: 0.75rem;
  }

  .le-body p {
    font-family: var(--serif-body);
    font-size: 1.05rem;
    line-height: 1.75;
    color: var(--text);
    margin-bottom: 1.25rem;
  }

  .le-body ul, .le-body ol {
    font-family: var(--serif-body);
    font-size: 1.05rem;
    line-height: 1.75;
    color: var(--text);
    margin-bottom: 1.25rem;
    padding-left: 1.5rem;
  }

  .le-body li {
    margin-bottom: 0.35rem;
  }

  .le-body code {
    font-family: var(--mono);
    font-size: 0.85em;
    background: var(--bg-dim);
    padding: 0.15rem 0.4rem;
    border-radius: 3px;
  }

  .le-body pre {
    background: var(--bg-dim);
    border: 1px solid var(--border);
    border-radius: 6px;
    padding: 1.25rem;
    overflow-x: auto;
    margin-bottom: 1.5rem;
  }

  .le-body pre code {
    background: none;
    padding: 0;
    font-size: 0.85rem;
    line-height: 1.5;
  }

  .le-body blockquote {
    font-family: var(--serif-body);
    font-style: italic;
    color: var(--text-muted);
    padding-left: 1.25rem;
    border-left: 2px solid var(--border);
    margin-bottom: 1.25rem;
  }

  .le-body a {
    color: var(--accent);
    text-decoration: none;
    border-bottom: 1px solid var(--border);
    transition: border-color 0.15s ease;
  }

  .le-body a:hover {
    border-bottom-color: var(--accent);
  }

  /* --- Footer --- */
  .le-footer {
    padding-top: 3rem;
    margin-top: 3rem;
    border-top: 1px solid var(--border);
  }

  .le-footer a {
    font-family: var(--serif-body);
    font-size: 1rem;
    color: var(--accent);
    text-decoration: none;
    border-bottom: 1px solid var(--border);
    padding-bottom: 0.15rem;
    transition: border-color 0.2s ease;
  }

  .le-footer a:hover {
    border-color: var(--accent);
  }

  @media (max-width: 768px) {
    .le-header { padding: 4rem 0 1.5rem; }
    .le-title { font-size: 1.5rem; }
  }
</style>
