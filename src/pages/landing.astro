---
import PublicLayout from '../layouts/PublicLayout.astro';
---

<PublicLayout title="Alice" active="home" minimal>

  <div class="landing">

    <section class="breath opening">
      <p>Alice asks you one question per day.</p>
    </section>

    <section class="breath">
      <p>You write.</p>
    </section>

    <section class="breath">
      <p>That's it.</p>
    </section>

    <section class="breath">
      <p>Your entries go in and do not come back out.</p>
    </section>

    <section class="breath">
      <p>Over time, a form emerges. A shape that is yours.</p>
    </section>

    <section class="breath closing">
      <a href="/auth/login" class="enter">Enter</a>
    </section>

  </div>

</PublicLayout>

<style is:global>
  .landing {
    max-width: 520px;
    margin: 0 auto;
    padding: 0 2rem;
  }

  .breath {
    min-height: 55vh;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .breath.opening {
    min-height: 85vh;
  }

  .breath.closing {
    min-height: 35vh;
    padding-bottom: 8rem;
  }

  .breath p {
    font-family: var(--serif-body);
    font-size: 1.2rem;
    line-height: 1.8;
    color: var(--text-muted);
    text-align: center;
    max-width: 400px;
  }

  .enter {
    font-family: var(--serif-body);
    font-size: 1rem;
    color: var(--text-faint);
    text-decoration: none;
  }

  .enter:hover {
    color: var(--text-muted);
    text-decoration: none;
  }

  @media (max-width: 768px) {
    .breath { min-height: 40vh; }
    .breath.opening { min-height: 60vh; }
    .breath p { font-size: 1.1rem; }
  }
</style>
