---
/**
 * Universal login page.
 *
 * Subjects and owner enter username + password, which POSTs to
 * /api/subject/login. The login handler issues the same session cookie
 * shape regardless of `is_owner`; the response body carries `isOwner` so
 * this page dispatches: owner → `/`, subject → `/subject` (or
 * `/reset-password` first if must_reset). Minimal UI — no nav, no chrome.
 */
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Alice</title>
    <script is:inline>
      (function() {
        var t = localStorage.getItem('alice-theme') || 'light';
        document.documentElement.setAttribute('data-theme', t);
      })();
    </script>
    <style is:global>
      @import url('https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,400;1,300;1,400&family=EB+Garamond:ital,wght@0,400;0,500;1,400&display=swap');

      :root {
        --bg: #f5f2ed;
        --text: #1a1a1a;
        --text-muted: #6b6560;
        --border: #ccc5bc;
        --border-focus: #8a8580;
        --bg-input: #ebe7e1;
        --btn-bg: #e0dbd5;
        --btn-hover: #ccc5bc;
      }

      [data-theme="dark"] {
        --bg: #141210;
        --text: #ffffff;
        --text-muted: #7a7570;
        --border: #333;
        --border-focus: #666;
        --bg-input: #161514;
        --btn-bg: #222;
        --btn-hover: #444;
      }

      * { margin: 0; padding: 0; box-sizing: border-box; }

      body {
        font-family: 'Cormorant Garamond', Georgia, serif;
        background: var(--bg);
        color: var(--text);
        min-height: 100vh;
        display: flex;
        align-items: center;
        justify-content: center;
      }

      .enter-container {
        text-align: center;
        max-width: 400px;
        padding: 2rem;
      }

      .enter-title {
        font-size: 1.8rem;
        font-weight: 300;
        margin-bottom: 2rem;
        color: var(--text-muted);
      }

      .enter-input {
        font-family: 'Cormorant Garamond', Georgia, serif;
        font-size: 1.2rem;
        width: 100%;
        padding: 0.8rem 1rem;
        background: var(--bg-input);
        border: 1px solid var(--border);
        border-radius: 6px;
        color: var(--text);
        text-align: center;
        letter-spacing: 0.05em;
        outline: none;
        transition: border-color 0.2s ease;
      }

      .enter-input:focus { border-color: var(--border-focus); }

      .enter-btn {
        font-family: 'Cormorant Garamond', Georgia, serif;
        font-size: 1.1rem;
        margin-top: 1rem;
        padding: 0.6rem 2rem;
        background: var(--btn-bg);
        border: 1px solid var(--border);
        border-radius: 6px;
        color: var(--text);
        cursor: pointer;
        transition: background 0.2s ease;
      }

      .enter-btn:hover { background: var(--btn-hover); }
      .enter-btn:disabled { opacity: 0.4; cursor: default; }

      .enter-error {
        color: #b5603f;
        font-size: 0.95rem;
        margin-top: 0.8rem;
        min-height: 1.4em;
      }
    </style>
  </head>
  <body>
    <div class="enter-container">
      <div class="enter-title">sign in</div>
      <input
        type="text"
        class="enter-input"
        id="username-input"
        placeholder="username"
        autocomplete="username"
        autocorrect="off"
        autocapitalize="off"
        spellcheck="false"
      />
      <br />
      <input
        type="password"
        class="enter-input"
        id="password-input"
        placeholder="password"
        autocomplete="current-password"
        style="margin-top: 0.6rem;"
      />
      <br />
      <button class="enter-btn" id="enter-btn" disabled>enter</button>
      <div class="enter-error" id="error-msg"></div>
    </div>

    <script>
      const usernameInput = document.getElementById('username-input') as HTMLInputElement;
      const passwordInput = document.getElementById('password-input') as HTMLInputElement;
      const btn = document.getElementById('enter-btn') as HTMLButtonElement;
      const errorMsg = document.getElementById('error-msg')!;

      function refreshDisabled() {
        btn.disabled = usernameInput.value.trim().length === 0
          || passwordInput.value.length === 0;
        errorMsg.textContent = '';
      }
      usernameInput.addEventListener('input', refreshDisabled);
      passwordInput.addEventListener('input', refreshDisabled);

      [usernameInput, passwordInput].forEach((el) => {
        el.addEventListener('keydown', (e: KeyboardEvent) => {
          if (e.key === 'Enter' && !btn.disabled) btn.click();
        });
      });

      btn.addEventListener('click', async () => {
        const username = usernameInput.value.trim();
        const password = passwordInput.value;
        if (!username || !password) return;

        btn.disabled = true;
        errorMsg.textContent = '';

        const res = await fetch('/api/subject/login', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ username, password }),
        });

        if (res.status === 401) {
          errorMsg.textContent = 'invalid credentials';
          passwordInput.value = '';
          refreshDisabled();
          return;
        }

        if (!res.ok) {
          errorMsg.textContent = 'server error, try again';
          btn.disabled = false;
          return;
        }

        const body = await res.json() as { mustResetPassword?: boolean; isOwner?: boolean };
        if (body.mustResetPassword) {
          window.location.href = '/reset-password';
          return;
        }
        // Honor `?next=` if same-origin, else dispatch by role.
        const params = new URLSearchParams(window.location.search);
        const next = params.get('next');
        if (next && next.startsWith('/') && !next.startsWith('//')) {
          window.location.href = next;
          return;
        }
        window.location.href = body.isOwner ? '/' : '/subject';
      });

      usernameInput.focus();
    </script>
  </body>
</html>
