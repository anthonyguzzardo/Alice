---
/**
 * Universal login page.
 *
 * Subjects and owner enter username + password, which POSTs to
 * /api/subject/login. The login handler issues the same session cookie
 * shape regardless of `is_owner`; the response body carries `isOwner` so
 * this page dispatches: owner → `/`, subject → `/subject` (or
 * `/reset-password` first if must_reset). Minimal UI — no nav, no chrome.
 */
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Alice</title>
    <script is:inline>
      (function() {
        var t = localStorage.getItem('alice-theme') || 'light';
        document.documentElement.setAttribute('data-theme', t);
      })();
    </script>
    <style is:global>
      @import url('/fonts/styFonts.css');

      :root {
        --bg: #f5f2ed;
        --text: #1a1a1a;
        --text-muted: #6b6560;
        --border: #ccc5bc;
        --border-focus: #8a8580;
        --bg-input: #ebe7e1;
        --btn-bg: #e0dbd5;
        --btn-hover: #ccc5bc;
      }

      [data-theme="dark"] {
        --bg: #141210;
        --text: #ffffff;
        --text-muted: #7a7570;
        --border: #333;
        --border-focus: #666;
        --bg-input: #161514;
        --btn-bg: #222;
        --btn-hover: #444;
      }

      * { margin: 0; padding: 0; box-sizing: border-box; }

      body {
        font-family: 'Cormorant Garamond', Georgia, serif;
        background: var(--bg);
        color: var(--text);
        min-height: 100vh;
        display: flex;
        align-items: center;
        justify-content: center;
      }

      .enter-container {
        text-align: center;
        max-width: 400px;
        padding: 2rem;
      }

      .enter-title {
        font-size: 1.8rem;
        font-weight: 300;
        margin-bottom: 2rem;
        color: var(--text-muted);
      }

      .enter-input {
        font-family: 'Cormorant Garamond', Georgia, serif;
        font-size: 1.2rem;
        width: 100%;
        padding: 0.8rem 1rem;
        background: var(--bg-input);
        border: 1px solid var(--border);
        border-radius: 6px;
        color: var(--text);
        text-align: center;
        letter-spacing: 0.05em;
        outline: none;
        transition: border-color 0.2s ease;
      }

      .enter-input:focus { border-color: var(--border-focus); }

      .enter-btn {
        font-family: 'Cormorant Garamond', Georgia, serif;
        font-size: 1.1rem;
        margin-top: 1rem;
        padding: 0.6rem 2rem;
        background: var(--btn-bg);
        border: 1px solid var(--border);
        border-radius: 6px;
        color: var(--text);
        cursor: pointer;
        transition: background 0.2s ease;
      }

      .enter-btn:hover { background: var(--btn-hover); }
      .enter-btn:disabled { opacity: 0.4; cursor: default; }

      .enter-error {
        color: #b5603f;
        font-size: 0.95rem;
        margin-top: 0.8rem;
        min-height: 1.4em;
      }
    </style>
  </head>
  <body>
    <div class="enter-container">
      <div class="enter-title">sign in</div>
      <input
        type="text"
        class="enter-input"
        id="username-input"
        placeholder="username"
        autocomplete="username"
        autocorrect="off"
        autocapitalize="off"
        spellcheck="false"
      />
      <br />
      <input
        type="password"
        class="enter-input"
        id="password-input"
        placeholder="password"
        autocomplete="current-password"
        style="margin-top: 0.6rem;"
      />
      <br />
      <button class="enter-btn" id="enter-btn" disabled>enter</button>
      <div class="enter-error" id="error-msg"></div>
    </div>

    <script>
      const usernameInput = document.getElementById('username-input') as HTMLInputElement;
      const passwordInput = document.getElementById('password-input') as HTMLInputElement;
      const btn = document.getElementById('enter-btn') as HTMLButtonElement;
      const errorMsg = document.getElementById('error-msg')!;

      function refreshDisabled() {
        btn.disabled = usernameInput.value.trim().length === 0
          || passwordInput.value.length === 0;
        errorMsg.textContent = '';
      }
      usernameInput.addEventListener('input', refreshDisabled);
      passwordInput.addEventListener('input', refreshDisabled);

      [usernameInput, passwordInput].forEach((el) => {
        el.addEventListener('keydown', (e: KeyboardEvent) => {
          if (e.key === 'Enter' && !btn.disabled) btn.click();
        });
      });

      function readNextParam(): string | null {
        const next = new URLSearchParams(window.location.search).get('next');
        // Same-origin absolute path only. The server re-validates this — the
        // client-side check is UX (don't bother sending a value the server is
        // guaranteed to drop). Path policy must match libSubjectAuth.isValidPostResetNextPath.
        if (!next || !next.startsWith('/') || next.startsWith('//')) return null;
        return next;
      }

      btn.addEventListener('click', async () => {
        const username = usernameInput.value.trim();
        const password = passwordInput.value;
        if (!username || !password) return;

        btn.disabled = true;
        errorMsg.textContent = '';

        const next = readNextParam();
        const res = await fetch('/api/subject/login', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          // `next` rides along so the server can stash it in a one-shot
          // HttpOnly cookie when the subject is being forced into a password
          // reset. After the reset the `next` cookie is read + cleared on
          // /api/subject/reset-password and returned in its JSON response,
          // so the second login lands at the original destination.
          body: JSON.stringify({ username, password, next }),
        });

        if (res.status === 401) {
          errorMsg.textContent = 'invalid credentials';
          passwordInput.value = '';
          refreshDisabled();
          return;
        }

        if (res.status === 429) {
          // Rate limited at the IP level (10 per 15 min). Surface the wait
          // time from the Retry-After header so the user knows it'll clear
          // on its own. Keep the button disabled — re-enabling would
          // encourage retries that are guaranteed to fail.
          const retryAfter = Number.parseInt(res.headers.get('retry-after') ?? '', 10);
          const waitMsg = Number.isFinite(retryAfter) && retryAfter > 0
            ? `too many attempts, wait ${retryAfter} seconds`
            : 'too many attempts, try again later';
          errorMsg.textContent = waitMsg;
          return;
        }

        if (res.status === 400) {
          // Malformed request (missing fields / invalid JSON). Client-side
          // validation already prevents the empty-fields case, so this
          // mostly fires on a JSON-parse failure or a manual fetch in
          // DevTools. Show the server's error code if present, generic
          // fallback otherwise.
          const body = await res.json().catch(() => ({})) as { error?: string };
          errorMsg.textContent = body.error === 'missing_credentials'
            ? 'username and password are required'
            : body.error === 'invalid_json'
              ? 'malformed request'
              : 'request rejected';
          btn.disabled = false;
          return;
        }

        if (!res.ok) {
          // 5xx and anything else — generic. Re-enable so a transient
          // server blip doesn't strand the user with no way to retry.
          errorMsg.textContent = 'server error, try again';
          btn.disabled = false;
          return;
        }

        const body = await res.json() as { mustResetPassword?: boolean; isOwner?: boolean };
        if (body.mustResetPassword) {
          window.location.href = '/reset-password';
          return;
        }
        // Honor `?next=` if same-origin, else dispatch by role.
        if (next) {
          window.location.href = next;
          return;
        }
        window.location.href = body.isOwner ? '/' : '/subject';
      });

      usernameInput.focus();
    </script>
  </body>
</html>
