<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Signal Sandbox</title>
    <script is:inline>
      (function() {
        var t = localStorage.getItem('alice-theme') || 'light';
        document.documentElement.setAttribute('data-theme', t);
      })();
    </script>
    <style is:global>
      @import url('https://fonts.googleapis.com/css2?family=EB+Garamond:ital,wght@0,400;0,500;1,400&display=swap');

      :root {
        --bg: #f5f2ed;
        --bg-input: #ebe7e1;
        --text: #1a1a1a;
        --text-muted: #6b6560;
        --text-faint: #9a9590;
        --border: #ccc5bc;
        --border-focus: #8a8580;
        --panel-bg: #ebe7e1;
        --metric-label: #6b6560;
        --metric-value: #1a1a1a;
        --section-border: #ddd8d2;
        --zero: #c5c0ba;
        --positive: #4a7c59;
        --negative: #8c4a4a;
        --bar-bg: #ddd8d2;
        --bar-fill: #8a8580;
      }

      [data-theme="dark"] {
        --bg: #0a0a0a;
        --bg-input: #161514;
        --text: #ffffff;
        --text-muted: #7a7570;
        --text-faint: #4a4540;
        --border: #333;
        --border-focus: #666;
        --panel-bg: #141312;
        --metric-label: #7a7570;
        --metric-value: #ffffff;
        --section-border: #2a2825;
        --zero: #4a4540;
        --positive: #6aaa79;
        --negative: #bb6a6a;
        --bar-bg: #2a2825;
        --bar-fill: #7a7570;
      }

      * { margin: 0; padding: 0; box-sizing: border-box; }

      html, body {
        min-height: 100%;
        background: var(--bg);
        color: var(--text);
        font-family: 'EB Garamond', Georgia, serif;
      }

      body {
        display: flex;
        padding: 2rem 2rem 6rem;
        gap: 2rem;
        max-width: 1800px;
        margin: 0 auto;
      }

      .write-col {
        flex: 0 0 420px;
        display: flex;
        flex-direction: column;
        position: sticky;
        top: 2rem;
        align-self: flex-start;
        max-height: calc(100vh - 4rem);
      }

      .header {
        display: flex;
        align-items: baseline;
        gap: 1.5rem;
        margin-bottom: 1.5rem;
      }

      .back-btn {
        color: var(--text-muted);
        text-decoration: none;
        font-size: 1.3rem;
        transition: color 0.2s;
      }

      .back-btn:hover {
        color: var(--text);
      }

      .header h1 {
        font-size: 1.3rem;
        font-weight: 400;
        color: var(--text-muted);
        letter-spacing: 0.08em;
        text-transform: uppercase;
      }

      .mode-toggle {
        display: flex;
        gap: 0.5rem;
      }

      .mode-btn {
        background: none;
        border: 1px solid var(--border);
        border-radius: 4px;
        color: var(--text-muted);
        font-family: inherit;
        font-size: 0.95rem;
        padding: 0.3rem 0.8rem;
        cursor: pointer;
        transition: all 0.2s;
      }

      .mode-btn.active {
        background: var(--border);
        color: var(--text);
      }

      .mode-btn:hover:not(.active) {
        border-color: var(--border-focus);
      }

      .reset-btn {
        background: none;
        border: 1px solid var(--border);
        border-radius: 4px;
        color: var(--text-faint);
        font-family: inherit;
        font-size: 0.85rem;
        padding: 0.2rem 0.6rem;
        cursor: pointer;
        margin-left: auto;
      }

      .reset-btn:hover {
        color: var(--negative);
        border-color: var(--negative);
      }

      .prompt-question {
        font-family: 'EB Garamond', Georgia, serif;
        font-size: 1.3rem;
        font-style: italic;
        font-weight: 400;
        color: var(--text-muted);
        margin-bottom: 0.8rem;
        line-height: 1.4;
      }

      .prompt-label {
        font-size: 1rem;
        color: var(--text-faint);
        margin-bottom: 0.8rem;
        font-style: italic;
      }

      textarea {
        width: 100%;
        flex: 1;
        min-height: 300px;
        background: var(--bg-input);
        border: 1px solid var(--border);
        border-radius: 4px;
        color: var(--text);
        font-family: inherit;
        font-size: 1.15rem;
        line-height: 1.7;
        padding: 1.2rem;
        resize: none;
        outline: none;
      }

      textarea:focus { border-color: var(--border-focus); }

      .submit-row {
        margin-top: 1rem;
      }

      .submit-row.hidden {
        opacity: 0;
        pointer-events: none;
        transition: opacity 0.6s ease;
      }

      .submit-row.visible {
        opacity: 1;
        pointer-events: auto;
        transition: opacity 0.6s ease;
      }

      .submit-btn {
        background: var(--panel-bg);
        border: 1px solid var(--border);
        border-radius: 4px;
        color: var(--text);
        font-family: inherit;
        font-size: 1.1rem;
        padding: 0.6rem 1.8rem;
        cursor: pointer;
        transition: all 0.2s;
      }

      .submit-btn:hover:not(:disabled) {
        border-color: var(--border-focus);
      }

      .submit-btn:disabled {
        opacity: 0.3;
        cursor: default;
      }

      .metrics-col {
        flex: 1;
        min-width: 0;
      }

      .metrics-grid {
        display: grid;
        grid-template-columns: repeat(3, 1fr);
        gap: 1rem;
        padding-bottom: 4rem;
      }

      .section {
        background: var(--panel-bg);
        border: 1px solid var(--section-border);
        border-radius: 4px;
        padding: 0.8rem 1rem;
      }

      .section-title {
        font-size: 0.7rem;
        text-transform: uppercase;
        letter-spacing: 0.12em;
        color: var(--text-faint);
        margin-bottom: 0.5rem;
      }

      .metric-row {
        display: flex;
        justify-content: space-between;
        align-items: baseline;
        padding: 0.1rem 0;
        font-size: 0.85rem;
      }

      .metric-label {
        color: var(--metric-label);
      }

      .metric-value {
        color: var(--metric-value);
        font-variant-numeric: tabular-nums;
        min-width: 50px;
        text-align: right;
      }

      .metric-value.zero { color: var(--zero); }
      .metric-value.positive { color: var(--positive); }
      .metric-value.negative { color: var(--negative); }

      .delta-section {
        background: var(--panel-bg);
        border: 1px solid var(--section-border);
        border-radius: 4px;
        padding: 0.8rem 1rem;
        grid-column: 1 / -1;
      }

      .delta-section .section-title {
        color: var(--text-muted);
      }

      .burst-bar {
        display: flex;
        gap: 2px;
        height: 18px;
        margin-top: 0.4rem;
        align-items: flex-end;
      }

      .burst-segment {
        background: var(--bar-fill);
        border-radius: 1px;
        min-width: 3px;
        transition: height 0.15s;
      }

      .status-line {
        font-size: 0.85rem;
        color: var(--text-faint);
        margin-top: 0.5rem;
        font-style: italic;
      }

      .info-toggle {
        background: none;
        border: 1px solid var(--border);
        border-radius: 4px;
        color: var(--text-faint);
        font-family: inherit;
        font-size: 0.85rem;
        padding: 0.3rem 0.8rem;
        cursor: pointer;
        width: 100%;
        text-align: left;
        margin-bottom: 0.8rem;
        transition: all 0.2s;
      }

      .info-toggle:hover {
        color: var(--text-muted);
        border-color: var(--border-focus);
      }

      .info-panel {
        display: none;
        font-size: 0.85rem;
        color: var(--text-muted);
        line-height: 1.6;
      }

      .info-panel.open { display: block; }

      .info-panel dt {
        color: var(--text);
        font-weight: 500;
        margin-top: 0.8rem;
      }

      .info-panel dt:first-child { margin-top: 0; }

      .info-panel dd {
        margin-left: 0;
        margin-bottom: 0.4rem;
        color: var(--text-muted);
      }

      .info-panel .cite {
        color: var(--text-faint);
        font-size: 0.8rem;
      }
    </style>
  </head>
  <body>
    <div class="write-col">
      <div class="header">
        <a href="/" class="back-btn" aria-label="Back to Alice">&larr;</a>
        <h1>Signal Sandbox</h1>
        <div class="mode-toggle">
          <button class="mode-btn active" id="mode-journal">Journal</button>
          <button class="mode-btn" id="mode-calib">Calibration</button>
        </div>
        <button class="reset-btn" id="reset">Reset</button>
        <button class="mode-btn" id="theme-toggle" style="margin-left: 0.5rem;"></button>
      </div>
      <div class="prompt-question" id="prompt-question"></div>
      <div class="prompt-label" id="prompt-label">Write anything. Metrics update live.</div>
      <textarea id="input" autocomplete="off" autocorrect="off" autocapitalize="off" spellcheck="false" autofocus></textarea>
      <div class="submit-row hidden" id="submit-row">
        <button class="submit-btn" id="submit" disabled>Submit</button>
      </div>
    </div>

    <div class="metrics-col">
      <button class="info-toggle" id="info-toggle">What do these numbers mean?</button>
      <div class="info-panel" id="info-panel">
        <dl>
          <dt>P-Burst (Production Burst)</dt>
          <dd>A continuous run of typing with no pause longer than 2 seconds. Each burst roughly maps to one "thought unit." Longer bursts = more fluent, ideas flowing. Short bursts = more fragmented, stop-and-think processing.</dd>
          <dd class="cite">Chenoweth & Hayes, 2001</dd>

          <dt>IKI (Inter-Key Interval)</dt>
          <dd>Milliseconds between consecutive keystrokes, capped at 5s. The mean captures average hesitation — higher = more deliberation per keystroke. The std dev captures consistency — high means you alternate between rapid and slow typing.</dd>
          <dd class="cite">Epp et al., 2011 (CHI)</dd>

          <dt>Commitment Ratio</dt>
          <dd>Final character count divided by total characters typed (including deleted). Low ratio = heavy self-editing. A ratio of 1.0 means you kept everything you typed.</dd>

          <dt>Large vs Small Deletions</dt>
          <dd>Small deletions (&lt;10 chars) are corrections — typos, word swaps. Large deletions (&ge;10 chars) are revisions — rethinking what you meant. The split between first-half and second-half deletion chars shows whether revision happens early (planning) or late (restructuring).</dd>
          <dd class="cite">Faigley & Witte, 1981</dd>

          <dt>Revision Chains</dt>
          <dd>Sequential deletion keystrokes within 500ms of each other count as one chain. More chains = more revision episodes. Longer chains = deeper per-episode rethinking.</dd>
          <dd class="cite">Leijten & Van Waes, 2013</dd>

          <dt>Hold Time / Flight Time</dt>
          <dd>Hold time = how long a key is pressed (keydown to keyup). Measures motor execution — tremor, rigidity, finger coordination. Flight time = gap between releasing one key and pressing the next. Measures cognitive planning — word retrieval, sentence planning. These are independent signals collapsed into IKI by most tools.</dd>
          <dd class="cite">Kim et al., 2024 (JMIR)</dd>

          <dt>Keystroke Entropy</dt>
          <dd>Shannon entropy of the inter-key interval distribution. Measures how unpredictable your typing rhythm is. High entropy = irregular, switching between fast bursts and long pauses. Low entropy = metronomic, consistent rhythm. Different from IKI std — entropy captures the shape of the distribution, not just its spread. Correlated with executive function at d=-1.28.</dd>
          <dd class="cite">Ajilore et al., 2025 (BiAffect/Frontiers in Psychiatry)</dd>

          <dt>Permutation Entropy</dt>
          <dd>Ordinal pattern distribution of consecutive IKI triplets. Instead of looking at timing values, looks at their rank order (is this interval faster, slower, or middle?). High = all patterns equally likely, genuinely novel composition. Low = habitual rhythm, cognitive autopilot. Invariant to device differences and caffeine.</dd>
          <dd class="cite">Bandt & Pompe, 2002</dd>

          <dt>DFA Alpha (Fractal Scaling)</dt>
          <dd>Detrended Fluctuation Analysis exponent. Measures whether your keystroke timing has fractal structure. ~0.5 = white noise (no structure, copying). ~0.7-0.9 = pink/1/f noise (long-range correlations, healthy engaged cognition). ~1.0+ = brown noise (over-correlated, perseveration).</dd>
          <dd class="cite">Peng et al., 1994; Van Orden et al., 2003</dd>

          <dt>RQA (Recurrence Quantification)</dt>
          <dd>Treats the IKI series as a trajectory through cognitive state space. Determinism = how predictable the trajectory is. Laminarity = how often the system gets stuck in a state (fixation). Trapping time = how long stuck states last. High determinism + high laminarity = deep structured processing.</dd>
          <dd class="cite">Webber & Zbilut, 2005</dd>

          <dt>Transfer Entropy</dt>
          <dd>Causal information flow between hold times (motor) and flight times (cognitive). TE hold-to-flight = motor driving cognition (automatic writing, fingers know before mind). TE flight-to-hold = cognition driving motor (deliberate writing, each keystroke decided). The dominance ratio shows which direction controls.</dd>
          <dd class="cite">Schreiber, 2000</dd>

          <dt>Mouse/Cursor Trajectory</dt>
          <dd>Cursor movement sampled every 200ms during typing pauses (>2s). Cursor distance = total px moved while not typing. Fidget ratio = distance per ms of active typing (involuntary motor restlessness). Stillness = proportion of pause samples with &lt;5px movement. Drift-to-submit = how many times the cursor entered the submit button during a pause then left (hesitation-to-commit signal).</dd>
          <dd class="cite">BioCatch (Unit 8200 cognitive biometrics)</dd>

          <dt>Error Correction</dt>
          <dd>Three-phase model: deletion execution speed = mean IKI within deletion chains (how fast you delete once you start). Postcorrection latency = ms from last delete to next insert (cognitive re-planning after an error). Separates motor automaticity from the thinking required to recover.</dd>
          <dd class="cite">Springer, 2021</dd>

          <dt>Revision Distance</dt>
          <dd>How far back from the leading edge (end of text) the cursor is when a deletion happens. Mean revision distance captures typical reach-back depth. Max revision distance captures the deepest restructuring event. Deep revisions indicate rethinking structure, not fixing typos.</dd>
          <dd class="cite">Lindgren & Sullivan, 2006 (ScriptLog)</dd>

          <dt>Punctuation Latency</dt>
          <dd>Flight time (key release to next key press) before punctuation keys vs. letter keys. Punctuation requires syntactic decisions (where to end a clause, whether to use a comma). The ratio captures how much harder punctuation placement is relative to word production. Higher ratio = more syntactic planning load.</dd>
          <dd class="cite">Plank, 2016 (COLING)</dd>

          <dt>Linguistic Densities</dt>
          <dd>Word category counts divided by total words. NRC emotion categories (anger, fear, joy, sadness, trust, anticipation) come from the NRC Emotion Lexicon. Cognitive, hedging, and first-person densities come from Pennebaker's LIWC categories. Slopes of these over time are the real signal.</dd>
          <dd class="cite">Mohammad & Turney, 2013; Pennebaker, 2011</dd>

          <dt>Session Delta</dt>
          <dd>Journal value minus calibration value across 7 dimensions. Isolates what the reflective question provoked beyond your neutral writing behavior. Same person, same keyboard, same day — any shift came from the prompt, not the typist. In production, these get z-normalized against your personal history after 10+ sessions.</dd>
        </dl>
      </div>
      <div id="metrics">
        <!-- Populated by JS -->
      </div>
    </div>

    <script>
      const textarea = document.getElementById('input') as HTMLTextAreaElement;
      const metricsEl = document.getElementById('metrics')!;
      const infoToggle = document.getElementById('info-toggle')!;
      const infoPanel = document.getElementById('info-panel')!;

      // Theme toggle
      const themeBtn = document.getElementById('theme-toggle')!;
      const savedTheme = localStorage.getItem('alice-theme') || 'light';
      document.documentElement.setAttribute('data-theme', savedTheme);
      themeBtn.textContent = savedTheme === 'dark' ? '☀' : '☾';

      themeBtn.addEventListener('click', () => {
        const current = document.documentElement.getAttribute('data-theme');
        const next = current === 'dark' ? 'light' : 'dark';
        document.documentElement.setAttribute('data-theme', next);
        localStorage.setItem('alice-theme', next);
        themeBtn.textContent = next === 'dark' ? '☀' : '☾';
      });

      infoToggle.addEventListener('click', () => {
        infoPanel.classList.toggle('open');
        infoToggle.textContent = infoPanel.classList.contains('open')
          ? 'Hide explanations'
          : 'What do these numbers mean?';
      });
      const resetBtn = document.getElementById('reset')!;
      const submitBtn = document.getElementById('submit') as HTMLButtonElement;
      const submitRow = document.getElementById('submit-row')!;
      const modeJournalBtn = document.getElementById('mode-journal')!;
      const modeCalibBtn = document.getElementById('mode-calib')!;
      const promptQuestion = document.getElementById('prompt-question')!;
      const promptLabel = document.getElementById('prompt-label')!;

      // ── State ──────────────────────────────────────────────
      type Mode = 'journal' | 'calibration';
      let mode: Mode = 'journal';
      let savedCalibMetrics: Record<string, any> | null = null;
      let savedJournalMetrics: Record<string, any> | null = null;

      let pageOpenTime = Date.now();
      let firstKeystrokeTime: number | null = null;
      let firstKeystrokeSent = false;
      let pauseTimer: number | null = null;
      let isPaused = false;
      let pauseStartTime: number | null = null;
      let totalPauseMs = 0;
      let pauseCount = 0;
      let totalCharsTyped = 0;
      let totalCharsDeleted = 0;
      let deletionCount = 0;
      let largestDeletion = 0;
      let lastTextLength = 0;
      let tabAwayCount = 0;
      let tabAwayStartTime: number | null = null;
      let totalTabAwayMs = 0;

      // Faigley & Witte deletion decomposition
      let smallDeletionCount = 0;
      let largeDeletionCount = 0;
      let largeDeletionChars = 0;
      const deletionTimestamps: Array<{chars: number; time: number}> = [];

      // P-burst tracking (Chenoweth & Hayes)
      let lastInputTime: number | null = null;
      let currentBurstChars = 0;
      let burstStartTime: number | null = null;
      const burstLengths: number[] = [];
      const burstSequence: Array<{chars: number; startOffsetMs: number; durationMs: number}> = [];

      // Keystroke dynamics (Epp et al. 2011)
      let lastKeystrokeTime: number | null = null;
      const interKeyIntervals: number[] = [];
      let currentRevisionChainLength = 0;
      let lastDeletionTime: number | null = null;
      const revisionChains: number[] = [];

      // Hold time + flight time decomposition (Kim et al. 2024)
      const holdTimes: number[] = [];
      const flightTimes: number[] = [];
      let lastKeyupTime: number | null = null;
      const keydownTimes = new Map<string, number>();

      // Raw keystroke stream for dynamical signals
      const keystrokeStream: Array<{c: string; d: number; u: number}> = [];

      // Scroll tracking
      let scrollBackCount = 0;
      let lastScrollTop = 0;

      // Linguistic densities (from server)
      let linguisticDensities: Record<string, number> = {};
      let linguisticDebounce: number | null = null;

      // ── Mode switching ─────────────────────────────────────
      function setMode(m: Mode) {
        // Save current metrics before switching
        const currentMetrics = computeAllMetrics();
        if (mode === 'calibration') savedCalibMetrics = { ...currentMetrics, ...linguisticDensities };
        if (mode === 'journal') savedJournalMetrics = { ...currentMetrics, ...linguisticDensities };

        mode = m;
        modeJournalBtn.classList.toggle('active', m === 'journal');
        modeCalibBtn.classList.toggle('active', m === 'calibration');
        updatePrompt();

        resetSession();
      }

      const journalPrompts = [
        'This is a deep question?',
        'How does this question make you feel?',
        'Write something that matters. Or don\'t.',
        'What if you just typed words right now?',
        'Reflect on the act of reflecting.',
      ];

      const calibrationPrompts = [
        'The word color is spelled in this sentence.',
        'Type some words here. Any words. These ones work.',
        'This prompt is intentionally unremarkable.',
        'Describe something you don\'t care about.',
        'Write normally. Whatever that means.',
      ];

      function pickRandom(arr: string[]): string {
        return arr[Math.floor(Math.random() * arr.length)];
      }

      function updatePrompt() {
        if (mode === 'journal') {
          promptQuestion.textContent = pickRandom(journalPrompts);
          promptLabel.textContent = 'Journal mode — write reflectively.';
        } else {
          promptQuestion.textContent = pickRandom(calibrationPrompts);
          promptLabel.textContent = 'Calibration mode — write something neutral.';
        }
      }

      modeJournalBtn.addEventListener('click', () => setMode('journal'));
      modeCalibBtn.addEventListener('click', () => setMode('calibration'));

      resetBtn.addEventListener('click', () => {
        savedCalibMetrics = null;
        savedJournalMetrics = null;
        resetSession();
      });

      submitBtn.addEventListener('click', async () => {
        if (!textarea.value.trim()) return;

        // Fetch final linguistic densities before snapshot
        await fetchLinguistic(textarea.value);

        const snapshot = { ...computeAllMetrics(), ...linguisticDensities };
        if (mode === 'calibration') {
          savedCalibMetrics = snapshot;
          setMode('journal');
        } else {
          savedJournalMetrics = snapshot;
          if (!savedCalibMetrics) {
            setMode('calibration');
          } else {
            // Both done — just reset the textarea, keep deltas visible
            resetSession();
          }
        }
      });

      function resetSession() {
        textarea.value = '';
        pageOpenTime = Date.now();
        firstKeystrokeTime = null;
        firstKeystrokeSent = false;
        if (pauseTimer) clearTimeout(pauseTimer);
        isPaused = false;
        pauseStartTime = null;
        totalPauseMs = 0;
        pauseCount = 0;
        totalCharsTyped = 0;
        totalCharsDeleted = 0;
        deletionCount = 0;
        largestDeletion = 0;
        lastTextLength = 0;
        tabAwayCount = 0;
        tabAwayStartTime = null;
        totalTabAwayMs = 0;
        smallDeletionCount = 0;
        largeDeletionCount = 0;
        largeDeletionChars = 0;
        deletionTimestamps.length = 0;
        lastInputTime = null;
        currentBurstChars = 0;
        burstStartTime = null;
        burstLengths.length = 0;
        burstSequence.length = 0;
        lastKeystrokeTime = null;
        interKeyIntervals.length = 0;
        currentRevisionChainLength = 0;
        lastDeletionTime = null;
        revisionChains.length = 0;
        holdTimes.length = 0;
        flightTimes.length = 0;
        lastKeyupTime = null;
        keydownTimes.clear();
        keystrokeStream.length = 0;
        scrollBackCount = 0;
        lastScrollTop = 0;
        linguisticDensities = {};
        submitRow.classList.add('hidden');
        submitRow.classList.remove('visible');
        submitBtn.disabled = true;
        renderMetrics();
        textarea.focus();
      }

      // ── Keystroke tracking ─────────────────────────────────
      textarea.addEventListener('scroll', () => {
        if (textarea.scrollTop < lastScrollTop && lastScrollTop > 0) {
          scrollBackCount++;
        }
        lastScrollTop = textarea.scrollTop;
      });

      textarea.addEventListener('keydown', (e: KeyboardEvent) => {
        const now = Date.now();

        // Skip auto-repeat events from held keys
        if (!e.repeat) {
          if (lastKeystrokeTime !== null) {
            const interval = now - lastKeystrokeTime;
            if (interval < 5000) interKeyIntervals.push(interval);
          }
          lastKeystrokeTime = now;

          // Hold time: record keydown timestamp per key (Kim et al. 2024)
          keydownTimes.set(e.code, now);

          // Flight time: keyup[n-1] → keydown[n]
          if (lastKeyupTime !== null) {
            const ft = now - lastKeyupTime;
            if (ft > 0 && ft < 5000) flightTimes.push(ft);
          }
        }

        if (e.key === 'Backspace' || e.key === 'Delete') {
          if (lastDeletionTime !== null && (now - lastDeletionTime) < 500) {
            currentRevisionChainLength++;
          } else {
            if (currentRevisionChainLength > 0) revisionChains.push(currentRevisionChainLength);
            currentRevisionChainLength = 1;
          }
          lastDeletionTime = now;
        } else {
          if (currentRevisionChainLength > 0) {
            revisionChains.push(currentRevisionChainLength);
            currentRevisionChainLength = 0;
          }
        }
      });

      // Hold time: keydown → keyup per key (motor execution duration)
      textarea.addEventListener('keyup', (e: KeyboardEvent) => {
        const now = Date.now();
        lastKeyupTime = now;
        const downTime = keydownTimes.get(e.code);
        if (downTime != null) {
          const ht = now - downTime;
          if (ht > 0 && ht < 2000) {
            holdTimes.push(ht);
            keystrokeStream.push({
              c: e.code,
              d: downTime - pageOpenTime,
              u: now - pageOpenTime,
            });
          }
          keydownTimes.delete(e.code);
        }
      });

      textarea.addEventListener('input', () => {
        const now = Date.now();
        const currentLength = textarea.value.length;
        const delta = currentLength - lastTextLength;

        if (delta > 0) {
          totalCharsTyped += delta;

          // P-burst: 2s gap = new burst
          if (lastInputTime !== null && (now - lastInputTime) > 2000) {
            if (currentBurstChars > 0) {
              burstLengths.push(currentBurstChars);
              burstSequence.push({
                chars: currentBurstChars,
                startOffsetMs: (burstStartTime ?? now) - pageOpenTime,
                durationMs: lastInputTime - (burstStartTime ?? lastInputTime),
              });
            }
            currentBurstChars = 0;
            burstStartTime = now;
          }
          if (burstStartTime === null) burstStartTime = now;
          currentBurstChars += delta;
          lastInputTime = now;
        } else if (delta < 0) {
          const deleted = Math.abs(delta);
          totalCharsDeleted += deleted;
          deletionCount++;
          if (deleted > largestDeletion) largestDeletion = deleted;

          if (deleted < 10) {
            smallDeletionCount++;
          } else {
            largeDeletionCount++;
            largeDeletionChars += deleted;
          }
          deletionTimestamps.push({ chars: deleted, time: now });
        }

        lastTextLength = currentLength;

        // Enable/show submit
        submitBtn.disabled = !textarea.value.trim();
        if (textarea.value.trim() && submitRow.classList.contains('hidden')) {
          submitRow.classList.remove('hidden');
          submitRow.classList.add('visible');
        }

        if (!firstKeystrokeSent && delta > 0) {
          firstKeystrokeTime = Date.now();
          firstKeystrokeSent = true;
        }

        if (isPaused) {
          if (pauseStartTime) {
            totalPauseMs += Date.now() - pauseStartTime;
            pauseStartTime = null;
          }
          isPaused = false;
        }

        if (pauseTimer) clearTimeout(pauseTimer);
        pauseTimer = window.setTimeout(() => {
          if (firstKeystrokeSent) {
            pauseCount++;
            pauseStartTime = Date.now();
            isPaused = true;
            renderMetrics();
          }
        }, 30000);

        // Debounced linguistic density fetch
        if (linguisticDebounce) clearTimeout(linguisticDebounce);
        linguisticDebounce = window.setTimeout(() => {
          fetchLinguistic(textarea.value);
        }, 400);

        renderMetrics();
      });

      document.addEventListener('visibilitychange', () => {
        if (document.hidden) {
          tabAwayStartTime = Date.now();
          if (currentBurstChars > 0) {
            burstLengths.push(currentBurstChars);
            burstSequence.push({
              chars: currentBurstChars,
              startOffsetMs: (burstStartTime ?? Date.now()) - pageOpenTime,
              durationMs: Date.now() - (burstStartTime ?? Date.now()),
            });
            currentBurstChars = 0;
            burstStartTime = null;
          }
        } else {
          if (tabAwayStartTime) {
            totalTabAwayMs += Date.now() - tabAwayStartTime;
            tabAwayCount++;
            tabAwayStartTime = null;
          }
          renderMetrics();
        }
      });

      // ── Linguistic fetch ───────────────────────────────────
      async function fetchLinguistic(text: string) {
        if (!text.trim()) {
          linguisticDensities = {};
          renderMetrics();
          return;
        }
        try {
          const res = await fetch('/api/dev/linguistic', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ text }),
          });
          if (res.ok) {
            linguisticDensities = await res.json();
            renderMetrics();
          }
        } catch { /* ignore */ }
      }

      // ── Dynamical signal computation (client-side) ─────────
      function computePermutationEntropy(series: number[], order = 3): { normalized: number; raw: number } | null {
        if (series.length < order + 10) return null;
        const patternCounts = new Map<string, number>();
        const n = series.length - order + 1;
        for (let i = 0; i < n; i++) {
          const w = series.slice(i, i + order);
          const idx = Array.from({ length: order }, (_, k) => k);
          idx.sort((a, b) => w[a] - w[b]);
          const key = idx.join(',');
          patternCounts.set(key, (patternCounts.get(key) ?? 0) + 1);
        }
        let entropy = 0;
        for (const count of patternCounts.values()) {
          const p = count / n;
          if (p > 0) entropy -= p * Math.log2(p);
        }
        let factorial = 1;
        for (let i = 2; i <= order; i++) factorial *= i;
        const maxEntropy = Math.log2(factorial);
        return { normalized: maxEntropy > 0 ? entropy / maxEntropy : 0, raw: entropy };
      }

      function computeDFA(series: number[]): number | null {
        if (series.length < 50) return null;
        const N = series.length;
        const mean = series.reduce((a, b) => a + b, 0) / N;
        const y = new Array(N);
        y[0] = series[0] - mean;
        for (let i = 1; i < N; i++) y[i] = y[i - 1] + (series[i] - mean);
        const minBox = 4, maxBox = Math.floor(N / 4);
        if (maxBox < minBox) return null;
        const logS: number[] = [], logF: number[] = [];
        const numSizes = Math.min(15, maxBox - minBox + 1);
        for (let i = 0; i < numSizes; i++) {
          const boxSize = Math.round(minBox * Math.pow(maxBox / minBox, i / (numSizes - 1)));
          if (logS.length > 0 && boxSize === logS[logS.length - 1]) continue;
          const numBoxes = Math.floor(N / boxSize);
          if (numBoxes < 2) continue;
          let sumF = 0;
          for (let b = 0; b < numBoxes; b++) {
            const start = b * boxSize;
            let sx = 0, sy = 0, sxx = 0, sxy = 0;
            for (let j = 0; j < boxSize; j++) { sx += j; sy += y[start + j]; sxx += j * j; sxy += j * y[start + j]; }
            const denom = boxSize * sxx - sx * sx;
            const slope = denom !== 0 ? (boxSize * sxy - sx * sy) / denom : 0;
            const intercept = (sy - slope * sx) / boxSize;
            let ss = 0;
            for (let j = 0; j < boxSize; j++) { const t = intercept + slope * j; ss += (y[start + j] - t) ** 2; }
            sumF += Math.sqrt(ss / boxSize);
          }
          const F = sumF / numBoxes;
          if (F > 0) { logS.push(Math.log(boxSize)); logF.push(Math.log(F)); }
        }
        if (logS.length < 4) return null;
        const n = logS.length;
        let sx = 0, sy = 0, sxx = 0, sxy = 0;
        for (let i = 0; i < n; i++) { sx += logS[i]; sy += logF[i]; sxx += logS[i] ** 2; sxy += logS[i] * logF[i]; }
        const d = n * sxx - sx * sx;
        return Math.abs(d) < 1e-10 ? null : (n * sxy - sx * sy) / d;
      }

      function computeRQA(series: number[]): { determinism: number; laminarity: number; trappingTime: number; recurrenceRate: number } | null {
        const N = series.length;
        if (N < 30) return null;
        const mean = series.reduce((a, b) => a + b, 0) / N;
        const std = Math.sqrt(series.reduce((s, v) => s + (v - mean) ** 2, 0) / N);
        const eps = std * 0.2;
        if (eps <= 0) return null;
        const M = Math.min(N, 500);
        let totalRec = 0, diagPts = 0, vertPts = 0, vertLen = 0, vertLines = 0;
        for (let k = 1; k < M; k++) {
          let ll = 0;
          for (let i = 0; i < M - k; i++) {
            if (Math.abs(series[i] - series[i + k]) <= eps) { totalRec++; ll++; }
            else { if (ll >= 2) diagPts += ll; ll = 0; }
          }
          if (ll >= 2) diagPts += ll;
        }
        for (let j = 0; j < M; j++) {
          let ll = 0;
          for (let i = 0; i < M; i++) {
            if (i === j) continue;
            if (Math.abs(series[i] - series[j]) <= eps) { ll++; }
            else { if (ll >= 2) { vertPts += ll; vertLen += ll; vertLines++; } ll = 0; }
          }
          if (ll >= 2) { vertPts += ll; vertLen += ll; vertLines++; }
        }
        const pairs = M * (M - 1) / 2;
        return {
          determinism: Math.min(1, totalRec > 0 ? diagPts / totalRec : 0),
          laminarity: Math.min(1, totalRec > 0 ? vertPts / (totalRec * 2) : 0),
          trappingTime: vertLines > 0 ? vertLen / vertLines : 0,
          recurrenceRate: pairs > 0 ? totalRec / pairs : 0,
        };
      }

      function computeTransferEntropy(source: number[], target: number[]): number | null {
        const N = Math.min(source.length, target.length);
        if (N < 30) return null;
        function disc(arr: number[]): number[] {
          const sorted = [...arr].sort((a, b) => a - b);
          const t1 = sorted[Math.floor(sorted.length / 3)];
          const t2 = sorted[Math.floor(2 * sorted.length / 3)];
          return arr.map(v => v <= t1 ? 0 : v <= t2 ? 1 : 2);
        }
        const S = disc(source.slice(0, N)), T = disc(target.slice(0, N));
        const counts: Record<string, number> = {}, cT: Record<string, number> = {}, cTS: Record<string, number> = {}, cTn: Record<string, number> = {};
        let total = 0;
        for (let i = 1; i < N - 1; i++) {
          const tP = T[i - 1], sP = S[i - 1], tN = T[i];
          const kF = `${tN},${tP},${sP}`, kT = `${tP}`, kTS = `${tP},${sP}`, kTn = `${tN},${tP}`;
          counts[kF] = (counts[kF] ?? 0) + 1;
          cT[kT] = (cT[kT] ?? 0) + 1;
          cTS[kTS] = (cTS[kTS] ?? 0) + 1;
          cTn[kTn] = (cTn[kTn] ?? 0) + 1;
          total++;
        }
        if (total < 20) return null;
        let te = 0;
        for (const [key, count] of Object.entries(counts)) {
          const [tN, tP, sP] = key.split(',');
          const pF = count / total, pTS = (cTS[`${tP},${sP}`] ?? 0) / total;
          const pTn = (cTn[`${tN},${tP}`] ?? 0) / total, pT = (cT[tP] ?? 0) / total;
          if (pTS > 0 && pT > 0 && pTn > 0) {
            const cond = pF / pTS, marg = pTn / pT;
            if (cond > 0 && marg > 0) te += pF * Math.log2(cond / marg);
          }
        }
        return Math.max(0, te);
      }

      function computeDynamicalSignals() {
        const ikis: number[] = [];
        for (let i = 1; i < keystrokeStream.length; i++) {
          const gap = keystrokeStream[i].d - keystrokeStream[i - 1].d;
          if (gap > 0 && gap < 5000) ikis.push(gap);
        }
        const holds: number[] = [], flights: number[] = [];
        for (let i = 0; i < keystrokeStream.length; i++) {
          const ht = keystrokeStream[i].u - keystrokeStream[i].d;
          if (ht > 0 && ht < 2000) holds.push(ht);
          if (i > 0) {
            const ft = keystrokeStream[i].d - keystrokeStream[i - 1].u;
            if (ft > 0 && ft < 5000) flights.push(ft);
          }
        }
        const minLen = Math.min(holds.length, flights.length);
        const pe = computePermutationEntropy(ikis);
        const alpha = computeDFA(ikis);
        const rqaResult = computeRQA(ikis);
        const teHF = computeTransferEntropy(holds.slice(0, minLen), flights.slice(0, minLen));
        const teFH = computeTransferEntropy(flights.slice(0, minLen), holds.slice(0, minLen));
        let teDom: number | null = null;
        if (teHF != null && teFH != null && (teHF + teFH) > 0) {
          teDom = teFH > 0 ? teHF / teFH : (teHF > 0 ? Infinity : 1);
        }
        return {
          ikiCount: ikis.length,
          holdFlightCount: minLen,
          permutationEntropy: pe?.normalized ?? null,
          permutationEntropyRaw: pe?.raw ?? null,
          dfaAlpha: alpha,
          rqaDeterminism: rqaResult?.determinism ?? null,
          rqaLaminarity: rqaResult?.laminarity ?? null,
          rqaTrappingTime: rqaResult?.trappingTime ?? null,
          rqaRecurrenceRate: rqaResult?.recurrenceRate ?? null,
          teHoldToFlight: teHF,
          teFlightToHold: teFH,
          teDominance: teDom,
        };
      }

      // ── Compute all client-side metrics ────────────────────
      function computeAllMetrics() {
        const now = Date.now();
        const text = textarea.value;
        const totalDurationMs = now - pageOpenTime;
        const firstKeystrokeMs = firstKeystrokeTime ? firstKeystrokeTime - pageOpenTime : null;
        const finalCharCount = text.length;
        const wordCount = text.split(/\s+/).filter(Boolean).length;
        const sentenceCount = text.split(/[.!?]+/).filter((s: string) => s.trim()).length;
        const commitmentRatio = totalCharsTyped > 0 ? finalCharCount / totalCharsTyped : null;

        // Account for current pause
        let effectivePauseMs = totalPauseMs;
        if (isPaused && pauseStartTime) effectivePauseMs += now - pauseStartTime;

        const activeTypingMs = Math.max(0, totalDurationMs - effectivePauseMs - totalTabAwayMs);
        const charsPerMinute = activeTypingMs > 0 ? totalCharsTyped / (activeTypingMs / 60000) : null;

        // Include current burst in count
        const allBursts = [...burstLengths];
        if (currentBurstChars > 0) allBursts.push(currentBurstChars);
        const pBurstCount = allBursts.length;
        const avgPBurstLength = pBurstCount > 0
          ? allBursts.reduce((a, b) => a + b, 0) / pBurstCount : null;

        // Deletion timing
        const midpoint = pageOpenTime + totalDurationMs / 2;
        let firstHalfDeletionChars = 0;
        let secondHalfDeletionChars = 0;
        for (const d of deletionTimestamps) {
          if (d.time <= midpoint) firstHalfDeletionChars += d.chars;
          else secondHalfDeletionChars += d.chars;
        }

        // IKI stats
        const ikiCount = interKeyIntervals.length;
        const ikiMean = ikiCount > 0
          ? interKeyIntervals.reduce((a, b) => a + b, 0) / ikiCount : null;
        const ikiStd = ikiCount > 1
          ? Math.sqrt(interKeyIntervals.reduce((sum, v) => sum + (v - ikiMean!) ** 2, 0) / (ikiCount - 1)) : null;

        // Revision chains (include current)
        const allChains = [...revisionChains];
        if (currentRevisionChainLength > 0) allChains.push(currentRevisionChainLength);
        const revChainCount = allChains.length;
        const revChainAvgLength = revChainCount > 0
          ? allChains.reduce((a, b) => a + b, 0) / revChainCount : null;

        // Hold time stats (Kim et al. 2024 — motor execution)
        const htCount = holdTimes.length;
        const holdTimeMean = htCount > 0
          ? holdTimes.reduce((a, b) => a + b, 0) / htCount : null;
        const holdTimeStd = htCount > 1
          ? Math.sqrt(holdTimes.reduce((sum, v) => sum + (v - holdTimeMean!) ** 2, 0) / (htCount - 1)) : null;

        // Flight time stats (Kim et al. 2024 — cognitive planning)
        const ftCount = flightTimes.length;
        const flightTimeMean = ftCount > 0
          ? flightTimes.reduce((a, b) => a + b, 0) / ftCount : null;
        const flightTimeStd = ftCount > 1
          ? Math.sqrt(flightTimes.reduce((sum, v) => sum + (v - flightTimeMean!) ** 2, 0) / (ftCount - 1)) : null;

        // Keystroke entropy (Ajilore et al. 2025, BiAffect)
        let keystrokeEntropy: number | null = null;
        if (ikiCount >= 10) {
          const BIN_WIDTH = 50;
          const NUM_BINS = 40;
          const bins = new Array(NUM_BINS).fill(0);
          for (const iki of interKeyIntervals) {
            const bin = Math.min(NUM_BINS - 1, Math.floor(iki / BIN_WIDTH));
            bins[bin]++;
          }
          let entropy = 0;
          for (const count of bins) {
            if (count > 0) {
              const p = count / ikiCount;
              entropy -= p * Math.log2(p);
            }
          }
          keystrokeEntropy = entropy;
        }

        return {
          totalDurationMs,
          firstKeystrokeMs,
          totalCharsTyped,
          finalCharCount,
          wordCount,
          sentenceCount,
          commitmentRatio,
          pauseCount,
          totalPauseMs: effectivePauseMs,
          deletionCount,
          largestDeletion,
          totalCharsDeleted,
          tabAwayCount,
          totalTabAwayMs,
          activeTypingMs,
          charsPerMinute,
          smallDeletionCount,
          largeDeletionCount,
          largeDeletionChars,
          firstHalfDeletionChars,
          secondHalfDeletionChars,
          pBurstCount,
          avgPBurstLength,
          burstSequence: [...burstSequence, ...(currentBurstChars > 0 ? [{
            chars: currentBurstChars,
            startOffsetMs: (burstStartTime ?? now) - pageOpenTime,
            durationMs: now - (burstStartTime ?? now),
          }] : [])],
          interKeyIntervalMean: ikiMean,
          interKeyIntervalStd: ikiStd,
          revisionChainCount: revChainCount,
          revisionChainAvgLength: revChainAvgLength,
          holdTimeMean,
          holdTimeStd,
          flightTimeMean,
          flightTimeStd,
          keystrokeEntropy,
          scrollBackCount,
        };
      }

      // ── Render ─────────────────────────────────────────────
      function fmt(v: number | null | undefined, decimals = 1): string {
        if (v == null) return '—';
        return decimals === 0 ? String(Math.round(v)) : v.toFixed(decimals);
      }

      function fmtMs(ms: number | null): string {
        if (ms == null) return '—';
        if (ms < 1000) return `${Math.round(ms)}ms`;
        return `${(ms / 1000).toFixed(1)}s`;
      }

      function fmtDuration(ms: number): string {
        const s = Math.floor(ms / 1000);
        const m = Math.floor(s / 60);
        const sec = s % 60;
        return m > 0 ? `${m}m ${sec}s` : `${sec}s`;
      }

      function fmtPct(v: number | null): string {
        if (v == null) return '—';
        return `${(v * 100).toFixed(1)}%`;
      }

      function fmtDensity(v: number | null | undefined): string {
        if (v == null) return '—';
        return (v * 100).toFixed(2) + '%';
      }

      function valueClass(v: number | null | undefined): string {
        if (v == null || v === 0) return 'zero';
        return '';
      }

      function deltaClass(v: number | null | undefined): string {
        if (v == null || Math.abs(v) < 0.001) return 'zero';
        return v > 0 ? 'positive' : 'negative';
      }

      function fmtDelta(v: number | null | undefined, decimals = 2): string {
        if (v == null) return '—';
        const prefix = v > 0 ? '+' : '';
        return prefix + v.toFixed(decimals);
      }

      function renderMetrics() {
        const m = computeAllMetrics();
        const l = linguisticDensities;

        // Burst visualization
        const maxBurst = Math.max(1, ...m.burstSequence.map(b => b.chars));
        const burstBars = m.burstSequence.map(b =>
          `<div class="burst-segment" style="height: ${Math.max(3, (b.chars / maxBurst) * 18)}px; width: ${Math.max(3, Math.min(20, b.chars / 2))}px"></div>`
        ).join('');

        let deltaHTML = '';
        if (savedCalibMetrics && savedJournalMetrics) {
          const c = savedCalibMetrics;
          const j = savedJournalMetrics;
          deltaHTML = `
            <div class="delta-section">
              <div class="section-title">Session Delta (Journal - Calibration)</div>
              ${deltaRow('First person', j.firstPersonDensity, c.firstPersonDensity)}
              ${deltaRow('Cognitive', j.cognitiveDensity, c.cognitiveDensity)}
              ${deltaRow('Hedging', j.hedgingDensity, c.hedgingDensity)}
              ${deltaRow('Chars/min', j.charsPerMinute, c.charsPerMinute)}
              ${deltaRow('Commitment', j.commitmentRatio, c.commitmentRatio)}
              ${deltaRow('Large deletions', j.largeDeletionCount, c.largeDeletionCount)}
              ${deltaRow('IKI mean', j.interKeyIntervalMean, c.interKeyIntervalMean)}
              ${deltaRow('Hold time', j.holdTimeMean, c.holdTimeMean)}
              ${deltaRow('Flight time', j.flightTimeMean, c.flightTimeMean)}
              ${deltaRow('Entropy', j.keystrokeEntropy, c.keystrokeEntropy)}
              ${deltaRow('Avg P-burst len', j.avgPBurstLength, c.avgPBurstLength)}
            </div>
          `;
        } else if (savedCalibMetrics || savedJournalMetrics) {
          const done = savedCalibMetrics ? 'Calibration' : 'Journal';
          const todo = savedCalibMetrics ? 'journal' : 'calibration';
          deltaHTML = `<div class="status-line">${done} saved. Switch to ${todo} mode and write to see deltas.</div>`;
        }

        // Save current metrics for delta display when switching modes
        const currentForDelta = { ...m, ...l };
        if (mode === 'calibration' && textarea.value.trim()) {
          savedCalibMetrics = currentForDelta;
        }
        if (mode === 'journal' && textarea.value.trim()) {
          savedJournalMetrics = currentForDelta;
        }

        metricsEl.innerHTML = `
          <div class="metrics-grid">
          <div class="section">
            <div class="section-title">Timing</div>
            ${row('Duration', fmtDuration(m.totalDurationMs))}
            ${row('First keystroke', fmtMs(m.firstKeystrokeMs))}
            ${row('Active typing', fmtDuration(m.activeTypingMs))}
            ${row('Pauses (>30s)', m.pauseCount)}
            ${row('Total pause time', fmtDuration(m.totalPauseMs))}
            ${row('Tab-aways', m.tabAwayCount)}
            ${row('Tab-away time', fmtDuration(m.totalTabAwayMs))}
          </div>

          <div class="section">
            <div class="section-title">Production</div>
            ${row('Total chars typed', m.totalCharsTyped)}
            ${row('Final char count', m.finalCharCount)}
            ${row('Words', m.wordCount)}
            ${row('Sentences', m.sentenceCount)}
            ${row('Commitment ratio', fmtPct(m.commitmentRatio), m.commitmentRatio)}
            ${row('Chars/min', fmt(m.charsPerMinute, 0))}
          </div>

          <div class="section">
            <div class="section-title">Deletions (Faigley & Witte)</div>
            ${row('Total deletions', m.deletionCount)}
            ${row('Chars deleted', m.totalCharsDeleted)}
            ${row('Largest deletion', m.largestDeletion)}
            ${row('Small (<10 chars)', m.smallDeletionCount)}
            ${row('Large (>=10 chars)', m.largeDeletionCount)}
            ${row('Large deletion chars', m.largeDeletionChars)}
            ${row('1st half del chars', m.firstHalfDeletionChars)}
            ${row('2nd half del chars', m.secondHalfDeletionChars)}
          </div>

          <div class="section">
            <div class="section-title">P-Bursts (Chenoweth & Hayes)</div>
            ${row('Burst count', m.pBurstCount)}
            ${row('Avg burst length', fmt(m.avgPBurstLength, 1))}
            <div class="burst-bar">${burstBars}</div>
          </div>

          <div class="section">
            <div class="section-title">Keystroke Dynamics (Epp et al.)</div>
            ${row('IKI mean', fmtMs(m.interKeyIntervalMean))}
            ${row('IKI std dev', fmtMs(m.interKeyIntervalStd))}
            ${row('Revision chains', m.revisionChainCount)}
            ${row('Avg chain length', fmt(m.revisionChainAvgLength, 1))}
            ${row('Scroll-backs', m.scrollBackCount)}
          </div>

          <div class="section">
            <div class="section-title">Motor / Cognitive (Kim et al. 2024)</div>
            ${row('Hold time mean', fmtMs(m.holdTimeMean))}
            ${row('Hold time std', fmtMs(m.holdTimeStd))}
            ${row('Flight time mean', fmtMs(m.flightTimeMean))}
            ${row('Flight time std', fmtMs(m.flightTimeStd))}
            ${row('Hold/flight ratio', m.holdTimeMean != null && m.flightTimeMean != null && m.flightTimeMean > 0 ? fmt(m.holdTimeMean / m.flightTimeMean, 2) : '—')}
            ${row('Keystroke entropy', m.keystrokeEntropy != null ? fmt(m.keystrokeEntropy, 2) + ' bits' : '—')}
          </div>

          <div class="section">
            <div class="section-title">Mouse / Cursor (BioCatch)</div>
            ${row('Cursor distance', m.cursorDistanceDuringPauses > 0 ? fmt(m.cursorDistanceDuringPauses, 0) + ' px' : '—')}
            ${row('Fidget ratio', m.cursorFidgetRatio != null ? fmt(m.cursorFidgetRatio, 4) + ' px/ms' : '—')}
            ${row('Stillness', fmtPct(m.cursorStillnessDuringPauses))}
            ${row('Drift to submit', m.driftToSubmitCount)}
            ${row('Pause samples', m.cursorPauseSampleCount)}
          </div>

          <div class="section">
            <div class="section-title">Error Correction (Springer 2021)</div>
            ${row('Del exec speed', fmtMs(m.deletionExecutionSpeedMean))}
            ${row('Postcorrection', fmtMs(m.postcorrectionLatencyMean))}
            ${row('Mean rev distance', m.meanRevisionDistance != null ? fmt(m.meanRevisionDistance, 0) + ' chars' : '—')}
            ${row('Max rev distance', m.maxRevisionDistance != null ? m.maxRevisionDistance + ' chars' : '—')}
          </div>

          <div class="section">
            <div class="section-title">Punctuation (Plank 2016)</div>
            ${row('Punct flight mean', fmtMs(m.punctuationFlightMean))}
            ${row('Punct/letter ratio', m.punctuationLetterRatio != null ? fmt(m.punctuationLetterRatio, 3) + 'x' : '—')}
          </div>

          ${(() => {
            const ds = computeDynamicalSignals();
            const sufficient = ds.ikiCount >= 30;
            const dfaLabel = ds.dfaAlpha != null
              ? (ds.dfaAlpha < 0.6 ? 'white noise' : ds.dfaAlpha < 0.85 ? 'pink (1/f)' : ds.dfaAlpha < 1.1 ? 'pink-brown' : 'brown noise')
              : '';
            const teLabel = ds.teDominance != null
              ? (ds.teDominance > 1 ? 'motor \u2192 cog ' + ds.teDominance.toFixed(2) + 'x' : 'cog \u2192 motor ' + (1 / ds.teDominance).toFixed(2) + 'x')
              : '';
            return `
              <div class="section">
                <div class="section-title">Dynamical Signals${!sufficient ? ' (need 30+ keystrokes)' : ''}</div>
                ${row('IKI series', ds.ikiCount + ' pts')}
                ${row('Hold/flight pairs', ds.holdFlightCount + ' pts')}
                ${row('Perm entropy', ds.permutationEntropy != null ? fmt(ds.permutationEntropy, 3) + ' (norm)' : '—')}
                ${row('DFA \u03b1', ds.dfaAlpha != null ? fmt(ds.dfaAlpha, 3) + (dfaLabel ? ' \u2014 ' + dfaLabel : '') : '—')}
                ${row('RQA determinism', ds.rqaDeterminism != null ? fmtPct(ds.rqaDeterminism) : '—')}
                ${row('RQA laminarity', ds.rqaLaminarity != null ? fmtPct(ds.rqaLaminarity) : '—')}
                ${row('RQA trapping time', ds.rqaTrappingTime != null ? fmt(ds.rqaTrappingTime, 1) : '—')}
                ${row('RQA recurrence', ds.rqaRecurrenceRate != null ? fmtPct(ds.rqaRecurrenceRate) : '—')}
                ${row('TE hold\u2192flight', ds.teHoldToFlight != null ? fmt(ds.teHoldToFlight, 4) + ' bits' : '—')}
                ${row('TE flight\u2192hold', ds.teFlightToHold != null ? fmt(ds.teFlightToHold, 4) + ' bits' : '—')}
                ${row('TE dominance', teLabel || '—')}
              </div>
            `;
          })()}

          <div class="section">
            <div class="section-title">Linguistic Densities (NRC / Pennebaker)</div>
            ${row('Anger', fmtDensity(l.nrcAngerDensity), l.nrcAngerDensity)}
            ${row('Fear', fmtDensity(l.nrcFearDensity), l.nrcFearDensity)}
            ${row('Joy', fmtDensity(l.nrcJoyDensity), l.nrcJoyDensity)}
            ${row('Sadness', fmtDensity(l.nrcSadnessDensity), l.nrcSadnessDensity)}
            ${row('Trust', fmtDensity(l.nrcTrustDensity), l.nrcTrustDensity)}
            ${row('Anticipation', fmtDensity(l.nrcAnticipationDensity), l.nrcAnticipationDensity)}
            ${row('Cognitive', fmtDensity(l.cognitiveDensity), l.cognitiveDensity)}
            ${row('Hedging', fmtDensity(l.hedgingDensity), l.hedgingDensity)}
            ${row('First person', fmtDensity(l.firstPersonDensity), l.firstPersonDensity)}
          </div>

          ${deltaHTML}
          </div>
        `;
      }

      function row(label: string, value: any, numericValue?: any): string {
        const cls = numericValue != null ? valueClass(numericValue) : '';
        return `<div class="metric-row"><span class="metric-label">${label}</span><span class="metric-value ${cls}">${value}</span></div>`;
      }

      function deltaRow(label: string, journalVal: any, calibVal: any): string {
        if (journalVal == null || calibVal == null) return row(label, '—');
        const d = journalVal - calibVal;
        return `<div class="metric-row"><span class="metric-label">${label}</span><span class="metric-value ${deltaClass(d)}">${fmtDelta(d)}</span></div>`;
      }

      // Initial render
      updatePrompt();
      renderMetrics();

      // Tick duration every second
      setInterval(renderMetrics, 1000);
    </script>
  </body>
</html>
