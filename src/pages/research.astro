<script>
  // Scroll-spy: highlight the active nav link based on scroll position
  document.addEventListener('DOMContentLoaded', () => {
    const nav = document.querySelector('.r-nav');
    if (!nav) return;

    const links = nav.querySelectorAll('.r-nav-link');
    const sections = Array.from(links).map(link => {
      const id = link.getAttribute('data-section');
      return id ? document.getElementById(id) : null;
    }).filter(Boolean) as HTMLElement[];

    const groups = nav.querySelectorAll('.r-nav-group');

    const observer = new IntersectionObserver((entries) => {
      for (const entry of entries) {
        if (entry.isIntersecting) {
          const id = entry.target.id;
          links.forEach(link => {
            link.classList.toggle('active', link.getAttribute('data-section') === id);
          });
          // Update active stage group
          const activeLink = nav.querySelector(`.r-nav-link[data-section="${id}"]`);
          if (activeLink) {
            const activeGroup = activeLink.closest('.r-nav-group');
            groups.forEach(g => g.classList.toggle('active', g === activeGroup));
          }
        }
      }
    }, { rootMargin: '-20% 0px -60% 0px' });

    sections.forEach(s => observer.observe(s));
  });

  // "Closing window" visualization: two curves converging
  // Left curve: motor noise declining (demographic resolution)
  // Right curve: AI contamination rising (construct replacement)
  // The gap between them is the window.
  (() => {
    const canvas = document.getElementById('window-viz') as HTMLCanvasElement;
    if (!canvas) return;
    const ctx = canvas.getContext('2d');
    if (!ctx) return;

    const dpr = window.devicePixelRatio || 1;
    const w = canvas.width;
    const h = canvas.height;
    canvas.width = w * dpr;
    canvas.height = h * dpr;
    canvas.style.width = w + 'px';
    canvas.style.height = h + 'px';
    ctx.scale(dpr, dpr);

    // Read CSS variables from computed style
    const style = getComputedStyle(document.documentElement);
    const textFaint = style.getPropertyValue('--text-faint').trim() || '#999';
    const border = style.getPropertyValue('--border').trim() || '#ddd';
    const accent = style.getPropertyValue('--accent').trim() || '#8b7355';
    const negative = style.getPropertyValue('--negative').trim() || '#c44';

    const pad = { top: 40, right: 30, bottom: 50, left: 30 };
    const plotW = w - pad.left - pad.right;
    const plotH = h - pad.top - pad.bottom;

    // Axes
    ctx.strokeStyle = border;
    ctx.lineWidth = 1;
    ctx.beginPath();
    ctx.moveTo(pad.left, pad.top);
    ctx.lineTo(pad.left, pad.top + plotH);
    ctx.lineTo(pad.left + plotW, pad.top + plotH);
    ctx.stroke();

    // Year labels
    ctx.fillStyle = textFaint;
    ctx.font = '10px monospace';
    ctx.textAlign = 'center';
    const years = [2025, 2030, 2035, 2040, 2045, 2050, 2055];
    for (const yr of years) {
      const x = pad.left + ((yr - 2025) / 30) * plotW;
      ctx.fillText(String(yr), x, pad.top + plotH + 18);

      // Tick
      ctx.strokeStyle = border;
      ctx.globalAlpha = 0.3;
      ctx.beginPath();
      ctx.moveTo(x, pad.top);
      ctx.lineTo(x, pad.top + plotH);
      ctx.stroke();
      ctx.globalAlpha = 1;
    }

    // Motor noise curve (declining sigmoid)
    const motorNoise = (t: number) => 0.92 / (1 + Math.exp(4 * (t - 0.45))) + 0.05;
    // AI contamination curve (rising sigmoid)
    const aiContam = (t: number) => 0.88 / (1 + Math.exp(-5 * (t - 0.35))) + 0.08;

    const steps = 200;

    // Fill the gap between curves where motor < AI (the window region)
    // Find where they cross
    let crossT = 0;
    for (let i = 0; i <= steps; i++) {
      const t = i / steps;
      if (motorNoise(t) < aiContam(t)) { crossT = t; break; }
    }

    // Shade the window region (where motor is still above AI)
    ctx.fillStyle = accent;
    ctx.globalAlpha = 0.06;
    ctx.beginPath();
    for (let i = 0; i <= steps; i++) {
      const t = i / steps;
      if (t > crossT) break;
      const x = pad.left + t * plotW;
      const y = pad.top + (1 - motorNoise(t)) * plotH;
      if (i === 0) ctx.moveTo(x, y); else ctx.lineTo(x, y);
    }
    // Walk back along AI curve
    for (let i = Math.floor(crossT * steps); i >= 0; i--) {
      const t = i / steps;
      const x = pad.left + t * plotW;
      const y = pad.top + (1 - aiContam(t)) * plotH;
      ctx.lineTo(x, y);
    }
    ctx.closePath();
    ctx.fill();
    ctx.globalAlpha = 1;

    // Draw motor noise curve
    ctx.strokeStyle = textFaint;
    ctx.lineWidth = 2;
    ctx.beginPath();
    for (let i = 0; i <= steps; i++) {
      const t = i / steps;
      const x = pad.left + t * plotW;
      const y = pad.top + (1 - motorNoise(t)) * plotH;
      if (i === 0) ctx.moveTo(x, y); else ctx.lineTo(x, y);
    }
    ctx.stroke();

    // Draw AI contamination curve
    ctx.strokeStyle = negative;
    ctx.lineWidth = 2;
    ctx.beginPath();
    for (let i = 0; i <= steps; i++) {
      const t = i / steps;
      const x = pad.left + t * plotW;
      const y = pad.top + (1 - aiContam(t)) * plotH;
      if (i === 0) ctx.moveTo(x, y); else ctx.lineTo(x, y);
    }
    ctx.stroke();

    // Cross point marker
    const crossX = pad.left + crossT * plotW;
    const crossY = pad.top + (1 - motorNoise(crossT)) * plotH;
    ctx.fillStyle = accent;
    ctx.beginPath();
    ctx.arc(crossX, crossY, 4, 0, Math.PI * 2);
    ctx.fill();

    // "The window" label with dashed bracket
    const windowMidT = crossT * 0.55;
    const windowMidX = pad.left + windowMidT * plotW;
    const motorMidY = pad.top + (1 - motorNoise(windowMidT)) * plotH;
    const aiMidY = pad.top + (1 - aiContam(windowMidT)) * plotH;
    const gapMidY = (motorMidY + aiMidY) / 2;

    ctx.fillStyle = accent;
    ctx.font = 'italic 13px serif';
    ctx.textAlign = 'center';
    ctx.fillText('the window', windowMidX, gapMidY + 4);

    // Curve labels
    ctx.font = '10px monospace';
    ctx.textAlign = 'left';
    ctx.fillStyle = textFaint;
    ctx.fillText('MOTOR NOISE', pad.left + plotW * 0.68, pad.top + (1 - motorNoise(0.7)) * plotH - 8);

    ctx.fillStyle = negative;
    ctx.fillText('AI CONTAMINATION', pad.left + plotW * 0.55, pad.top + (1 - aiContam(0.7)) * plotH + 18);

    // Y-axis label
    ctx.save();
    ctx.fillStyle = textFaint;
    ctx.font = '9px monospace';
    ctx.textAlign = 'center';
    ctx.translate(12, pad.top + plotH / 2);
    ctx.rotate(-Math.PI / 2);
    ctx.fillText('SIGNAL VALIDITY', 0, 0);
    ctx.restore();
  })();

  // ── Reconstruction fidelity visualization ──
  // Horizontal bar chart showing projected per-dimension fidelity.
  // Filled = what the instrument captures. Gap = the residual.
  (() => {
    const canvas = document.getElementById('reconstruction-viz') as HTMLCanvasElement;
    if (!canvas) return;
    const ctx = canvas.getContext('2d');
    if (!ctx) return;

    const dpr = window.devicePixelRatio || 1;
    const w = canvas.width;
    const h = canvas.height;
    canvas.width = w * dpr;
    canvas.height = h * dpr;
    canvas.style.width = w + 'px';
    canvas.style.height = h + 'px';
    ctx.scale(dpr, dpr);

    const style = getComputedStyle(document.documentElement);
    const textFaint = style.getPropertyValue('--text-faint').trim() || '#999';
    const text = style.getPropertyValue('--text').trim() || '#333';
    const border = style.getPropertyValue('--border').trim() || '#ddd';
    const accent = style.getPropertyValue('--accent').trim() || '#8b7355';
    const negative = style.getPropertyValue('--negative').trim() || '#c44';
    const bgDim = style.getPropertyValue('--bg-dim').trim() || '#f5f5f3';

    const pad = { top: 30, right: 80, bottom: 30, left: 180 };
    const barH = 28;
    const gap = 22;

    // Signal families with projected fidelity (schematic, not measured)
    const dimensions = [
      { label: 'MOTOR FINGERPRINT', sub: 'ex-Gaussian, digraph latency', fidelity: 0.93 },
      { label: 'PAUSE ARCHITECTURE', sub: 'P-burst, sentence, word', fidelity: 0.84 },
      { label: 'TEMPORAL DYNAMICS', sub: 'PE spectrum, DFA, autocorrelation', fidelity: 0.55 },
      { label: 'REVISION TOPOLOGY', sub: 'R-burst, I-burst, timing bias', fidelity: 0.45 },
      { label: 'SEMANTIC COHERENCE', sub: 'argument structure, meaning', fidelity: 0.04 },
    ];

    const barW = w - pad.left - pad.right;

    for (let i = 0; i < dimensions.length; i++) {
      const d = dimensions[i];
      const y = pad.top + i * (barH + gap);

      // Label
      ctx.fillStyle = text;
      ctx.font = '10px monospace';
      ctx.textAlign = 'right';
      ctx.textBaseline = 'top';
      ctx.fillText(d.label, pad.left - 14, y + 2);

      // Sub-label
      ctx.fillStyle = textFaint;
      ctx.font = '9px monospace';
      ctx.fillText(d.sub, pad.left - 14, y + 16);

      // Background bar (the gap / residual)
      ctx.fillStyle = bgDim;
      ctx.fillRect(pad.left, y, barW, barH);

      // Residual fill (subtle)
      ctx.fillStyle = negative;
      ctx.globalAlpha = 0.06;
      ctx.fillRect(pad.left + barW * d.fidelity, y, barW * (1 - d.fidelity), barH);
      ctx.globalAlpha = 1;

      // Fidelity bar
      ctx.fillStyle = accent;
      ctx.globalAlpha = 0.45 + d.fidelity * 0.35; // brighter for higher fidelity
      ctx.fillRect(pad.left, y, barW * d.fidelity, barH);
      ctx.globalAlpha = 1;

      // Border around full bar
      ctx.strokeStyle = border;
      ctx.lineWidth = 1;
      ctx.strokeRect(pad.left, y, barW, barH);

      // Fidelity divider line
      if (d.fidelity > 0.02 && d.fidelity < 0.98) {
        ctx.strokeStyle = accent;
        ctx.lineWidth = 1.5;
        ctx.beginPath();
        ctx.moveTo(pad.left + barW * d.fidelity, y);
        ctx.lineTo(pad.left + barW * d.fidelity, y + barH);
        ctx.stroke();
      }

      // Percentage label
      ctx.fillStyle = d.fidelity > 0.5 ? text : textFaint;
      ctx.font = '11px monospace';
      ctx.textAlign = 'left';
      ctx.textBaseline = 'middle';
      ctx.fillText(Math.round(d.fidelity * 100) + '%', pad.left + barW + 10, y + barH / 2);
    }

    // Residual bracket on the right side spanning the bottom rows
    const bracketTop = pad.top + 2 * (barH + gap) + barH * 0.3;
    const bracketBot = pad.top + 4 * (barH + gap) + barH * 0.7;
    const bracketX = pad.left + barW + 52;

    ctx.strokeStyle = textFaint;
    ctx.lineWidth = 1;
    ctx.beginPath();
    ctx.moveTo(bracketX - 6, bracketTop);
    ctx.lineTo(bracketX, bracketTop);
    ctx.lineTo(bracketX, bracketBot);
    ctx.lineTo(bracketX - 6, bracketBot);
    ctx.stroke();

    // Bracket label
    ctx.save();
    ctx.fillStyle = textFaint;
    ctx.font = 'italic 10px serif';
    ctx.textAlign = 'center';
    ctx.translate(bracketX + 14, (bracketTop + bracketBot) / 2);
    ctx.rotate(-Math.PI / 2);
    ctx.fillText('the residual', 0, 0);
    ctx.restore();

    // Axis labels
    ctx.fillStyle = textFaint;
    ctx.font = '9px monospace';
    ctx.textAlign = 'center';
    ctx.textBaseline = 'top';
    const axisY = pad.top + dimensions.length * (barH + gap) - gap + 10;
    ctx.fillText('CAPTURED', pad.left + barW * 0.25, axisY);
    ctx.fillText('RESIDUAL', pad.left + barW * 0.82, axisY);

    // Arrow between them
    ctx.strokeStyle = textFaint;
    ctx.lineWidth = 0.5;
    ctx.beginPath();
    ctx.moveTo(pad.left + barW * 0.38, axisY + 5);
    ctx.lineTo(pad.left + barW * 0.7, axisY + 5);
    ctx.stroke();
  })();

  // Instrument status: fetch live metadata and populate residual cards + strip.
  // Uses full adversary (variant 5) for the strongest claim, baseline (variant 1) as reference.
  fetch('/api/instrument-status')
    .then(r => r.json())
    .then(data => {
      if (data.error) return;

      // Full adversary is the strongest ghost; fall back to baseline if not yet computed
      const fa = data.fullAdversary || {};
      const bl = data.convergence || {};
      const hasMulti = fa.motorL2 != null;
      const motor = hasMulti ? fa : bl;
      const nVariants = data.variants ? data.variants.length : 1;
      const sessionsPerVariant = data.variants && data.variants[0] ? data.variants[0].sessions : 0;

      // Populate measured values on residual cards
      const contentEl = document.getElementById('measured-content');
      if (contentEl && fa.semanticL2 != null) {
        contentEl.textContent = `Measured: semantic L2 = ${fa.semanticL2} (full adversary, n=${sessionsPerVariant})`;
      } else if (contentEl && bl.semanticL2 != null) {
        contentEl.textContent = `Measured: semantic L2 = ${bl.semanticL2} (baseline, n=${sessionsPerVariant})`;
      }

      const motorEl = document.getElementById('measured-motor');
      if (motorEl && hasMulti) {
        const range = data.variants
          .map((v: {motorL2: number | null}) => v.motorL2)
          .filter((v: number | null) => v != null);
        const min = Math.min(...range);
        const max = Math.max(...range);
        motorEl.textContent = `Measured: motor L2 = ${min}\u2013${max} across ${nVariants} adversary variants (n=${sessionsPerVariant})`;
      } else if (motorEl && bl.motorL2 != null) {
        motorEl.textContent = `Measured: motor L2 = ${bl.motorL2} (baseline, n=${sessionsPerVariant})`;
      }

      const cogLoadEl = document.getElementById('measured-cognitive-load');
      if (cogLoadEl && motor.journalL2 != null && motor.calibrationL2 != null) {
        cogLoadEl.textContent = `Measured: journal L2 = ${motor.journalL2}, calibration L2 = ${motor.calibrationL2}`;
      }

      // Populate instrument strip
      const strip = document.getElementById('instrument-strip');
      if (strip) {
        strip.style.display = 'flex';
        const days = document.getElementById('strip-days');
        if (days) days.textContent = `${data.daysActive} days active`;
        const sess = document.getElementById('strip-sessions');
        if (sess) sess.textContent = `${data.sessions} sessions`;
        const fam = document.getElementById('strip-families');
        if (fam) fam.textContent = `${data.signalFamilies.active}/${data.signalFamilies.total} signal families`;
        const res = document.getElementById('strip-residuals');
        if (res) res.textContent = `${data.reconstructionResiduals} reconstruction residuals`;
        const vEl = document.getElementById('strip-variants');
        if (vEl && nVariants > 1) vEl.textContent = `${nVariants} adversary variants`;
      }
    })
    .catch(() => {});
</script>

