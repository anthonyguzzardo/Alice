---

---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Marrow</title>
    <style is:global>
      @import url('https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,400;1,300;1,400&family=EB+Garamond:ital,wght@0,400;0,500;1,400&display=swap');

      * {
        margin: 0;
        padding: 0;
        box-sizing: border-box;
      }

      html, body {
        height: 100%;
        background: #0a0a0a;
        color: #e8e4df;
        font-family: 'EB Garamond', Georgia, serif;
      }

      body {
        display: flex;
        align-items: center;
        justify-content: center;
        padding: 2rem;
      }

      .container {
        max-width: 540px;
        width: 100%;
      }

      .date {
        font-size: 0.85rem;
        color: #5a5550;
        letter-spacing: 0.08em;
        text-transform: uppercase;
        margin-bottom: 2.5rem;
      }

      .question {
        font-family: 'Cormorant Garamond', Georgia, serif;
        font-size: 1.6rem;
        font-weight: 300;
        line-height: 1.8;
        letter-spacing: 0.03em;
        color: #e8e4df;
        margin-bottom: 3rem;
        font-style: italic;
      }

      .response-area {
        width: 100%;
        min-height: 160px;
        background-color: #161514;
        border: 1px solid #333;
        border-radius: 4px;
        color: #e8e4df;
        font-family: 'EB Garamond', Georgia, serif;
        font-size: 1.1rem;
        line-height: 1.7;
        padding: 1.25rem;
        resize: none;
        outline: none;
        -webkit-appearance: none;
        appearance: none;
        transition: border-color 0.3s ease;
      }

      .response-area:focus {
        border-color: #555;
        outline: none;
      }

      .response-area::placeholder {
        color: #5a5550;
        font-style: italic;
      }

      .submit-row {
        margin-top: 1.5rem;
      }

      .submit-btn {
        background: #222;
        border: 1px solid #444;
        border-radius: 4px;
        color: #e8e4df;
        font-family: 'EB Garamond', Georgia, serif;
        font-size: 1rem;
        padding: 0.6rem 1.8rem;
        cursor: pointer;
        letter-spacing: 0.05em;
      }

      .submit-btn:hover:not(:disabled) {
        background: #444;
        border-color: #888;
        color: #fff;
      }

      .submit-btn:active:not(:disabled) {
        background: #555;
      }

      .submit-btn:disabled {
        opacity: 0.4;
        cursor: default;
      }

      .done-message {
        font-family: 'Cormorant Garamond', Georgia, serif;
        font-size: 1.3rem;
        font-weight: 300;
        font-style: italic;
        line-height: 1.8;
        color: #6a6560;
        margin-top: 1rem;
      }

      .loading {
        color: #3a3530;
        font-style: italic;
      }
    </style>
  </head>
  <body>
    <div class="container">
      <div class="date" id="date"></div>
      <div class="question loading" id="question">...</div>
      <div id="input-area"></div>
    </div>

    <script>
      const dateEl = document.getElementById('date')!;
      const questionEl = document.getElementById('question')!;
      const inputArea = document.getElementById('input-area')!;

      const today = new Date();
      dateEl.textContent = today.toLocaleDateString('en-US', {
        weekday: 'long',
        year: 'numeric',
        month: 'long',
        day: 'numeric',
      });

      async function load() {
        const res = await fetch('/api/today');
        if (!res.ok) {
          questionEl.textContent = 'No question today. Rest.';
          return;
        }

        const data = await res.json();
        questionEl.textContent = data.question.text;
        questionEl.classList.remove('loading');

        if (data.response) {
          trackEvent(data.question.id, 'revisit');
          questionEl.textContent = '';
          inputArea.innerHTML = `<div class="done-message">${getDoneMessage()}</div>`;
        } else {
          const questionId = data.question.id;
          const pageOpenTime = Date.now();
          trackEvent(questionId, 'page_open');

          inputArea.innerHTML = `
            <textarea
              class="response-area"
              id="response"
              placeholder="Think before you type..."
            ></textarea>
            <div class="submit-row">
              <button class="submit-btn" id="submit" disabled>Submit</button>
            </div>
          `;

          const textarea = document.getElementById('response') as HTMLTextAreaElement;
          const submitBtn = document.getElementById('submit') as HTMLButtonElement;

          // Behavioral tracking state
          let firstKeystrokeSent = false;
          let firstKeystrokeTime: number | null = null;
          let pauseTimer: number | null = null;
          let isPaused = false;
          let pauseStartTime: number | null = null;
          let totalPauseMs = 0;
          let pauseCount = 0;
          let totalCharsTyped = 0;
          let totalCharsDeleted = 0;
          let deletionCount = 0;
          let largestDeletion = 0;
          let lastTextLength = 0;
          let tabAwayCount = 0;
          let tabAwayStartTime: number | null = null;
          let totalTabAwayMs = 0;

          textarea.addEventListener('input', () => {
            const currentLength = textarea.value.length;
            const delta = currentLength - lastTextLength;

            if (delta > 0) {
              totalCharsTyped += delta;
            } else if (delta < 0) {
              const deleted = Math.abs(delta);
              totalCharsDeleted += deleted;
              deletionCount++;
              if (deleted > largestDeletion) largestDeletion = deleted;
              trackEvent(questionId, 'deletion', JSON.stringify({
                charsDeleted: deleted,
                textLength: currentLength,
              }));
            }

            lastTextLength = currentLength;
            submitBtn.disabled = !textarea.value.trim();

            if (!firstKeystrokeSent) {
              firstKeystrokeTime = Date.now();
              trackEvent(questionId, 'first_keystroke');
              firstKeystrokeSent = true;
            }

            if (isPaused) {
              if (pauseStartTime) {
                totalPauseMs += Date.now() - pauseStartTime;
                pauseStartTime = null;
              }
              trackEvent(questionId, 'resume', JSON.stringify({
                textLength: currentLength,
              }));
              isPaused = false;
            }

            if (pauseTimer) clearTimeout(pauseTimer);
            pauseTimer = window.setTimeout(() => {
              if (textarea.value.trim()) {
                pauseCount++;
                pauseStartTime = Date.now();
                trackEvent(questionId, 'pause', JSON.stringify({
                  textLength: currentLength,
                }));
                isPaused = true;
              }
            }, 30000);
          });

          document.addEventListener('visibilitychange', () => {
            if (document.hidden) {
              tabAwayStartTime = Date.now();
              trackEvent(questionId, 'tab_blur');
            } else {
              if (tabAwayStartTime) {
                const awayMs = Date.now() - tabAwayStartTime;
                totalTabAwayMs += awayMs;
                tabAwayCount++;
                tabAwayStartTime = null;
              }
              trackEvent(questionId, 'tab_focus');
            }
          });

          submitBtn.addEventListener('click', async () => {
            const text = textarea.value.trim();
            if (!text) return;

            submitBtn.disabled = true;
            submitBtn.textContent = '...';

            // Finalize pause if still in one
            if (isPaused && pauseStartTime) {
              totalPauseMs += Date.now() - pauseStartTime;
            }

            const submitTime = Date.now();
            const finalCharCount = text.length;
            const wordCount = text.split(/\s+/).filter(Boolean).length;
            const sentenceCount = text.split(/[.!?]+/).filter((s: string) => s.trim()).length;
            const totalDurationMs = submitTime - pageOpenTime;
            const firstKeystrokeMs = firstKeystrokeTime ? firstKeystrokeTime - pageOpenTime : null;
            const commitmentRatio = totalCharsTyped > 0 ? finalCharCount / totalCharsTyped : null;

            const sessionSummary = {
              questionId,
              firstKeystrokeMs,
              totalDurationMs,
              totalCharsTyped,
              finalCharCount,
              commitmentRatio,
              pauseCount,
              totalPauseMs,
              deletionCount,
              largestDeletion,
              totalCharsDeleted,
              tabAwayCount,
              totalTabAwayMs,
              wordCount,
              sentenceCount,
            };

            const res = await fetch('/api/respond', {
              method: 'POST',
              headers: { 'Content-Type': 'application/json' },
              body: JSON.stringify({ questionId, text, sessionSummary }),
            });

            if (res.ok) {
              trackEvent(questionId, 'submit', JSON.stringify({
                charCount: finalCharCount,
                wordCount,
              }));
              questionEl.textContent = '';
              inputArea.innerHTML = `<div class="done-message">${getDoneMessage()}</div>`;
            } else {
              submitBtn.textContent = 'Submit';
              submitBtn.disabled = false;
            }
          });

          textarea.focus();
        }
      }

      function trackEvent(questionId: number, eventType: string, metadata?: string) {
        fetch('/api/event', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ questionId, eventType, metadata }),
        }).catch(() => {});
      }

      function getDoneMessage(): string {
        const messages = [
          "Noted. Let it sit.",
          "That thought is yours now. Come back tomorrow.",
          "Done. Don't rehearse it — let it breathe.",
          "Saved. Go do something with your hands.",
          "Good. Now forget about it until tomorrow.",
          "The thought is planted. Leave it alone.",
          "You showed up. That's the whole thing.",
          "Noted. The next question is already forming.",
          "Stop thinking about what you just wrote.",
          "That's enough for today.",
        ];
        return messages[Math.floor(Math.random() * messages.length)];
      }

      function escapeHtml(text: string): string {
        const div = document.createElement('div');
        div.textContent = text;
        return div.innerHTML;
      }

      load();
    </script>
  </body>
</html>
