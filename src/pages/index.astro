---

---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Alice</title>
    <script is:inline>
      (function() {
        var t = localStorage.getItem('alice-theme') || 'light';
        document.documentElement.setAttribute('data-theme', t);
      })();
    </script>
    <style is:global>
      @import url('https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,400;1,300;1,400&family=EB+Garamond:ital,wght@0,400;0,500;1,400&display=swap');

      :root {
        --bg: #f5f2ed;
        --bg-input: #ebe7e1;
        --text: #1a1a1a;
        --text-muted: #6b6560;
        --text-faint: #9a9590;
        --border: #ccc5bc;
        --border-focus: #8a8580;
        --btn-bg: #e0dbd5;
        --btn-hover: #ccc5bc;
        --btn-text: #1a1a1a;
        --done-text: #8a8580;
        --loading: #c5c0ba;
        --free-border: #c5c0ba;
        --free-hover-bg: rgba(0, 0, 0, 0.03);
      }

      [data-theme="dark"] {
        --bg: #0a0a0a;
        --bg-input: #161514;
        --text: #ffffff;
        --text-muted: #7a7570;
        --text-faint: #4a4540;
        --border: #333;
        --border-focus: #666;
        --btn-bg: #222;
        --btn-hover: #444;
        --btn-text: #ffffff;
        --done-text: #8a8580;
        --loading: #4a4540;
        --free-border: #3a3530;
        --free-hover-bg: rgba(255, 255, 255, 0.04);
      }

      * {
        margin: 0;
        padding: 0;
        box-sizing: border-box;
      }

      html, body {
        height: 100%;
        background: var(--bg);
        color: var(--text);
        font-family: 'EB Garamond', Georgia, serif;
      }

      body {
        display: flex;
        align-items: center;
        justify-content: center;
        padding: 2rem;
      }

      .container {
        max-width: 700px;
        width: 100%;
      }

      .date {
        font-size: 1.15rem;
        color: var(--text-muted);
        letter-spacing: 0.08em;
        text-transform: uppercase;
        margin-bottom: 2.5rem;
      }

      .question {
        font-family: 'Cormorant Garamond', Georgia, serif;
        font-size: 2.6rem;
        font-weight: 300;
        line-height: 1.6;
        letter-spacing: 0.03em;
        color: var(--text);
        margin-bottom: 3rem;
        font-style: italic;
        transition: opacity 8s ease;
      }

      .question.fading {
        opacity: 0.3;
      }

      .response-area {
        width: 100%;
        min-height: 400px;
        background-color: var(--bg-input);
        border: 1px solid var(--border);
        border-radius: 4px;
        color: var(--text);
        font-family: 'EB Garamond', Georgia, serif;
        font-size: 1.45rem;
        line-height: 1.8;
        padding: 1.5rem;
        resize: none;
        outline: none;
        -webkit-appearance: none;
        appearance: none;
        transition: border-color 0.3s ease, opacity 0.6s ease;
      }

      .response-area.waiting {
        opacity: 0.3;
        cursor: default;
      }

      .response-area:focus {
        border-color: var(--border-focus);
        outline: none;
      }

      .response-area::placeholder {
        color: var(--text-muted);
        font-style: italic;
      }

      .submit-row {
        margin-top: 1.5rem;
      }

      .submit-btn {
        background: var(--btn-bg);
        border: 1px solid var(--border);
        border-radius: 4px;
        color: var(--btn-text);
        font-family: 'EB Garamond', Georgia, serif;
        font-size: 1.3rem;
        padding: 0.8rem 2.2rem;
        cursor: pointer;
        letter-spacing: 0.05em;
        transition: all 0.3s ease;
      }

      .submit-btn:hover:not(:disabled) {
        background: var(--btn-hover);
        border-color: var(--border-focus);
      }

      .submit-btn:active:not(:disabled) {
        opacity: 0.8;
      }

      .submit-btn:disabled {
        opacity: 0.4;
        cursor: default;
      }

      .submit-row.hidden {
        opacity: 0;
        pointer-events: none;
        transition: opacity 1.5s ease;
      }

      .submit-row.visible {
        opacity: 1;
        pointer-events: auto;
        transition: opacity 1.5s ease;
      }

      .done-message {
        font-family: 'Cormorant Garamond', Georgia, serif;
        font-size: 1.8rem;
        font-weight: 300;
        font-style: italic;
        line-height: 1.8;
        color: var(--done-text);
        margin-top: 1rem;
      }

      .loading {
        color: var(--loading);
        font-style: italic;
      }

      .free-write-link {
        display: inline-block;
        margin-top: 3rem;
        color: var(--text-muted);
        font-size: 1.25rem;
        letter-spacing: 0.1em;
        text-transform: lowercase;
        cursor: pointer;
        border: 1px solid var(--free-border);
        background: none;
        font-family: 'Cormorant Garamond', Georgia, serif;
        font-style: italic;
        font-weight: 300;
        text-decoration: none;
        padding: 0.6rem 1.8rem;
        border-radius: 4px;
        transition: all 0.4s ease;
      }

      .free-write-link:hover {
        color: var(--text);
        border-color: var(--border-focus);
        background: var(--free-hover-bg);
      }

      .feedback-row {
        margin-top: 2.5rem;
        display: flex;
        align-items: center;
        gap: 1.2rem;
      }

      .feedback-label {
        font-family: 'Cormorant Garamond', Georgia, serif;
        font-size: 1.25rem;
        font-weight: 300;
        font-style: italic;
        color: var(--text-muted);
      }

      .feedback-btn {
        background: none;
        border: 1px solid var(--free-border);
        border-radius: 4px;
        color: var(--text-muted);
        font-family: 'Cormorant Garamond', Georgia, serif;
        font-size: 1.1rem;
        font-style: italic;
        padding: 0.4rem 1.2rem;
        cursor: pointer;
        transition: all 0.3s ease;
      }

      .feedback-btn:hover {
        color: var(--text);
        border-color: var(--border-focus);
      }

      .calibration-prompt {
        font-family: 'Cormorant Garamond', Georgia, serif;
        font-size: 1.8rem;
        font-weight: 300;
        line-height: 1.8;
        letter-spacing: 0.03em;
        color: var(--done-text);
        margin-bottom: 2rem;
        font-style: italic;
      }
      .top-controls {
        position: fixed;
        top: 2rem;
        right: 2rem;
        display: flex;
        gap: 0.6rem;
        align-items: center;
        z-index: 10;
      }

      .top-btn {
        background: none;
        border: 1px solid var(--border);
        border-radius: 50%;
        width: 36px;
        height: 36px;
        cursor: pointer;
        display: flex;
        align-items: center;
        justify-content: center;
        transition: all 0.3s ease;
        color: var(--text-muted);
        font-size: 1rem;
        text-decoration: none;
      }

      .top-btn:hover {
        border-color: var(--border-focus);
        color: var(--text);
      }

      .nav-btn.hidden {
        opacity: 0;
        pointer-events: none;
        transition: opacity 0.3s ease;
      }
    </style>
  </head>
  <body>
    <div class="top-controls">
      <a href="/alice-negative" class="top-btn nav-btn" id="alice-negative-btn" aria-label="Alice Negative" title="Alice Negative">&#x25CF;</a>
      <a href="/trajectory" class="top-btn nav-btn" id="trajectory-btn" aria-label="Trajectory" title="Trajectory">&#x2237;</a>
      <a href="/observatory" class="top-btn nav-btn" id="observatory-btn" aria-label="Observatory" title="Observatory">&#x25A1;</a>
      <a href="/dev/signals" class="top-btn nav-btn" id="signals-btn" aria-label="Signal Sandbox" title="Signal Sandbox">&#x2261;</a>
      <button class="top-btn" id="theme-toggle" aria-label="Toggle theme"></button>
    </div>
    <div class="container">
      <div class="date" id="date"></div>
      <div class="question loading" id="question">...</div>
      <div id="input-area"></div>
    </div>

    <script>
      // Theme toggle
      const themeBtn = document.getElementById('theme-toggle')!;
      const savedTheme = localStorage.getItem('alice-theme') || 'light';
      document.documentElement.setAttribute('data-theme', savedTheme);
      themeBtn.textContent = savedTheme === 'dark' ? '☀' : '☾';

      themeBtn.addEventListener('click', () => {
        const current = document.documentElement.getAttribute('data-theme');
        const next = current === 'dark' ? 'light' : 'dark';
        document.documentElement.setAttribute('data-theme', next);
        localStorage.setItem('alice-theme', next);
        themeBtn.textContent = next === 'dark' ? '☀' : '☾';
      });

      // Nav visibility — hide Alice Negative/trajectory buttons when writing
      function hideNav() {
        document.querySelectorAll('.nav-btn').forEach(el => el.classList.add('hidden'));
      }
      function showNav() {
        document.querySelectorAll('.nav-btn').forEach(el => el.classList.remove('hidden'));
      }

      // Device context — captured once per page load
      const isMobile = /Mobi|Android|iPhone|iPad/i.test(navigator.userAgent);
      const deviceType = isMobile ? 'mobile' : 'desktop';
      const hourOfDay = new Date().getHours();
      const dayOfWeek = new Date().getDay();
      const rawUserAgent = navigator.userAgent;

      const dateEl = document.getElementById('date')!;
      const questionEl = document.getElementById('question')!;
      const inputArea = document.getElementById('input-area')!;

      const today = new Date();
      dateEl.textContent = today.toLocaleDateString('en-US', {
        weekday: 'long',
        year: 'numeric',
        month: 'long',
        day: 'numeric',
      });

      async function load() {
        const res = await fetch('/api/today');
        if (!res.ok) {
          questionEl.textContent = 'No question today. Rest.';
          return;
        }

        const data = await res.json();
        questionEl.textContent = data.question.text;
        questionEl.classList.remove('loading');

        if (data.response) {
          trackEvent(data.question.id, 'revisit');
          questionEl.textContent = '';
          showDoneState();
        } else {
          hideNav();
          const questionId = data.question.id;
          const pageOpenTime = Date.now();
          trackEvent(questionId, 'page_open');

          inputArea.innerHTML = `
            <textarea
              class="response-area waiting"
              id="response"
              autocomplete="off"
              autocorrect="off"
              autocapitalize="off"
              spellcheck="false"
              disabled
            ></textarea>
            <div class="submit-row hidden" id="submit-row">
              <button class="submit-btn" id="submit" disabled>Submit</button>
            </div>
          `;

          const textarea = document.getElementById('response') as HTMLTextAreaElement;
          const submitBtn = document.getElementById('submit') as HTMLButtonElement;

          const submitRow = document.getElementById('submit-row')!;

          // Reflection pause — Hallnäs & Redström (2001, KTH): slow technology
          // amplifies time for reflection. 4-second pause before writing opens.
          setTimeout(() => {
            textarea.disabled = false;
            textarea.classList.remove('waiting');
            textarea.focus();
          }, 4000);

          // Submit button delay — hidden until 90s after writing opens.
          // Removes implicit "finish" pressure (Hallnäs & Redström 2001).
          setTimeout(() => {
            submitRow.classList.remove('hidden');
            submitRow.classList.add('visible');
          }, 94000); // 4s reflection pause + 90s writing

          // Behavioral tracking state
          let firstKeystrokeSent = false;
          let firstKeystrokeTime: number | null = null;
          let pauseTimer: number | null = null;
          let isPaused = false;
          let pauseStartTime: number | null = null;
          let totalPauseMs = 0;
          let pauseCount = 0;
          let totalCharsTyped = 0;
          let totalCharsDeleted = 0;
          let deletionCount = 0;
          let largestDeletion = 0;
          let lastTextLength = 0;
          let tabAwayCount = 0;
          let tabAwayStartTime: number | null = null;
          let totalTabAwayMs = 0;

          // Enriched: deletion decomposition (Faigley & Witte)
          let smallDeletionCount = 0;
          let largeDeletionCount = 0;
          let largeDeletionChars = 0;
          const deletionTimestamps: Array<{chars: number; time: number}> = [];

          // Enriched: P-burst tracking (Chenoweth & Hayes, 2s threshold)
          let lastInputTime: number | null = null;
          let currentBurstChars = 0;
          let burstStartTime: number | null = null;
          const burstLengths: number[] = [];
          const burstSequence: Array<{chars: number; startOffsetMs: number; durationMs: number}> = [];

          // Enriched: keystroke dynamics (Epp et al. 2011, CHI)
          // Inter-key intervals reveal affect signatures; revision chains reveal cognitive mode
          let lastKeystrokeTime: number | null = null;
          const interKeyIntervals: number[] = [];
          let currentRevisionChainLength = 0;
          let lastDeletionTime: number | null = null;
          const revisionChains: number[] = [];

          // Hold time + flight time decomposition (Kim et al. 2024, JMIR)
          // Hold time (keydown→keyup) = motor execution; flight time (keyup→next keydown) = cognitive planning
          const holdTimes: number[] = [];
          const flightTimes: number[] = [];
          let lastKeyupTime: number | null = null;
          const keydownTimes = new Map<string, number>();

          // Enriched: session metadata (Czerwinski et al. 2004)
          // Scroll-back and re-read behavior correlate with engagement depth
          let scrollBackCount = 0;
          let questionRereadCount = 0;
          let lastScrollTop = 0;

          textarea.addEventListener('scroll', () => {
            if (textarea.scrollTop < lastScrollTop && lastScrollTop > 0) {
              scrollBackCount++;
            }
            lastScrollTop = textarea.scrollTop;
          });

          // Track if user scrolls page up to re-read the question
          window.addEventListener('scroll', () => {
            if (window.scrollY < 50 && textarea.value.length > 0) {
              questionRereadCount++;
            }
          }, { passive: true });

          textarea.addEventListener('keydown', (e: KeyboardEvent) => {
            const now = Date.now();

            // Inter-key interval tracking (Epp et al. 2011)
            if (lastKeystrokeTime !== null) {
              const interval = now - lastKeystrokeTime;
              if (interval < 5000) { // cap at 5s to exclude pauses
                interKeyIntervals.push(interval);
              }
            }
            lastKeystrokeTime = now;

            // Hold time: record keydown timestamp per key (Kim et al. 2024)
            keydownTimes.set(e.code, now);

            // Flight time: keyup[n-1] → keydown[n] (cognitive planning interval)
            if (lastKeyupTime !== null) {
              const ft = now - lastKeyupTime;
              if (ft > 0 && ft < 5000) flightTimes.push(ft);
            }

            // Revision chain detection (Leijten & Van Waes 2013)
            // Sequential deletions within 500ms = one revision chain
            if (e.key === 'Backspace' || e.key === 'Delete') {
              if (lastDeletionTime !== null && (now - lastDeletionTime) < 500) {
                currentRevisionChainLength++;
              } else {
                if (currentRevisionChainLength > 0) {
                  revisionChains.push(currentRevisionChainLength);
                }
                currentRevisionChainLength = 1;
              }
              lastDeletionTime = now;
            } else {
              if (currentRevisionChainLength > 0) {
                revisionChains.push(currentRevisionChainLength);
                currentRevisionChainLength = 0;
              }
            }
          });

          // Hold time: keydown → keyup per key (motor execution duration)
          textarea.addEventListener('keyup', (e: KeyboardEvent) => {
            const now = Date.now();
            lastKeyupTime = now;
            const downTime = keydownTimes.get(e.code);
            if (downTime != null) {
              const ht = now - downTime;
              if (ht > 0 && ht < 2000) holdTimes.push(ht); // cap at 2s — held keys are not motor signal
              keydownTimes.delete(e.code);
            }
          });

          textarea.addEventListener('input', () => {
            const now = Date.now();
            const currentLength = textarea.value.length;
            const delta = currentLength - lastTextLength;

            // Question fading — Czerwinski et al. (2004, Microsoft Research):
            // faded prompts produce more associative, less literal responses
            if (!firstKeystrokeSent && delta > 0) {
              questionEl.classList.add('fading');
            }

            if (delta > 0) {
              totalCharsTyped += delta;

              // P-burst tracking: 2s gap = new burst
              if (lastInputTime !== null && (now - lastInputTime) > 2000) {
                if (currentBurstChars > 0) {
                  burstLengths.push(currentBurstChars);
                  burstSequence.push({
                    chars: currentBurstChars,
                    startOffsetMs: (burstStartTime ?? now) - pageOpenTime,
                    durationMs: lastInputTime - (burstStartTime ?? lastInputTime),
                  });
                }
                currentBurstChars = 0;
                burstStartTime = now;
              }
              if (burstStartTime === null) burstStartTime = now;
              currentBurstChars += delta;
              lastInputTime = now;
            } else if (delta < 0) {
              const deleted = Math.abs(delta);
              totalCharsDeleted += deleted;
              deletionCount++;
              if (deleted > largestDeletion) largestDeletion = deleted;

              // Deletion decomposition
              if (deleted < 10) {
                smallDeletionCount++;
              } else {
                largeDeletionCount++;
                largeDeletionChars += deleted;
              }
              deletionTimestamps.push({ chars: deleted, time: now });

              trackEvent(questionId, 'deletion', JSON.stringify({
                charsDeleted: deleted,
                textLength: currentLength,
              }));
            }

            lastTextLength = currentLength;
            submitBtn.disabled = !textarea.value.trim();

            if (!firstKeystrokeSent) {
              firstKeystrokeTime = Date.now();
              trackEvent(questionId, 'first_keystroke');
              firstKeystrokeSent = true;
            }

            if (isPaused) {
              if (pauseStartTime) {
                totalPauseMs += Date.now() - pauseStartTime;
                pauseStartTime = null;
              }
              trackEvent(questionId, 'resume', JSON.stringify({
                textLength: currentLength,
              }));
              isPaused = false;
            }

            if (pauseTimer) clearTimeout(pauseTimer);
            pauseTimer = window.setTimeout(() => {
              if (textarea.value.trim()) {
                pauseCount++;
                pauseStartTime = Date.now();
                trackEvent(questionId, 'pause', JSON.stringify({
                  textLength: currentLength,
                }));
                isPaused = true;
              }
            }, 30000);
          });

          document.addEventListener('visibilitychange', () => {
            if (document.hidden) {
              const blurTime = Date.now();
              tabAwayStartTime = blurTime;
              // Close current P-burst on tab-away
              if (currentBurstChars > 0) {
                burstLengths.push(currentBurstChars);
                burstSequence.push({
                  chars: currentBurstChars,
                  startOffsetMs: (burstStartTime ?? blurTime) - pageOpenTime,
                  durationMs: blurTime - (burstStartTime ?? blurTime),
                });
                currentBurstChars = 0;
                burstStartTime = null;
              }
              trackEvent(questionId, 'tab_blur');
            } else {
              if (tabAwayStartTime) {
                const awayMs = Date.now() - tabAwayStartTime;
                totalTabAwayMs += awayMs;
                tabAwayCount++;
                tabAwayStartTime = null;
              }
              trackEvent(questionId, 'tab_focus');
            }
          });

          submitBtn.addEventListener('click', async () => {
            const text = textarea.value.trim();
            if (!text) return;

            submitBtn.disabled = true;
            submitBtn.textContent = '...';

            // Finalize pause if still in one
            if (isPaused && pauseStartTime) {
              totalPauseMs += Date.now() - pauseStartTime;
            }

            // Close final P-burst
            if (currentBurstChars > 0) {
              const now = Date.now();
              burstLengths.push(currentBurstChars);
              burstSequence.push({
                chars: currentBurstChars,
                startOffsetMs: (burstStartTime ?? now) - pageOpenTime,
                durationMs: now - (burstStartTime ?? now),
              });
            }

            // Close final revision chain
            if (currentRevisionChainLength > 0) {
              revisionChains.push(currentRevisionChainLength);
            }

            const submitTime = Date.now();
            const finalCharCount = text.length;
            const wordCount = text.split(/\s+/).filter(Boolean).length;
            const sentenceCount = text.split(/[.!?]+/).filter((s: string) => s.trim()).length;
            const totalDurationMs = submitTime - pageOpenTime;
            const firstKeystrokeMs = firstKeystrokeTime ? firstKeystrokeTime - pageOpenTime : null;
            const commitmentRatio = totalCharsTyped > 0 ? finalCharCount / totalCharsTyped : null;

            // Derived: active typing time and speed
            const activeTypingMs = Math.max(0, totalDurationMs - totalPauseMs - totalTabAwayMs);
            const charsPerMinute = activeTypingMs > 0 ? totalCharsTyped / (activeTypingMs / 60000) : null;

            // Derived: P-burst stats
            const pBurstCount = burstLengths.length;
            const avgPBurstLength = pBurstCount > 0
              ? burstLengths.reduce((a, b) => a + b, 0) / pBurstCount : null;

            // Derived: deletion timing (first half vs second half of session)
            const midpoint = pageOpenTime + totalDurationMs / 2;
            let firstHalfDeletionChars = 0;
            let secondHalfDeletionChars = 0;
            for (const d of deletionTimestamps) {
              if (d.time <= midpoint) firstHalfDeletionChars += d.chars;
              else secondHalfDeletionChars += d.chars;
            }

            // Derived: inter-key interval stats (Epp et al. 2011)
            const ikiCount = interKeyIntervals.length;
            const ikiMean = ikiCount > 0
              ? interKeyIntervals.reduce((a, b) => a + b, 0) / ikiCount : null;
            const ikiStd = ikiCount > 1
              ? Math.sqrt(interKeyIntervals.reduce((sum, v) => sum + (v - ikiMean!) ** 2, 0) / (ikiCount - 1)) : null;

            // Derived: hold time stats (Kim et al. 2024 — motor execution)
            const htCount = holdTimes.length;
            const holdTimeMean = htCount > 0
              ? holdTimes.reduce((a, b) => a + b, 0) / htCount : null;
            const holdTimeStd = htCount > 1
              ? Math.sqrt(holdTimes.reduce((sum, v) => sum + (v - holdTimeMean!) ** 2, 0) / (htCount - 1)) : null;

            // Derived: flight time stats (Kim et al. 2024 — cognitive planning)
            const ftCount = flightTimes.length;
            const flightTimeMean = ftCount > 0
              ? flightTimes.reduce((a, b) => a + b, 0) / ftCount : null;
            const flightTimeStd = ftCount > 1
              ? Math.sqrt(flightTimes.reduce((sum, v) => sum + (v - flightTimeMean!) ** 2, 0) / (ftCount - 1)) : null;

            // Derived: keystroke entropy (Ajilore et al. 2025, BiAffect)
            // Shannon entropy of IKI distribution — measures timing unpredictability
            // Bins: 50ms width over 0-2000ms range (40 bins)
            let keystrokeEntropy: number | null = null;
            if (ikiCount >= 10) {
              const BIN_WIDTH = 50;
              const NUM_BINS = 40;
              const bins = new Array(NUM_BINS).fill(0);
              for (const iki of interKeyIntervals) {
                const bin = Math.min(NUM_BINS - 1, Math.floor(iki / BIN_WIDTH));
                bins[bin]++;
              }
              let entropy = 0;
              for (const count of bins) {
                if (count > 0) {
                  const p = count / ikiCount;
                  entropy -= p * Math.log2(p);
                }
              }
              keystrokeEntropy = entropy;
            }

            // Derived: revision chain stats (Leijten & Van Waes 2013)
            const revChainCount = revisionChains.length;
            const revChainAvgLength = revChainCount > 0
              ? revisionChains.reduce((a, b) => a + b, 0) / revChainCount : null;

            const sessionSummary = {
              questionId,
              firstKeystrokeMs,
              totalDurationMs,
              totalCharsTyped,
              finalCharCount,
              commitmentRatio,
              pauseCount,
              totalPauseMs,
              deletionCount,
              largestDeletion,
              totalCharsDeleted,
              tabAwayCount,
              totalTabAwayMs,
              wordCount,
              sentenceCount,
              // Enriched fields
              smallDeletionCount,
              largeDeletionCount,
              largeDeletionChars,
              firstHalfDeletionChars,
              secondHalfDeletionChars,
              activeTypingMs,
              charsPerMinute,
              pBurstCount,
              avgPBurstLength,
              burstSequence,
              // Keystroke dynamics (Epp et al. 2011; Leijten & Van Waes 2013)
              interKeyIntervalMean: ikiMean,
              interKeyIntervalStd: ikiStd,
              revisionChainCount: revChainCount,
              revisionChainAvgLength: revChainAvgLength,
              // Hold time + flight time decomposition (Kim et al. 2024)
              holdTimeMean,
              holdTimeStd,
              flightTimeMean,
              flightTimeStd,
              // Keystroke entropy (Ajilore et al. 2025, BiAffect)
              keystrokeEntropy,
              // Session metadata (Czerwinski et al. 2004)
              scrollBackCount,
              questionRereadCount,
              // Context
              deviceType,
              userAgent: rawUserAgent,
              hourOfDay,
              dayOfWeek,
            };

            const res = await fetch('/api/respond', {
              method: 'POST',
              headers: { 'Content-Type': 'application/json' },
              body: JSON.stringify({ questionId, text, sessionSummary }),
            });

            if (res.ok) {
              const resData = await res.json();
              trackEvent(questionId, 'submit', JSON.stringify({
                charCount: finalCharCount,
                wordCount,
              }));
              questionEl.textContent = '';
              showDoneState(resData.askFeedback ? questionId : null);
            } else {
              submitBtn.textContent = 'Submit';
              submitBtn.disabled = false;
            }
          });
        }
      }

      function trackEvent(questionId: number, eventType: string, metadata?: string) {
        fetch('/api/event', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ questionId, eventType, metadata }),
        }).catch(() => {});
      }

      function getDoneMessage(): string {
        const messages = [
          "Noted. Let it sit.",
          "That thought is yours now. Come back tomorrow.",
          "Done. Don't rehearse it — let it breathe.",
          "Saved. Go do something with your hands.",
          "Good. Now forget about it until tomorrow.",
          "The thought is planted. Leave it alone.",
          "You showed up. That's the whole thing.",
          "Noted. The next question is already forming.",
          "Stop thinking about what you just wrote.",
          "That's enough for today.",
        ];
        return messages[Math.floor(Math.random() * messages.length)];
      }

      function escapeHtml(text: string): string {
        const div = document.createElement('div');
        div.textContent = text;
        return div.innerHTML;
      }

      function showDoneState(feedbackQuestionId: number | null = null) {
        showNav();
        let feedbackHtml = '';
        if (feedbackQuestionId) {
          feedbackHtml = `
            <div class="feedback-row" id="feedback-row">
              <span class="feedback-label">did it land?</span>
              <button class="feedback-btn" data-landed="true">yes</button>
              <button class="feedback-btn" data-landed="false">no</button>
            </div>
          `;
        }
        inputArea.innerHTML = `
          <div class="done-message">${getDoneMessage()}</div>
          ${feedbackHtml}
          <button class="free-write-link" id="free-write-btn">free write</button>
        `;
        document.getElementById('free-write-btn')!.addEventListener('click', startFreeWrite);

        if (feedbackQuestionId) {
          const feedbackRow = document.getElementById('feedback-row')!;
          feedbackRow.querySelectorAll('.feedback-btn').forEach((btn) => {
            btn.addEventListener('click', async () => {
              const landed = (btn as HTMLElement).dataset.landed === 'true';
              await fetch('/api/feedback', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ questionId: feedbackQuestionId, landed }),
              });
              feedbackRow.innerHTML = `<span class="feedback-label">noted.</span>`;
            });
          });
        }
      }

      async function startFreeWrite() {
        const res = await fetch('/api/calibrate');
        if (!res.ok) return;
        const data = await res.json();
        const prompt = data.prompt;

        hideNav();
        questionEl.textContent = '';
        inputArea.innerHTML = '';

        const promptDiv = document.createElement('div');
        promptDiv.className = 'calibration-prompt';
        promptDiv.textContent = prompt;
        inputArea.appendChild(promptDiv);

        const pageOpenTime = Date.now();

        const formHtml = document.createElement('div');
        formHtml.innerHTML = `
          <textarea
            class="response-area"
            id="response"
            autocomplete="off"
            autocorrect="off"
            autocapitalize="off"
            spellcheck="false"
          ></textarea>
          <div class="submit-row">
            <button class="submit-btn" id="submit" disabled>Submit</button>
          </div>
        `;
        inputArea.appendChild(formHtml);

        const textarea = document.getElementById('response') as HTMLTextAreaElement;
        const submitBtn = document.getElementById('submit') as HTMLButtonElement;

        // Behavioral tracking state
        let firstKeystrokeSent = false;
        let firstKeystrokeTime: number | null = null;
        let pauseTimer: number | null = null;
        let isPaused = false;
        let pauseStartTime: number | null = null;
        let totalPauseMs = 0;
        let pauseCount = 0;
        let totalCharsTyped = 0;
        let totalCharsDeleted = 0;
        let deletionCount = 0;
        let largestDeletion = 0;
        let lastTextLength = 0;
        let tabAwayCount = 0;
        let tabAwayStartTime: number | null = null;
        let totalTabAwayMs = 0;

        // Enriched: deletion decomposition (Faigley & Witte)
        let smallDeletionCount = 0;
        let largeDeletionCount = 0;
        let largeDeletionChars = 0;
        const calDeletionTimestamps: Array<{chars: number; time: number}> = [];

        // Enriched: P-burst tracking (Chenoweth & Hayes, 2s threshold)
        let lastInputTime: number | null = null;
        let currentBurstChars = 0;
        const calBurstLengths: number[] = [];

        // Enriched: keystroke dynamics (Epp et al. 2011)
        let lastKeystrokeTime: number | null = null;
        const calInterKeyIntervals: number[] = [];
        let calCurrentRevChainLength = 0;
        let calLastDeletionTime: number | null = null;
        const calRevisionChains: number[] = [];

        // Hold time + flight time decomposition (Kim et al. 2024)
        const calHoldTimes: number[] = [];
        const calFlightTimes: number[] = [];
        let calLastKeyupTime: number | null = null;
        const calKeydownTimes = new Map<string, number>();

        // Session metadata (Czerwinski et al. 2004)
        let calScrollBackCount = 0;
        let calLastScrollTop = 0;

        textarea.addEventListener('scroll', () => {
          if (textarea.scrollTop < calLastScrollTop && calLastScrollTop > 0) {
            calScrollBackCount++;
          }
          calLastScrollTop = textarea.scrollTop;
        });

        textarea.addEventListener('keydown', (e: KeyboardEvent) => {
          const now = Date.now();
          if (lastKeystrokeTime !== null) {
            const interval = now - lastKeystrokeTime;
            if (interval < 5000) calInterKeyIntervals.push(interval);
          }
          lastKeystrokeTime = now;

          // Hold time: record keydown timestamp per key (Kim et al. 2024)
          calKeydownTimes.set(e.code, now);

          // Flight time: keyup[n-1] → keydown[n]
          if (calLastKeyupTime !== null) {
            const ft = now - calLastKeyupTime;
            if (ft > 0 && ft < 5000) calFlightTimes.push(ft);
          }

          if (e.key === 'Backspace' || e.key === 'Delete') {
            if (calLastDeletionTime !== null && (now - calLastDeletionTime) < 500) {
              calCurrentRevChainLength++;
            } else {
              if (calCurrentRevChainLength > 0) calRevisionChains.push(calCurrentRevChainLength);
              calCurrentRevChainLength = 1;
            }
            calLastDeletionTime = now;
          } else {
            if (calCurrentRevChainLength > 0) {
              calRevisionChains.push(calCurrentRevChainLength);
              calCurrentRevChainLength = 0;
            }
          }
        });

        // Hold time: keydown → keyup per key (motor execution duration)
        textarea.addEventListener('keyup', (e: KeyboardEvent) => {
          const now = Date.now();
          calLastKeyupTime = now;
          const downTime = calKeydownTimes.get(e.code);
          if (downTime != null) {
            const ht = now - downTime;
            if (ht > 0 && ht < 2000) calHoldTimes.push(ht);
            calKeydownTimes.delete(e.code);
          }
        });

        textarea.addEventListener('input', () => {
          const now = Date.now();
          const currentLength = textarea.value.length;
          const delta = currentLength - lastTextLength;

          if (delta > 0) {
            totalCharsTyped += delta;

            // P-burst tracking: 2s gap = new burst
            if (lastInputTime !== null && (now - lastInputTime) > 2000) {
              if (currentBurstChars > 0) calBurstLengths.push(currentBurstChars);
              currentBurstChars = 0;
            }
            currentBurstChars += delta;
            lastInputTime = now;
          } else if (delta < 0) {
            const deleted = Math.abs(delta);
            totalCharsDeleted += deleted;
            deletionCount++;
            if (deleted > largestDeletion) largestDeletion = deleted;

            // Deletion decomposition
            if (deleted < 10) {
              smallDeletionCount++;
            } else {
              largeDeletionCount++;
              largeDeletionChars += deleted;
            }
            calDeletionTimestamps.push({ chars: deleted, time: now });
          }

          lastTextLength = currentLength;
          submitBtn.disabled = !textarea.value.trim();

          if (!firstKeystrokeSent) {
            firstKeystrokeTime = Date.now();
            firstKeystrokeSent = true;
          }

          if (isPaused) {
            if (pauseStartTime) {
              totalPauseMs += Date.now() - pauseStartTime;
              pauseStartTime = null;
            }
            isPaused = false;
          }

          if (pauseTimer) clearTimeout(pauseTimer);
          pauseTimer = window.setTimeout(() => {
            if (textarea.value.trim()) {
              pauseCount++;
              pauseStartTime = Date.now();
              isPaused = true;
            }
          }, 30000);
        });

        submitBtn.addEventListener('click', async () => {
          const text = textarea.value.trim();
          if (!text) return;

          submitBtn.disabled = true;
          submitBtn.textContent = '...';

          if (isPaused && pauseStartTime) {
            totalPauseMs += Date.now() - pauseStartTime;
          }

          // Close final P-burst
          if (currentBurstChars > 0) calBurstLengths.push(currentBurstChars);

          // Close final revision chain
          if (calCurrentRevChainLength > 0) calRevisionChains.push(calCurrentRevChainLength);

          const submitTime = Date.now();
          const finalCharCount = text.length;
          const wordCount = text.split(/\s+/).filter(Boolean).length;
          const sentenceCount = text.split(/[.!?]+/).filter((s: string) => s.trim()).length;
          const totalDurationMs = submitTime - pageOpenTime;
          const firstKeystrokeMs = firstKeystrokeTime ? firstKeystrokeTime - pageOpenTime : null;
          const commitmentRatio = totalCharsTyped > 0 ? finalCharCount / totalCharsTyped : null;

          // Derived: active typing time and speed
          const activeTypingMs = Math.max(0, totalDurationMs - totalPauseMs - totalTabAwayMs);
          const charsPerMinute = activeTypingMs > 0 ? totalCharsTyped / (activeTypingMs / 60000) : null;

          // Derived: P-burst stats
          const pBurstCount = calBurstLengths.length;
          const avgPBurstLength = pBurstCount > 0
            ? calBurstLengths.reduce((a, b) => a + b, 0) / pBurstCount : null;

          // Derived: deletion timing
          const midpoint = pageOpenTime + totalDurationMs / 2;
          let firstHalfDeletionChars = 0;
          let secondHalfDeletionChars = 0;
          for (const d of calDeletionTimestamps) {
            if (d.time <= midpoint) firstHalfDeletionChars += d.chars;
            else secondHalfDeletionChars += d.chars;
          }

          // Derived: inter-key interval stats (Epp et al. 2011)
          const calIkiCount = calInterKeyIntervals.length;
          const calIkiMean = calIkiCount > 0
            ? calInterKeyIntervals.reduce((a, b) => a + b, 0) / calIkiCount : null;
          const calIkiStd = calIkiCount > 1
            ? Math.sqrt(calInterKeyIntervals.reduce((sum, v) => sum + (v - calIkiMean!) ** 2, 0) / (calIkiCount - 1)) : null;

          // Derived: hold time stats (Kim et al. 2024 — motor execution)
          const calHtCount = calHoldTimes.length;
          const calHoldTimeMean = calHtCount > 0
            ? calHoldTimes.reduce((a, b) => a + b, 0) / calHtCount : null;
          const calHoldTimeStd = calHtCount > 1
            ? Math.sqrt(calHoldTimes.reduce((sum, v) => sum + (v - calHoldTimeMean!) ** 2, 0) / (calHtCount - 1)) : null;

          // Derived: flight time stats (Kim et al. 2024 — cognitive planning)
          const calFtCount = calFlightTimes.length;
          const calFlightTimeMean = calFtCount > 0
            ? calFlightTimes.reduce((a, b) => a + b, 0) / calFtCount : null;
          const calFlightTimeStd = calFtCount > 1
            ? Math.sqrt(calFlightTimes.reduce((sum, v) => sum + (v - calFlightTimeMean!) ** 2, 0) / (calFtCount - 1)) : null;

          // Derived: keystroke entropy (Ajilore et al. 2025, BiAffect)
          let calKeystrokeEntropy: number | null = null;
          if (calIkiCount >= 10) {
            const BIN_WIDTH = 50;
            const NUM_BINS = 40;
            const bins = new Array(NUM_BINS).fill(0);
            for (const iki of calInterKeyIntervals) {
              const bin = Math.min(NUM_BINS - 1, Math.floor(iki / BIN_WIDTH));
              bins[bin]++;
            }
            let entropy = 0;
            for (const count of bins) {
              if (count > 0) {
                const p = count / calIkiCount;
                entropy -= p * Math.log2(p);
              }
            }
            calKeystrokeEntropy = entropy;
          }

          // Derived: revision chain stats (Leijten & Van Waes 2013)
          const calRevChainCount = calRevisionChains.length;
          const calRevChainAvgLen = calRevChainCount > 0
            ? calRevisionChains.reduce((a, b) => a + b, 0) / calRevChainCount : null;

          const sessionSummary = {
            firstKeystrokeMs,
            totalDurationMs,
            totalCharsTyped,
            finalCharCount,
            commitmentRatio,
            pauseCount,
            totalPauseMs,
            deletionCount,
            largestDeletion,
            totalCharsDeleted,
            tabAwayCount,
            totalTabAwayMs,
            wordCount,
            sentenceCount,
            smallDeletionCount,
            largeDeletionCount,
            largeDeletionChars,
            firstHalfDeletionChars,
            secondHalfDeletionChars,
            activeTypingMs,
            charsPerMinute,
            pBurstCount,
            avgPBurstLength,
            // Keystroke dynamics (Epp et al. 2011; Leijten & Van Waes 2013)
            interKeyIntervalMean: calIkiMean,
            interKeyIntervalStd: calIkiStd,
            revisionChainCount: calRevChainCount,
            revisionChainAvgLength: calRevChainAvgLen,
            // Hold time + flight time decomposition (Kim et al. 2024)
            holdTimeMean: calHoldTimeMean,
            holdTimeStd: calHoldTimeStd,
            flightTimeMean: calFlightTimeMean,
            flightTimeStd: calFlightTimeStd,
            // Keystroke entropy (Ajilore et al. 2025, BiAffect)
            keystrokeEntropy: calKeystrokeEntropy,
            scrollBackCount: calScrollBackCount,
            questionRereadCount: 0, // not tracked in calibration — no persistent question to re-read
            // Context
            deviceType,
            userAgent: rawUserAgent,
            hourOfDay,
            dayOfWeek,
          };

          const calRes = await fetch('/api/calibrate', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ prompt, text, sessionSummary }),
          });

          if (calRes.ok) {
            showNav();
            promptDiv.textContent = '';
            inputArea.innerHTML = `
              <div class="done-message">Noted.</div>
              <button class="free-write-link" id="another-btn">another one</button>
            `;
            document.getElementById('another-btn')!.addEventListener('click', startFreeWrite);
          } else {
            submitBtn.textContent = 'Submit';
            submitBtn.disabled = false;
          }
        });

        textarea.focus();
      }

      load();
    </script>
  </body>
</html>
