---

---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Alice</title>
    <script is:inline>
      (function() {
        var t = localStorage.getItem('alice-theme') || 'light';
        document.documentElement.setAttribute('data-theme', t);
      })();
    </script>
    <style is:global>
      @import url('https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,400;1,300;1,400&family=EB+Garamond:ital,wght@0,400;0,500;1,400&display=swap');

      :root {
        --bg: #f5f2ed;
        --bg-pre: #e9e5de;
        --bg-input: #ebe7e1;
        --text: #1a1a1a;
        --text-pre: #a8a39d;
        --text-muted: #6b6560;
        --text-faint: #9a9590;
        --border: #ccc5bc;
        --border-focus: #8a8580;
        --btn-bg: #e0dbd5;
        --btn-hover: #ccc5bc;
        --btn-text: #1a1a1a;
        --done-text: #8a8580;
        --loading: #c5c0ba;
        --free-border: #c5c0ba;
        --free-hover-bg: rgba(0, 0, 0, 0.03);
      }

      [data-theme="dark"] {
        --bg: #141210;
        --bg-pre: #050505;
        --bg-input: #161514;
        --text: #ffffff;
        --text-pre: #3a3530;
        --text-muted: #7a7570;
        --text-faint: #4a4540;
        --border: #333;
        --border-focus: #666;
        --btn-bg: #222;
        --btn-hover: #444;
        --btn-text: #ffffff;
        --done-text: #8a8580;
        --loading: #4a4540;
        --free-border: #3a3530;
        --free-hover-bg: rgba(255, 255, 255, 0.04);
      }

      * {
        margin: 0;
        padding: 0;
        box-sizing: border-box;
      }

      html, body {
        height: 100%;
        background: var(--bg);
        color: var(--text);
        font-family: 'EB Garamond', Georgia, serif;
      }

      body {
        display: flex;
        align-items: center;
        justify-content: center;
        padding: 2rem;
        background-color: var(--bg);
        transition: background-color 2.5s ease;
      }

      /* Pre-arrival — the room is dim until presence is detected. */
      body.pre-arrival {
        background-color: var(--bg-pre);
      }

      .container {
        max-width: 680px;
        width: 100%;
      }

      .date {
        font-size: 11px;
        color: var(--text-faint);
        letter-spacing: 0.22em;
        text-transform: uppercase;
        margin-bottom: 5rem;
        transition: opacity 2s ease;
      }

      body.pre-arrival .date { opacity: 0.5; }
      body.deepening-3 .date { opacity: 0.3; }

      .question {
        font-family: 'Cormorant Garamond', Georgia, serif;
        font-size: 1.95rem;
        font-weight: 300;
        line-height: 1.7;
        letter-spacing: 0.015em;
        color: var(--text);
        margin-bottom: 1.4rem;
        font-style: italic;
        transition: color 2.5s ease, opacity 3s ease;
      }

      body.pre-arrival .question { color: var(--text-pre); }
      body.deepening-1 .question { opacity: 0.55; }
      body.deepening-2 .question { opacity: 0.3; }
      body.deepening-3 .question { opacity: 0.12; }

      /* Writing surface — the page itself. No box, no border, no affordance
         except a cursor. Response flows directly from the prompt, same column,
         same measure, same line-height. Serif roman under serif italic reads
         as one continuous piece of writing, not a form. */
      .response-area {
        width: 100%;
        min-height: 200px;
        background: transparent;
        border: none;
        border-radius: 0;
        color: var(--text);
        font-family: 'EB Garamond', Georgia, serif;
        font-size: 1.55rem;
        line-height: 1.7;
        letter-spacing: 0.005em;
        padding: 0;
        resize: none;
        outline: none;
        -webkit-appearance: none;
        appearance: none;
        caret-color: var(--text);
        transition: caret-color 2s ease, color 2.5s ease;
      }

      .response-area:focus {
        outline: none;
      }

      /* Caret faint in pre-arrival — enough to signal "this is where your
         words go" without demanding. Any presence signal (mouse/scroll/touch/
         keystroke) warms the room and sharpens the caret. */
      body.pre-arrival .response-area {
        caret-color: var(--text-faint);
        color: var(--text-pre);
      }

      .submit-row {
        margin-top: 3.5rem;
      }

      .submit-btn {
        background: none;
        border: 1px solid var(--border);
        border-radius: 3px;
        color: var(--text-muted);
        font-family: 'Cormorant Garamond', Georgia, serif;
        font-size: 1.15rem;
        font-style: italic;
        font-weight: 300;
        letter-spacing: 0.06em;
        padding: 0.55rem 2.4rem;
        cursor: pointer;
        transition: color 0.4s ease, border-color 0.4s ease, opacity 0.4s ease;
      }

      .submit-btn:hover:not(:disabled) {
        color: var(--text);
        border-color: var(--border-focus);
      }

      .submit-btn:active:not(:disabled) {
        opacity: 0.7;
      }

      .submit-btn:disabled {
        opacity: 0.3;
        cursor: default;
      }

      .submit-row.hidden {
        opacity: 0;
        pointer-events: none;
        transition: opacity 2s ease;
      }

      .submit-row.visible {
        opacity: 1;
        pointer-events: auto;
        transition: opacity 2s ease;
      }

      .done-message {
        font-family: 'Cormorant Garamond', Georgia, serif;
        font-size: 1.8rem;
        font-weight: 300;
        font-style: italic;
        line-height: 1.8;
        color: var(--done-text);
        margin-top: 1rem;
      }

      .loading {
        color: var(--loading);
        font-style: italic;
      }

      .free-write-link {
        display: inline-block;
        margin-top: 3rem;
        color: var(--text-muted);
        font-size: 1.25rem;
        letter-spacing: 0.1em;
        text-transform: lowercase;
        cursor: pointer;
        border: 1px solid var(--free-border);
        background: none;
        font-family: 'Cormorant Garamond', Georgia, serif;
        font-style: italic;
        font-weight: 300;
        text-decoration: none;
        padding: 0.6rem 1.8rem;
        border-radius: 4px;
        transition: all 0.4s ease;
      }

      .free-write-link:hover {
        color: var(--text);
        border-color: var(--border-focus);
        background: var(--free-hover-bg);
      }

      .feedback-row {
        margin-top: 2.5rem;
        display: flex;
        align-items: center;
        gap: 1.2rem;
      }

      .feedback-label {
        font-family: 'Cormorant Garamond', Georgia, serif;
        font-size: 1.25rem;
        font-weight: 300;
        font-style: italic;
        color: var(--text-muted);
      }

      .feedback-btn {
        background: none;
        border: 1px solid var(--free-border);
        border-radius: 4px;
        color: var(--text-muted);
        font-family: 'Cormorant Garamond', Georgia, serif;
        font-size: 1.1rem;
        font-style: italic;
        padding: 0.4rem 1.2rem;
        cursor: pointer;
        transition: all 0.3s ease;
      }

      .feedback-btn:hover {
        color: var(--text);
        border-color: var(--border-focus);
      }

      .calibration-prompt {
        font-family: 'Cormorant Garamond', Georgia, serif;
        font-size: 1.95rem;
        font-weight: 300;
        line-height: 1.7;
        letter-spacing: 0.015em;
        color: var(--text);
        margin-bottom: 1.4rem;
        font-style: italic;
        transition: opacity 3s ease;
      }

      body.deepening-1 .calibration-prompt { opacity: 0.55; }
      body.deepening-2 .calibration-prompt { opacity: 0.3; }
      body.deepening-3 .calibration-prompt { opacity: 0.12; }
      .top-controls {
        position: fixed;
        top: 2rem;
        right: 2rem;
        display: flex;
        gap: 0.6rem;
        align-items: center;
        z-index: 10;
      }

      .top-btn {
        background: none;
        border: 1px solid var(--border);
        border-radius: 50%;
        width: 36px;
        height: 36px;
        cursor: pointer;
        display: flex;
        align-items: center;
        justify-content: center;
        transition: all 0.3s ease;
        color: var(--text-muted);
        font-size: 1rem;
        text-decoration: none;
      }

      .top-btn:hover {
        border-color: var(--border-focus);
        color: var(--text);
      }

      .nav-btn.hidden {
        opacity: 0;
        pointer-events: none;
        transition: opacity 0.3s ease;
      }

      /* ── pipeline health indicator ─────────────────────────────────────── */
      .health-wrap { position: relative; }
      .health-dot {
        width: 36px; height: 36px;
        border: 1px solid var(--border);
        border-radius: 50%;
        background: none;
        cursor: pointer;
        display: flex;
        align-items: center;
        justify-content: center;
        transition: all 0.3s ease;
        padding: 0;
      }
      .health-dot:hover { border-color: var(--border-focus); }
      .health-dot .pip {
        width: 10px; height: 10px;
        border-radius: 50%;
        background: var(--loading);
        transition: background 0.4s ease;
      }
      .health-dot[data-status="green"]  .pip { background: #6b8e6b; }
      .health-dot[data-status="yellow"] .pip { background: #c9a55e; }
      .health-dot[data-status="red"]    .pip { background: #b5603f; }

      .health-panel {
        position: absolute;
        top: calc(100% + 0.6rem);
        right: 0;
        background: var(--bg);
        border: 1px solid var(--border);
        border-radius: 8px;
        padding: 1rem 1.2rem;
        width: 280px;
        opacity: 0;
        pointer-events: none;
        transform: translateY(-4px);
        transition: opacity 0.2s ease, transform 0.2s ease;
        z-index: 100;
        font-family: 'Cormorant Garamond', Georgia, serif;
        font-size: 0.95rem;
        color: var(--text-muted);
        line-height: 1.55;
      }
      .health-panel.open {
        opacity: 1;
        pointer-events: auto;
        transform: translateY(0);
      }
      .health-panel .section {
        font-size: 0.72rem;
        letter-spacing: 0.12em;
        text-transform: uppercase;
        color: var(--text-faint);
        margin: 0.6rem 0 0.25rem;
      }
      .health-panel .section:first-child { margin-top: 0; }
      .health-panel .row {
        display: flex;
        justify-content: space-between;
        gap: 1rem;
        padding: 0.12rem 0;
      }
      .health-panel .row .val { color: var(--text); }
      .health-panel .row.warn .val { color: #c9a55e; }
      .health-panel .row.bad  .val { color: #b5603f; }
      .health-panel .stage-list {
        display: flex;
        flex-wrap: wrap;
        gap: 0.4rem;
        margin-top: 0.2rem;
      }
      .health-panel .stage {
        font-size: 0.78rem;
        padding: 0.1rem 0.5rem;
        border-radius: 3px;
        border: 1px solid var(--border);
        color: var(--text-muted);
      }
      .health-panel .stage.ok  { color: #6b8e6b; border-color: #6b8e6b55; }
      .health-panel .stage.bad { color: #b5603f; border-color: #b5603f55; }
      .health-panel .empty { font-style: italic; color: var(--text-faint); font-size: 0.85rem; }

      .nav-menu {
        position: relative;
      }

      .nav-menu-btn {
        background: none;
        border: 1px solid var(--border);
        border-radius: 50%;
        width: 36px;
        height: 36px;
        cursor: pointer;
        display: flex;
        align-items: center;
        justify-content: center;
        transition: all 0.3s ease;
        color: var(--text-muted);
        font-size: 1.1rem;
      }

      .nav-menu-btn:hover {
        border-color: var(--border-focus);
        color: var(--text);
      }

      .nav-menu-btn.open {
        border-color: var(--border-focus);
        color: var(--text);
      }

      .nav-dropdown {
        position: absolute;
        top: calc(100% + 0.6rem);
        right: 0;
        background: var(--bg);
        border: 1px solid var(--border);
        border-radius: 8px;
        padding: 0.5rem 0;
        min-width: 180px;
        opacity: 0;
        pointer-events: none;
        transform: translateY(-4px);
        transition: opacity 0.2s ease, transform 0.2s ease;
        z-index: 100;
      }

      .nav-dropdown.open {
        opacity: 1;
        pointer-events: auto;
        transform: translateY(0);
      }

      .nav-dropdown a {
        display: block;
        padding: 0.6rem 1.2rem;
        color: var(--text-muted);
        text-decoration: none;
        font-size: 1.05rem;
        letter-spacing: 0.03em;
        transition: color 0.2s ease, background 0.2s ease;
      }

      .nav-dropdown a:hover {
        color: var(--text);
        background: var(--bg-input);
      }

      .nav-dropdown .nav-divider {
        height: 1px;
        background: var(--border);
        margin: 0.4rem 1.2rem;
      }
    </style>
  </head>
  <body>
    <div class="top-controls">
      <div class="nav-menu nav-btn" id="nav-menu">
        <button class="nav-menu-btn" id="nav-menu-btn" aria-label="Navigation" title="Navigation">&#x2022;&#x2022;&#x2022;</button>
        <div class="nav-dropdown" id="nav-dropdown">
          <a href="/about">About</a>
          <a href="/papers">Papers</a>
          <div class="nav-divider"></div>
          <a href="/alice-negative">Alice Negative</a>
          <a href="/observatory">Observatory</a>
          <div class="nav-divider"></div>
          <a href="/dev/signals">Signal Sandbox</a>
        </div>
      </div>
      <div class="health-wrap">
        <button class="health-dot" id="health-dot" aria-label="Pipeline health" title="Pipeline health">
          <span class="pip"></span>
        </button>
        <div class="health-panel" id="health-panel" role="dialog" aria-label="Pipeline status"></div>
      </div>
      <button class="top-btn" id="theme-toggle" aria-label="Toggle theme"></button>
    </div>
    <div class="container">
      <div class="date" id="date"></div>
      <div class="question loading" id="question">...</div>
      <div id="input-area"></div>
    </div>

    <script>
      // Nav menu dropdown
      const navMenuBtn = document.getElementById('nav-menu-btn')!;
      const navDropdown = document.getElementById('nav-dropdown')!;

      navMenuBtn.addEventListener('click', (e) => {
        e.stopPropagation();
        const isOpen = navDropdown.classList.toggle('open');
        navMenuBtn.classList.toggle('open', isOpen);
      });

      document.addEventListener('click', () => {
        navDropdown.classList.remove('open');
        navMenuBtn.classList.remove('open');
      });

      // Theme toggle
      const themeBtn = document.getElementById('theme-toggle')!;
      const savedTheme = localStorage.getItem('alice-theme') || 'light';
      document.documentElement.setAttribute('data-theme', savedTheme);
      themeBtn.textContent = savedTheme === 'dark' ? '☀' : '☾';

      themeBtn.addEventListener('click', () => {
        const current = document.documentElement.getAttribute('data-theme');
        const next = current === 'dark' ? 'light' : 'dark';
        document.documentElement.setAttribute('data-theme', next);
        localStorage.setItem('alice-theme', next);
        themeBtn.textContent = next === 'dark' ? '☀' : '☾';
      });

      // Presence — the room is dim until you arrive. Pre-arrival is purely
      // a visual state: nothing is blocked, the caret is faintly visible.
      // Any signal of arrival — mouse, scroll, touch, or typing — warms the
      // room. The brightening happens *around* your typing rather than
      // *before* it; still honest, still responsive to you.
      document.body.classList.add('pre-arrival');
      {
        const presenceEvents: Array<keyof WindowEventMap> = ['mousemove', 'scroll', 'touchstart', 'pointerdown', 'keydown'];
        function onPresence() {
          document.body.classList.remove('pre-arrival');
          presenceEvents.forEach((e) => window.removeEventListener(e, onPresence as any));
        }
        presenceEvents.forEach((e) => window.addEventListener(e, onPresence, { passive: true } as any));
      }

      // Keep the writing surface focused — the top controls (theme, health,
      // nav) steal focus when clicked; this snaps it back. Deferred to the
      // next tick so the clicked element can run its own handler first
      // (including DOM replacements like free-write → calibration surface).
      // Exclusions: form controls, panel content (let you interact with open
      // popovers), and links (they navigate away).
      document.addEventListener('click', (e) => {
        const t = e.target as HTMLElement | null;
        if (!t) return;
        if (t.closest('input, select, a[href]')) return;
        if (t.closest('.nav-dropdown, .health-panel')) return;
        setTimeout(() => {
          const ta = document.getElementById('response') as HTMLTextAreaElement | null;
          if (ta) ta.focus();
        }, 0);
      });

      // Time-based prompt fade — the scaffolding recedes because you've
      // been with it long enough, not because you've produced enough.
      // Char-count fading creates output pressure; sentence-break fading
      // becomes a tic. Time says: presence, not performance.
      let fadeScheduled = false;
      function scheduleFade() {
        if (fadeScheduled) return;
        fadeScheduled = true;
        setTimeout(() => document.body.classList.add('deepening-1'), 30000);
        setTimeout(() => document.body.classList.add('deepening-2'), 75000);
        setTimeout(() => document.body.classList.add('deepening-3'), 150000);
      }
      function resetFade() {
        fadeScheduled = false;
        document.body.classList.remove('deepening-1', 'deepening-2', 'deepening-3');
      }

      // Pipeline health — pre-session visibility.
      // IMPORTANT: the endpoint returns no content (no question/response text,
      // no signal values). The panel renders counts + booleans only.
      const healthDot = document.getElementById('health-dot')!;
      const healthPanel = document.getElementById('health-panel')!;

      healthDot.addEventListener('click', (e) => {
        e.stopPropagation();
        healthPanel.classList.toggle('open');
      });
      document.addEventListener('click', () => healthPanel.classList.remove('open'));
      healthPanel.addEventListener('click', (e) => e.stopPropagation());

      function renderHealth(h: any) {
        healthDot.setAttribute('data-status', h.overall);
        const row = (label: string, val: string, cls = '') =>
          `<div class="row ${cls}"><span>${label}</span><span class="val">${val}</span></div>`;

        let html = '';

        // TODAY
        html += '<div class="section">Today</div>';
        html += row('Question ready', h.today.questionReady ? 'yes' : 'no',
          h.today.questionReady ? '' : 'bad');
        html += row('Session submitted', h.today.sessionSubmittedToday ? 'yes' : 'not yet');

        // LAST SESSION PIPELINE
        html += '<div class="section">Last session</div>';
        if (!h.lastSession) {
          html += '<div class="empty">none yet</div>';
        } else {
          html += row('Date', h.lastSession.date);
          html += row('Fully processed',
            h.lastSession.fullyProcessed ? 'yes' : `${h.lastSession.missing.length} missing`,
            h.lastSession.fullyProcessed ? '' : 'bad');
          const p = h.lastSession.pipeline;
          const stage = (name: string, key: string) =>
            `<span class="stage ${p[key] ? 'ok' : 'bad'}">${name}</span>`;
          html += '<div class="stage-list">' +
            stage('embed', 'embedded') +
            stage('state', 'entryState') +
            stage('observe', 'observed') +
            stage('suppress', 'suppressedQuestion') +
            stage('witness', 'witnessRendered') +
            '</div>';
        }

        // SESSIONS
        html += '<div class="section">Sessions</div>';
        html += row('Completed', String(h.sessions.count));
        html += row('Tomorrow ready', h.tomorrow.questionReady ? 'yes' : 'no',
          h.tomorrow.questionReady ? '' : 'warn');

        // ANOMALIES
        const a = h.anomalies;
        const anomalyCount = a.duplicateScheduledQuestions + a.sessionsMissingSummary + a.recentErrorCount;
        html += '<div class="section">Anomalies</div>';
        if (anomalyCount === 0) {
          html += '<div class="empty">none</div>';
        } else {
          if (a.recentErrorCount > 0) {
            html += row('Recent errors', String(a.recentErrorCount), 'bad');
            if (a.recentErrorJobs.length > 0) {
              html += '<div class="stage-list">' +
                a.recentErrorJobs.map((j: string) => `<span class="stage bad">${j}</span>`).join('') +
                '</div>';
            }
          }
          if (a.duplicateScheduledQuestions > 0) {
            html += row('Duplicate questions', String(a.duplicateScheduledQuestions), 'warn');
          }
          if (a.sessionsMissingSummary > 0) {
            html += row('Sessions missing summary', String(a.sessionsMissingSummary), 'warn');
          }
        }

        healthPanel.innerHTML = html;
      }

      async function loadHealth() {
        try {
          const res = await fetch('/api/health');
          if (!res.ok) { healthDot.setAttribute('data-status', 'red'); return; }
          renderHealth(await res.json());
        } catch {
          healthDot.setAttribute('data-status', 'red');
        }
      }
      loadHealth();

      // Nav visibility — hide nav buttons when writing
      function hideNav() {
        document.querySelectorAll('.nav-btn').forEach(el => el.classList.add('hidden'));
      }
      function showNav() {
        document.querySelectorAll('.nav-btn').forEach(el => el.classList.remove('hidden'));
      }

      // Device context — captured once per page load
      const isMobile = /Mobi|Android|iPhone|iPad/i.test(navigator.userAgent);
      const deviceType = isMobile ? 'mobile' : 'desktop';
      const hourOfDay = new Date().getHours();
      const dayOfWeek = new Date().getDay();
      const rawUserAgent = navigator.userAgent;

      // QWERTY left-hand key mapping (shared by journal + calibration capture)
      const LEFT_HAND_CODES = new Set([
        'Backquote','Digit1','Digit2','Digit3','Digit4','Digit5',
        'KeyQ','KeyW','KeyE','KeyR','KeyT',
        'KeyA','KeyS','KeyD','KeyF','KeyG',
        'KeyZ','KeyX','KeyC','KeyV','KeyB',
        'Tab','CapsLock','ShiftLeft','ControlLeft','AltLeft','MetaLeft',
      ]);

      const dateEl = document.getElementById('date')!;
      const questionEl = document.getElementById('question')!;
      const inputArea = document.getElementById('input-area')!;

      const today = new Date();
      dateEl.textContent = today.toLocaleDateString('en-US', {
        weekday: 'long',
        year: 'numeric',
        month: 'long',
        day: 'numeric',
      });

      async function load() {
        const res = await fetch('/api/today');
        if (!res.ok) {
          questionEl.textContent = 'No question today. Rest.';
          return;
        }

        const data = await res.json();
        questionEl.textContent = data.question.text;
        questionEl.classList.remove('loading');

        if (data.response) {
          trackEvent(data.question.id, 'revisit');
          questionEl.textContent = '';
          showDoneState();
        } else {
          hideNav();
          const questionId = data.question.id;
          const pageOpenTime = Date.now();
          trackEvent(questionId, 'page_open');

          inputArea.innerHTML = `
            <textarea
              class="response-area"
              id="response"
              autocomplete="off"
              autocorrect="off"
              autocapitalize="off"
              spellcheck="false"
            ></textarea>
            <div class="submit-row hidden" id="submit-row">
              <button class="submit-btn" id="submit" disabled>done</button>
            </div>
          `;

          const textarea = document.getElementById('response') as HTMLTextAreaElement;
          const submitBtn = document.getElementById('submit') as HTMLButtonElement;

          const submitRow = document.getElementById('submit-row')!;

          // Writing is open from the moment the surface renders. The room
          // may still be dim until presence lands, but nothing is blocked.
          textarea.focus();
          const writingOpenedAt = Date.now();

          // Submit visibility: both gates must pass (time + content).
          // 90s from writing-open removes implicit "finish" pressure
          // (Hallnäs & Redström 2001); 20-char threshold prevents the
          // button appearing before there's anything to close.
          setTimeout(maybeShowSubmit, 90000);

          function maybeShowSubmit() {
            const timeOk = Date.now() - writingOpenedAt >= 90000;
            const contentOk = textarea.value.trim().length >= 20;
            if (timeOk && contentOk) {
              submitRow.classList.remove('hidden');
              submitRow.classList.add('visible');
            }
          }


          // Behavioral tracking state
          let firstKeystrokeSent = false;
          let firstKeystrokeTime: number | null = null;
          let pauseTimer: number | null = null;
          let isPaused = false;
          let pauseStartTime: number | null = null;
          let totalPauseMs = 0;
          let pauseCount = 0;
          let totalCharsTyped = 0;
          let totalCharsDeleted = 0;
          let deletionCount = 0;
          let largestDeletion = 0;
          let lastTextLength = 0;
          let tabAwayCount = 0;
          let tabAwayStartTime: number | null = null;
          let totalTabAwayMs = 0;

          // Enriched: deletion decomposition (Faigley & Witte)
          let smallDeletionCount = 0;
          let largeDeletionCount = 0;
          let largeDeletionChars = 0;
          const deletionTimestamps: Array<{chars: number; time: number}> = [];

          // Read-only playback event log: delta-encoded.
          // Format: [offsetMs, cursorPos, deletedCount, insertedText]
          // Reconstructed to full text snapshots by the playback API.
          // No cap needed — deltas are ~20 bytes each vs hundreds for snapshots.
          let eventLogTotalInputs = 0;
          const eventLog: Array<[number, string]> = [];

          // Enriched: P-burst tracking (Chenoweth & Hayes, 2s threshold)
          let lastInputTime: number | null = null;
          let currentBurstChars = 0;
          let burstStartTime: number | null = null;
          const burstLengths: number[] = [];
          const burstSequence: Array<{chars: number; startOffsetMs: number; durationMs: number}> = [];

          // Enriched: keystroke dynamics (Epp et al. 2011, CHI)
          // Inter-key intervals reveal affect signatures; revision chains reveal cognitive mode
          let lastKeystrokeTime: number | null = null;
          const interKeyIntervals: number[] = [];
          let currentRevisionChainLength = 0;
          let lastDeletionTime: number | null = null;
          const revisionChains: number[] = [];

          // Hold time + flight time decomposition (Kim et al. 2024, JMIR)
          // Hold time (keydown→keyup) = motor execution; flight time (keyup→next keydown) = cognitive planning
          const holdTimes: number[] = [];
          const flightTimes: number[] = [];
          let lastKeyupTime: number | null = null;
          const keydownTimes = new Map<string, number>();

          // Raw keystroke stream for dynamical signal analysis (RQA, DFA,
          // permutation entropy, transfer entropy). Stores compact
          // {c: keyCode, d: downOffsetMs, u: upOffsetMs} tuples.
          const keystrokeStream: Array<{c: string; d: number; u: number}> = [];

          // Enriched: cursor behavior and writing process tracking
          // Selection tracking for leading-edge vs navigated-back classification
          let leadingEdgeInputCount = 0;
          let totalInputActionCount = 0;
          let contextualRevisionCount = 0;
          let preContextualRevisionCount = 0;

          // Read-back detection: cursor moves without subsequent editing
          let readBackCount = 0;
          let readBackPending = false;
          let readBackTimer: ReturnType<typeof setTimeout> | null = null;

          // Selection-without-deletion: considered-and-kept events
          let consideredAndKeptCount = 0;
          let lastSelectionWasRange = false;

          // Paste detection: construct validity signal
          let pasteCount = 0;
          let pasteCharsTotal = 0;

          // Hand-lateralized hold times (QWERTY mapping, Kim et al. 2024)
          const holdTimesLeft: number[] = [];
          const holdTimesRight: number[] = [];

          // Negative flight time (rollover rate, Teh et al. 2013)
          let negativeFlightTimeCount = 0;

          // Error detection latency: char-to-backspace intervals (Haag et al. 2020)
          const errorDetectionLatencies: number[] = [];
          let lastNonDeleteKeystrokeTime: number | null = null;

          // Enriched: session metadata (Czerwinski et al. 2004)
          // Scroll-back and re-read behavior correlate with engagement depth
          let scrollBackCount = 0;
          let questionRereadCount = 0;
          let lastScrollTop = 0;

          textarea.addEventListener('scroll', () => {
            if (textarea.scrollTop < lastScrollTop && lastScrollTop > 0) {
              scrollBackCount++;
            }
            lastScrollTop = textarea.scrollTop;
          });

          // Track if user scrolls page up to re-read the question
          window.addEventListener('scroll', () => {
            if (window.scrollY < 50 && textarea.value.length > 0) {
              questionRereadCount++;
            }
          }, { passive: true });

          // Read-back detection: cursor repositioning without subsequent editing
          // Fires when user arrows/clicks into existing text to re-read, then
          // moves back without changing anything. (Lindgren & Sullivan 2006)
          document.addEventListener('selectionchange', () => {
            if (document.activeElement !== textarea) return;
            if (readBackTimer) clearTimeout(readBackTimer);
            readBackPending = true;
            readBackTimer = setTimeout(() => {
              if (readBackPending) {
                readBackCount++;
                readBackPending = false;
              }
            }, 500);

            // Selection-without-deletion tracking: if previously had a range
            // selection and now it's collapsed, user selected and deselected
            // without deleting = considered-and-kept
            const hasRange = textarea.selectionStart !== textarea.selectionEnd;
            if (lastSelectionWasRange && !hasRange) {
              consideredAndKeptCount++;
            }
            lastSelectionWasRange = hasRange;
          });

          // Paste blocked: construct isolation (Option C thesis)
          // Count attempts but prevent the action. The attempt count is itself
          // a signal about moments of construct pressure.
          let pasteMessageShown = false;
          textarea.addEventListener('paste', (e: ClipboardEvent) => {
            e.preventDefault();
            pasteCount++;
            const pasted = e.clipboardData?.getData('text/plain') ?? '';
            pasteCharsTotal += pasted.length;
            if (!pasteMessageShown) {
              pasteMessageShown = true;
              const msg = document.createElement('div');
              msg.textContent = 'paste is disabled during writing';
              msg.style.cssText = 'position:fixed;bottom:2rem;left:50%;transform:translateX(-50%);font-family:var(--mono);font-size:10px;letter-spacing:0.14em;text-transform:uppercase;color:var(--text-faint);opacity:1;transition:opacity 2s ease 3s;pointer-events:none;';
              document.body.appendChild(msg);
              setTimeout(() => { msg.style.opacity = '0'; }, 100);
              setTimeout(() => { msg.remove(); }, 6000);
            }
          });

          textarea.addEventListener('keydown', (e: KeyboardEvent) => {
            const now = Date.now();

            // Skip auto-repeat events from held keys — not real keypresses
            if (!e.repeat) {
              // Inter-key interval tracking (Epp et al. 2011)
              if (lastKeystrokeTime !== null) {
                const interval = now - lastKeystrokeTime;
                if (interval < 5000) { // cap at 5s to exclude pauses
                  interKeyIntervals.push(interval);
                }
              }
              lastKeystrokeTime = now;

              // Hold time: record keydown timestamp per key (Kim et al. 2024)
              keydownTimes.set(e.code, now);

              // Flight time: keyup[n-1] → keydown[n] (cognitive planning interval)
              if (lastKeyupTime !== null) {
                const ft = now - lastKeyupTime;
                if (ft > 0 && ft < 5000) {
                  flightTimes.push(ft);
                } else if (ft < 0) {
                  // Negative flight time = key rollover (next key pressed before
                  // previous released). Signature of motor automaticity.
                  negativeFlightTimeCount++;
                }
              }
            }

            // Leading-edge vs navigated-back classification (Galbraith 2009)
            totalInputActionCount++;
            if (textarea.selectionStart >= textarea.value.length) {
              leadingEdgeInputCount++;
            }

            // Cancel pending read-back — an edit followed the cursor move
            if (readBackPending) {
              readBackPending = false;
              if (readBackTimer) clearTimeout(readBackTimer);
            }

            // Revision chain detection (Leijten & Van Waes 2013)
            // Sequential deletions within 500ms = one revision chain
            if (e.key === 'Backspace' || e.key === 'Delete') {
              if (lastDeletionTime !== null && (now - lastDeletionTime) < 500) {
                currentRevisionChainLength++;
              } else {
                if (currentRevisionChainLength > 0) {
                  revisionChains.push(currentRevisionChainLength);
                }
                currentRevisionChainLength = 1;
              }
              lastDeletionTime = now;

              // Error detection latency: time from last non-delete keystroke
              // to this backspace (Haag et al. 2020 fatigue marker)
              if (lastNonDeleteKeystrokeTime !== null) {
                const edl = now - lastNonDeleteKeystrokeTime;
                if (edl > 0 && edl < 5000) errorDetectionLatencies.push(edl);
              }

              // Contextual vs pre-contextual revision (Lindgren & Sullivan 2006)
              if (textarea.selectionStart < textarea.value.length - 1) {
                contextualRevisionCount++;
              } else {
                preContextualRevisionCount++;
              }
            } else {
              if (currentRevisionChainLength > 0) {
                revisionChains.push(currentRevisionChainLength);
                currentRevisionChainLength = 0;
              }
              lastNonDeleteKeystrokeTime = now;
            }
          });

          // Hold time: keydown → keyup per key (motor execution duration)
          textarea.addEventListener('keyup', (e: KeyboardEvent) => {
            const now = Date.now();
            lastKeyupTime = now;
            const downTime = keydownTimes.get(e.code);
            if (downTime != null) {
              const ht = now - downTime;
              if (ht > 0 && ht < 2000) {
                holdTimes.push(ht); // cap at 2s — held keys are not motor signal
                keystrokeStream.push({
                  c: e.code,
                  d: downTime - pageOpenTime,
                  u: now - pageOpenTime,
                });
                // Hand-lateralized hold times (QWERTY, Kim et al. 2024)
                if (LEFT_HAND_CODES.has(e.code)) {
                  holdTimesLeft.push(ht);
                } else {
                  holdTimesRight.push(ht);
                }
              }
              keydownTimes.delete(e.code);
            }
          });

          textarea.addEventListener('input', () => {
            const now = Date.now();
            const currentLength = textarea.value.length;
            const delta = currentLength - lastTextLength;

            // Capture text snapshot for read-only playback. Cap entries; if
            // the cap is hit, drop every other prior entry to keep newer ones
            // (preserves recent fidelity at the cost of older granularity).
            eventLogTotalInputs++;
            // Delta-encoded: [offsetMs, cursorPos, deletedCount, insertedText]
            const cursorPos = textarea.selectionStart;
            if (delta > 0) {
              const inserted = textarea.value.slice(cursorPos - delta, cursorPos);
              eventLog.push([now - pageOpenTime, cursorPos - delta, 0, inserted]);
            } else if (delta < 0) {
              eventLog.push([now - pageOpenTime, cursorPos, -delta, '']);
            }

            // Time-based prompt fade starts on first keystroke — the prompt
            // dims because you've been with it long enough, not because
            // you've produced enough. (Czerwinski et al. 2004: faded prompts
            // produce more associative, less literal responses.)
            if (!firstKeystrokeSent && delta > 0) {
              scheduleFade();
            }

            if (delta > 0) {
              totalCharsTyped += delta;

              // P-burst tracking: 2s gap = new burst
              if (lastInputTime !== null && (now - lastInputTime) > 2000) {
                if (currentBurstChars > 0) {
                  burstLengths.push(currentBurstChars);
                  burstSequence.push({
                    chars: currentBurstChars,
                    startOffsetMs: (burstStartTime ?? now) - pageOpenTime,
                    durationMs: lastInputTime - (burstStartTime ?? lastInputTime),
                  });
                }
                currentBurstChars = 0;
                burstStartTime = now;
              }
              if (burstStartTime === null) burstStartTime = now;
              currentBurstChars += delta;
              lastInputTime = now;
            } else if (delta < 0) {
              const deleted = Math.abs(delta);
              totalCharsDeleted += deleted;
              deletionCount++;
              if (deleted > largestDeletion) largestDeletion = deleted;

              // Deletion decomposition
              if (deleted < 10) {
                smallDeletionCount++;
              } else {
                largeDeletionCount++;
                largeDeletionChars += deleted;
              }
              deletionTimestamps.push({ chars: deleted, time: now });

              trackEvent(questionId, 'deletion', JSON.stringify({
                charsDeleted: deleted,
                textLength: currentLength,
              }));
            }

            lastTextLength = currentLength;
            submitBtn.disabled = !textarea.value.trim();
            maybeShowSubmit();

            if (!firstKeystrokeSent) {
              firstKeystrokeTime = Date.now();
              trackEvent(questionId, 'first_keystroke');
              firstKeystrokeSent = true;
            }

            if (isPaused) {
              if (pauseStartTime) {
                totalPauseMs += Date.now() - pauseStartTime;
                pauseStartTime = null;
              }
              trackEvent(questionId, 'resume', JSON.stringify({
                textLength: currentLength,
              }));
              isPaused = false;
            }

            if (pauseTimer) clearTimeout(pauseTimer);
            pauseTimer = window.setTimeout(() => {
              if (firstKeystrokeSent) {
                pauseCount++;
                pauseStartTime = Date.now();
                trackEvent(questionId, 'pause', JSON.stringify({
                  textLength: currentLength,
                }));
                isPaused = true;
              }
            }, 30000);
          });

          document.addEventListener('visibilitychange', () => {
            if (document.hidden) {
              const blurTime = Date.now();
              tabAwayStartTime = blurTime;
              // Close current P-burst on tab-away
              if (currentBurstChars > 0) {
                burstLengths.push(currentBurstChars);
                burstSequence.push({
                  chars: currentBurstChars,
                  startOffsetMs: (burstStartTime ?? blurTime) - pageOpenTime,
                  durationMs: blurTime - (burstStartTime ?? blurTime),
                });
                currentBurstChars = 0;
                burstStartTime = null;
              }
              trackEvent(questionId, 'tab_blur');
            } else {
              if (tabAwayStartTime) {
                const awayMs = Date.now() - tabAwayStartTime;
                totalTabAwayMs += awayMs;
                tabAwayCount++;
                tabAwayStartTime = null;
              }
              trackEvent(questionId, 'tab_focus');
            }
          });

          submitBtn.addEventListener('click', async () => {
            const text = textarea.value.trim();
            if (!text) return;

            submitBtn.disabled = true;
            submitBtn.textContent = '...';

            // Finalize pause if still in one
            if (isPaused && pauseStartTime) {
              totalPauseMs += Date.now() - pauseStartTime;
            }

            // Close final P-burst
            if (currentBurstChars > 0) {
              const now = Date.now();
              burstLengths.push(currentBurstChars);
              burstSequence.push({
                chars: currentBurstChars,
                startOffsetMs: (burstStartTime ?? now) - pageOpenTime,
                durationMs: now - (burstStartTime ?? now),
              });
            }

            // Close final revision chain
            if (currentRevisionChainLength > 0) {
              revisionChains.push(currentRevisionChainLength);
            }

            const submitTime = Date.now();
            const finalCharCount = text.length;
            const wordCount = text.split(/\s+/).filter(Boolean).length;
            const sentenceCount = text.split(/[.!?]+/).filter((s: string) => s.trim()).length;
            const totalDurationMs = submitTime - pageOpenTime;
            const firstKeystrokeMs = firstKeystrokeTime ? firstKeystrokeTime - pageOpenTime : null;
            const commitmentRatio = totalCharsTyped > 0 ? finalCharCount / totalCharsTyped : null;

            // Derived: active typing time and speed
            const activeTypingMs = Math.max(0, totalDurationMs - totalPauseMs - totalTabAwayMs);
            const charsPerMinute = activeTypingMs > 0 ? totalCharsTyped / (activeTypingMs / 60000) : null;

            // Derived: P-burst stats
            const pBurstCount = burstLengths.length;
            const avgPBurstLength = pBurstCount > 0
              ? burstLengths.reduce((a, b) => a + b, 0) / pBurstCount : null;

            // Derived: deletion timing (first half vs second half of session)
            const midpoint = pageOpenTime + totalDurationMs / 2;
            let firstHalfDeletionChars = 0;
            let secondHalfDeletionChars = 0;
            for (const d of deletionTimestamps) {
              if (d.time <= midpoint) firstHalfDeletionChars += d.chars;
              else secondHalfDeletionChars += d.chars;
            }

            // Derived: inter-key interval stats (Epp et al. 2011)
            const ikiCount = interKeyIntervals.length;
            const ikiMean = ikiCount > 0
              ? interKeyIntervals.reduce((a, b) => a + b, 0) / ikiCount : null;
            const ikiStd = ikiCount > 1
              ? Math.sqrt(interKeyIntervals.reduce((sum, v) => sum + (v - ikiMean!) ** 2, 0) / (ikiCount - 1)) : null;

            // Derived: hold time stats (Kim et al. 2024 — motor execution)
            const htCount = holdTimes.length;
            const holdTimeMean = htCount > 0
              ? holdTimes.reduce((a, b) => a + b, 0) / htCount : null;
            const holdTimeStd = htCount > 1
              ? Math.sqrt(holdTimes.reduce((sum, v) => sum + (v - holdTimeMean!) ** 2, 0) / (htCount - 1)) : null;

            // Derived: flight time stats (Kim et al. 2024 — cognitive planning)
            const ftCount = flightTimes.length;
            const flightTimeMean = ftCount > 0
              ? flightTimes.reduce((a, b) => a + b, 0) / ftCount : null;
            const flightTimeStd = ftCount > 1
              ? Math.sqrt(flightTimes.reduce((sum, v) => sum + (v - flightTimeMean!) ** 2, 0) / (ftCount - 1)) : null;

            // Derived: keystroke entropy (Ajilore et al. 2025, BiAffect)
            // Shannon entropy of IKI distribution — measures timing unpredictability
            // Bins: 50ms width over 0-2000ms range (40 bins)
            let keystrokeEntropy: number | null = null;
            if (ikiCount >= 10) {
              const BIN_WIDTH = 50;
              const NUM_BINS = 40;
              const bins = new Array(NUM_BINS).fill(0);
              for (const iki of interKeyIntervals) {
                const bin = Math.min(NUM_BINS - 1, Math.floor(iki / BIN_WIDTH));
                bins[bin]++;
              }
              let entropy = 0;
              for (const count of bins) {
                if (count > 0) {
                  const p = count / ikiCount;
                  entropy -= p * Math.log2(p);
                }
              }
              keystrokeEntropy = entropy;
            }

            // Derived: revision chain stats (Leijten & Van Waes 2013)
            const revChainCount = revisionChains.length;
            const revChainAvgLength = revChainCount > 0
              ? revisionChains.reduce((a, b) => a + b, 0) / revChainCount : null;

            // Derived: confirmation latency (Monaro et al. 2018, deception detection)
            // Time between last keystroke and submit — the "is it done?" moment
            const confirmationLatencyMs = lastInputTime
              ? submitTime - lastInputTime : null;

            // Derived: writing linearity (Galbraith 2009, knowledge-transforming)
            const leadingEdgeRatio = totalInputActionCount > 0
              ? leadingEdgeInputCount / totalInputActionCount : null;

            // Derived: hand-lateralized hold times (neuroQWERTY, Giancardo et al. 2016)
            const htLeftCount = holdTimesLeft.length;
            const holdTimeMeanLeft = htLeftCount > 0
              ? holdTimesLeft.reduce((a, b) => a + b, 0) / htLeftCount : null;
            const holdTimeStdLeft = htLeftCount > 1
              ? Math.sqrt(holdTimesLeft.reduce((s, v) => s + (v - holdTimeMeanLeft!) ** 2, 0) / (htLeftCount - 1)) : null;
            const htRightCount = holdTimesRight.length;
            const holdTimeMeanRight = htRightCount > 0
              ? holdTimesRight.reduce((a, b) => a + b, 0) / htRightCount : null;
            const holdTimeStdRight = htRightCount > 1
              ? Math.sqrt(holdTimesRight.reduce((s, v) => s + (v - holdTimeMeanRight!) ** 2, 0) / (htRightCount - 1)) : null;

            // Derived: hold time CV — motor consistency (neuroQWERTY, most sensitive PD feature)
            const holdTimeCV = (holdTimeMean != null && holdTimeMean > 0 && holdTimeStd != null)
              ? holdTimeStd / holdTimeMean : null;

            // Derived: IKI skewness and kurtosis (Heliyon 2021, distribution shape)
            let ikiSkewness: number | null = null;
            let ikiKurtosis: number | null = null;
            if (ikiCount >= 10 && ikiMean != null && ikiStd != null && ikiStd > 0) {
              let m3 = 0, m4 = 0;
              for (const iki of interKeyIntervals) {
                const d = (iki - ikiMean) / ikiStd;
                m3 += d * d * d;
                m4 += d * d * d * d;
              }
              ikiSkewness = m3 / ikiCount;
              ikiKurtosis = (m4 / ikiCount) - 3; // excess kurtosis
            }

            // Derived: error detection latency (Haag et al. 2020)
            const edlCount = errorDetectionLatencies.length;
            const errorDetectionLatencyMean = edlCount > 0
              ? errorDetectionLatencies.reduce((a, b) => a + b, 0) / edlCount : null;

            // Derived: terminal velocity (chronemics — approach to the finish line)
            let terminalVelocity: number | null = null;
            if (ikiCount >= 20 && ikiMean != null && ikiMean > 0) {
              const tail = Math.max(2, Math.floor(ikiCount * 0.1));
              const tailSlice = interKeyIntervals.slice(-tail);
              const tailMean = tailSlice.reduce((a, b) => a + b, 0) / tailSlice.length;
              terminalVelocity = tailMean / ikiMean;
            }

            const sessionSummary = {
              questionId,
              firstKeystrokeMs,
              totalDurationMs,
              totalCharsTyped,
              finalCharCount,
              commitmentRatio,
              pauseCount,
              totalPauseMs,
              deletionCount,
              largestDeletion,
              totalCharsDeleted,
              tabAwayCount,
              totalTabAwayMs,
              wordCount,
              sentenceCount,
              // Enriched fields
              smallDeletionCount,
              largeDeletionCount,
              largeDeletionChars,
              firstHalfDeletionChars,
              secondHalfDeletionChars,
              activeTypingMs,
              charsPerMinute,
              pBurstCount,
              avgPBurstLength,
              burstSequence,
              // Keystroke dynamics (Epp et al. 2011; Leijten & Van Waes 2013)
              interKeyIntervalMean: ikiMean,
              interKeyIntervalStd: ikiStd,
              revisionChainCount: revChainCount,
              revisionChainAvgLength: revChainAvgLength,
              // Hold time + flight time decomposition (Kim et al. 2024)
              holdTimeMean,
              holdTimeStd,
              flightTimeMean,
              flightTimeStd,
              // Keystroke entropy (Ajilore et al. 2025, BiAffect)
              keystrokeEntropy,
              // Session metadata (Czerwinski et al. 2004)
              scrollBackCount,
              questionRereadCount,
              // Cursor behavior and writing process (Phase 1 expansion)
              confirmationLatencyMs,
              pasteCount,
              pasteCharsTotal,
              readBackCount,
              leadingEdgeRatio,
              contextualRevisionCount,
              preContextualRevisionCount,
              consideredAndKeptCount,
              holdTimeMeanLeft,
              holdTimeMeanRight,
              holdTimeStdLeft,
              holdTimeStdRight,
              holdTimeCV,
              negativeFlightTimeCount,
              ikiSkewness,
              ikiKurtosis,
              errorDetectionLatencyMean,
              terminalVelocity,
              // Slice-3 follow-up: deletion events with ms-offset for
              // deletion-density curve classification.
              deletionEvents: deletionTimestamps.map(d => ({
                chars: d.chars,
                time: d.time - pageOpenTime,
              })),
              // Read-only playback substrate (delta-encoded).
              eventLog,
              eventLogTotalInputs,
              // Raw keystroke stream for dynamical signal analysis
              keystrokeStream,
              // Context
              deviceType,
              userAgent: rawUserAgent,
              hourOfDay,
              dayOfWeek,
            };

            const res = await fetch('/api/respond', {
              method: 'POST',
              headers: { 'Content-Type': 'application/json' },
              body: JSON.stringify({ questionId, text, sessionSummary }),
            });

            if (res.ok) {
              const resData = await res.json();
              trackEvent(questionId, 'submit', JSON.stringify({
                charCount: finalCharCount,
                wordCount,
              }));
              questionEl.textContent = '';
              showDoneState(resData.askFeedback ? questionId : null);
            } else {
              submitBtn.textContent = 'done';
              submitBtn.disabled = false;
            }
          });
        }
      }

      function trackEvent(questionId: number, eventType: string, metadata?: string) {
        fetch('/api/event', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ questionId, eventType, metadata }),
        }).catch(() => {});
      }

      function getDoneMessage(): string {
        const messages = [
          "Noted. Let it sit.",
          "That thought is yours now. Come back tomorrow.",
          "Done. Don't rehearse it — let it breathe.",
          "Saved. Go do something with your hands.",
          "Good. Now forget about it until tomorrow.",
          "The thought is planted. Leave it alone.",
          "You showed up. That's the whole thing.",
          "Noted. The next question is already forming.",
          "Stop thinking about what you just wrote.",
          "That's enough for today.",
        ];
        return messages[Math.floor(Math.random() * messages.length)];
      }

      function escapeHtml(text: string): string {
        const div = document.createElement('div');
        div.textContent = text;
        return div.innerHTML;
      }

      function showDoneState(feedbackQuestionId: number | null = null) {
        showNav();
        // Reset stage — the done state is fully visible; the prompt is gone
        // anyway, so no scaffolding needs to stay receded.
        document.body.classList.remove('pre-arrival');
        resetFade();
        let feedbackHtml = '';
        if (feedbackQuestionId) {
          feedbackHtml = `
            <div class="feedback-row" id="feedback-row">
              <span class="feedback-label">did it land?</span>
              <button class="feedback-btn" data-landed="true">yes</button>
              <button class="feedback-btn" data-landed="false">no</button>
            </div>
          `;
        }
        inputArea.innerHTML = `
          <div class="done-message">${getDoneMessage()}</div>
          ${feedbackHtml}
          <button class="free-write-link" id="free-write-btn">free write</button>
        `;
        document.getElementById('free-write-btn')!.addEventListener('click', startFreeWrite);

        if (feedbackQuestionId) {
          const feedbackRow = document.getElementById('feedback-row')!;
          feedbackRow.querySelectorAll('.feedback-btn').forEach((btn) => {
            btn.addEventListener('click', async () => {
              const landed = (btn as HTMLElement).dataset.landed === 'true';
              await fetch('/api/feedback', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ questionId: feedbackQuestionId, landed }),
              });
              feedbackRow.innerHTML = `<span class="feedback-label">noted.</span>`;
            });
          });
        }
      }

      async function startFreeWrite() {
        const res = await fetch('/api/calibrate');
        if (!res.ok) return;
        const data = await res.json();
        const prompt = data.prompt;

        hideNav();
        // Calibration is a deliberate click — presence is already established.
        // Reset any lingering stage classes so the surface starts lit.
        document.body.classList.remove('pre-arrival');
        resetFade();
        questionEl.textContent = '';
        inputArea.innerHTML = '';

        const promptDiv = document.createElement('div');
        promptDiv.className = 'calibration-prompt';
        promptDiv.textContent = prompt;
        inputArea.appendChild(promptDiv);

        const pageOpenTime = Date.now();

        const formHtml = document.createElement('div');
        formHtml.innerHTML = `
          <textarea
            class="response-area"
            id="response"
            autocomplete="off"
            autocorrect="off"
            autocapitalize="off"
            spellcheck="false"
          ></textarea>
          <div class="submit-row visible">
            <button class="submit-btn" id="submit" disabled>done</button>
          </div>
        `;
        inputArea.appendChild(formHtml);

        const textarea = document.getElementById('response') as HTMLTextAreaElement;
        const submitBtn = document.getElementById('submit') as HTMLButtonElement;

        // Behavioral tracking state
        let firstKeystrokeSent = false;
        let firstKeystrokeTime: number | null = null;
        let pauseTimer: number | null = null;
        let isPaused = false;
        let pauseStartTime: number | null = null;
        let totalPauseMs = 0;
        let pauseCount = 0;
        let totalCharsTyped = 0;
        let totalCharsDeleted = 0;
        let deletionCount = 0;
        let largestDeletion = 0;
        let lastTextLength = 0;
        let tabAwayCount = 0;
        let tabAwayStartTime: number | null = null;
        let totalTabAwayMs = 0;

        // Enriched: deletion decomposition (Faigley & Witte)
        let smallDeletionCount = 0;
        let largeDeletionCount = 0;
        let largeDeletionChars = 0;
        const calDeletionTimestamps: Array<{chars: number; time: number}> = [];

        // Enriched: P-burst tracking (Chenoweth & Hayes, 2s threshold)
        let lastInputTime: number | null = null;
        let currentBurstChars = 0;
        const calBurstLengths: number[] = [];

        // Enriched: keystroke dynamics (Epp et al. 2011)
        let lastKeystrokeTime: number | null = null;
        const calInterKeyIntervals: number[] = [];
        let calCurrentRevChainLength = 0;
        let calLastDeletionTime: number | null = null;
        const calRevisionChains: number[] = [];

        // Hold time + flight time decomposition (Kim et al. 2024)
        const calHoldTimes: number[] = [];
        const calFlightTimes: number[] = [];
        let calLastKeyupTime: number | null = null;
        const calKeydownTimes = new Map<string, number>();

        // Raw keystroke stream + event log (same as journal sessions)
        const calKeystrokeStream: Array<{c: string; d: number; u: number}> = [];
        const calEventLog: Array<[number, string]> = [];
        // Session metadata (Czerwinski et al. 2004)
        let calScrollBackCount = 0;
        let calLastScrollTop = 0;

        // Phase 1 expansion: cursor behavior + writing process tracking
        let calLeadingEdgeInputCount = 0;
        let calTotalInputActionCount = 0;
        let calContextualRevisionCount = 0;
        let calPreContextualRevisionCount = 0;
        let calReadBackCount = 0;
        let calReadBackPending = false;
        let calReadBackTimer: ReturnType<typeof setTimeout> | null = null;
        let calConsideredAndKeptCount = 0;
        let calLastSelectionWasRange = false;
        let calPasteCount = 0;
        let calPasteCharsTotal = 0;
        const calHoldTimesLeft: number[] = [];
        const calHoldTimesRight: number[] = [];
        let calNegativeFlightTimeCount = 0;
        const calErrorDetectionLatencies: number[] = [];
        let calLastNonDeleteKeystrokeTime: number | null = null;

        textarea.addEventListener('scroll', () => {
          if (textarea.scrollTop < calLastScrollTop && calLastScrollTop > 0) {
            calScrollBackCount++;
          }
          calLastScrollTop = textarea.scrollTop;
        });

        document.addEventListener('selectionchange', () => {
          if (document.activeElement !== textarea) return;
          if (calReadBackTimer) clearTimeout(calReadBackTimer);
          calReadBackPending = true;
          calReadBackTimer = setTimeout(() => {
            if (calReadBackPending) { calReadBackCount++; calReadBackPending = false; }
          }, 500);
          const hasRange = textarea.selectionStart !== textarea.selectionEnd;
          if (calLastSelectionWasRange && !hasRange) calConsideredAndKeptCount++;
          calLastSelectionWasRange = hasRange;
        });

        let calPasteMessageShown = false;
        textarea.addEventListener('paste', (e: ClipboardEvent) => {
          e.preventDefault();
          calPasteCount++;
          calPasteCharsTotal += e.clipboardData?.getData('text/plain')?.length ?? 0;
          if (!calPasteMessageShown) {
            calPasteMessageShown = true;
            const msg = document.createElement('div');
            msg.textContent = 'paste is disabled during writing';
            msg.style.cssText = 'position:fixed;bottom:2rem;left:50%;transform:translateX(-50%);font-family:var(--mono);font-size:10px;letter-spacing:0.14em;text-transform:uppercase;color:var(--text-faint);opacity:1;transition:opacity 2s ease 3s;pointer-events:none;';
            document.body.appendChild(msg);
            setTimeout(() => { msg.style.opacity = '0'; }, 100);
            setTimeout(() => { msg.remove(); }, 6000);
          }
        });

        textarea.addEventListener('keydown', (e: KeyboardEvent) => {
          const now = Date.now();

          // Skip auto-repeat events from held keys
          if (!e.repeat) {
            if (lastKeystrokeTime !== null) {
              const interval = now - lastKeystrokeTime;
              if (interval < 5000) calInterKeyIntervals.push(interval);
            }
            lastKeystrokeTime = now;

            // Hold time: record keydown timestamp per key (Kim et al. 2024)
            calKeydownTimes.set(e.code, now);

            // Flight time: keyup[n-1] → keydown[n]
            if (calLastKeyupTime !== null) {
              const ft = now - calLastKeyupTime;
              if (ft > 0 && ft < 5000) {
                calFlightTimes.push(ft);
              } else if (ft < 0) {
                calNegativeFlightTimeCount++;
              }
            }
          }

          calTotalInputActionCount++;
          if (textarea.selectionStart >= textarea.value.length) {
            calLeadingEdgeInputCount++;
          }

          if (calReadBackPending) {
            calReadBackPending = false;
            if (calReadBackTimer) clearTimeout(calReadBackTimer);
          }

          if (e.key === 'Backspace' || e.key === 'Delete') {
            if (calLastDeletionTime !== null && (now - calLastDeletionTime) < 500) {
              calCurrentRevChainLength++;
            } else {
              if (calCurrentRevChainLength > 0) calRevisionChains.push(calCurrentRevChainLength);
              calCurrentRevChainLength = 1;
            }
            calLastDeletionTime = now;

            if (calLastNonDeleteKeystrokeTime !== null) {
              const edl = now - calLastNonDeleteKeystrokeTime;
              if (edl > 0 && edl < 5000) calErrorDetectionLatencies.push(edl);
            }

            if (textarea.selectionStart < textarea.value.length - 1) {
              calContextualRevisionCount++;
            } else {
              calPreContextualRevisionCount++;
            }
          } else {
            if (calCurrentRevChainLength > 0) {
              calRevisionChains.push(calCurrentRevChainLength);
              calCurrentRevChainLength = 0;
            }
            calLastNonDeleteKeystrokeTime = now;
          }
        });

        // Hold time: keydown → keyup per key (motor execution duration)
        textarea.addEventListener('keyup', (e: KeyboardEvent) => {
          const now = Date.now();
          calLastKeyupTime = now;
          const downTime = calKeydownTimes.get(e.code);
          if (downTime != null) {
            const ht = now - downTime;
            if (ht > 0 && ht < 2000) {
              calHoldTimes.push(ht);
              calKeystrokeStream.push({
                c: e.code,
                d: downTime - pageOpenTime,
                u: now - pageOpenTime,
              });
              if (LEFT_HAND_CODES.has(e.code)) {
                calHoldTimesLeft.push(ht);
              } else {
                calHoldTimesRight.push(ht);
              }
            }
            calKeydownTimes.delete(e.code);
          }
        });

        textarea.addEventListener('input', () => {
          const now = Date.now();
          const currentLength = textarea.value.length;
          const delta = currentLength - lastTextLength;

          // Delta-encoded event log (same format as journal sessions)
          const calCursorPos = textarea.selectionStart;
          if (delta > 0) {
            const inserted = textarea.value.slice(calCursorPos - delta, calCursorPos);
            calEventLog.push([now - pageOpenTime, calCursorPos - delta, 0, inserted]);
          } else if (delta < 0) {
            calEventLog.push([now - pageOpenTime, calCursorPos, -delta, '']);
          }

          if (delta > 0) {
            totalCharsTyped += delta;

            // P-burst tracking: 2s gap = new burst
            if (lastInputTime !== null && (now - lastInputTime) > 2000) {
              if (currentBurstChars > 0) calBurstLengths.push(currentBurstChars);
              currentBurstChars = 0;
            }
            currentBurstChars += delta;
            lastInputTime = now;
          } else if (delta < 0) {
            const deleted = Math.abs(delta);
            totalCharsDeleted += deleted;
            deletionCount++;
            if (deleted > largestDeletion) largestDeletion = deleted;

            // Deletion decomposition
            if (deleted < 10) {
              smallDeletionCount++;
            } else {
              largeDeletionCount++;
              largeDeletionChars += deleted;
            }
            calDeletionTimestamps.push({ chars: deleted, time: now });
          }

          lastTextLength = currentLength;
          submitBtn.disabled = !textarea.value.trim();

          if (!firstKeystrokeSent) {
            firstKeystrokeTime = Date.now();
            firstKeystrokeSent = true;
            scheduleFade();
          }

          if (isPaused) {
            if (pauseStartTime) {
              totalPauseMs += Date.now() - pauseStartTime;
              pauseStartTime = null;
            }
            isPaused = false;
          }

          if (pauseTimer) clearTimeout(pauseTimer);
          pauseTimer = window.setTimeout(() => {
            if (firstKeystrokeSent) {
              pauseCount++;
              pauseStartTime = Date.now();
              isPaused = true;
            }
          }, 30000);
        });

        submitBtn.addEventListener('click', async () => {
          const text = textarea.value.trim();
          if (!text) return;

          submitBtn.disabled = true;
          submitBtn.textContent = '...';

          if (isPaused && pauseStartTime) {
            totalPauseMs += Date.now() - pauseStartTime;
          }

          // Close final P-burst
          if (currentBurstChars > 0) calBurstLengths.push(currentBurstChars);

          // Close final revision chain
          if (calCurrentRevChainLength > 0) calRevisionChains.push(calCurrentRevChainLength);

          const submitTime = Date.now();
          const finalCharCount = text.length;
          const wordCount = text.split(/\s+/).filter(Boolean).length;
          const sentenceCount = text.split(/[.!?]+/).filter((s: string) => s.trim()).length;
          const totalDurationMs = submitTime - pageOpenTime;
          const firstKeystrokeMs = firstKeystrokeTime ? firstKeystrokeTime - pageOpenTime : null;
          const commitmentRatio = totalCharsTyped > 0 ? finalCharCount / totalCharsTyped : null;

          // Derived: active typing time and speed
          const activeTypingMs = Math.max(0, totalDurationMs - totalPauseMs - totalTabAwayMs);
          const charsPerMinute = activeTypingMs > 0 ? totalCharsTyped / (activeTypingMs / 60000) : null;

          // Derived: P-burst stats
          const pBurstCount = calBurstLengths.length;
          const avgPBurstLength = pBurstCount > 0
            ? calBurstLengths.reduce((a, b) => a + b, 0) / pBurstCount : null;

          // Derived: deletion timing
          const midpoint = pageOpenTime + totalDurationMs / 2;
          let firstHalfDeletionChars = 0;
          let secondHalfDeletionChars = 0;
          for (const d of calDeletionTimestamps) {
            if (d.time <= midpoint) firstHalfDeletionChars += d.chars;
            else secondHalfDeletionChars += d.chars;
          }

          // Derived: inter-key interval stats (Epp et al. 2011)
          const calIkiCount = calInterKeyIntervals.length;
          const calIkiMean = calIkiCount > 0
            ? calInterKeyIntervals.reduce((a, b) => a + b, 0) / calIkiCount : null;
          const calIkiStd = calIkiCount > 1
            ? Math.sqrt(calInterKeyIntervals.reduce((sum, v) => sum + (v - calIkiMean!) ** 2, 0) / (calIkiCount - 1)) : null;

          // Derived: hold time stats (Kim et al. 2024 — motor execution)
          const calHtCount = calHoldTimes.length;
          const calHoldTimeMean = calHtCount > 0
            ? calHoldTimes.reduce((a, b) => a + b, 0) / calHtCount : null;
          const calHoldTimeStd = calHtCount > 1
            ? Math.sqrt(calHoldTimes.reduce((sum, v) => sum + (v - calHoldTimeMean!) ** 2, 0) / (calHtCount - 1)) : null;

          // Derived: flight time stats (Kim et al. 2024 — cognitive planning)
          const calFtCount = calFlightTimes.length;
          const calFlightTimeMean = calFtCount > 0
            ? calFlightTimes.reduce((a, b) => a + b, 0) / calFtCount : null;
          const calFlightTimeStd = calFtCount > 1
            ? Math.sqrt(calFlightTimes.reduce((sum, v) => sum + (v - calFlightTimeMean!) ** 2, 0) / (calFtCount - 1)) : null;

          // Derived: keystroke entropy (Ajilore et al. 2025, BiAffect)
          let calKeystrokeEntropy: number | null = null;
          if (calIkiCount >= 10) {
            const BIN_WIDTH = 50;
            const NUM_BINS = 40;
            const bins = new Array(NUM_BINS).fill(0);
            for (const iki of calInterKeyIntervals) {
              const bin = Math.min(NUM_BINS - 1, Math.floor(iki / BIN_WIDTH));
              bins[bin]++;
            }
            let entropy = 0;
            for (const count of bins) {
              if (count > 0) {
                const p = count / calIkiCount;
                entropy -= p * Math.log2(p);
              }
            }
            calKeystrokeEntropy = entropy;
          }

          // Derived: revision chain stats (Leijten & Van Waes 2013)
          const calRevChainCount = calRevisionChains.length;
          const calRevChainAvgLen = calRevChainCount > 0
            ? calRevisionChains.reduce((a, b) => a + b, 0) / calRevChainCount : null;

          // Phase 1 derived metrics (calibration)
          const calConfirmationLatencyMs = lastInputTime ? submitTime - lastInputTime : null;
          const calLeadingEdgeRatio = calTotalInputActionCount > 0
            ? calLeadingEdgeInputCount / calTotalInputActionCount : null;

          const calHtLeftCount = calHoldTimesLeft.length;
          const calHoldTimeMeanLeft = calHtLeftCount > 0
            ? calHoldTimesLeft.reduce((a, b) => a + b, 0) / calHtLeftCount : null;
          const calHoldTimeStdLeft = calHtLeftCount > 1
            ? Math.sqrt(calHoldTimesLeft.reduce((s, v) => s + (v - calHoldTimeMeanLeft!) ** 2, 0) / (calHtLeftCount - 1)) : null;
          const calHtRightCount = calHoldTimesRight.length;
          const calHoldTimeMeanRight = calHtRightCount > 0
            ? calHoldTimesRight.reduce((a, b) => a + b, 0) / calHtRightCount : null;
          const calHoldTimeStdRight = calHtRightCount > 1
            ? Math.sqrt(calHoldTimesRight.reduce((s, v) => s + (v - calHoldTimeMeanRight!) ** 2, 0) / (calHtRightCount - 1)) : null;

          const calHoldTimeCV = (calHoldTimeMean != null && calHoldTimeMean > 0 && calHoldTimeStd != null)
            ? calHoldTimeStd / calHoldTimeMean : null;

          let calIkiSkewness: number | null = null;
          let calIkiKurtosis: number | null = null;
          if (calIkiCount >= 10 && calIkiMean != null && calIkiStd != null && calIkiStd > 0) {
            let m3 = 0, m4 = 0;
            for (const iki of calInterKeyIntervals) {
              const d = (iki - calIkiMean) / calIkiStd;
              m3 += d * d * d;
              m4 += d * d * d * d;
            }
            calIkiSkewness = m3 / calIkiCount;
            calIkiKurtosis = (m4 / calIkiCount) - 3;
          }

          const calEdlCount = calErrorDetectionLatencies.length;
          const calErrorDetectionLatencyMean = calEdlCount > 0
            ? calErrorDetectionLatencies.reduce((a, b) => a + b, 0) / calEdlCount : null;

          let calTerminalVelocity: number | null = null;
          if (calIkiCount >= 20 && calIkiMean != null && calIkiMean > 0) {
            const tail = Math.max(2, Math.floor(calIkiCount * 0.1));
            const tailSlice = calInterKeyIntervals.slice(-tail);
            const tailMean = tailSlice.reduce((a, b) => a + b, 0) / tailSlice.length;
            calTerminalVelocity = tailMean / calIkiMean;
          }

          const sessionSummary = {
            firstKeystrokeMs,
            totalDurationMs,
            totalCharsTyped,
            finalCharCount,
            commitmentRatio,
            pauseCount,
            totalPauseMs,
            deletionCount,
            largestDeletion,
            totalCharsDeleted,
            tabAwayCount,
            totalTabAwayMs,
            wordCount,
            sentenceCount,
            smallDeletionCount,
            largeDeletionCount,
            largeDeletionChars,
            firstHalfDeletionChars,
            secondHalfDeletionChars,
            activeTypingMs,
            charsPerMinute,
            pBurstCount,
            avgPBurstLength,
            // Keystroke dynamics (Epp et al. 2011; Leijten & Van Waes 2013)
            interKeyIntervalMean: calIkiMean,
            interKeyIntervalStd: calIkiStd,
            revisionChainCount: calRevChainCount,
            revisionChainAvgLength: calRevChainAvgLen,
            // Hold time + flight time decomposition (Kim et al. 2024)
            holdTimeMean: calHoldTimeMean,
            holdTimeStd: calHoldTimeStd,
            flightTimeMean: calFlightTimeMean,
            flightTimeStd: calFlightTimeStd,
            // Keystroke entropy (Ajilore et al. 2025, BiAffect)
            keystrokeEntropy: calKeystrokeEntropy,
            scrollBackCount: calScrollBackCount,
            questionRereadCount: 0,
            // Phase 1 expansion
            confirmationLatencyMs: calConfirmationLatencyMs,
            pasteCount: calPasteCount,
            pasteCharsTotal: calPasteCharsTotal,
            readBackCount: calReadBackCount,
            leadingEdgeRatio: calLeadingEdgeRatio,
            contextualRevisionCount: calContextualRevisionCount,
            preContextualRevisionCount: calPreContextualRevisionCount,
            consideredAndKeptCount: calConsideredAndKeptCount,
            holdTimeMeanLeft: calHoldTimeMeanLeft,
            holdTimeMeanRight: calHoldTimeMeanRight,
            holdTimeStdLeft: calHoldTimeStdLeft,
            holdTimeStdRight: calHoldTimeStdRight,
            holdTimeCV: calHoldTimeCV,
            negativeFlightTimeCount: calNegativeFlightTimeCount,
            ikiSkewness: calIkiSkewness,
            ikiKurtosis: calIkiKurtosis,
            errorDetectionLatencyMean: calErrorDetectionLatencyMean,
            terminalVelocity: calTerminalVelocity,
            // Read-only playback substrate (text snapshots over time)
            eventLog: calEventLog,
            // Raw keystroke stream for dynamical signal analysis
            keystrokeStream: calKeystrokeStream,
            // Context
            deviceType,
            userAgent: rawUserAgent,
            hourOfDay,
            dayOfWeek,
          };

          const calRes = await fetch('/api/calibrate', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ prompt, text, sessionSummary }),
          });

          if (calRes.ok) {
            showNav();
            promptDiv.textContent = '';
            inputArea.innerHTML = `
              <div class="done-message">Noted.</div>
              <button class="free-write-link" id="another-btn">another one</button>
            `;
            document.getElementById('another-btn')!.addEventListener('click', startFreeWrite);
          } else {
            submitBtn.textContent = 'done';
            submitBtn.disabled = false;
          }
        });

        textarea.focus();
      }

      load();
    </script>
  </body>
</html>
