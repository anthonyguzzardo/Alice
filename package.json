    "tsx": "^4.21.0",
    "voyageai": "^0.2.1"
  },
  "devDependencies": {
    "@astrojs/node": "^10.0.4",
    "@napi-rs/cli": "^3.6.2",
    "@testcontainers/postgresql": "^11.14.0",
    "@types/three": "^0.183.1",
    "@vitest/coverage-v8": "^3.2.4",
