# /etc/alice/secrets.env — root-owned, group-readable by `alice` user.
# Copy this template to /etc/alice/secrets.env, fill in real values, then:
#   sudo chown root:alice /etc/alice/secrets.env
#   sudo chmod 640 /etc/alice/secrets.env
#
# Never commit a populated copy. Keep a backup of every value in your
# password manager — losing ALICE_ENCRYPTION_KEY means losing every
# encrypted subject response permanently.

# ─── Encryption ─────────────────────────────────────────────────────
# Generate ONCE, keep forever:
#   openssl rand -base64 32
ALICE_ENCRYPTION_KEY=

# ─── Database ───────────────────────────────────────────────────────
# Supabase project's connection string (Settings → Database → Connection string).
# Use the pooler URL for production traffic.
ALICE_PG_URL=

# ─── External services ─────────────────────────────────────────────
ANTHROPIC_API_KEY=

# Local TEI server URL (typically http://localhost:8090 if you run TEI on the
# same host). Leave empty if not deploying TEI on this host.
ALICE_TEI_URL=

# ─── Optional ───────────────────────────────────────────────────────
# Enable verbose native-loader debug output if the .node fails to load.
# ALICE_DEBUG_NATIVE=1
