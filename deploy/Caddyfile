# Caddy config for Alice on Hetzner.
# Place at /etc/caddy/Caddyfile, then `sudo systemctl reload caddy`.
#
# Caddy auto-issues + renews TLS certs via Let's Encrypt. This handles
# real end-to-end TLS — Cloudflare flexible-mode (no real TLS to origin)
# was rejected as a downgrade.
#
# DNS: Cloudflare A record fweeo.com → Hetzner IP, proxy ON.
#      Cloudflare A record www.fweeo.com → Hetzner IP, proxy ON.
#
# Auth: every protected route is gated by the application's session-cookie
# middleware (`src/middleware.ts`). Caddy is purely TLS termination + a
# reverse proxy to the Astro server on localhost:4321. Pre-2026-04-28
# this file held an HTTP Basic Auth gate over owner-only paths
# (`@owner_paths` + `OWNER_BASICAUTH_HASH`); both have been removed now
# that owner and subjects share the universal `/login` flow.

# Redirect www → apex (canonical hostname is fweeo.com).
www.fweeo.com {
  redir https://fweeo.com{uri} permanent
}

fweeo.com {
  encode gzip zstd

  reverse_proxy localhost:4321 {
    header_up Host {host}
    header_up X-Real-IP {remote_host}
    header_up X-Forwarded-For {remote_host}
    header_up X-Forwarded-Proto {scheme}
  }

  log {
    output file /var/log/caddy/alice.log {
      roll_size 50mb
      roll_keep 5
    }
    format console
  }
}
